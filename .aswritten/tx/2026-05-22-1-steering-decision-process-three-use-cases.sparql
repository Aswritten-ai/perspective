INSERT DATA {
  GRAPH narr:Tx_20260526T120000Z {

    # ── SAMPLE ──────────────────────────────────────────────────────────
    narr:Sample_SteeringDecisionProcess_May2026 a narr:Sample ;
      dct:title "The central frame is 'steering a decision process' — three use cases under it" ;
      dct:created "2026-05-01"^^xsd:date ;
      dct:description "Pitch-reframe session notes from May 2026. Scarlet established 'steering a decision process' as the central organizing frame for aswritten's positioning, with three use cases: governing a human team, agentic steering, and steering shared process across engagements. Grounds the genus/species distinction between steering (genus) and governance (species)." ;
      narr:inputLength 3842 .

    # ── NARRATIVES ──────────────────────────────────────────────────────

    narr:Narrative_SteeringDecisionProcess a narr:Narrative ;
      dct:source narr:Sample_SteeringDecisionProcess_May2026 ;
      skos:broader narr:PositioningThesis ;
      skos:prefLabel "Steering a Decision Process: The Central Organizing Frame" ;
      skos:note "What a recurring decision body does — an Architecture Review Board, an investment committee, a law firm's partners' meeting, a clinical case conference — is steering a process of decisions: a group, or a person, recurringly deciding how the work should go. This is the genus. Governance is one species of it (when the team is human and the venue is a formal meeting). Steering covers all three use cases; governance covers only the first. This frame was established by Scarlet across the May 2026 pitch-reframe sessions as the central organizing concept for aswritten's positioning." ;
      narr:theme "Recurring decision bodies steer a process of decisions — governance is one species of this genus; aswritten is the memory the steering runs on across all three use cases" .

    narr:Narrative_GovernanceAsSpeciesOfSteering a narr:Narrative ;
      dct:source narr:Sample_SteeringDecisionProcess_May2026 ;
      skos:broader narr:NarrativeAnchor ;
      skos:prefLabel "Governance Is One Species of Steering — Not the Category" ;
      skos:note "'Governance' names the customer's world — their meetings, their venues. It must not become aswritten's product category: 'governance software' reads as GRC (compliance, approval workflows, audit), a graveyard category aswritten does not belong in. Steering is the genus; governance is one species. The distinction protects aswritten from being miscategorized as GRC software while still speaking the customer's language." ;
      narr:theme "Governance names the customer's world but must not become aswritten's product category — GRC is a graveyard; steering is the genus that covers all three use cases" .

    narr:Narrative_AswrittenIsMemorySubstrate a narr:Narrative ;
      dct:source narr:Sample_SteeringDecisionProcess_May2026 ;
      skos:broader narr:PositioningThesis ;
      skos:prefLabel "aswritten Is the Memory the Steering Runs On — Never the Loop" ;
      skos:note "In every use case, aswritten is the memory the steering runs on — read at the start of the work, written at the end — never the tool that does the governing or orchestrating. The substrate is the same across all three use cases and is read by both humans and agents. This is the unifying positioning principle across the three use cases." ;
      narr:theme "aswritten is always the substrate — read at the start of work, written at the end — never the loop that does the governing or orchestrating" .

    narr:Narrative_UseCase1GoverningHumanTeam a narr:Narrative ;
      dct:source narr:Sample_SteeringDecisionProcess_May2026 ;
      skos:broader narr:SolutionArchetypes ;
      skos:prefLabel "Use Case 1: Governing a Human Team" ;
      skos:note "Organizational governance and process governance — the ARB is the engineering version; the act generalizes to any leadership or governance process. Faces both inward (internal architecture) and outward (what the organization can deliver to its clients). This is the use case already represented in aswritten's deck and fundraising brief." ;

      narr:theme "Governing a human team — ARB, leadership processes, governance bodies — is Use Case 1; aswritten is the memory the governance runs on" .

    narr:Narrative_UseCase2AgenticSteering a narr:Narrative ;
      dct:source narr:Sample_SteeringDecisionProcess_May2026 ;
      skos:broader narr:SolutionArchetypes ;
      skos:prefLabel "Use Case 2: Agentic Steering (Currently Underrepresented)" ;
      skos:note "Two nested scales: (1) steering one model — the founding thesis; (2) steering the entire agentic development process around it, which is functionally the same as ARB but often done by a smaller team or single person orchestrating agents instead of humans. Grounded in the a founder beta user / factoryfactory.ai briefing (PR #264): factoryfactory builds the Agent Expert Systems orchestration loop; aswritten is the memory the loop runs on. aswritten dogfoods this — its own product development is agentic steering. This use case is currently underrepresented in aswritten's materials; foregrounding it is the main thing this framing corrects." ;
      narr:supports narr:Narrative_NamedPerspectiveArchitecture ;
      narr:theme "Agentic steering at two scales — one model and the entire agentic ecosystem — is Use Case 2; currently underrepresented in aswritten's materials; grounded in factoryfactory.ai briefing" .

    narr:Narrative_UseCase3SharedProcessSteering a narr:Narrative ;
      dct:source narr:Sample_SteeringDecisionProcess_May2026 ;
      skos:broader narr:SolutionArchetypes ;
      skos:prefLabel "Use Case 3: Steering the Shared Process Across Engagements" ;
      skos:note "Process governance and process steering for aligning the commonalities and shared process between different engagements, different clients, different processes — so that it can be consumed by both humans and agents. The methodology layer — the shared process underneath many engagements, extracted and aligned so one memory substrate serves every team, human or agent." ;
      narr:theme "Steering the shared process across engagements — the methodology layer extracted and aligned so one memory substrate serves every team, human or agent — is Use Case 3" .

    narr:Narrative_SteeringLoopPlusMemorySubstrate a narr:Narrative ;
      dct:source narr:Sample_SteeringDecisionProcess_May2026 ;
      skos:broader narr:NarrativeAnchor ;
      skos:prefLabel "Each Use Case Is a Steering Loop Plus a Memory Substrate" ;
      skos:note "The unifier across all three use cases: each is a steering loop plus a memory substrate. aswritten is always the substrate — read at the start of the work, written at the end — never the loop. The team being steered is human (Use Case 1), agent (Use Case 2), or the shared process across engagements (Use Case 3); the substrate is the same, and it is read by both humans and agents." ;
      narr:theme "Steering loop + memory substrate is the structural pattern across all three use cases; aswritten is always the substrate, never the loop" .

    # ── CLAIMS ──────────────────────────────────────────────────────────

    narr:Claim_SteeringIsFoundingThesis a narr:Claim ;
      dct:source narr:Sample_SteeringDecisionProcess_May2026 ;
      skos:note "Steering is also aswritten's founding thesis — narrative as the steering vector for a language model. The genus (steering) connects the product's founding insight to all three use cases, making the frame internally coherent and not merely a marketing reframe." ;
      narr:aboutNode narr:Narrative_SteeringDecisionProcess ;
