      skos:note "Use Case 2 (agentic steering) is currently underrepresented in aswritten's materials — the deck and fundraising brief carry Use Case 1 but not Use Case 2. Foregrounding Use Case 2 is the main thing the steering frame corrects. This is a gap in current positioning materials that must be addressed." ;
      narr:aboutNode narr:Narrative_UseCase2AgenticSteering ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_UseCase2AgenticSteering .

    narr:Claim_CedarCedarLoopAswrittenMemory a narr:Claim ;
