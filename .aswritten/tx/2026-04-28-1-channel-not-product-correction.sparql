INSERT DATA {
  GRAPH narr:Tx_20260428T120000Z {

    # ── Sample ──────────────────────────────────────────────────
    narr:Sample_ChannelStrategyCorrection_20260428 a narr:Sample ;
      dct:title "Channel Strategy Correction — Scarlet Dame / Claude session, April 28 2026" ;
      dct:created "2026-04-28"^^xsd:date ;
      narr:inputLength 7842 ;
      dct:description "Conversation between Scarlet Dame and Claude (Opus 4.7, mobile session). Corrects the over-embedded claim that the product is a phone number; establishes SMS as a distribution channel with context-dependent fit; documents two structural extraction gaps (temporality, subgraph segmentation); records a beta user from outside tech pushback and seven Twilio toll-free verification rejections as triggering evidence." .

    # ── Actors ──────────────────────────────────────────────────
    narr:Actor_ScarletDame a narr:Actor ;
      skos:prefLabel "Scarlet Dame" ;
      skos:note "Founder of aswritten.ai. Primary speaker in this session. Initiating the channel-strategy correction and documenting extraction failure modes." .

    # ── Primary Narrative ────────────────────────────────────────
    narr:Narrative_ChannelIsDistributionNotIdentity a narr:Narrative ;
      dct:source narr:Sample_ChannelStrategyCorrection_20260428 ;
      narr:theme "Channel is distribution, not product identity" ;
      skos:broader narr:PositioningThesis ;
      skos:note "The phone number / SMS is a distribution channel — one of several — not the product itself. The product is curated expertise installation. SMS is the right channel in contexts where the trust-signal of 'not an AI chat' is worth its operational cost (primarily enterprise); it is the wrong channel where spam association creates friction or operational cost is unjustified. This narrative supersedes the over-embedded 'the product is a phone number' claim that propagated from the text-for-topic experiment." .

    # ── Claims ──────────────────────────────────────────────────

    # Section: The correction
    narr:Claim_ProductIsNotPhoneNumber a narr:Claim ;
      narr:aboutNode narr:WhatIsIt ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:challenges narr:Claim_CoreValuePropInstallExpertise ;
      dct:source narr:Sample_ChannelStrategyCorrection_20260428 ;
      skos:note "Explicit correction: the product is NOT a phone number. The prior tagline-level assertion ('the product is a phone number') was generated by the text-for-topic experiment and incorrectly promoted to current worldview by the extraction pipeline, which could not distinguish experiment-channel from product identity. This claim is Boulder (high conviction, explicitly stated by founder) but not Foundation because the positive replacement is the Foundation-level anchor." .

    # Section: The corrected positive position
    narr:Claim_SMSIsDistributionChannel a narr:Claim ;
      narr:aboutNode narr:WhatIsIt ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_ChannelIsDistributionNotIdentity ;
      dct:source narr:Sample_ChannelStrategyCorrection_20260428 ;
      skos:note "The phone number / SMS is a distribution channel. It is one of several. It is the right channel in some contexts (enterprise, trust-signal value) and the wrong channel in others (spam association, prospect reluctance to share number, unjustified operational cost). Channel fit is context-dependent, not universal." .

    narr:Claim_ProductIsCuratedExpertiseInstallation a narr:Claim ;
      narr:aboutNode narr:WhatIsIt ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Claim_CoreValuePropInstallExpertise ;
      dct:source narr:Sample_ChannelStrategyCorrection_20260428 ;
      skos:note "The product is curated expertise installation — a way to install expertise into your AI and verify where it's coming from. Consistent with Claim_CoreValuePropInstallExpertise (Foundation, March 19 2026 strategy session). This session reaffirms that claim as the correct positive identity anchor, in contrast to the superseded phone-number tagline." .

    # Section: Why SMS feels right when it's right
    narr:Claim_SMSTrustSignalChannelProperty a narr:Claim ;
      narr:aboutNode narr:Differentiators ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Claim_SMSFormatHonesty ;
      dct:source narr:Sample_ChannelStrategyCorrection_20260428 ;
      skos:note "The trust-signal value of SMS (a phone number doesn't feel like an AI chat) is genuine and not superseded by the channel correction. It is a channel property, not a product identity. Scarlet frames it as 'a bonus; it's an upsell.' Consistent with Claim_SMSFormatHonesty (Foundation). The correction is about scope, not about negating the trust-signal value." .

    # Section: Why SMS is operationally expensive
    narr:Claim_SMSOperationalCost a narr:Claim ;
      narr:aboutNode narr:RiskGuardrails ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      dct:source narr:Sample_ChannelStrategyCorrection_20260428 ;
      skos:note "SMS is operationally expensive due to fraud maintenance, verification cycles, and ongoing compliance overhead. This cost is a permanent feature of running SMS at scale, not a one-time setup cost. It is one reason SMS may be appropriate only for enterprise contexts where clients can absorb the cost." .

    # Section: a beta user from outside tech pushback
    narr:Claim_SMSSpamFrictionKRC a narr:Claim ;
      narr:aboutNode narr:Archetype_KnowledgeRichConsumer ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Claim_SMSIsDistributionChannel ;
      dct:source narr:Sample_ChannelStrategyCorrection_20260428 ;
      skos:note "For the Knowledge-Rich Consumer archetype (a beta user from outside tech canonical), SMS-as-channel adds a trust friction that does not exist for the Knowledge Packager (an early prospect) or Delegator (the customer's chief architect). Spam association is the specific friction: in skeptical or lower-trust contexts, requiring someone to text may be a real downside. a beta user from outside tech's expressed preference: 'Can you just give me a chat widget on a web form?' This is new evidence extending Archetype_KnowledgeRichConsumer." .

    # Section: What this changes about prior canonical content
    narr:Claim_TaglineSupersession a narr:Claim ;
      narr:aboutNode narr:Tagline ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:challenges narr:Tagline ;
      dct:source narr:Sample_ChannelStrategyCorrection_20260428 ;
      skos:note "The tagline 'The product is a phone number.' in the Identity section of the worldview is superseded. Replacement positioning: 'The product is curated expertise installation. The phone number is the distribution channel for contexts where the trust-signal of not an AI chat is worth its operational cost — primarily enterprise.' The other Identity tagline ('Feather your arrows.') is unaffected. Supersession must be executed as an explicit deletion of the old tagline assertion in the same transaction as the new one — not a parallel addition." .

    # Section: What is not decided
    narr:Claim_SMSEnterpriseOnlyLeaning a narr:Claim ;
      narr:aboutNode narr:PackagingEntitlement ;
      narr:hasConvictionLevel narr:Conviction_Notion ;
      dct:source narr:Sample_ChannelStrategyCorrection_20260428 ;
      skos:note "Leaning (not decision): SMS should be offered only for the enterprise plan, because numbers must be provisioned individually and managed. Scarlet's actual epistemic state: 'We don't know yet how this maps to tiers... I don't want to make that decision right now.' The leaning is recorded; it is not yet a decision. Whether SMS becomes Enterprise-only specifically, or remains available across tiers as an opt-in upsell, is deliberately undecided as of April 28 2026." .

