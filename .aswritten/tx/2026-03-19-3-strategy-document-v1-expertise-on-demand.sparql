    # ── SECTION 3: Category Definition ───────────────────────────────────────
    narr:Claim_CategoryDefinitionCuratedExpertise
      a narr:Claim ;
      dct:source narr:Sample_StrategyDocV1_20260319 ;
      skos:note "Category defined as: 'Curated expertise installation — the layer above context engineering that determines not just what AI knows, but how it thinks.' Scarlet confirmed: 'Yeah, bam, spot on.' This is a category-creation move positioning aswritten above context engineering." ;
      narr:aboutNode narr:PositioningThesis ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_CategoryCuratedExpertiseInstallation .

