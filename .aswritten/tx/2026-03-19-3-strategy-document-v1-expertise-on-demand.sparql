    narr:Actor_ScarletDame_StrategyV1
      a narr:Actor ;
      skos:prefLabel "Scarlet Dame" ;
      skos:note "Founder of aswritten.ai. Led full-day strategic session on 2026-03-19 producing Strategy Document V1. Iterated through six tagline variations, confirmed core value proposition, defined category, restructured archetypes, and named tier structure." .

    # ── SECTION 1: Tagline Finalized ─────────────────────────────────────────
    narr:Claim_TaglineFinalized
      a narr:Claim ;
      dct:source narr:Sample_StrategyDocV1_20260319 ;
      skos:note "Tagline finalized after six iterations: 'Expertise from humans you trust. Cited by AI, aswritten.' Two-beat structure: trust (human source) then proof (AI citation). Scarlet iterated through six variations before landing on this form." ;
      narr:aboutNode narr:Tagline ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:NarrativeAnchor .

    narr:Obs_TaglineIterationProcess
      a narr:Observation ;
      dct:source narr:Sample_StrategyDocV1_20260319 ;
      skos:broader narr:Tagline ;
