# ── UPDATE: Narrative_NewTierStructure_20260319 — rename Enterprise → Organization ──
# Memory explicitly states: "renamed from 'Enterprise'" to "Organization ([amount]/month + [amount]setup)"
# Snapshot has: narr:Narrative_NewTierStructure_20260319 with skos:note mentioning Enterprise as top tier
DELETE {
  GRAPH ?g {
    narr:Narrative_NewTierStructure_20260319 skos:note ?oldNote ;
      skos:prefLabel ?oldLabel .
  }
}
INSERT {
  GRAPH narr:Tx_20260319T200000Z {
    narr:Narrative_NewTierStructure_20260319
      skos:note "Four tiers with distinct GitHub requirements and upgrade triggers. Free (read-only): consume from global marketplace of expertise, install, compile, cite — no GitHub needed. Individual (read-write): personal org-managed repo, add own memories, review, build personal graph — no GitHub needed ideally. Publisher/Team: connect own GitHub account, fork modules, multiple repos, collaboration, publish to global marketplace — GitHub required. Organization (formerly Enterprise, [amount]/month + [amount]setup): own internal marketplace of organizational expertise — GitHub required (own org). Renamed from 'Enterprise' to 'Organization' in Strategy Document V1 (2026-03-19). Key upgrade triggers: Free→Individual (want to add own knowledge); Individual→Publisher (want to fork, publish, or collaborate); Publisher→Organization (want own marketplace, not publish to global)." ;
      skos:prefLabel "New Tier Structure: Free / Individual / Publisher / Organization (2026-03-19, updated)" .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_NewTierStructure_20260319 skos:note ?oldNote .
    OPTIONAL { narr:Narrative_NewTierStructure_20260319 skos:prefLabel ?oldLabel . }
  }
} ;

