      skos:prefLabel "Curated Expertise Installation as Category" ;
      skos:note "aswritten defines a new category: curated expertise installation. It sits above context engineering — context engineering determines what AI knows; curated expertise installation determines how AI thinks. This is the category-creation framing for Strategy Document V1." ;
      narr:theme "Curated expertise installation is the layer above context engineering — it determines not just what AI knows but how it thinks" .

    # ── SECTION 4: Three Eras Framing (already captured in Claim_ThreeErasKnowledgeDistribution — skip) ──

    # ── SECTION 5: Expert Relationship Reframed ──────────────────────────────
    narr:Claim_ExpertRelationshipReframed
      a narr:Claim ;
      dct:source narr:Sample_StrategyDocV1_20260319 ;
      skos:note "Expert relationship reframed: the product does NOT replace experts — it expands their reach. Scarlet pushed back on 'What it replaces' framing. Corrected to 'What it changes': experts are sources, not bottlenecks. Their perspective scales exponentially while remaining traceable to them. The need for experts becomes the engine of the platform." ;
      narr:aboutNode narr:Narrative_ExpertReachExpansion ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:PositioningThesis .

    narr:Narrative_ExpertReachExpansion

