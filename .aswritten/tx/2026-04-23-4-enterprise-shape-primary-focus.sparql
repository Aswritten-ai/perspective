    # ── SAMPLE ──────────────────────────────────────────────────────
    narr:Sample_EnterpriseShapePrimaryFocus_20260421 a narr:Sample ;
      dct:title "Enterprise-Shape as Primary Focus (Tentative) — Tony Maley Check-in, April 21, 2026" ;
      dct:created "2026-04-21"^^xsd:date ;
      dct:description "Check-in call between Tony Maley and Scarlet Dame. Tony's additive vs. incremental diagnostic applied to Scarlet's current funnel points toward the enterprise customer-shape (enterprise or SMB with internal knowledge bottleneck + stakeholder access pattern) as primary sales focus. Expertise-distributor archetypes deprioritized as primary targets. an early prospect identified as straddling both archetypes. Decision is tentative — needs 2-3 more the enterprise customer-shape conversations to validate." ;
      narr:inputLength 5200 .

    # ── NARRATIVE ───────────────────────────────────────────────────
    narr:Narrative_EnterpriseShapePrimaryFocus a narr:Narrative ;
      dct:source narr:Sample_EnterpriseShapePrimaryFocus_20260421 ;
      skos:broader narr:FocusSequencing ;
      skos:prefLabel "Enterprise-Shape as Tentative Primary Sales Focus" ;
      skos:note "Tony's additive vs. incremental test applied to Scarlet's funnel points toward the the enterprise customer-shape (internal expert as bottleneck + stakeholder access pattern) as the primary focus. Expertise-distributor archetypes (a beta user from outside tech, an engineering manager at the customer-as-course-creator, a founder beta user) are relatively incremental and should be deprioritized as primary sales targets. 'Enterprise shape' is the engagement pattern, not org size — an early prospect's 5-person acupuncture practice has the same shape as the enterprise customer's 150-person consultancy." ;
      narr:theme "The additive diagnostic applied to the current funnel points to the enterprise customer-shape (internal bottleneck + stakeholder access) as the primary sales focus, with expertise-distributor archetypes moved to secondary track" .

    # ── CLAIMS ──────────────────────────────────────────────────────

    narr:Claim_EnterpriseShapeTentativePriority a narr:Claim ;
      dct:source narr:Sample_EnterpriseShapePrimaryFocus_20260421 ;
      skos:note "Tony's additive vs. incremental test applied to Scarlet's current funnel pointed toward the the enterprise customer-shape as primary focus. Conviction is tentative (Notion-level) — needs validation with 2-3 more the enterprise customer-shape prospects before moving to decision. Based on sample size of one (the enterprise customer) plus Tony's diagnostic framework. Honest framing: if the only evidence is one pilot with a lukewarm champion (the customer's chief architect is sponsor, not champion), this may be rationalization." ;
      narr:aboutNode narr:Narrative_EnterpriseShapePrimaryFocus ;
      narr:hasConvictionLevel narr:Conviction_Notion ;
      narr:supports narr:FocusSequencing .

    narr:Claim_EnterpriseShapeEngagementPattern a narr:Claim ;
      dct:source narr:Sample_EnterpriseShapePrimaryFocus_20260421 ;
      skos:note "'Enterprise shape' should be read as the engagement pattern — internal expert as bottleneck + stakeholder access — rather than as enterprise-only org size. an early prospect (5-person practice) and the enterprise customer (150-person consultancy) have the same engagement shape. The pattern is additive: the prospect cannot do this thing today without the product." ;
      narr:aboutNode narr:Narrative_AdditiveVsIncremental ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_EnterpriseShapePrimaryFocus .

    narr:Claim_ExpertiseDistributorDeprioritized a narr:Claim ;
      dct:source narr:Sample_EnterpriseShapePrimaryFocus_20260421 ;
      skos:note "Expertise-distributor archetypes (a beta user from outside tech, a founder beta user, a collaborator, an engineering manager at the customer-as-course-creator) are relatively incremental for their users and should be deprioritized as primary sales targets. They move to secondary track: keep warm but don't invest primary sales effort until the primary track has 2-3 closed deals. Free tier / expertise-distributor product direction is not abandoned — it is deferred as a primary motion." ;
      narr:aboutNode narr:Archetype_KnowledgePackager ;
      narr:hasConvictionLevel narr:Conviction_Notion ;
      narr:supports narr:Narrative_EnterpriseShapePrimaryFocus .

    narr:Claim_EarlyProspectBothArchetypes a narr:Claim ;
      dct:source narr:Sample_EnterpriseShapePrimaryFocus_20260421 ;
      skos:note "an early prospect's role is nuanced — he fits BOTH the Knowledge Packager archetype (expertise distribution for students/practitioners) AND the inbound-bottleneck pattern (fields inbound inquiries from clients and prescribing practitioners constantly). The engagement shape is the same as a B2B use case like the enterprise customer, even though the org is 5 vs. 150 people. This may require archetype refinement — an engineering manager at the customer may be more additive than the expertise-distribution framing suggested." ;

      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Claim_EnterpriseShapeEngagementPattern .

    narr:Claim_EnterpriseShapeValidationCriteria a narr:Claim ;
