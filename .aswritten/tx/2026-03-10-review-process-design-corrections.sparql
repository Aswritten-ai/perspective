  narr:Narrative_ReviewMemoryFlow a narr:Narrative ;
    dct:source   narr:Sample_ReviewProcessDesign ;
    narr:theme   "Saving a review memory ends a round and triggers extraction; merge signals no corrections needed and closes the PR — corrections always require at least two rounds." ;
    skos:broader narr:ChangeManagement ;
    prov:wasGeneratedBy narr:Tx_20260310T234028Z .

