    narr:supports           narr:CoreWorkflows ;
    dct:source              narr:Sample_ReviewProcessDesign ;
    skos:note               "Correction 2: Each shift must be labeled as improvement (sharpening current direction) or counter (testing alternative direction). Reviewer must know why they are looking at the shifted version." ;
    prov:wasGeneratedBy     narr:Tx_20260310T234028Z .

  narr:Claim_ComparisonScale a narr:Claim ;
