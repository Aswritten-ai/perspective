    narr:hasConvictionLevel narr:Conviction_Foundation ;
    narr:supports           narr:CoreWorkflows ;
    dct:source              narr:Sample_ReviewProcessDesign ;
    skos:note               "Correction 3: Maximum comparison unit is a few sentences. Longer content must be broken into comparison-sized chunks. Four paragraphs side-by-side is too much." ;
    prov:wasGeneratedBy     narr:Tx_20260310T234028Z .

  narr:Claim_LargeTXScale a narr:Claim ;
