  # --- Sample ---
  narr:Sample_TwoCallSalesMotion a narr:Sample ;
    dct:title "Two-Call Sales Motion: Read-Path Demo + Consultative Interview" ;
    narr:inputLength 5021 ;
    prov:wasGeneratedBy narr:Tx_20260310T151535Z .

  # --- Actors ---
  narr:Actor_Poplar a narr:Actor ;
    skos:prefLabel "Prospect" ;
    skos:note "Potential customer; may be CEO, CTO, or Ops persona. Evaluates aswritten's collective memory product during sales calls." ;
    dct:source narr:Sample_TwoCallSalesMotion ;
    prov:wasGeneratedBy narr:Tx_20260310T151535Z .

  # --- Narratives ---
  narr:Narrative_ReadPathFirst a narr:Narrative ;
    dct:source narr:Sample_TwoCallSalesMotion ;
    narr:theme "Demonstrate the product at full maturity (read path) before showing how it is built (write path)" ;
    skos:note "The core strategic reframe: the old demo showed the fragile write path live; the new demo shows the stable read path against a mature graph, deferring write-path complexity to offline work between calls." ;
    prov:wasGeneratedBy narr:Tx_20260310T151535Z .

  narr:Narrative_DelegationAsValue a narr:Narrative ;
    dct:source narr:Sample_TwoCallSalesMotion ;
    narr:theme "The value of collective memory is delegation — enabling someone who knows nothing about your business to do work that would normally require your most senior person" ;
    skos:note "All three demo beats (cold delegation, citation layer, gap honesty) connect to this single thread. Output quality, citations, and epistemic integrity are all facets of delegation." ;
    prov:wasGeneratedBy narr:Tx_20260310T151535Z .

  narr:Narrative_MemoryAsCollaboration a narr:Narrative ;
    dct:source narr:Sample_TwoCallSalesMotion ;
    narr:theme "Remember is collaboration — across teams and across chats — not a save action" ;
    skos:note "Scarlet's reframe: the memory save is the most confusing part for prospects; the value is upfront in compile/annotate/introspect. Remember is introduced as a concept, not a live feature, on call one." ;
    prov:wasGeneratedBy narr:Tx_20260310T151535Z .

  # --- Claims ---
  narr:Claim_SalesMotionIsDelivery a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Foundation ;
    narr:aboutNode narr:Narrative_SalesIsDelivery ;
    skos:note "The sales motion and product delivery are the same thing — but the delivery happens across two calls, not compressed into one." ;
    dct:source narr:Sample_TwoCallSalesMotion ;
    prov:wasGeneratedBy narr:Tx_20260310T151535Z .

  narr:Claim_NotProductDemoButConsulting a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Foundation ;
    narr:aboutNode narr:Narrative_ReadPathFirst ;
    skos:note "Explicitly not a product demo but a consulting engagement session — call one's interview phase." ;
    dct:source narr:Sample_TwoCallSalesMotion ;
    prov:wasGeneratedBy narr:Tx_20260310T151535Z .

  narr:Claim_ReadPathStable a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Boulder ;
    narr:aboutNode narr:Narrative_ReadPathFirst ;
    skos:note "The read path (compile, annotate, introspect) consists of stable, rehearsable operations. The write path has too many moving parts to reliably demonstrate live with unknown content." ;
    dct:source narr:Sample_TwoCallSalesMotion ;
    prov:wasGeneratedBy narr:Tx_20260310T151535Z .

  narr:Claim_MemorySaveIsMostConfusing a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Boulder ;
    narr:aboutNode narr:Narrative_MemoryAsCollaboration ;
    skos:note "Scarlet may overfocus on the memory save as the moment of value when it is actually the most confusing part for prospects. The value is upfront in compile/annotate/introspect." ;
    dct:source narr:Sample_TwoCallSalesMotion ;
    prov:wasGeneratedBy narr:Tx_20260310T151535Z .

  narr:Claim_GapHonestyIsCounterIntuitive a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Stake ;
    narr:aboutNode narr:Narrative_DelegationAsValue ;
    skos:note "Asking the AI something it does not know and having it identify the gap and who to ask is counterintuitively powerful — it demonstrates epistemic integrity." ;
    dct:source narr:Sample_TwoCallSalesMotion ;
    prov:wasGeneratedBy narr:Tx_20260310T151535Z .

  narr:Claim_DeckOnlyIfDoorOpens a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Stake ;
    narr:aboutNode narr:Narrative_ReadPathFirst ;
    skos:note "The sales deck appears only if the conversation naturally opens that door during the consultative interview phase of call one." ;
    dct:source narr:Sample_TwoCallSalesMotion ;
    prov:wasGeneratedBy narr:Tx_20260310T151535Z .

  # --- Observations ---
  narr:Observation_Beat1_ColdDelegation a narr:Observation ;
    skos:broader narr:WhatDoesItDo ;
    dct:source narr:Sample_TwoCallSalesMotion ;
    skos:note "Beat 1: Cold delegation. Ask the AI to do real work that would normally require an hour of briefing. The prospect evaluates output quality directly. The AI did not need briefing because it already has the worldview." ;
    prov:wasGeneratedBy narr:Tx_20260310T151535Z .

  narr:Observation_Beat2_CitationLayer a narr:Observation ;
    skos:broader narr:WhatDoesItDo ;
    dct:source narr:Sample_TwoCallSalesMotion ;
    skos:note "Beat 2: Citation layer (annotate). Shown as a quality attribute of the work product, not a separate feature. Claims trace to specific conversations and decisions, not hallucination." ;
    prov:wasGeneratedBy narr:Tx_20260310T151535Z .

  narr:Observation_Beat3_GapHonesty a narr:Observation ;
    skos:broader narr:WhatDoesItDo ;
    dct:source narr:Sample_TwoCallSalesMotion ;
    skos:note "Beat 3: Gap honesty (introspect). Ask the AI something it does not know. It tells you what is missing and who to ask. Demonstrates epistemic integrity." ;
    prov:wasGeneratedBy narr:Tx_20260310T151535Z .

  narr:Observation_TwoCallStructure a narr:Observation ;
    skos:broader narr:CoreWorkflows ;
    dct:source narr:Sample_TwoCallSalesMotion ;
    skos:note "Two-call structure: Call 1 = read-path demo on own org + consultative interview. Between calls = write path offline. Call 2 = read-path demo on prospect's org." ;
    prov:wasGeneratedBy narr:Tx_20260310T151535Z .

  narr:Observation_WritePathOffline a narr:Observation ;
    skos:broader narr:CoreWorkflows ;
    dct:source narr:Sample_TwoCallSalesMotion ;
    skos:note "Between calls: Scarlet ingests the call transcript into the prospect's repo, runs extraction, sets up examples based on their actual workflow. Bugs are private. No time pressure." ;
    prov:wasGeneratedBy narr:Tx_20260310T151535Z .

  narr:Observation_RememberAsConcept a narr:Observation ;
