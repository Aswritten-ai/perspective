# Extracted Entities
INSERT DATA {
  GRAPH narr:Tx_20260421T190000Z {
    narr:Sample_SecondWaveBridge_20260421 a narr:Sample ;
      dct:title "Second Wave Bridge Positioning" ;
      dct:created "2026-04-21"^^xsd:date ;
      narr:inputLength 3200 .

    narr:Narrative_SecondWaveBridge a narr:Narrative ;
      dct:source narr:Sample_SecondWaveBridge_20260421 ;
      narr:theme "aswritten as the Bridge to the Second Wave" ;
      skos:broader narr:PositioningThesis ;
      skos:note "aswritten positions itself as the bridge between the First Wave of AI (learning/experimentation) and the Second Wave (enterprise platforms). It wins by filling the gaps and being consumed by Second Wave platforms that lack embedded enterprise customer history." .

    narr:Claim_CustomerListAsAsset a narr:Claim ;
      narr:aboutNode narr:ValueExchange ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      dct:source narr:Sample_SecondWaveBridge_20260421 ;
      skos:note "The customer list is the primary asset. Enterprise customers with aswritten embedded in their stack represent the core acquisition value for Second Wave platforms." .

    narr:Claim_StakeInGroundStrategy a narr:Claim ;
      narr:aboutNode narr:FocusSequencing ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      dct:source narr:Sample_SecondWaveBridge_20260421 ;
      skos:note "Strategy: Get a stake in the ground with one enterprise customer, then replicate that pattern as many times as possible to build a valuable list for the Second Wave." .

    narr:Claim_SurviveToWin a narr:Claim ;
      narr:aboutNode narr:TimingThesis ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      dct:source narr:Sample_SecondWaveBridge_20260421 ;
      skos:note "The survival thesis: In technology, the winner is the one who survives. Survival means constantly riding the waves until it is your time to be at the front." .

    narr:StyleMetrics_SecondWaveBridge a narr:StyleMetrics ;
      skos:broader narr:StyleMetrics ;
      dct:source narr:Sample_SecondWaveBridge_20260421 ;
      narr:AverageSentenceLength 16 ;
      narr:ActiveVoiceRatio 0.85 ;
      narr:JargonDensity 0.08 ;
      skos:note "Strategic and thesis-driven register. High use of metaphors (waves, bridges, stakes). Direct and authoritative tone." .

    narr:StyleObs_WaveMetaphor a narr:StyleObservation ;
      skos:broader narr:Metaphor ;
      dct:source narr:Sample_SecondWaveBridge_20260421 ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_SecondWaveBridge_20260421 ;
        oa:hasSelector [ a oa:TextPositionSelector ; oa:start 200 ; oa:end 400 ] ;
        oa:hasSelector [ a oa:TextQuoteSelector ; oa:exact "The exact same reaction you're seeing now with AI was the same reaction the world had for the Internet" ]
      ] .

    narr:StyleObs_BridgeMetaphor a narr:StyleObservation ;
      skos:broader narr:Metaphor ;
      dct:source narr:Sample_SecondWaveBridge_20260421 ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_SecondWaveBridge_20260421 ;
        oa:hasSelector [ a oa:TextPositionSelector ; oa:start 600 ; oa:end 800 ] ;
        oa:hasSelector [ a oa:TextQuoteSelector ; oa:exact "You're the bridge to that and the bridge to the gap that you get consumed by one of them." ]
      ] .

    narr:StyleObs_SurvivalTone a narr:StyleObservation ;
      skos:broader narr:ToneAuthoritative ;
      dct:source narr:Sample_SecondWaveBridge_20260421 ;
      oa:hasTarget [
