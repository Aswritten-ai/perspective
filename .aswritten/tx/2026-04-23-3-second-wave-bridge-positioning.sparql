        oa:hasSelector [ a oa:TextPositionSelector ; oa:start 1500 ; oa:end 1700 ] ;
        oa:hasSelector [ a oa:TextQuoteSelector ; oa:exact "If you can survive, you win. And what does survive mean? Well, it means that you have to constantly be riding the waves" ]
