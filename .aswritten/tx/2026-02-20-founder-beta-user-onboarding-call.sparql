INSERT DATA {

  narr:Narrative_OnboardingGap a narr:Narrative ;
      dct:source narr:Sample_1 ;
      narr:theme "The gap between technical connection and first value is the core onboarding problem" ;
      skos:broader narr:OrganizationalChangeManual ;
      skos:note "Even sophisticated technical founders need live guidance to understand what to do first. The friction is cognitive, not technical." ;
      prov:wasGeneratedBy narr:Transaction_20260220 .

  narr:Narrative_MemoryAsSourceOfTruth a narr:Narrative ;
      dct:source narr:Sample_1 ;
      narr:theme "Transactions and memories are the source of truth; generated docs are transient and regenerable" ;
      skos:broader narr:Architecture ;
      skos:note "a founder beta user's key moment of understanding: the .aswritten directory is the only durable artifact; docs folder is generated and disposable." ;
      prov:wasGeneratedBy narr:Transaction_20260220 .

  narr:Narrative_ChatFirstCodeLater a narr:Narrative ;
      dct:source narr:Sample_1 ;
      narr:theme "Chat-first adoption path: populate worldview before coding" ;
      skos:broader narr:NarrativeDrivenRoadmap ;
      skos:note "Even dev-focused users should treat aswritten as a chat session first, not a coding session. First value is worldview population." ;
      prov:wasGeneratedBy narr:Transaction_20260220 .

  narr:Narrative_ConvictionDecay a narr:Narrative ;
      dct:source narr:Sample_1 ;
      narr:theme "Conviction should decay over time when claims are not reinforced" ;
      skos:broader narr:Conviction ;
      skos:note "a founder beta user's spaced-repetition framing: claims mentioned once and not reinforced should lose conviction weight. Maps to graph-level temporal analysis." ;
      prov:wasGeneratedBy narr:Transaction_20260220 .

  narr:Narrative_DemocratizedConsensus a narr:Narrative ;
      dct:source narr:Sample_1 ;
      narr:theme "Democratizing knowledge collection creates balanced organizational representation and reduces political influence" ;
      skos:broader narr:OrganizationalChangeManual ;
      skos:note "a founder beta user's insight on political dynamics: people avoid decisions to avoid accountability. Equal-footing knowledge collection counters this." ;
      prov:wasGeneratedBy narr:Transaction_20260220 .

  narr:Narrative_StaffingAIAdoptionWall a narr:Narrative ;
      dct:source narr:Sample_1 ;
      narr:theme "AI that works too well can create internal organizational conflict, blocking adoption" ;
      skos:broader narr:FrictionFailure ;
      skos:note "a collaborator: recruiter hit quota in a week, started poaching colleagues' candidates. Org change management was the blocker, not the technology." ;
      prov:wasGeneratedBy narr:Transaction_20260220 .

  narr:Narrative_VoiceMemoAsInput a narr:Narrative ;
      dct:source narr:Sample_1 ;
      narr:theme "Long rambling voice memos are high-quality memory input for the extraction pipeline" ;
      skos:broader narr:Product ;
      skos:note "Both Scarlet and a founder beta user converge on voice memo as a validated input format. More material is not a problem — richer input benefits extraction." ;
      prov:wasGeneratedBy narr:Transaction_20260220 .

} ;

