  GRAPH narr:Tx_20250715T190000Z {

    narr:Narrative_PreRegisteredEvalDiscipline a narr:Narrative ;

      skos:broader narr:QualityReviewGates ;
      skos:prefLabel "Pre-Registered Eval Battery as the Bar for Validated" ;
      skos:note "Three operational rules for holding the eval discipline: (1) Pre-register the comparison before building, committed to git, so the bar cannot drift to fit the outcome. (2) Keep the baseline as a real control — do not collapse it prematurely by merging the change being measured against it. (3) Report the actual numbers in the task before the words 'at par' or 'ready.' If a metric falls short, iterate — do not narrate around it. aswritten is its own first user; the rigor of the evaluation is the product validation, the same discipline the product sells." ;
      narr:theme "Pre-register before building, keep the baseline clean, report actual numbers — the eval discipline is the product validation" .

    # ── STYLE OBSERVATIONS ──────────────────────────────────────────────────
    narr:StyleObs_Antithesis_SmokesVsBattery a narr:StyleObservation ;
      skos:broader narr:Antithesis ;

      skos:note "Antithesis-heavy structure throughout: smokes vs. battery, mechanism vs. quality, appearance of being finished vs. the control mattering more. The core principle is stated as a paired antithesis: 'Smokes prove the mechanism; the battery proves quality.'" ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;

        oa:hasSelector [
