    narr:Narrative_AttendanceGrantsAccess a narr:Narrative ;
        dct:source narr:Sample_1MvpV2ConcisionOneProductRulings ;
        narr:theme "Visibility into a call's theatre and its linked memories is granted by having attended the source call; cross-links resolve against the target call's own access, and digest narrations of connected nodes are provisionally visible because the digest is abstraction, not source." ;
