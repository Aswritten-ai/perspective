# ── NEW ENTITIES ──────────────────────────────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260323T120000Z {

    # Section 1: Podcast/Interview as Sales Motion
    narr:Narrative_PodcastInterviewSalesMotion a narr:Narrative ;
      dct:source narr:Sample_DesignCollaborator_20260323 ;
      skos:broader narr:SalesDecks ;
      skos:prefLabel "The Podcast/Interview as Sales Motion: Three Outputs from One Conversation" ;
      skos:note "The breakthrough insight from the a design collaborator session: the demo call, the marketing content, and the product onboarding are the same event. You interview an expert about their expertise. That conversation becomes: (1) their installable perspective — the product, they get a free account with it already in it; (2) a podcast episode / content piece — marketing, published with permission; (3) a live demo of the product — proof, the interview itself shows the product working. Three outputs from one conversation. This is a content flywheel that also builds the marketplace supply side. a design collaborator's reaction to the demo walkthrough confirmed this: the human moment sells better than any screen recording." ;
      narr:theme "The interview is simultaneously the sales call, the product demo, the onboarding, and the content piece — three outputs from one conversation" .

    narr:Narrative_ContentFlywheel a narr:Narrative ;
      dct:source narr:Sample_DesignCollaborator_20260323 ;
      skos:broader narr:ExpansionPathway ;
      skos:prefLabel "Interview as Content Flywheel: Supply Side + Marketing + Demo" ;
      skos:note "The interview model creates a flywheel: each expert interview produces an installable perspective (supply side), a published content piece (marketing), and a live proof of the product working (sales). Scarlet: 'I could build out the marketplace by basically creating a podcast where I interview people about their business and perspective, and each of those things gets packaged into an installable expertise and they're just available.' This resolves the cold-start problem, the content problem, and the demo problem simultaneously." ;
      narr:theme "Each interview compounds: it builds supply side, generates marketing content, and demonstrates the product — a flywheel with no wasted motion" .

    narr:Claim_InterviewThreeOutputs a narr:Claim ;
      dct:source narr:Sample_DesignCollaborator_20260323 ;
      skos:note "One interview conversation produces three distinct outputs: (1) installable perspective for the expert (product delivery — free account pre-populated); (2) podcast episode / content piece (marketing — published with permission); (3) live demo of the product working (proof — the interview itself is the demo). This collapses the sales motion, onboarding, content creation, and supply-side building into a single event." ;
      narr:aboutNode narr:Narrative_PodcastInterviewSalesMotion ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_ContentFlywheel .

    narr:Claim_HumanMomentSellsBetter a narr:Claim ;
      dct:source narr:Sample_DesignCollaborator_20260323 ;
      skos:note "a design collaborator's reaction to the demo walkthrough confirmed: the human moment (the call, the expert's reaction to seeing their words cited) sells better than any screen recording. Tony's 'it just looks real' applied to video, not just GIFs. The hero video should be a human moment, not a screen recording." ;
      narr:aboutNode narr:Narrative_HeroVideoFormat ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_GIFBasedSalesMaterials .

    # Section 2: Tier Upgrade Path
    narr:Narrative_TierRenameExpertTeam a narr:Narrative ;
      dct:source narr:Sample_DesignCollaborator_20260323 ;
      skos:broader narr:PackagingPricing ;
      skos:prefLabel "Tier Rename: Individual→Expert, Publisher→Team" ;
      skos:note "Decided in earlier session on March 23, not yet propagated. Individual tier renamed to Expert ([amount]/month). Publisher tier renamed to Team ([amount]/month). The upgrade path from the interview: Free (interviewed, here's your perspective, free forever) → Expert ([amount]/month, want to add more materials) → Team ([amount]/month, team collaboration, cited) → Organization ([amount]/month, full engagement, distillation, multiple roles, on-prem). Each tier is a natural next step, not a paywall. The interview seeds the perspective; the user decides how far to take it." ;
      narr:theme "Tier rename (Individual→Expert, Publisher→Team) and the interview-seeded upgrade path make each tier a natural behavioral next step, not a paywall" .

    narr:Claim_TierRenameDecided a narr:Claim ;
      dct:source narr:Sample_DesignCollaborator_20260323 ;
      skos:note "Tier rename decided in earlier session on March 23: Individual→Expert, Publisher→Team. Not yet propagated in code. This is an open item from the session. The upgrade path is: interview → trial with perspective → Free (free forever) → Expert ([amount]/month, add more) → Team ([amount]/month, team collaboration) → Organization ([amount]/month, full engagement)." ;
      narr:aboutNode narr:PackagingPricing ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_TierRenameExpertTeam .

    # Section 3: Hero Video Format
    narr:Narrative_HeroVideoFormat a narr:Narrative ;
      dct:source narr:Sample_DesignCollaborator_20260323 ;
      skos:broader narr:SalesDecks ;
      skos:prefLabel "Hero Video Format: Human Moment, Not Screen Recording" ;
      skos:note "a design collaborator's design insight: don't make people read text in a video. The hero video is a human moment, not a screen recording. Format: (1) you on a call with someone — 10 seconds of real conversation; (2) brief clip showing the perspective being created; (3) the output citing the person's words — screen showing citations; (4) the expert's reaction — 'whoa, that's my methodology'; (5) brief statement of what they now have and what their team/students/clients can do with it. Can be assembled from existing a beta user from outside tech call footage if video exists, or from a new short recording. Key insight: 'The human moment sells, not the text.'" ;
      narr:theme "The hero video is a human moment — real conversation, expert reaction, cited output — not a screen recording or text-heavy explainer" .

    # Section 4: Demo Script
    narr:Narrative_DemoScriptOutsideTechBetaUser a narr:Narrative ;
      dct:source narr:Sample_DesignCollaborator_20260323 ;
      skos:broader narr:SalesDecks ;
      skos:prefLabel "Demo Script Finalized: a beta user from outside tech / Bluebird Learning Partners Scenario" ;
      skos:note "Four-step demo script using a beta user from outside tech @ bluebirdlearningpartners.com as scenario: (1) 'Just got off the phone with a beta user from outside tech @ bluebirdlearningpartners.com. She told me that program directors are afraid to use AI because they don't trust it to use reliable sources. Can you explain in a short paragraph how her program directors can get AI to cite her methodology when working with teachers?' → AI asks for a brain dump (the problem — everyone recognizes this). (2) 'Write the intro paragraph for the SOW to turn her training docs for new interns into installable perspectives, so her intern's work can cite her words, aswritten. Annotate your work.' → 100% cited output. Every claim traces to a beta user from outside tech's actual methodology. Footnotes visible. (3) 'What are we missing about her market?' → Gap analysis. Three specific gaps with severity. The product knows what it doesn't know. (4) 'Here's the call transcript, can you add her experiences to our perspective?' → Paste transcript. Memory saved. Perspective grows. The ', aswritten' at the end of prompt 2 is the mode switch — it tells the AI to use real sources, not make things up. The viewer learns what this means by seeing the output change." ;
      narr:theme "The four-step demo script shows the full product loop: problem recognition, cited output, gap analysis, memory growth — using a beta user from outside tech as the canonical scenario" .

    narr:Claim_AswrittenModeSwitch a narr:Claim ;
      dct:source narr:Sample_DesignCollaborator_20260323 ;
      skos:note "The ', aswritten' suffix at the end of a prompt is the mode switch — it tells the AI to use real sources from the installed perspective, not make things up. The viewer learns what this means by seeing the output change. This is the product's core differentiator made visible in the demo." ;
      narr:aboutNode narr:Narrative_DemoScriptOutsideTechBetaUser ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_ProvenanceCitationMoment .

    # Section 5: Scarlet's Articulation
