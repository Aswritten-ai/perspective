# ── UPDATE: narr:Claim_CoreValuePropInstallExpertise — installable expertise framing ──
DELETE {
  GRAPH ?g {
    narr:Claim_CoreValuePropInstallExpertise skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260323T120000Z {
    narr:Claim_CoreValuePropInstallExpertise skos:note "Core value proposition emerged from MVP redefinition session: 'A way to install expertise into your AI and verify where it's coming from.' Scarlet confirmed: 'That's gold.' REINFORCED 2026-03-23 (a design collaborator session): Scarlet explicitly dropped the 'memory' word and reframed as 'installable expertise.' Quote: 'I've let go of the memory word sort of entirely and I'm now calling it installable expertise. Because what we need and the big narrative foundation is not intelligence is capability. And more information does not solve your problem.' This is the crystallized positioning statement replacing prior framings." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_CoreValuePropInstallExpertise skos:note ?oldNote .
  }
} ;

# ── UPDATE: narr:Narrative_SupplierSideDistribution — interview IS distribution ─
DELETE {
  GRAPH ?g {
    narr:Narrative_SupplierSideDistribution skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260323T120000Z {
    narr:Narrative_SupplierSideDistribution skos:note "The expert is not coming to a marketplace to browse. They encounter aswritten because an expert they trust distributed it to them — QR code in a clinic, link in a training, install instructions from an employer. This is supplier-side distribution, not buyer-side marketplace. REINFORCED 2026-03-23: The podcast/interview model IS the distribution mechanism. Scarlet: 'I could build out the marketplace by basically creating a podcast where I interview people about their business and perspective, and each of those things gets packaged into an installable expertise and they're just available.' The interview removes the 'finding time' barrier and builds the supply side simultaneously. The product may not need a marketplace at launch, just a share/install flow." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_SupplierSideDistribution skos:note ?oldNote .
  }
} ;

