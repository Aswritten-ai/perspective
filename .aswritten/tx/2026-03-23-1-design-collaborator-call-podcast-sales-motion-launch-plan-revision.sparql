      skos:broader narr:BrandNameStylization ;
      dct:source narr:Sample_DesignCollaborator_20260323 ;
      skos:note "', aswritten' as a lowercase suffix appended to prompts — a mode-switch marker that is simultaneously a brand name, a command, and a rhetorical device. Lowercase consistent with brand stylization." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_DesignCollaborator_20260323 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 2600 ;
          oa:end 2720
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "so her intern's work can cite her words, aswritten. Annotate your work." ;
          oa:prefix "installable perspectives, " ;
          oa:suffix "\n\n3. **\"What are we missing"
        ]
      ] .

    narr:StyleObs_RuleOfThreeOutputs a narr:StyleObservation ;
      skos:broader narr:RuleOfThree ;
      dct:source narr:Sample_DesignCollaborator_20260323 ;
      skos:note "Rule of three used to structure the interview outputs: (1) installable perspective, (2) podcast episode/content piece, (3) live demo. The numbered list format reinforces the parallel structure and makes the flywheel legible." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_DesignCollaborator_20260323 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 420 ;
          oa:end 620
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "1. **Their installable perspective** (the product — they get a free account with it already in it)\n2. **A podcast episode / content piece** (marketing — published with permission)\n3. **A live demo of the product** (proof — the interview itself shows the product working)" ;
          oa:prefix "That conversation becomes:\n\n" ;
          oa:suffix "\n\nThree outputs from one conversation."
        ]
      ] .
  }
}