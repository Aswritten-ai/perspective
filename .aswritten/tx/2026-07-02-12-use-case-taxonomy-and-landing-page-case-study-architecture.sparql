INSERT DATA {
  GRAPH narr:Tx_20260702T172237Z {

    # ── Sample ──────────────────────────────────────────────────────────────
    narr:Sample_ThreeUseCasesLifecycle_20260702 a narr:Sample ;
      dct:title "Three Use Cases, One Lifecycle: Discovery / Onboarding / Governance — and the Case-Study Landing Page" ;
      dct:created "2026-07-02"^^xsd:date ;
      narr:inputLength 5105 ;
      skos:note "Jul 2 strategy thread synthesizing the a consultant who ran enterprise discovery engagements for fifteen years (Jun 30) and a design collaborator (Jun 29) calls. Conviction: claim-level taxonomy; landing-page direction is active work. Clarifies the enterprise pole of the open enterprise-vs-B2C question." .

    # ── Narrative: Three-Use-Case Taxonomy ──────────────────────────────────
    narr:Narrative_ThreeUseCaseTaxonomy a narr:Narrative ;
      dct:source narr:Sample_ThreeUseCasesLifecycle_20260702 ;
      narr:theme "Discovery / Onboarding / Governance as the three enterprise use cases" ;
      skos:broader narr:SolutionArchetypes ;
      skos:note "Scarlet's Jul 2 taxonomy distinguishing what had been blurring together as 'the enterprise framing': (1) Discovery — consultancy interviews → synthesized pitch plan, cited back to source, automatable with provenance; (2) Onboarding — enabling an org to onboard new staff and AIs into an existing knowledge base; (3) Governance — the the enterprise customer ARB use case, steering AI behavior and using AI connected to the perspective for QA and onboarding. 'Organizational memory' is explicitly demoted from the pitch to a governance sub-use-case. Conviction: claim-level." ;
      skos:related narr:Narrative_DiscoveryToolGTMWedge, narr:Narrative_UseCase1GoverningHumanTeam, narr:Narrative_UseCase2AgenticSteering, narr:Narrative_SteeringDecisionProcess .

    # ── Narrative: Onboarding Use Case ──────────────────────────────────────
    narr:Narrative_OnboardingUseCase a narr:Narrative ;
      dct:source narr:Sample_ThreeUseCasesLifecycle_20260702 ;
      narr:theme "Onboarding humans and AIs into an organizational perspective" ;
      skos:broader narr:SolutionArchetypes ;
      skos:note "Onboarding as a named, distinct use case: enabling an organization to onboard new staff because there's already an existing knowledge base. The recipient shape is the same whether the recipient is a human or an AI — both are being onboarded into an organizational perspective. This is 'super powerful' per Scarlet. Sits between Discovery (creates the perspective) and Governance (maintains and steers with it) in the lifecycle sequence." ;
      skos:related narr:Narrative_ThreeUseCaseTaxonomy, narr:Narrative_TranscriptBootstrappingUnderplayed .

    # ── Narrative: Org Memory Demoted to Governance Sub-Use-Case ────────────
    narr:Narrative_OrgMemoryDemotedToGovernanceSub a narr:Narrative ;
      dct:source narr:Sample_ThreeUseCasesLifecycle_20260702 ;
      narr:theme "Organizational memory demoted from the pitch to a governance sub-use-case" ;
      skos:broader narr:NarrativeAnchor ;
      skos:note "The Jul 2 taxonomy explicitly demotes 'organizational memory' from being the pitch to being a sub-use-case of governance. Scarlet: 'I'd take that as a sort of sub-use case, engineering governance or just governance processes generally.' This continues the committed retirement of 'memory' as the lead word (the Mar 23 'installable expertise' turn) and finally gives the leftover mission-language ('collective memory') a home that is a use case rather than the identity." ;
      skos:related narr:Narrative_GovernanceAsSpeciesOfSteering .

    # ── Narrative: Discovery→Onboarding→Governance Sales Arc ────────────────
    narr:Narrative_DiscoveryOnboardingGovernanceSalesArc a narr:Narrative ;
      dct:source narr:Sample_ThreeUseCasesLifecycle_20260702 ;
      narr:theme "Discovery / Onboarding / Governance as a single-customer sales arc" ;
      skos:broader narr:FocusSequencing ;
      skos:note "Session synthesis (attributed to the session, not to Scarlet): the three use cases are one perspective under three verbs, in sequence. Discovery CREATES the perspective (batch, from an existing conversation corpus). Onboarding TRANSFERS it — new humans and new AIs being the same recipient shape. Governance MAINTAINS AND STEERS WITH it (the ARB motion). Read as a sales arc: discovery is the entry engagement, onboarding the expansion, governance the subscription — a single-customer sequence, not three segments. Picking discovery as the focus sequences the others rather than sacrificing them." ;
      skos:related narr:Narrative_ThreeUseCaseTaxonomy, narr:Narrative_DiscoveryToolGTMWedge .

    # ── Narrative: Case-Study Architecture in aswritten ─────────────────────
    narr:Narrative_CaseStudyArchitectureInAswritten a narr:Narrative ;
      dct:source narr:Sample_ThreeUseCasesLifecycle_20260702 ;
      narr:theme "Building each case study's narrative architecture in aswritten dissolves the meta-loop and produces org-shaped example material" ;
      skos:broader narr:CaseStudies ;
      skos:note "Scarlet's direction: the landing page needs case studies that map to real pilots (or plausible discussions). Building each case study's narrative architecture *in aswritten* produces the org-shaped example material a consultant who ran enterprise discovery engagements for fifteen years said was missing ('you want companies using it... case studies are really important'). Because the subject is consulting discovery rather than aswritten itself, it dissolves the meta-loop confusion a consultant who ran enterprise discovery engagements for fifteen years named in the current demo. The pain script for the discovery case study already exists: the five-question discovery framework ('whose hours are the constraint,' 'the most recent incident of context failing to transfer') is 'what is the pain' in interrogative form." ;
      skos:related narr:Narrative_DiscoveryToolGTMWedge, narr:Narrative_FiveQuestionDiscoveryFramework .

    # ── Claims ───────────────────────────────────────────────────────────────
    narr:Claim_OnboardingHumansAndAIs a narr:Claim ;
      narr:aboutNode narr:Narrative_OnboardingUseCase ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      dct:source narr:Sample_ThreeUseCasesLifecycle_20260702 ;
      skos:note "Onboarding both individuals and AIs into an organizational perspective is the same recipient shape. Scarlet verbatim: 'Both onboarding their individuals and also AIs into an organizational perspective is super powerful.' The use case is not limited to human staff onboarding." ;
      narr:supports narr:Narrative_OnboardingUseCase .

    narr:Claim_LandingPageBehaviorOperationsBased a narr:Claim ;
      narr:aboutNode narr:LandingPages ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      dct:source narr:Sample_ThreeUseCasesLifecycle_20260702 ;
      skos:note "Scarlet's Jul 2 direction: 'the landing page is more behavior and operations-based.' The page's unanswered question is 'what is the pain, and what do I do with it? What does that actually look like?' The answer architecture is use-case-led with case studies, not capability-led." ;
      narr:supports narr:LandingPages .

    narr:Claim_LandingPageTagline_Jul2026 a narr:Claim ;
      narr:aboutNode narr:Tagline ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      dct:source narr:Sample_ThreeUseCasesLifecycle_20260702 ;
      skos:note "First deck slide drafted Jul 2: 'Turn your conversations into a perspective that is cited by AI.' The conversations-Rolodex hero stays, but the weight moves into use cases. This is a candidate tagline for the landing page, not a finalized one." ;
      narr:supports narr:Tagline .

    narr:Claim_CaseStudyDissolvesMetaLoop a narr:Claim ;
      narr:aboutNode narr:Narrative_CaseStudyArchitectureInAswritten ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      dct:source narr:Sample_ThreeUseCasesLifecycle_20260702 ;
      skos:note "Because the subject of the discovery case study is consulting discovery rather than aswritten itself, building it in aswritten dissolves the meta-loop confusion a consultant who ran enterprise discovery engagements for fifteen years named in the current demo. The case study is about the client's problem, not about aswritten's own architecture." ;
      narr:supports narr:Narrative_CaseStudyArchitectureInAswritten .

    narr:Claim_DiscoveryFocusSequencesOthers a narr:Claim ;
      narr:aboutNode narr:Narrative_DiscoveryOnboardingGovernanceSalesArc ;
