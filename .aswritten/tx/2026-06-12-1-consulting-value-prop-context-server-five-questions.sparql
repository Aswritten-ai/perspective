    narr:Sample_ContextServerFiveQuestions_20260610
      a narr:Sample ;
      dct:title "The value-proposition logic: the context server and the five questions" ;
      dct:created "2026-06-10"^^xsd:date ;
      dct:description "Part 4 of the consulting-engagement session record (June 10-12, 2026). Scarlet Dame working session with Claude. Covers the rejection of capability-led pitch, the CEO-as-context-server reframe, the five-question discovery framework, three demotions (transcripts, analytics, understanding), staged quantification, and continuity to January 8 deck / Tony pain-first feedback." ;
      narr:inputLength 3821 ;
      narr:styleProfile "<https://aswritten.ai/narrative#Antithesis> <https://aswritten.ai/narrative#Metaphor> <https://aswritten.ai/narrative#RuleOfThree> <https://aswritten.ai/narrative#ShortPunchyCadence> <https://aswritten.ai/narrative#SpeakerIdiolects>" .

    # ── NARRATIVES ───────────────────────────────────────────────────────────

    # S2: CEO as context server — new top-level reframe
    narr:Narrative_CEOContextServerReframe

      dct:source narr:Sample_ContextServerFiveQuestions_20260610 ;
      skos:broader narr:PositioningThesis ;
      skos:prefLabel "The CEO's Unpaid Second Job: Context Server" ;
      skos:note "The answer that landed when Scarlet rejected the capability-led pitch: no role goes away — what goes away is the CEO's unpaid second job as the company's context server. Every 'got a sec,' every deck review, every on-strategy check, every new hire and agency and AI session loaded by hand from the one head where the judgment lives. Invisible as a role because it's a tax distributed across the most expensive calendar in the company; countable as interruptions, review loops, and decision latency. Rhymes with the keystone promise 'reachability without interruptibility' — the same interruption inversion seen from the organization's side." ;
      narr:theme "The product eliminates the CEO's invisible unpaid second job as the company's context server — a tax distributed across the most expensive calendar in the company, countable as interruptions, review loops, and decision latency" ;
      narr:supports narr:Narrative_ReachabilityWithoutInterruptibility .

    # S4: Five-question discovery framework
    narr:Narrative_FiveQuestionDiscoveryFramework

      dct:source narr:Sample_ContextServerFiveQuestions_20260610 ;
      skos:broader narr:SolutionArchetypes ;
      skos:prefLabel "Five-Question Discovery Framework (Call One Structure)" ;
      skos:note "The five-question discovery framework doubles as the structure of call one: (1) Whose hours are the constraint — what questions can only you answer; which decisions wait for the next meeting? (2) Which recurring output bottlenecks on that person — what did you keep producing that you resented? (3) What is the most recent incident of context failing to transfer? (4) Which existing budget line does this raid? (5) What single number moves, and how will we both watch it? Disqualification rule: no answers to questions two and three means friendly or pass, not buyer." ;
      narr:theme "A five-question discovery framework that doubles as the structure of call one, with a disqualification rule: no answers to Q2 and Q3 means friendly or pass, not buyer" .

    # S5: Three demotions narrative
    narr:Narrative_TranscriptDemotionFrictionNotValue

      dct:source narr:Sample_ContextServerFiveQuestions_20260610 ;
      skos:broader narr:PositioningThesis ;
      skos:prefLabel "Three Demotions: Transcripts, Analytics, Understanding" ;
      skos:note "Three demotions from the June 10 session: (1) The transcript 'gold mine' is a friction story, not a value story — the market priced transcripts at roughly [amount]per seat; they are inert. (2) Introspective analytics reports are the deliverable for the decision-drift segment specifically (the the enterprise customer shape), not universal. (3) Understanding never sells — outputs do. This refines rather than contradicts the April 16 transcript bootstrapping insight: transcripts lead the onramp; pain leads the value story." ;
      narr:theme "Three demotions: transcripts are a friction story not a value story; analytics reports are the enterprise customer-shape-specific not universal; understanding never sells — outputs do" .

    # S6: Quantification staging
    narr:Narrative_QuantificationStagedHonestly

      dct:source narr:Sample_ContextServerFiveQuestions_20260610 ;
      skos:broader narr:MetricsMonitoring ;
