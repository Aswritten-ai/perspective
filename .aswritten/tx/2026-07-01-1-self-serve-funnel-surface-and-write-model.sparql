INSERT DATA {
  GRAPH narr:Tx_20260701T233458Z {

    # ── Sample ──────────────────────────────────────────────────
    narr:Sample_SelfServeProductSurface_20260624 a narr:Sample ;
      dct:title "Individual self-serve product — funnel, surface, and the content/commentary write model" ;
      dct:created "2026-06-24"^^xsd:date ;
      narr:inputLength 8368 ;
      dct:description "Scarlet working session (2026-06-24). Provisional/forward conviction. Covers digest browser surface, synchronous per-message integration, content/commentary split, multi-pass extraction pipeline, reconciliation-as-set-transaction, unified write path, individuation curve, and graph-in-memory storage." .

    # ── Actor ───────────────────────────────────────────────────
    narr:Actor_Scarlet_SelfServe a narr:Actor ;
      skos:prefLabel "Scarlet" ;
      skos:note "Primary speaker in the 2026-06-24 self-serve product design session. Verbatim quotes sourced from this session." .

    # ── Narrative 1: Content / Commentary Split ──────────────────
    narr:Narrative_ContentCommentarySplit a narr:Narrative ;
      dct:source narr:Sample_SelfServeProductSurface_20260624 ;
      narr:theme "Content/commentary split: per-message integration is the content layer; reconciliation is the authored commentary layer" ;
      skos:broader narr:Primitives ;
      skos:note "The keystone design decision of the session. Current memories conflate primary source content with commentary. The correct model: per-message integration captures primary source material (content layer); reconciliation is authored commentary about a referent set of previously extracted nodes (commentary layer). The read model already separates these (digest renders grounded position + RECONCILED conclusion); the write practice has not yet implemented the split. This is a write primitive that is read-implemented but not yet written." ;
      skos:related narr:Narrative_NavigationReplacesEmbeddedSnapshot, narr:Narrative_DigestAsRecognitionAid .

    # ── Narrative 2: Synchronous Per-Message Integration ─────────
    narr:Narrative_SynchronousPerMessageIntegration a narr:Narrative ;
      dct:source narr:Sample_SelfServeProductSurface_20260624 ;
      narr:theme "Integration is synchronous, per-message, and silent — async breaks the individual and the deliberate feedback-in-chat decision" ;
      skos:broader narr:ArchitectureOverview ;
      skos:note "The drift argument: a stale individual breaks the promise. Async integration was deliberately rejected because: (1) feedback from extraction results must appear directly in chat, not hidden behind the scenes; (2) the next extraction must wait for the previous to finish or it extracts against a stale state; (3) async creates drift between the individual and the actual experience of the individual. Synchronous per-message integration is the safer and easier starting point. MCP integration may require a hybrid model since MCP clients cannot be forced to call a tool every message." ;
      skos:related narr:Narrative_NavigationReplacesEmbeddedSnapshot .

    # ── Narrative 3: Digest Browser as Product Surface ───────────
    narr:Narrative_DigestBrowserProductSurface a narr:Narrative ;
      dct:source narr:Sample_SelfServeProductSurface_20260624 ;
      narr:theme "The product surface is the digest browser — the human as consumer of the same collapse/expand navigation that extraction and citation already use" ;
      skos:broader narr:ProductOverview ;
      skos:note "The individual self-serve surface looks like a digest browser where the user can collapse and expand up and down the tree. A clean UI: chat on one side, each message's transaction expandable next to it to show its effect on the graph. Scrolling to the bottom reveals the current graph with the full digest browser. Possibly an Undo Tree-style interface above the transaction view. The human is a consumer of the same read path that extraction and citation already use — the surface is the read model made visible." ;
      skos:related narr:Narrative_DigestAsRecognitionAid, narr:Narrative_NavigationReplacesEmbeddedSnapshot .

    # ── Narrative 5: Reconciliation as Set Transaction ───────────
    narr:Narrative_ReconciliationAsSetTransaction a narr:Narrative ;
      dct:source narr:Sample_SelfServeProductSurface_20260624 ;
      narr:theme "Reconciliation is a transaction about a set of transactions or nodes — the design of correction and commentary about the past" ;
      skos:broader narr:Primitives ;
      skos:note "Reconciliation is structurally a transaction about a set of transactions or a set of nodes in the graph. This is exactly what correction and commentary about the past are. The product surface: select multiple transactions, say something about them, submit a reconciliation request. The system asks 'are you talking about these?' — surfacing which graph nodes it is reasoning from. This is the legibility differentiator: unlike current AI use where the user never knows what the AI is reasoning from, aswritten surfaces the referent set explicitly. Disambiguate, never permission — the prompt rule." ;
      skos:related narr:Narrative_ContentCommentarySplit, narr:Narrative_DigestAsRecognitionAid .

    # ── Narrative 7: Individuation Curve + Conversion Mechanic ───
    narr:Narrative_IndividuationCurveConversionMechanic a narr:Narrative ;
      dct:source narr:Sample_SelfServeProductSurface_20260624 ;
      narr:theme "Engagement = individuation curve (generic → first divergence → accretion → ownership → expansion); conversion mechanic is own-by-default, pay-to-continue" ;
      skos:broader narr:PositioningThesis ;
      skos:note "The individuation curve describes the engagement arc for the individual self-serve product: generic (no divergence from base) → first divergence (graph begins to reflect the individual) → accretion (graph grows richer) → ownership (the individual identifies with the graph) → expansion (the individual extends the graph to others). The conversion mechanic is own-by-default, pay-to-continue: the graph belongs to the user by default; payment is required to continue building it past the free threshold." ;
      skos:related narr:Narrative_B2CPivot, narr:Narrative_TierContinuumNotDistinctMarkets .

    # ── Narrative 8: Graph-in-Memory / GitHub-Optional Storage ───
    narr:Narrative_GraphInMemoryStorage a narr:Narrative ;
      dct:source narr:Sample_SelfServeProductSurface_20260624 ;
      narr:theme "The graph can live in memory, stored nowhere by default — download at session end, upload to resume; GitHub becomes optional storage, not a required third party" ;
      skos:broader narr:ArchitectureOverview ;
      skos:note "A later refinement on ownership: the graph can live in memory, stored nowhere by default. The user downloads it at session end and uploads to resume. GitHub becomes optional storage, not a required third party. This structurally mitigates the demo-pollution problem by confining conviction and pollution risk to the commentary layer, and removes the GitHub dependency from the individual self-serve path." ;
      skos:related narr:Narrative_GraphInMemoryStorage, narr:Narrative_IndividuationCurveConversionMechanic .

    # ── Claims ───────────────────────────────────────────────────
    narr:Claim_SyncIntegrationDriftArgument a narr:Claim ;
      narr:aboutNode narr:Narrative_SynchronousPerMessageIntegration ;
      narr:hasConvictionLevel narr:Conviction_Notion ;
      narr:supports narr:Narrative_SynchronousPerMessageIntegration ;
      dct:source narr:Sample_SelfServeProductSurface_20260624 ;
      skos:note "Drift argument: async integration creates drift between the individual and the actual experience of the individual. The next extraction must wait for the previous to finish or it extracts against a stale state. Synchronous per-message integration is safer and easier in the beginning. Provisional/notion-level conviction — unbuilt." .

    narr:Claim_ContentLayerPerMessage a narr:Claim ;
      narr:aboutNode narr:Narrative_ContentCommentarySplit ;
      narr:hasConvictionLevel narr:Conviction_Notion ;
      narr:supports narr:Narrative_ContentCommentarySplit ;
      dct:source narr:Sample_SelfServeProductSurface_20260624 ;
      skos:note "Per-message integration is the content layer. Each message's primary source material is transacted individually as it happens. This is what the current memory model is missing — the per-message integrations that memories are then saved about." .

    narr:Claim_ReconciliationIsCommentaryLayer a narr:Claim ;
      narr:aboutNode narr:Narrative_ContentCommentarySplit ;
      narr:hasConvictionLevel narr:Conviction_Notion ;
      narr:supports narr:Narrative_ContentCommentarySplit ;
      dct:source narr:Sample_SelfServeProductSurface_20260624 ;
      skos:note "Reconciliation is the authored commentary — a write primitive that is read-implemented but not yet written. The read model already separates primary-source grounding from authored reconciliation (the digest renders a position grounded in source plus a separate RECONCILED conclusion). The write practice has conflated them by requiring memories to include enough primary source content." .

    narr:Claim_SourceAppendOnlyNeverDedup a narr:Claim ;

      narr:hasConvictionLevel narr:Conviction_Stake ;

      dct:source narr:Sample_SelfServeProductSurface_20260624 ;
      skos:note "Source is append-only and never deduplicated. All dedup/merge/supersession lives in the reconciliation layer. This is a pipeline law, not a preference." .

    narr:Claim_PassesNotTransactions a narr:Claim ;

      narr:hasConvictionLevel narr:Conviction_Stake ;

      dct:source narr:Sample_SelfServeProductSurface_20260624 ;
      skos:note "Passes ≠ transactions. A pass is a compute stage; a transaction is an atomic write. Fan out the compute, write atomically at the edge. This distinction prevents conflating pipeline orchestration with graph mutation." .

    narr:Claim_AreYouTalkingAboutThese a narr:Claim ;
      narr:aboutNode narr:Narrative_ReconciliationAsSetTransaction ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Narrative_ReconciliationAsSetTransaction ;
      dct:source narr:Sample_SelfServeProductSurface_20260624 ;
      skos:note "'Are you talking about these?' is the legibility differentiator and one of the most important questions aswritten can surface. It shows the user exactly what the AI is currently reasoning from in their graph — a huge differentiator from current AI use where the user never knows what the AI is referencing in memory. Disambiguate, never permission — the prompt rule." .

    narr:Claim_OwnByDefaultPayToContinue a narr:Claim ;
      narr:aboutNode narr:Narrative_IndividuationCurveConversionMechanic ;
      narr:hasConvictionLevel narr:Conviction_Notion ;
      narr:supports narr:Narrative_IndividuationCurveConversionMechanic ;
      dct:source narr:Sample_SelfServeProductSurface_20260624 ;
      skos:note "Own-by-default, pay-to-continue is the conversion mechanic for the individual self-serve product. The graph belongs to the user by default; payment gates continued building past the free threshold. This is the individuation curve's monetization point." .

    narr:Claim_GitHubOptionalNotRequired a narr:Claim ;
      narr:aboutNode narr:Narrative_GraphInMemoryStorage ;
      narr:hasConvictionLevel narr:Conviction_Notion ;
      narr:supports narr:Narrative_GraphInMemoryStorage ;
      dct:source narr:Sample_SelfServeProductSurface_20260624 ;
      skos:note "GitHub becomes optional storage, not a required third party. The graph can live in memory, stored nowhere by default. Download at session end, upload to resume. This removes the GitHub dependency from the individual self-serve path and structurally mitigates demo-pollution risk." .

