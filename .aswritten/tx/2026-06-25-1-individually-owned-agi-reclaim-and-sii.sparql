          oa:prefix "in a world where AI is the primary worker, \"" ;
          oa:suffix "\" Right now, you do"
        ]
      ] .

    # Observation: Exportable data blade
    narr:Obs_ExportableDataBlade a narr:Observation ;
      skos:broader narr:PositioningThesis ;
      dct:source narr:Sample_SII_AGIReclaim_20260624 ;
      skos:note "The aphoristic compression of the ownership argument: exportable data ≠ ownership; right to be forgotten ≠ freedom. Two parallel antitheses that sharpen the scanner essay to a blade." ;
      oa:hasSelector [
