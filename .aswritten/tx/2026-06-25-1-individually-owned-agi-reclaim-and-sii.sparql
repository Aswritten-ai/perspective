INSERT DATA {
  GRAPH narr:Tx_20260625T162442Z {

    # Actor
    narr:Actor_ScarletDame a narr:Actor ;
      skos:prefLabel "Scarlet Dame" ;
      skos:note "Founder of aswritten.ai / Synthetic Identity Co. Primary voice across all positioning, naming, and strategy sessions." .

    # Narrative: Fable wake-up call
    narr:Narrative_FableWakeUpCall a narr:Narrative ;
      dct:source narr:Sample_SII_AGIReclaim_20260624 ;
      narr:theme "Fable 5 takedown radicalizes anti-lock-in moat from feature into means-of-production politics" ;
      skos:broader narr:MoatLeverage ;
      skos:note "Scarlet treats the Fable 5 takedown — pulled through government pressure over Anthropic's refusal to cooperate with the national-security apparatus — as proof of who holds the bag when centralized power is withdrawn: the user. This radicalizes the anti-lock-in moat from a product feature into a political argument: in a world where AI is the primary worker, ownership of the expertise that allows it to execute its task is the means of production. The manifesto banner that sits above, not in place of, the pain-led context-server pitch." .

    # Claim: Human expertise is irreplaceable
    narr:Claim_HumanExpertiseIrreplaceable a narr:Claim ;
      narr:aboutNode narr:Narrative_FableWakeUpCall ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Insight_AntiLockInMoat ;
      dct:source narr:Sample_SII_AGIReclaim_20260624 ;
      skos:note "The nature of expertise is the selection of what to do and when, based on prior experience — exactly what humans are needed for. Nowhere in this future do humans get replaced or supplanted; perspective becomes more important, not less." .

    # Claim: SII naming rejected candidates
    narr:Claim_SIINamingRejectedCandidates a narr:Claim ;
      narr:aboutNode narr:Claim_SIINameConvergedFull ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      dct:source narr:Sample_SII_AGIReclaim_20260624 ;
      skos:note "Rejected candidates with reasons: 'Conversationally / Individuated Intelligence' (too modified); 'Sovereign Individual Intelligence' (web3 / security-tech connotation); 'Artificial Individual / Personal / Perspective Intelligence' (keeps the labs' word, API collision); 'IRI' (collides with perspective graph IRIs); 'ISI' (Pakistan's intelligence agency). Each rejection sharpens why SII works: one axis in the name, rest in tagline." .

    # Observation: Model-as-OS metaphor
    narr:Obs_ModelAsOSMetaphor a narr:Observation ;
      skos:broader narr:Metaphor ;
      dct:source narr:Sample_SII_AGIReclaim_20260624 ;
      skos:note "The supporting metaphor for the AGI reclaim: expecting the general-purpose model to handle every case is like expecting your OS to ship with all programs preinstalled. The task-adapted perspective is the program." ;
      oa:hasSelector [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_SII_AGIReclaim_20260624 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 1191 ; oa:end 1335
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "your operating system should come with all programs preinstalled instead of shipping with a programming language and having an open marketplace." ;
          oa:prefix "the mistake is expecting the general-purpose model to handle every case — \"" ;
          oa:suffix "\" The task-adapted perspective is the program."
        ]
      ] .

    # Observation: Fable anti-lock-in politics quote
    narr:Obs_FableAntiLockInPolitics a narr:Observation ;
      skos:broader narr:MoatLeverage ;
      dct:source narr:Sample_SII_AGIReclaim_20260624 ;
