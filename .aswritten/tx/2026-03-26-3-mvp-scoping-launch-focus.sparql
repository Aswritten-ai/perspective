INSERT DATA {
  GRAPH narr:Tx_20260326T120000Z {

    # ── Sample ──────────────────────────────────────────────────────────────
    narr:Sample_ScarletMVPScoping_20260326 a narr:Sample ;
      dct:title "MVP Scoping Session: What Ships, What's Cut, and Why" ;
      dct:created "2026-03-26"^^xsd:date ;
      narr:inputLength "9842"^^xsd:integer ;
      dct:description "Walking voice memo → session. Scarlet reviewing what's above/below the line for April 1 launch. Major scoping decisions driven by the synchronous extraction pipeline (Mar 24) fundamentally changing what's needed." .

    # ── Narratives ──────────────────────────────────────────────────────────

    narr:Narrative_FocusOvertooling a narr:Narrative ;
      dct:source narr:Sample_ScarletMVPScoping_20260326 ;
      narr:theme "Radical product focus: bounded behaviors done extremely well over feature breadth" ;
      skos:broader narr:PositioningThesis ;
      skos:note "The governing principle for all MVP scoping decisions: the product does a bounded set of behaviors that perform a bounded set of tasks extremely well. Explicitly compared to Apple (opinionated workflow) vs. Microsoft (does everything). The hardest thing is focus." .

    narr:Narrative_SeparationPrincipleProductVsOrg a narr:Narrative ;
      dct:source narr:Sample_ScarletMVPScoping_20260326 ;
      narr:theme "Separation of product features from org automation: what ships vs. what Scarlet runs internally" ;
      skos:broader narr:FocusSequencing ;
      skos:note "Running through the entire session: a distinction between product features (compile, remember, review, introspect, annotate, feedback/help) and org automation (changelog, graph health, refract, blog post generation). The latter become local skills or scheduled crons." .

    narr:Narrative_ExpertSingleStreamWorldview a narr:Narrative ;
      dct:source narr:Sample_ScarletMVPScoping_20260326 ;
      narr:theme "Expert plan adopts single-stream worldview: no branching, no PRs, one worldview updated on every remember" ;
      skos:broader narr:OperatingModelShifts ;
      skos:note "Major architectural decision for Expert tier: memories save to main by default, no multiple review, no concurrent branch handling. The remember → review → merge cycle becomes remember → get TX → optionally review → done." .

    # ── Claims: Hard Removes ─────────────────────────────────────────────────

    narr:Claim_StoriesRemoved a narr:Claim ;
      narr:aboutNode narr:CoreWorkflows ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      dct:source narr:Sample_ScarletMVPScoping_20260326 ;
      skos:note "Stories system entirely removed from product. TX summaries now returned directly from synchronous remember; blog post ideas, changelog, graph health become on-demand local skills. Workflows to delete: stories-list, story-draft, story-write, story-backfill, story-narrate-diff. Strip story calls from tx-post-commit (keep PR comment)." ;
      narr:supports narr:Narrative_SeparationPrincipleProductVsOrg .

    narr:Claim_NotificationsRemoved a narr:Claim ;
      narr:aboutNode narr:CoreWorkflows ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      dct:source narr:Sample_ScarletMVPScoping_20260326 ;
      skos:note "Notifications system entirely removed. Synchronous remember eliminates primary use case (memory processed notification). Secondary case (review requests) handled by GitHub natively. Workflows to delete: review-notify, msg-review-notify. Keep msg-send and front-webhook for feedback/help tool." ;
      narr:supports narr:Narrative_SeparationPrincipleProductVsOrg .

    narr:Claim_DiscoveriesRemoved a narr:Claim ;
      narr:aboutNode narr:CoreWorkflows ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      dct:source narr:Sample_ScarletMVPScoping_20260326 ;
      skos:note "Discoveries fully removed (not just disabled). Already disabled but artifacts remain. Full deletion required." ;
      narr:supports narr:Narrative_SeparationPrincipleProductVsOrg .

    narr:Claim_RefractRegistryRemovedFromProduct a narr:Claim ;
      narr:aboutNode narr:ModulesCapabilities ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      dct:source narr:Sample_ScarletMVPScoping_20260326 ;
      skos:note "Refract tool and registry removed from product. Registry is just the docs folder. Refract becomes a local Claude Code skill. Eliminates need to separate tools between org and everyone else — now one tool set for everyone. Workflows to delete: graph-refract, graph-scope (scope rolling into introspect). Remove from mcp-generic tool routing." ;
      narr:supports narr:Narrative_SeparationPrincipleProductVsOrg .

    narr:Claim_TXSummariesAutoGenRemoved a narr:Claim ;
      narr:aboutNode narr:ModulesCapabilities ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      dct:source narr:Sample_ScarletMVPScoping_20260326 ;
      skos:note "TX summaries on PR removed as auto-generated feature. Agent provides this from the returned transaction. Keep the PR comment mechanism in tx-post-commit — not hurting anything." .

    narr:Claim_MemoriesSourceToolRemoved a narr:Claim ;
      narr:aboutNode narr:ModulesCapabilities ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      dct:source narr:Sample_ScarletMVPScoping_20260326 ;
      skos:note "Memories/source tool removed from product. Memories are just files in the repo — anyone with a coding agent can read them directly. Org-only skill at most." ;
      narr:supports narr:Narrative_SeparationPrincipleProductVsOrg .

    narr:Claim_AdminTierEliminated a narr:Claim ;
      narr:aboutNode narr:PackagingEntitlement ;
