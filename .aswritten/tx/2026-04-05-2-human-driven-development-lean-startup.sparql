# Extracted entities (named graph)
INSERT DATA {
  GRAPH narr:Tx_20260401T120000Z {

    # ── SAMPLE ──────────────────────────────────────────────────────────────
    narr:Sample_TonyScarletCall_20260331 a narr:Sample ;
      dct:title "Tony-Scarlet Call: Human-Driven Development as Forcing Function (March 31, 2026)" ;
      dct:created "2026-03-31"^^xsd:date ;
      dct:description "Call between Scarlet Dame and Anthony Maley covering the principle that all software development must be directly connected to specific humans and their needs, the AI-specific trap of infinite scope, the interview sales motion as a forcing function for human-driven development, and the execution-to-strategy shift caused by AI restoring IC status." ;
      narr:inputLength 2847 .

    # ── NARRATIVES ──────────────────────────────────────────────────────────

    narr:Narrative_HumanDrivenDevelopmentPrinciple a narr:Narrative ;
      dct:source narr:Sample_TonyScarletCall_20260331 ;
      skos:broader narr:FocusSequencing ;
      skos:prefLabel "All Software Development Must Be Directly About People and Their Needs" ;
      skos:note "Scarlet articulated a foundational principle: all software development must be directly connected to specific humans and their needs, or the infinite scope of AI-assisted building becomes pathological. Without this constraint, a builder can walk out on an ever-extending limb — building entire products for days without any human anchor. This is the AI-era update to the Lean Startup's core insight." ;
      narr:theme "Without a direct human connection, AI-assisted development has no natural stopping point — the scope is infinite and the limb keeps extending" .

    narr:Narrative_LeanStartupUpdatedForAI a narr:Narrative ;
      dct:source narr:Sample_TonyScarletCall_20260331 ;
      skos:broader narr:PositioningThesis ;
      skos:prefLabel "Lean Startup Updated for AI: Start with Humans, Work Back" ;
      skos:note "Scarlet reframes the Lean Startup's test-first principle for the AI era. The original insight was: test or you build in the back room and miss customer needs. The AI-era update is stronger: you must start with the humans and work back from there, not just test eventually. Tony and a technical collaborator operationalized this by putting Lean Startup books into their working repo as a reference to prevent overthinking and over-engineering before talking to anyone." ;
      narr:theme "The Lean Startup's test-first principle upgrades to humans-first in the AI era — start with the person, work back to the feature, never the reverse" .

    narr:Narrative_AIActionTrap a narr:Narrative ;
      dct:source narr:Sample_TonyScarletCall_20260331 ;
      skos:broader narr:FrictionFailure ;
      skos:prefLabel "The AI Action Trap: Every Response Prompts Another Action, Answer Is Always Yes" ;
      skos:note "Tony named the mechanism that makes AI-assisted development pathological without human grounding: by the very nature of AI tools, every single response prompts another action. And while that is good for token consumption, it is not good for humans — because if the prompt is 'do you want me to do that? do you want me to make that happen?' the answer is always yes. This creates an infinite loop of building without human validation." ;
      narr:theme "AI tools create an action loop where every response prompts another action and the answer is always yes — without human grounding, this loop has no natural exit" .

    narr:Narrative_InterviewForcingFunction a narr:Narrative ;
      dct:source narr:Sample_TonyScarletCall_20260331 ;
      skos:broader narr:SalesDecks ;
      skos:prefLabel "Interview Sales Motion as Forcing Function for Human-Driven Development" ;
      skos:note "Scarlet connected the human-driven development principle directly to the interview-first sales motion. The interview puts her brain into human mode: the result of the interview is the start of the prospect's perspective (free), and if they want to add memories, shift the perspective, or share with their team, they upgrade to paid. Features become reactionary to actual people instead of the opposite. Without this forcing function, Scarlet risks losing the plot entirely." ;
      narr:theme "The interview-first sales motion is a forcing function that keeps development human-driven — features become reactionary to actual people, not the reverse" .

    narr:Narrative_ExecutionToStrategyShift a narr:Narrative ;
      dct:source narr:Sample_TonyScarletCall_20260331 ;
      skos:broader narr:OperatingModelShifts ;
      skos:prefLabel "AI Restored IC Status: The Real Work Is Curation and Strategy, Not Execution" ;
      skos:note "Scarlet identified that AI has made everyone individual contributors again — the execution work (terminal, coding) is now cheap and fast, but the real shift is getting back to strategy and curation. The goal is to stop the work being about actual execution in a terminal and start it being about curating a perspective that is then used by somebody else. Tony validated: the biggest asset of experienced people is the experience and strategy they bring, not their execution capacity." ;
      narr:theme "AI has restored IC status for everyone — the real competitive advantage is now strategy and curation, not execution capacity" .

    # ── CLAIMS ──────────────────────────────────────────────────────────────

    narr:Claim_AllDevMustBeHumanConnected a narr:Claim ;
      dct:source narr:Sample_TonyScarletCall_20260331 ;
      skos:note "Scarlet's foundational principle from the March 31 call: all software development must now be directly about people and the thing that they need. Without this constraint, there is no end to the limb you can walk yourself out on — you can build an entire product for days and days with AI assistance and never connect it to a human need." ;
      narr:aboutNode narr:Narrative_HumanDrivenDevelopmentPrinciple ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:FocusSequencing .

    narr:Claim_LeanStartupRepoAsGuardrail a narr:Claim ;
      dct:source narr:Sample_TonyScarletCall_20260331 ;
      skos:note "Tony and a technical collaborator put the Lean Startup books into the repo they're working on and use them as a reference to keep on track — specifically to prevent overthinking and over-engineering before actually talking to anyone about anything. This is a concrete operationalization of the humans-first principle as a guardrail in the development workflow." ;
      narr:aboutNode narr:Narrative_LeanStartupUpdatedForAI ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_HumanDrivenDevelopmentPrinciple .

    narr:Claim_AIAlwaysSaysYes a narr:Claim ;
      dct:source narr:Sample_TonyScarletCall_20260331 ;
      skos:note "Tony's diagnosis of the AI action trap: by the very nature of AI tools, every single response prompts another action. While this is good for token consumption, it is not good for humans — because if the prompt is 'do you want me to do that? do you want me to make that happen?' the answer is always yes. This is the mechanism that makes human grounding a prerequisite, not an option." ;
      narr:aboutNode narr:Narrative_AIActionTrap ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_HumanDrivenDevelopmentPrinciple .

    narr:Claim_InterviewPutsYouInHumanMode a narr:Claim ;
      dct:source narr:Sample_TonyScarletCall_20260331 ;
      skos:note "Scarlet's insight: the interview sales motion puts her brain into human mode. The sales motion becomes: do an interview with an actual human, the result of the interview is the start of their perspective (free), and if they want to add memories, shift the perspective, or share with their team, they upgrade to paid. This puts features in a reactionary position to actual people instead of the opposite. Without doing this soon, Scarlet risks losing the plot." ;
      narr:aboutNode narr:Narrative_InterviewForcingFunction ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_PodcastInterviewSalesMotion .

    narr:Claim_AIRestoredICStatus a narr:Claim ;
      dct:source narr:Sample_TonyScarletCall_20260331 ;
      skos:note "Scarlet's observation: AI has made everyone individual contributors again. The shift she thought she had made in her career — from execution to strategy — has been undone by AI making execution cheap. The real work now is getting back to strategy and curation of a perspective that is then used by somebody else. Tony validated: the biggest asset of experienced people is the experience and strategy they bring." ;
      narr:aboutNode narr:Narrative_ExecutionToStrategyShift ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_B2CPivot .

