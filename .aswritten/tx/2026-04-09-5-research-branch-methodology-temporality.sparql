    # ── STYLE OBSERVATIONS ───────────────────────────────────────

    narr:StyleObs_AntithesisConvictionTemporality
      a narr:StyleObservation ;
      skos:broader narr:Antithesis ;
      dct:source narr:Sample_ResearchBranchMethodology_20260408 ;
      skos:note "Sustained antithesis between conviction (how settled) and temporality (when applicable) — the structural spine of the entire document. Pairs like 'canon-in-conviction but canon-soon in temporality' and 'decision-level conviction / roadmap-level applicability' repeat across sections." ;
      rdf:value true ;
