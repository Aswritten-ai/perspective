    narr:Obs_ScarletBranchAtRootQuote
      a narr:Observation ;
      dct:source narr:Sample_ResearchBranchMethodology_20260408 ;
      skos:broader narr:ProcessPolicyUpdates ;
      skos:note "Scarlet's decision to use branch-at-root over subdirectory scoping — the boring-and-works principle applied to temporal isolation." ;
      oa:hasTarget [
