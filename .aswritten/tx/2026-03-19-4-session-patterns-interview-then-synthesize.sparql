INSERT DATA {
  GRAPH narr:Tx_20260319T220000Z {

    # ── Sample ──────────────────────────────────────────────────
    narr:Sample_InterviewSaveDraftAnnotate_20260319
      a narr:Sample ;
      dct:title "Session Pattern: Interview → Save → Draft → Annotate (2026-03-19)" ;
      dct:created "2026-03-19"^^xsd:date ;
      dct:description "Post-session retrospective capturing the four-phase arc of the 9-hour V1 strategy session between Scarlet Dame and Claude. Documents why the session worked, what to replicate, and anti-patterns to avoid." ;
      narr:inputLength 3842 .

    # ── Narrative: The four-phase pattern itself ─────────────────
    narr:Narrative_InterviewSaveDraftAnnotatePattern

      dct:source narr:Sample_InterviewSaveDraftAnnotate_20260319 ;
      skos:broader narr:CoreWorkflows ;
      skos:prefLabel "Interview → Save → Draft → Annotate: The V1 Strategy Session Pattern" ;
      skos:note "A 9-hour session that produced the V1 strategy document followed a four-phase arc: (1) Interview (~3 hours) — structured questions one at a time, reflect back, pull threads, let the user correct; (2) Save — three memories at natural decision points, extraction pipeline ran while discussion continued; (3) Draft (~4 hours) — section by section against newly grounded material with real-time feedback; (4) Annotate (~2 hours) — full document annotated against collective memory, 97 footnotes with narrative citations, provenance summaries per section. The product demonstrates itself through the process." ;
      narr:theme "The interview elicits thinking not yet in collective memory; save captures it; draft synthesizes it; annotation proves it — the product demonstrates itself through the process" .

    # ── Narrative: Interview before synthesis ────────────────────
    narr:Narrative_InterviewBeforeSynthesis

      dct:source narr:Sample_InterviewSaveDraftAnnotate_20260319 ;
      skos:broader narr:CoreWorkflows ;
      skos:prefLabel "Interview Before Synthesis: User Corrections Are More Valuable Than Initial Hypotheses" ;
      skos:note "The interview format meant the strategy emerged from Scarlet's thinking, not from the worldview alone. Key breakthroughs came from her corrections to the AI's hypotheses. Each correction was more valuable than the original hypothesis because it revealed thinking not yet in collective memory. The Tinkerer correction, Custom GPT correction, expert reach correction, and ambient behavior correction all came from this dynamic." ;
      narr:theme "The user's corrections to your hypotheses are more valuable than your initial hypotheses — interview before synthesizing, never write strategy from the worldview alone" .

    # ── Narrative: Real-time feedback loop ──────────────────────
    narr:Narrative_RealTimeFeedbackLoop

      dct:source narr:Sample_InterviewSaveDraftAnnotate_20260319 ;
      skos:broader narr:FeedbackLoops ;
      skos:prefLabel "Real-Time Feedback Loop: Read and React as Each Section Is Written" ;
      skos:note "Scarlet read and reacted as each section was written. More productive than batch review because errors got caught immediately and did not compound into later sections. Her reactions often surfaced new insights — 'the deck is a derived artifact; the real value is the perspective shift.' The document stayed aligned with her voice and thinking throughout." ;
      narr:theme "Real-time per-section feedback prevents error compounding and surfaces insights that batch review misses" .

    # ── Narrative: Save before drafting ─────────────────────────
    narr:Narrative_SaveBeforeDrafting

      dct:source narr:Sample_InterviewSaveDraftAnnotate_20260319 ;
      skos:broader narr:CoreWorkflows ;
      skos:prefLabel "Save Before Drafting: Ground the Knowledge Before Synthesizing It" ;
      skos:note "Three memories were saved before the document was started. By the time sections were being drafted, the extraction pipeline had run and the annotation tool could verify claims against the new knowledge. The document was grounded because the knowledge was grounded first. Sequence: Save → wait for extraction → compile → draft → annotate." ;
      narr:theme "Save memories at natural decision points before drafting — the extraction pipeline needs time, and grounded knowledge produces grounded documents" .

    # ── Narrative: Annotation as quality control ─────────────────
    narr:Narrative_AnnotationAsQualityControl

      dct:source narr:Sample_InterviewSaveDraftAnnotate_20260319 ;
      skos:broader narr:QualityReviewGates ;
      skos:prefLabel "Annotation as Quality Control, Not Decoration" ;
      skos:note "The annotation pass caught where the document made claims not yet in collective memory, identified which source memories each section drew from, and created a visible trust layer. Provenance summaries let a reader see at a glance what is earned knowledge vs. new assertion. Annotate per-section as you draft — the text length limit causes silent failures on full sections. Write full narrative footnotes from the start; the narrative IS the value." ;
      narr:theme "Annotation is quality control — it catches unsupported claims, surfaces source memories, and creates a visible trust layer that proves the document" .

    # ── Narrative: One question at a time ───────────────────────
    narr:Narrative_OneQuestionAtATime

      dct:source narr:Sample_InterviewSaveDraftAnnotate_20260319 ;
      skos:broader narr:CoreWorkflows ;
      skos:prefLabel "One Question at a Time: Interview Discipline" ;
      skos:note "Do not dump 10 questions. Ask one, listen, reflect back, pull the thread. Name patterns without prescribing: 'Here's what I'm hearing' not 'here's what you should do.' The interview format is what makes the strategy emerge from the user's thinking rather than the worldview alone." ;
      narr:theme "One question at a time — listen, reflect back, pull the thread — is the discipline that makes the interview format work" .

    # ── Claims ──────────────────────────────────────────────────
    narr:Claim_SessionPatternReplicable
      a narr:Claim ;
      dct:source narr:Sample_InterviewSaveDraftAnnotate_20260319 ;
      skos:note "The Interview → Save → Draft → Annotate pattern applies to any session that needs to produce a strategic document, content piece, or decision framework. The core insight: the interview elicits thinking not yet in collective memory, the save captures it, the draft synthesizes it, and the annotation proves it." ;
      narr:aboutNode narr:Narrative_InterviewSaveDraftAnnotatePattern ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:CoreWorkflows .

    narr:Claim_CorrectionsMoreValuableThanHypotheses
      a narr:Claim ;
      dct:source narr:Sample_InterviewSaveDraftAnnotate_20260319 ;
      skos:note "Each correction from Scarlet was more valuable than the original hypothesis because it revealed thinking that was not yet in collective memory. The Tinkerer correction ('their existing solution is a barrier'), the Custom GPT correction ('they're just local RAG'), the expert reach correction ('we're expanding their reach'), and the ambient behavior correction ('expertise at the moment of need, not ambient') all came from this dynamic." ;
      narr:aboutNode narr:Narrative_InterviewBeforeSynthesis ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_InterviewBeforeSynthesis .

    narr:Claim_DeckIsDerivedArtifact
      a narr:Claim ;
      dct:source narr:Sample_InterviewSaveDraftAnnotate_20260319 ;
      skos:note "Scarlet's insight during real-time feedback: 'the deck is a derived artifact; the real value is the perspective shift.' Surfaced during the drafting phase when she reacted to a section as it was written — an insight that would not have emerged in batch review." ;
      narr:aboutNode narr:Narrative_RealTimeFeedbackLoop ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_ConsultingModuleDeliverable .

    narr:Claim_AnnotatePerSectionNotFullDoc
      a narr:Claim ;
      dct:source narr:Sample_InterviewSaveDraftAnnotate_20260319 ;
      skos:note "Annotating the full document in one pass at the end is less effective than per-section annotation during drafting. The text length limit causes silent failures on full sections. Paragraphs are reliable. Distance from the writing also makes end-of-session annotation less effective." ;
      narr:aboutNode narr:Narrative_AnnotationAsQualityControl ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:QualityReviewGates .

