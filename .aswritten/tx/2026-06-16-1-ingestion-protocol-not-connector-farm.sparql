          oa:prefix "Give us your transcripts and we'll give you...' " ;
          oa:suffix " We are not over and over again"
        ]
      ] .

    # SO2 — Antithesis: "achieved by not building"
    narr:StyleObs_AntithesisNotBuilding a narr:StyleObservation ;
      skos:broader narr:Antithesis ;
      dct:source narr:Sample_IngestionProtocol_20260609 ;
      skos:note "Rhetorical antithesis used to crystallize the strategic inversion: the purest version of the philosophy is achieved by not building the thing you might expect to build. Compact paradox that carries the whole reframe." ;
      rdf:value true ;
