# ── UPDATE: narr:Claim_NarrAppliesAsOntologyExtension — add customer validation evidence ──
DELETE {
  GRAPH ?g {
    narr:Claim_NarrAppliesAsOntologyExtension skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260501T200000Z {
    narr:Claim_NarrAppliesAsOntologyExtension
      skos:note "A new ontology property — narr:appliesAs — with values like current | nearFuture | exploration | speculative would solve the temporality gap structurally. Compile would filter by temporality as well as conviction: default worldview layer includes only current-applicability claims; worldview:roadmap pulls in near-future claims; worldview:all includes exploration-level claims. This is captured as a near-future notion — genuinely good idea, deliberately deferred. Introducing it mid-launch would break extraction tests, require tooling updates, propagate through compile layers, touch SHACL schemas, and steal a week from April 9 launch-critical work. NOW VALIDATED BY PRODUCTION FAILURE: the customer's chief architect's demo pollution experience (2026-05-01) is the first documented customer case where the absence of this property caused a destructive corrective action (full memory deletion). Scarlet independently arrived at the same need on the same call. This claim should be promoted from notion to stake-level and added to the product roadmap with concrete acceptance criteria." ;
      narr:evidencedBy narr:Obs_CustomerArchitectDemoPollutionQuote .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_NarrAppliesAsOntologyExtension skos:note ?oldNote .
  }
}