    # ── SAMPLE ──────────────────────────────────────────────────
    narr:Sample_TranscriptBootstrapping_20260416 a narr:Sample ;
      dct:title "Transcript Bootstrapping Is Underplayed (April 16, 2026)" ;
      dct:created "2026-04-16"^^xsd:date ;
      dct:description "Post-launch walk voice memo from Scarlet Dame reflecting on three signals from the the enterprise customer engagement and the customer's chief architect's question that reveal aswritten is underplaying call transcripts as a bootstrap onramp and value proposition. Argues for promoting the Fireflies/Gemini/Zoom webhook pipeline from 'waiting to build' to 'actively pitch'." ;
      narr:inputLength 3850 ;
      narr:styleProfile "<https://aswritten.ai/narrative#ToneDirectPersonal> <https://aswritten.ai/narrative#IdiolectPhrasing> <https://aswritten.ai/narrative#Antithesis> <https://aswritten.ai/narrative#ShortPunchyCadence>" .

    # ── PRIMARY NARRATIVE ────────────────────────────────────────
    narr:Narrative_TranscriptBootstrappingUnderplayed a narr:Narrative ;
      dct:source narr:Sample_TranscriptBootstrapping_20260416 ;
      skos:broader narr:PositioningThesis ;
      skos:prefLabel "Transcript Bootstrapping Is Underplayed as Onramp and Value Proposition" ;
      skos:note "Three signals from the April 16 post-launch walk converge on a single diagnosis: aswritten is underplaying the call transcript angle both as an onramp and as a value proposition. Signal 1: the enterprise customer's surprise that their own ARB transcripts were an asset. Signal 2: the customer's chief architect had to ask whether Scarlet uses her own transcripts — she does, constantly, as one of two primary inputs. Signal 3: The 'send me your last 10 Fireflies transcripts and I'll give you back a working perspective tomorrow' pitch is stronger than 'let's schedule an interview.' The pitch should lead with transcripts, not interviews." ;
      narr:theme "Call transcripts are already an asset prospects don't recognize as such — the surprise-to-them pattern is itself a signal that aswritten is underplaying the transcript bootstrap pitch" .

    # ── CLAIMS ──────────────────────────────────────────────────

    # Signal 1: the enterprise customer surprise as pitch signal
    narr:Claim_TranscriptSurpriseSignal a narr:Claim ;
      dct:source narr:Sample_TranscriptBootstrapping_20260416 ;
      skos:note "The fact that the enterprise customer was surprised to learn their own historical ARB transcripts were an asset is itself a signal — not just evidence that transcripts are useful, but evidence that aswritten is failing to communicate this as the default pitch. People do not think of their own transcripts as an asset until someone points at them. The pattern of surprise-to-them is the pitch gap." ;
      narr:aboutNode narr:Narrative_TranscriptBootstrappingUnderplayed ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_PodcastInterviewSalesMotion .

    # Signal 2: Scarlet's own usage — voice memos and call transcripts as primary inputs
    narr:Claim_VoiceMemosAndTranscriptsPrimaryInputs a narr:Claim ;
      dct:source narr:Sample_TranscriptBootstrapping_20260416 ;
      skos:note "Scarlet herself uses call transcripts and voice memos as her two primary inputs into aswritten. The fact that the customer's chief architect had to ask, and Scarlet had to confirm, reveals this is not being communicated as the default usage pattern. Both inputs — conversations with others (call transcripts) and conversations with herself (voice memos) — are downplayed in the pitch as 'this is what you do.'" ;
      narr:aboutNode narr:Narrative_TranscriptBootstrappingUnderplayed ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_ExpertiseOnDemandReframe .

    # Signal 3: Language constraint — "create a perspective" not "train"
    narr:Claim_CreatePerspectiveNotTrain a narr:Claim ;
      dct:source narr:Sample_TranscriptBootstrapping_20260416 ;
      skos:note "Do NOT say 'train' — say 'create a perspective'. The inputs are 'conversations you're already having' — not extra work, not additional effort. Transcripts are already an asset, not yet-to-be-created material. This language constraint is required for the transcript bootstrap pitch to land correctly." ;
      narr:aboutNode narr:NamingConventions ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_TranscriptBootstrappingUnderplayed .

    # Signal 3: Fireflies/webhook pipeline should move from waiting-to-build to actively-pitch
    narr:Claim_FirefliesWebhookActivePitch a narr:Claim ;
      dct:source narr:Sample_TranscriptBootstrapping_20260416 ;
      skos:note "The Fireflies/Gemini/Zoom webhook pipeline — where every call automatically updates the perspective and the system texts the person to do the review over text — has already been discussed. This should move from 'waiting to build' to 'actively pitch.' The sales pitch 'send me your last 10 Fireflies transcripts and I'll give you back a working perspective tomorrow' is a stronger opener than 'let's schedule an interview.' It removes the favor framing. the enterprise customer and similar prospects may want this." ;
      narr:aboutNode narr:Narrative_TranscriptBootstrappingUnderplayed ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Claim_AIAgentLongTailInterviews .

