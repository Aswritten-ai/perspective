          oa:suffix " And not... is there going to be a super intelligence behind it"
        ]
      ] .

    narr:StyleObs_DesignCollaboratorCall_Antithesis a narr:StyleObservation ;
      skos:broader narr:Antithesis ;
      dct:source narr:Sample_DesignCollaboratorCall_20260629 ;
      rdf:value true ;
      skos:note "Antithesis structures the entire moonshot argument: monoculture vs. diversity, uniformity vs. amplification, 'AI more different, not less', 'amplifier not uniformity machine'. The 'X, not Y' negation pattern is Scarlet's dominant rhetorical device for sharpening a position by naming its opposite." ;
      oa:hasTarget [
