          oa:start 2554 ; oa:end 2723
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "we're right now having this shift where things get agentified and like they go the M Dash, they like start quoting and they start talking about things being load bearing" ;
          oa:prefix "She points at the homogenization already visible as systems get agentified and converge on one register: \"" ;
          oa:suffix " and whatever else... that's not a problem if it's one voice out of many."
        ]
      ] .

    narr:Obs_MoonshotPlainStatementQuote a narr:Observation ;
      skos:broader narr:Narrative_HowManyVoicesInSuperintelligence ;
      dct:source narr:Sample_DesignCollaboratorCall_20260629 ;
      skos:note "Scarlet's plainest statement of the moonshot: not an AI agent for everything, but as many distinct voices as there are humans." ;
      oa:hasSelector [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_DesignCollaboratorCall_20260629 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 3245 ; oa:end 3425
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "the moonshot idea is not, are we going to have an AI agent for everything? It's when we do have an AI agent for everything, can we have as many distinct voices as there are humans?" ;
          oa:prefix "the question for me and I think, like, " ;
          oa:suffix " Can we have more diversity of voice?"
        ]
      ] .

    narr:Obs_DesignCollaboratorAmplificationQuote a narr:Observation ;
      skos:broader narr:Narrative_AntiMonocultureAmplifier ;
      dct:source narr:Sample_DesignCollaboratorCall_20260629 ;
      skos:note "a design collaborator's verbatim articulation of the amplification framing — AI amplifies craft, not uniformity." ;
      oa:hasSelector [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_DesignCollaboratorCall_20260629 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 4450 ; oa:end 4639
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "I really like the word amplification that you used... rather than everything is becoming uniform. Amplifying things rather than making things consistent... AI to me is an amplification tool" ;
          oa:prefix "a design collaborator frames AI as an amplification tool: \"" ;
          oa:suffix " to enable me to do things I couldn't do before... it amplifies my capabilities"
        ]
      ] .

    narr:Obs_AltitudeSwitchingQuote a narr:Observation ;
      skos:broader narr:Narrative_AltitudeSwitchingCognitiveCost ;
      dct:source narr:Sample_DesignCollaboratorCall_20260629 ;
      skos:note "Scarlet's verbatim identification of altitude-switching as the specific cognitive limit — distinct from context-switching." ;
      oa:hasSelector [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_DesignCollaboratorCall_20260629 ;
        oa:hasSelector [
