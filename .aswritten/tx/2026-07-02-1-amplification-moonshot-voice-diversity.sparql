          oa:exact "who cares if AI can produce an email? Like who cares if it can give you a website? ... the question is, is it going to give you a meaningful website, a unique perspective" ;
          oa:prefix "Scarlet folds amplification into the product thesis: \"" ;
          oa:suffix " that people come back to and are like, oh wow, that's really different"
        ]
      ] .

    # ── Style Observations ───────────────────────────────────────────────────
    narr:StyleObs_DesignCollaboratorCall_ProfanityIntensifier a narr:StyleObservation ;
      skos:broader narr:ToneDirectPersonal ;
      dct:source narr:Sample_DesignCollaboratorCall_20260629 ;
      rdf:value true ;
      skos:note "Profanity used as rhetorical intensifier at conviction peaks — 'every single business around the fucking world' — consistent with Scarlet's voice-memo idiolect. Signals authentic, unfiltered founder voice rather than polished pitch register." ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_DesignCollaboratorCall_20260629 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 3875 ; oa:end 3999
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "do I get the same perspective from every single customer service agent, from every single business around the fucking world?" ;
          oa:prefix "Applied to the company/agent layer: \"" ;
          oa:suffix " Or do I get as many perspectives as there are companies"
        ]
      ] .

    narr:StyleObs_DesignCollaboratorCall_RhetoricalQuestion a narr:StyleObservation ;
      skos:broader narr:RhetoricalQuestion ;
      dct:source narr:Sample_DesignCollaboratorCall_20260629 ;
      rdf:value true ;
      skos:note "Rhetorical questions used to stage the binary choice at the heart of the moonshot: 'Are we going to end up in a monoculture... Or do we end up with some weird crackpot?' and 'can we have as many distinct voices as there are humans?' The question form enacts the choice rather than asserting it." ;
      oa:hasTarget [
