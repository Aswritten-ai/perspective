          oa:start 6434 ; oa:end 6576
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "I find it's not context [switching]. Like I can context switch across multiple different projects, but I can't context switch across altitude." ;
          oa:prefix "Scarlet identifies why this pitch had been so hard to reach: \"" ;
          oa:suffix " Right... software for a couple different people at one time [is fine]."
        ]
      ] .

    narr:Obs_WhoCaresIfAIEmailQuote a narr:Observation ;
      skos:broader narr:Narrative_AntiMonocultureAmplifier ;
      dct:source narr:Sample_DesignCollaboratorCall_20260629 ;
      skos:note "Scarlet's restatement of the product thesis through the amplification lens: the question is not whether AI can produce an email but whether it produces a meaningful, unique one." ;
      oa:hasSelector [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_DesignCollaboratorCall_20260629 ;
