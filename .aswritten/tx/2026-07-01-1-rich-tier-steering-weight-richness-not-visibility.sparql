  GRAPH narr:Tx_20260701T222001Z {

    # ── Sample ──────────────────────────────────────────────────────────────
    narr:Sample_RichTierSteeringWeight_20260701 a narr:Sample ;
      dct:title "Rich-tier selection by steering weight and complete area index" ;
      dct:created "2026-07-01"^^xsd:date ;
      dct:description "Design review session (Scarlet Dame + Claude, Fable session, 2026-07-01) deciding how the perspective map's rich-tier slots are allocated — by steering weight (conviction-carrying children) rather than raw in-degree — and establishing the complete area index as a visibility invariant." ;
      narr:inputLength 3303 .

    # ── Narratives ───────────────────────────────────────────────────────────

    narr:Narrative_RichTierBySteeringWeight a narr:Narrative ;
      dct:source narr:Sample_RichTierSteeringWeight_20260701 ;
      narr:theme "Rich-tier slot allocation by steering weight: conviction-carrying children ranked over style-taxonomy record types" ;
      skos:broader narr:ArchitectureOverview ;
      skos:note "The full-digest slots in the perspective map go to hubs ranked by how many conviction-carrying children they gather — claims, narratives, observations, evidence — with style-taxonomy record types ordered later. The discriminator is the ontology's own types, not name-matching or hand-curation. On the real graph this put the positioning thesis, friction/failure region, narrative spine, strategy overview, and core workflows in the rich tier. Decided 2026-07-01, same session as the response-ordering decision." ;
      skos:related narr:Narrative_PerspectiveResponseOrderedByVolatility .

    narr:Narrative_VisibilityInvariantAreaIndex a narr:Narrative ;
      dct:source narr:Sample_RichTierSteeringWeight_20260701 ;
      narr:theme "Complete area index: every hub named in every response, one-line entry with child count, one expand away" ;
      skos:broader narr:ArchitectureOverview ;
      skos:note "Every hub in the graph is named in every response — the richest areas render their full digest, and every other area gets a one-line entry with its name and child count, one expand away. The index is the meta layer Scarlet asked for, and it restores the nothing-is-hidden guarantee structurally rather than aspirationally. Decided 2026-07-01." ;
      skos:related narr:Narrative_PerspectiveResponseOrderedByVolatility, narr:Narrative_DigestAsRecognitionAid .

    narr:Narrative_RichnessVsVisibilitySeparation a narr:Narrative ;
      dct:source narr:Sample_RichTierSteeringWeight_20260701 ;
      narr:theme "Richness is a budget decision; visibility is an invariant — the principled separation that makes tier weighting compatible with compression-only" ;
      skos:broader narr:ArchitectureOverview ;
      skos:note "Selection decides richness only — visibility is guaranteed for every area by the index. A style hub that loses its rich slot is still named, counted, and one expand away in every single response. That separation — richness is a budget decision, visibility is an invariant — is what lets the map have an opinion about steering value without becoming a demotion engine. This is the principled line that makes rich-tier weighting compatible with the compression-only projection principle." ;
      skos:related narr:Narrative_DigestAsRecognitionAid, narr:Claim_IndexNeverGatesStore .

    # ── Claims ───────────────────────────────────────────────────────────────

    narr:Claim_InDegreeSelectionFlawed a narr:Claim ;
      narr:aboutNode narr:ArchitectureOverview ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      dct:source narr:Sample_RichTierSteeringWeight_20260701 ;
      skos:note "The v1 map selected its umbrellas by raw in-degree — whichever hubs had the most children. Measured against the real graph, that gave style-taxonomy hubs (StyleMetrics, KeyPhrases, Antithesis, tone records) the majority of the map's slots, because extraction funnels every style observation into a small set of taxonomy hubs. Meanwhile the strategy and architecture overviews — the regions an agent actually steers from — sat below the cutoff." ;
      narr:supports narr:Narrative_RichTierBySteeringWeight ;
      narr:challenges narr:ArchitectureOverview .

    narr:Claim_SteeringWeightDiscriminator a narr:Claim ;
      narr:aboutNode narr:Narrative_RichTierBySteeringWeight ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      dct:source narr:Sample_RichTierSteeringWeight_20260701 ;
      skos:note "The discriminator for rich-tier selection is the ontology's own types — claims, narratives, observations, evidence count as conviction-carrying; style-taxonomy record types are ordered later. This is not name-matching or hand-curation. The ontology's type system is the ranking criterion." ;
      narr:supports narr:Narrative_RichTierBySteeringWeight .

    narr:Claim_VisibilityIsInvariantNotBudget a narr:Claim ;
      narr:aboutNode narr:Narrative_RichnessVsVisibilitySeparation ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      dct:source narr:Sample_RichTierSteeringWeight_20260701 ;
      skos:note "Visibility is guaranteed for every area by the index — it is not a budget decision. Richness (full-digest rendering) is the budget decision. A hub that loses its rich slot is still named, counted, and one expand away. This is the invariant that prevents the map from becoming a demotion engine." ;
      narr:supports narr:Narrative_RichnessVsVisibilitySeparation .

    # ── Observations ─────────────────────────────────────────────────────────

    narr:Obs_ScarletMetaLayerQuote a narr:Observation ;
      skos:broader narr:Quotes ;
      dct:source narr:Sample_RichTierSteeringWeight_20260701 ;
      skos:note "Scarlet's reaction when shown the v1 map composition — the genesis of the complete area index requirement." ;
      oa:hasSelector [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_RichTierSteeringWeight_20260701 ;
        oa:hasSelector [
