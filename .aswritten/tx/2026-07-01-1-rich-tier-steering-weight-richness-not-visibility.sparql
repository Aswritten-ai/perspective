        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "oh i hate that. yes we definitely need a better way to select the rich tier. yes sounds like we might need a meta layer that is an index of the umbrellas?" ;
          oa:prefix "Scarlet's reaction when shown the composition:\n\n> " ;
          oa:suffix "\n\n## The decision"
        ]
      ] .

    narr:Obs_RichTierCompositionResult a narr:Observation ;
