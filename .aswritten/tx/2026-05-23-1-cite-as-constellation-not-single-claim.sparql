INSERT DATA {
  GRAPH narr:Tx_20260523T000000Z {

    # ── Actor ───────────────────────────────────────────────────────────────
    narr:Actor_Scarlet_Dame a narr:Actor ;
      skos:prefLabel "Scarlet Dame" ;
      skos:note "Reviewer and product lead who diagnosed the cite tool's deduplication and single-claim-frame bugs during the 2026-05-23 landing page comp review." .

    # ── Narratives ──────────────────────────────────────────────────────────

    narr:Narrative_CiteConstellationModel a narr:Narrative ;

      narr:theme "Citations are constellations, not single claims" ;
      skos:broader narr:CoreNarratives ;
      skos:note "The cite tool should return a primary source plus a ranked set of related sources (each annotated with a relevance type and a why sentence) rather than a single matched claim. The journalistic narrative paragraph weaves the constellation. This reframes the matching question from 'what is THE claim' to 'what claims, narratives, and historical changes BEAR ON this text'." .

    narr:Narrative_CiteDeduplicationInvariant a narr:Narrative ;

      narr:theme "Deduplication invariant: unique_citations ≤ supported; no two citations share a primary" ;
      skos:broader narr:CoreNarratives ;
      skos:note "When the same primary source supports multiple text points, those points share ONE citation entry. Primary sources are globally unique within a single response. Inline footnote markers may repeat; citation entries do not duplicate. Two citations whose related[] arrays are identical signal flat copies, not distinct constellations." .

    # ── Claims ──────────────────────────────────────────────────────────────

    narr:Claim_SingleClaimFrameReductionist a narr:Claim ;
      narr:aboutNode narr:Narrative_CiteConstellationModel ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_CiteConstellationModel ;

      skos:note "The current cite prompt asks 'what is THE claim that supports this text' — a single-match, reductionist frame that produces thin, wooden citations. The right question is 'what claims, narratives, and historical changes in the graph BEAR ON this text'." .

    narr:Claim_CitationsAreConstellations a narr:Claim ;
      narr:aboutNode narr:Narrative_CiteConstellationModel ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_CiteConstellationModel ;

      skos:note "A citation that surfaces the constellation — primary plus related plus what-changed-over-time — preserves the structure the ontology was built to hold. The product's differentiator is showing the lineage of how the organization thinks, not just retrieving facts." .

    narr:Claim_PrimaryUniquenessInvariant a narr:Claim ;
      narr:aboutNode narr:Narrative_CiteDeduplicationInvariant ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_CiteDeduplicationInvariant ;

      skos:note "Primary sources are globally unique within a single response. The deduplication invariant: unique_citations ≤ supported, where two citations never share a primary. Inline footnote markers ([^1]) may repeat across text; citation entries do not duplicate." .

    narr:Claim_RelatedArraysMustDiffer a narr:Claim ;
      narr:aboutNode narr:Narrative_CiteDeduplicationInvariant ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Narrative_CiteDeduplicationInvariant ;

      skos:note "A related source can legitimately appear in multiple constellations under different relevance tags. What is NOT acceptable is two citations whose related[] arrays are identical — that signals flat copies, not distinct constellations." .

    narr:Claim_NewSchemaAddsPrimaryRelatedNarrative a narr:Claim ;

      narr:hasConvictionLevel narr:Conviction_Stake ;


      skos:note "Consumers of aswritten_cite should expect: each citation entry carries a primary source object, a related[] array with relevance tags, and a narrative paragraph rendered directly as the footnote body. The narrative embeds the primary's verbatim quote as an inline blockquote. Plan: merge to dev and test against multiple models." .

    narr:Obs_ScarletQuote_SameClaim a narr:Observation ;
      skos:broader narr:Quotes ;

      skos:note "Scarlet's direct diagnosis of the deduplication problem." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 1452 ;
        oa:end 1510
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "we don't want to cite the same claim for the same piece of text." ;
        oa:prefix "> \"" ;
        oa:suffix "\""
      ] .

    narr:Obs_ScarletQuote_Reductionist a narr:Observation ;
      skos:broader narr:Quotes ;

      skos:note "Scarlet's diagnosis of the single-claim reductionist frame in the cite prompt." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 1720 ;
        oa:end 1870
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "It's trying to find 'one claim to cite', and actually it should be returning all of the claims that bear on that particular thing" ;
        oa:prefix "> \"" ;
        oa:suffix ", or a ranked list"
      ] .

    narr:Obs_ScarletQuote_Constellation a narr:Observation ;
      skos:broader narr:Quotes ;

      skos:note "Scarlet articulates the constellation frame: richer citations from the interaction between many claims and narratives." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 1880 ;
        oa:end 2030
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "we're not just talking about one claim. We're actually talking about the interaction between quite a number of claims and narratives" ;
        oa:prefix "> \"I think we'll get much richer citations that way, because " ;
        oa:suffix " and things that have changed"
      ] .

    narr:Obs_ScarletQuote_PrimaryUnique a narr:Observation ;
      skos:broader narr:Quotes ;

      skos:note "Scarlet's refinement: primary must be unique within a single return, but constellations can have intersecting related sets." ;
      oa:hasSelector [
