# ── UPDATE 1: Extend Narrative_CategoryCuratedExpertiseInstallation ──────────
# Memory asserts matching-search framing extends the category definition.
DELETE {
  GRAPH ?g {
    narr:Narrative_CategoryCuratedExpertiseInstallation skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260424T120000Z {
    narr:Narrative_CategoryCuratedExpertiseInstallation skos:note "aswritten defines a new category: curated expertise installation. It sits above context engineering — context engineering determines what AI knows; curated expertise installation determines how AI thinks. This is the category-creation framing for Strategy Document V1. Extended 2026-04-24: when deployed externally, the category is also a matching-search instrument — perspectives are an incredibly powerful search tool for a matching problem currently done very poorly (matching individuals to appropriate practitioners). 'Install expertise' is the mechanism; 'matching-search' is what makes installation valuable in external deployment contexts." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_CategoryCuratedExpertiseInstallation skos:note ?oldNote .
  }
} ;

