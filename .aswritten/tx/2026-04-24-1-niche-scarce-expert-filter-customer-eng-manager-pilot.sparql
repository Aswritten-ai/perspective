# ── Sample node ──────────────────────────────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260424T120000Z {
    narr:Sample_NicheEmerges_20260424 a narr:Sample ;
      dct:title "Niche Emerges: Scarce-Expert Filter with Goal-Gated Escalation (April 24, 2026)" ;
      dct:created "2026-04-24"^^xsd:date ;
      dct:description "~45-minute session between Scarlet Dame and Claude. Scarlet moved from scattered/confused about ICP to a concrete first pilot (an early prospect), a unified product pattern (Scarce-Expert Filter with Goal-Gated Escalation), and a refined pricing architecture (CPC-on-goal-URL for external, subscription for internal). Session also produced the first values-level personal why: alternative healthcare navigation and the two-sided legibility problem." ;
      narr:inputLength 7200 ;
      narr:styleProfile "<https://aswritten.ai/narrative#SpeakerIdiolects> <https://aswritten.ai/narrative#Antithesis> <https://aswritten.ai/narrative#ToneDirectPersonal> <https://aswritten.ai/narrative#IdiolectPhrasing>" .
  }
} ;

# ── NEW Narratives ───────────────────────────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260424T120000Z {

    narr:Narrative_MatchingSearchReframe a narr:Narrative ;
      dct:source narr:Sample_NicheEmerges_20260424 ;
      skos:broader narr:PositioningThesis ;
      skos:prefLabel "Perspectives as Matching-Search: The Category Reframe" ;
      skos:note "Scarlet reframed the product category: perspectives are an incredibly powerful search tool for a matching problem currently done very poorly — matching individuals to appropriate healthcare providers. Psychology Today is the negative example: property-based matching (specialties, modalities) that says nothing about how a practitioner actually thinks or what integrative care means to them. The reframe extends past alternative healthcare to therapists, psychiatrists, and traditional medicine. This does not replace the 'install expertise' mechanism — matching-search is what makes installation valuable when deployed externally." ;
      narr:theme "Perspectives are a matching-search instrument for a problem currently done very poorly — matching individuals to practitioners whose approach actually fits them" .

    narr:Narrative_TwoSidedLegibilityProblem a narr:Narrative ;
      dct:source narr:Sample_NicheEmerges_20260424 ;
      skos:broader narr:FrictionFailure ;
      skos:prefLabel "Two-Sided Legibility Problem: Patient Illegibility and Practitioner Flattening" ;
      skos:note "an early prospect's advertising problem (positioning around pain, two pieces of expertise, but a perspective behind that) is the inverse of Scarlet's patient problem (can't parse the medical system, can't tell which credentials are meaningful, can't find referrals). Patient-side illegibility and practitioner-side flattening are the same problem from opposite ends. aswritten makes the practitioner's perspective legible without forcing them to flatten." ;
      narr:theme "The patient's inability to evaluate practitioners and the practitioner's inability to communicate their actual approach are the same problem from opposite ends — aswritten resolves both simultaneously" .

    narr:Narrative_ScarceExpertFilterGoalGated a narr:Narrative ;
      dct:source narr:Sample_NicheEmerges_20260424 ;
      skos:broader narr:ProductOverview ;
      skos:prefLabel "Unified Instrument: Scarce-Expert Filter with Goal-Gated Escalation" ;
      skos:note "Unified pattern across all use cases: an expert with scarce time currently serves as the answer-of-last-resort for repeated questions. Their perspective, installed via aswritten, absorbs the repeatable questions and gates escalation to the expert on a forward to a goal URL — booking form, referral form, office hours, DM, meeting. an early prospect use cases (patient vets fit before booking, referring practitioner decides if case is appropriate, student filters questions answerable by class content) and the customer's chief architect/the enterprise customer use case (coworkers only ask the customer's chief architect if they make it to the end of the funnel) all fit the same structural pattern. One instrument, variable escalation targets by deployment context. This dissolves the earlier 60-day ICP drift (enterprise → SMB → B2C → transcripts) — it was not different customers but different deployments of the same instrument." ;
      narr:theme "One instrument — scarce-expert filter with goal-gated escalation — unifies all deployment contexts; the escalation target (booking form, DM, office hours) varies but the pattern is identical" .

    narr:Narrative_CPCOnGoalURL a narr:Narrative ;
      dct:source narr:Sample_NicheEmerges_20260424 ;
      skos:broader narr:PackagingPricing ;
      skos:prefLabel "CPC-on-Goal-URL for External, Subscription for Internal" ;
      skos:note "Instead of taking a cut of practitioner fees, pricing is outcome-based: every perspective carries a goal which is a forward to a link — essentially a click like ads, but a very high-value click with explicit end-of-funnel intent. Qualification happens before the click: the user self-qualifies through engagement with the perspective before the forward fires. Two pricing models map to deployment context, not competing homepages: External funnel (patient→practitioner, student→teacher, prospect→professional) = CPC-on-goal-URL. Internal organization (coworker→ARB expert, employee→specialist) = subscription. Ethical framing: aswritten only wins when the practitioner wins when the patient is well-matched. Also dissolves Claim_UnderstandingNotEqualSale — CPC removes the upfront purchase decision; perspective-on-spec is the sales pitch itself; first payment arrives with first forward." ;
      narr:theme "CPC-on-goal-URL for external deployments and subscription for internal deployments — two pricing models mapped to deployment context, not customer type" .
  }
} ;

# ── NEW Claims ───────────────────────────────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260424T120000Z {

    narr:Claim_MatchingSearchExtendsCVP a narr:Claim ;
      dct:source narr:Sample_NicheEmerges_20260424 ;
      skos:note "'Install expertise' is the mechanism; 'matching-search' is what makes installation valuable when deployed externally. The two framings are complementary: the category reframe does not replace Claim_CoreValuePropInstallExpertise but extends it with the external deployment value proposition." ;
      narr:aboutNode narr:Narrative_MatchingSearchReframe ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Claim_CoreValuePropInstallExpertise .

    narr:Claim_CPCDissolvesSaleGap a narr:Claim ;
      dct:source narr:Sample_NicheEmerges_20260424 ;
      skos:note "CPC-on-goal-URL removes the upfront purchase decision that caused an engineering manager at the customer, the customer's chief architect, a collaborator, and a founder beta user to see value but not pay. Perspective-on-spec is the sales pitch itself; first payment arrives with first forward. This directly resolves the activation gap identified in Claim_UnderstandingNotEqualSale." ;
      narr:aboutNode narr:Narrative_CPCOnGoalURL ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_CPCOnGoalURL .

    narr:Claim_UnifiedInstrumentPattern a narr:Claim ;
      dct:source narr:Sample_NicheEmerges_20260424 ;
      skos:note "The 60-day ICP drift (enterprise → SMB → B2C → transcripts) was not about different customers — it was about different deployments of the same instrument. The Scarce-Expert Filter with Goal-Gated Escalation unifies an engineering manager at the customer's three use cases and the the enterprise customer/the customer's chief architect use case under one structural pattern. One instrument, variable escalation targets by deployment context." ;
      narr:aboutNode narr:Narrative_ScarceExpertFilterGoalGated ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_ScarceExpertFilterGoalGated .

    narr:Claim_TwoSidedLegibilityInverse a narr:Claim ;
      dct:source narr:Sample_NicheEmerges_20260424 ;
      skos:note "an early prospect's advertising problem (practitioner-side flattening) is the inverse of Scarlet's patient problem (patient-side illegibility). They are the same problem from opposite ends. aswritten makes the practitioner's perspective legible without forcing them to flatten — resolving both sides simultaneously." ;
      narr:aboutNode narr:Narrative_TwoSidedLegibilityProblem ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_TwoSidedLegibilityProblem .

    narr:Claim_NotTreatmentProxy a narr:Claim ;
      dct:source narr:Sample_NicheEmerges_20260424 ;
      skos:note "This is not necessarily a good tool to be a treatment proxy or to be giving advice. What is interesting is it as a matching solution or a sort of vetting for potential patients into the funnel. Valid questions the perspective answers: 'How is your practice different? How do you approach X issue? How do you think about that in relationship to these other issues?' Even lossy answers beat Psychology Today's 'lists bipolar as specialty.'" ;
      narr:aboutNode narr:Narrative_ScarceExpertFilterGoalGated ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_MatchingSearchReframe .

    narr:Claim_CategoryExtensionMatchingSearch a narr:Claim ;
      dct:source narr:Sample_NicheEmerges_20260424 ;
      skos:note "The category evolves: 'expertise installation' (mechanism) + 'matching-search' (external deployment value) = 'goal-directed delegation with citable escalation' (product). This extends Claim_CategoryExtensionDelegation with the matching-search framing from the healthcare context." ;
      narr:aboutNode narr:Narrative_CategoryCuratedExpertiseInstallation ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Claim_CategoryExtensionDelegation .
  }
} ;

