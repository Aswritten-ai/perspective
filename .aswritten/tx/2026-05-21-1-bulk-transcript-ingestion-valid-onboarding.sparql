      skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260521T120000Z {
    narr:Claim_DirectIngestionIsTrap narr:hasConvictionLevel narr:Conviction_Notion ;
      skos:note "CORRECTED 2026-05-21 by Scarlet: The direct ingestion framing is overplayed. It is not an explicit anti-pattern. Bulk historical ingestion via AI summarization is a valid and effective method — Scarlet advised the customer's chief architect to use it for the enterprise customer ARB transcripts specifically because it would be faster, and it was effective. The 'we discovered it by failing' framing was a bad AI artifact. Prior Foundation-level conviction is superseded." ;
      narr:challenges narr:Narrative_DirectIngestionAntiPattern .
  }
}
