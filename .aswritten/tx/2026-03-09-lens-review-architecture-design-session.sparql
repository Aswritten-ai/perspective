  narr:Claim_TextAndEyeChartSameOperation a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Foundation ;
    narr:aboutNode narr:Architecture ;
    narr:supports narr:Narrative_SeparationOfConcerns ;
    dct:source narr:Sample_LensArchReview_20260309 ;
    skos:note "Both text (refraction mode) and eye chart (generation mode) are mechanically identical: run this prompt against the snapshot with this lens applied. Eye chart is a saved/curated prompt; user-provided text is an ad-hoc prompt." ;
    prov:wasGeneratedBy narr:Tx_LensArchReview_20260309 .

  narr:Claim_EyeChartIsDocumentBeingEvaluated a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Foundation ;
    narr:aboutNode narr:Architecture ;
    narr:supports narr:Narrative_SeparationOfConcerns ;
    dct:source narr:Sample_LensArchReview_20260309 ;
    skos:note "Eye chart is the document or set of domain statements being evaluated. In review mode, an existing document IS the eye chart. In drafting mode, the outline/structure IS the eye chart. The chart is the prompt; the refracted chart is the prompt run against snapshot + lens." ;
    prov:wasGeneratedBy narr:Tx_LensArchReview_20260309 .

  narr:Claim_AbsenceIsIntrospect a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Foundation ;
    narr:aboutNode narr:Architecture ;
    narr:supports narr:Narrative_SeparationOfConcerns ;
    dct:source narr:Sample_LensArchReview_20260309 ;
    skos:note "Absence as a lens shift dimension duplicates introspect. Scarlet confirmed: absence is what introspect does." ;
    prov:wasGeneratedBy narr:Tx_LensArchReview_20260309 .

  narr:Claim_LensIsCompoundNotStacked a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Foundation ;
    narr:aboutNode narr:Architecture ;
    narr:supports narr:Narrative_SeparationOfConcerns ;
    dct:source narr:Sample_LensArchReview_20260309 ;
    skos:note "A lens is inherently multi-dimensional — it can combine audience + conviction + domain into one perspective. You do not stack lenses; you craft one compound lens. The shift is the delta between canonical view and lens-weighted view." ;
    prov:wasGeneratedBy narr:Tx_LensArchReview_20260309 .

  narr:Claim_WorldviewSummaryIsAlreadyLens a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Boulder ;
    narr:aboutNode narr:Architecture ;
    narr:supports narr:Narrative_LossyCompressionProblem ;
    dct:source narr:Sample_LensArchReview_20260309 ;
    skos:note "compile(layer=worldview) is ~4-8K tokens, already editorially compressed — the everything-weighted-equally-and-compressed lens. Shifting a summary shifts lossy compression, not knowledge. The lens needs full-depth content for the domains it touches." ;
    prov:wasGeneratedBy narr:Tx_LensArchReview_20260309 .

  narr:Claim_CompileNoFocusParam a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Stake ;
    narr:aboutNode narr:Architecture ;
    narr:supports narr:Narrative_SeparationOfConcerns ;
    dct:source narr:Sample_LensArchReview_20260309 ;
    skos:note "Adding focus to compile risks agents calling compile(focus=task) instead of full worldview bootstrap. Compile/worldview should always ground the agent in the WHOLE organizational context first." ;
    prov:wasGeneratedBy narr:Tx_LensArchReview_20260309 .

  narr:Claim_IntrospectNoSubgraphReturn a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Stake ;
    narr:aboutNode narr:Architecture ;
    narr:supports narr:Narrative_SeparationOfConcerns ;
    dct:source narr:Sample_LensArchReview_20260309 ;
    skos:note "Returning subgraph alongside introspect analysis causes attention dilution. Analysis (gaps, tensions, questions) and subgraph content serve different purposes at different moments." ;
    prov:wasGeneratedBy narr:Tx_LensArchReview_20260309 .

  narr:Claim_ScopeIsNewSeparateTool a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Stake ;
    narr:aboutNode narr:Architecture ;
    narr:supports narr:Narrative_SeparationOfConcerns ;
    dct:source narr:Sample_LensArchReview_20260309 ;
    skos:note "Scope tool: takes focus and context like introspect, returns windowed graph to full depth in LLM-readable format. Effectively deprecates worldview:domain layers." ;
    prov:wasGeneratedBy narr:Tx_LensArchReview_20260309 .

  narr:Claim_LensToolIsGenerator a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Boulder ;
    narr:aboutNode narr:Architecture ;
    narr:supports narr:Narrative_SeparationOfConcerns ;
    dct:source narr:Sample_LensArchReview_20260309 ;
    skos:note "The lens tool does not run lenses — it generates them. Output: a set of lenses each containing a centrist focus prompt, a shift prompt, an eye chart, and usage instructions." ;
    prov:wasGeneratedBy narr:Tx_LensArchReview_20260309 .

  narr:Claim_EveryMemorySaveEndsReviewRound a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Boulder ;
    narr:aboutNode narr:QualityReviewGates ;
    narr:supports narr:Narrative_ConvergenceNotCompleteness ;
    dct:source narr:Sample_LensArchReview_20260309 ;
    skos:note "Every saved memory ends that review round and shifts the branch closer to the target. Extraction updates the graph; next round's lenses reflect the updated graph." ;
    prov:wasGeneratedBy narr:Tx_LensArchReview_20260309 .

  narr:Claim_LensesConvergeOnBranchIntent a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Boulder ;
    narr:aboutNode narr:QualityReviewGates ;
    narr:supports narr:Narrative_ConvergenceNotCompleteness ;
    dct:source narr:Sample_LensArchReview_20260309 ;
    skos:note "Some lenses push TOWARD the branch thesis (confirm sharpening); some push AWAY (confirm alternatives are worse). Goal is sharpness on what the branch is trying to do, not answering all questions." ;
    prov:wasGeneratedBy narr:Tx_LensArchReview_20260309 .

  narr:Claim_WorldviewDomainLayersDeprecated a narr:Claim ;
