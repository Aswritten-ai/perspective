# =============================================================
# NARRATIVES (new)
# =============================================================
INSERT DATA {
  narr:Narrative_CorrectBeforeBuilding a narr:Narrative ;
    dct:source narr:Sample_LensArchReview_20260309 ;
    narr:theme "Foundational misunderstandings must be corrected before any building begins" ;
    skos:broader narr:Process ;
    skos:note "The entire session was devoted to correcting five misunderstandings from the March 8 plan before any implementation started." ;
    prov:wasGeneratedBy narr:Tx_LensArchReview_20260309 .

  narr:Narrative_ConvergenceNotCompleteness a narr:Narrative ;
    dct:source narr:Sample_LensArchReview_20260309 ;
    narr:theme "The goal of review is convergence on the branch's intent, not exhaustive completeness" ;
    skos:broader narr:QualityReviewGates ;
    skos:note "Lenses push toward and away from the branch thesis to confirm sharpness. The optometrist analogy: iterative correction rounds, not a single pass." ;
    prov:wasGeneratedBy narr:Tx_LensArchReview_20260309 .

  narr:Narrative_LossyCompressionProblem a narr:Narrative ;
    dct:source narr:Sample_LensArchReview_20260309 ;
    narr:theme "A compressed worldview summary is already a lens — shifting it shifts lossy data, not knowledge" ;
    skos:broader narr:Architecture ;
    skos:note "The manual lens test exposed that compile(layer=worldview) is ~4-8K editorially compressed tokens. The lens needs the relevant subgraph at full fidelity, not the summary." ;
    prov:wasGeneratedBy narr:Tx_LensArchReview_20260309 .

  narr:Narrative_ARRepoIdentity a narr:Narrative ;
    dct:source narr:Sample_LensArchReview_20260309 ;
    narr:theme "Every aswritten repo IS a perspective — there is no special category of perspective repo" ;
    skos:broader narr:NarrativeAnchor ;
    skos:note "AR (Artificial Representative) repos are not a subtype of aswritten repos with perspective baked in. All aswritten repos are perspectives. The lens tool queries the same graph from a different angle." ;
    prov:wasGeneratedBy narr:Tx_LensArchReview_20260309 .
} ;

