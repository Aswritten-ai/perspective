  narr:Tx_20260518T160000Z a prov:Activity ;
    prov:generatedAtTime "2026-05-18T16:00:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith "aswritten.ai" ;
    prov:wasAttributedTo "+15044353923" ;
    narr:originPath ".aswritten/memories/2026-05-17-investor-pipeline-research.md" ;
