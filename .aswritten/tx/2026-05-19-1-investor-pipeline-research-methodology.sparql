# Extracted Entities
INSERT DATA {
  GRAPH narr:Tx_20260518T160000Z {

    narr:Claim_AggregatorDataUnreliable a narr:Claim ;
      narr:aboutNode narr:MarketContext ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;

      skos:note "Aggregator data (Tracxn, VCSheet, Crunchbase) lags 1-3 years. Rule: always verify from primary source before recommending." .

