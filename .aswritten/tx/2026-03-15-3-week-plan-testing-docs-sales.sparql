    # ── BRAD DEMO PLAN NARRATIVES ────────────────────────────────
    narr:Narrative_TamarackDemoAsLiveSalesMotion a narr:Narrative ;

      skos:broader narr:SalesDecks ;
      skos:note "The demo with a collaborator is explicitly framed as the same sales motion used with any SMB prospect — not a special investor demo. Live knowledge extraction, product walkthrough, account setup. a collaborator is technically savvy but not in the domain, providing a useful outside perspective distinct from the typical beta cohort." ;
      narr:theme "The a collaborator demo IS the sales motion: live knowledge extraction with any prospect is the product" .

    narr:Claim_GIFDemoReady a narr:Claim ;

      skos:note "GIF generation is ready and impressive. May make sense to embed an intro demo GIF into the F&F plan itself as a visual proof point." ;

      narr:hasConvictionLevel narr:Conviction_Stake ;
      .

    narr:Claim_SalesPlaybookForDemoProspect a narr:Claim ;

      skos:note "A sales playbook for a demo-call prospect is the critical sales enablement piece this week. It should be a play-by-play with GIF descriptions showing what it looks like to take someone from first contact through a demo with deep knowledge extraction, setting them up with the product, and ongoing engagement. The playbook must be ready so a demo-call prospect has a repeatable process, not just a deal structure." ;

      narr:hasConvictionLevel narr:Conviction_Boulder ;
