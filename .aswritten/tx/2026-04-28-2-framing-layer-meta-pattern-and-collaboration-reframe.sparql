    prov:generated narr:Sample_FramingLayerMetaPattern, narr:Narrative_FramingLayerDeflection, narr:Narrative_MemoriesAsCollaborativeNarrative, narr:Claim_FramingIncentivesMisaligned, narr:Claim_ExitRampGeneration, narr:StyleMetrics_FramingLayerMetaPattern, narr:StyleObs_VerbatimPreservation, narr:StyleObs_StructuralContent, narr:StyleObs_DefensiveRegister .
