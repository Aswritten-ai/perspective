} ;

# Updates to existing entities
DELETE {
  GRAPH ?g {
    narr:Claim_ScopeIsNewSeparateTool narr:hasConvictionLevel ?oldConviction .
    narr:Claim_ScopeIsNewSeparateTool skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T120000Z {
    narr:Claim_ScopeIsNewSeparateTool narr:hasConvictionLevel narr:Conviction_Notion ;
      skos:note "SUPERSEDED: Scope is not a separate tool; it is a mode of introspect. Functional absorption landed on dev at b0811095." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_ScopeIsNewSeparateTool narr:hasConvictionLevel ?oldConviction ;
      skos:note ?oldNote .
  }
} ;

