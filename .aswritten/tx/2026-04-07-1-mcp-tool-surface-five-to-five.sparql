    narr:Claim_FiveCoreMCPTools skos:note ?oldNoteTools .
  }
}
INSERT {
  GRAPH narr:Tx_20260406T120000Z {
    narr:Claim_FiveCoreMCPTools skos:note "The five user-facing MCP tools are: perspective, cite, introspect, remember, and review. Scope, refract, and lens are removed from the user-facing surface." .
  }
}
WHERE {
