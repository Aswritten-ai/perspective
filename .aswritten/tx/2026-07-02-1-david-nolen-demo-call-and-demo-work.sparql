INSERT DATA {
  GRAPH narr:Tx_20260702T122943Z {

    # ── Sample ──────────────────────────────────────────────────
    narr:Sample_DavidNolenDemoCall_20260625 a narr:Sample ;
      dct:title "David Nolen Demo Call — What Landed, the Audience Question, and the Demo Work It Forced" ;
      dct:created "2026-06-25"^^xsd:date ;
      narr:inputLength 8354 ;
      dct:description "~45-min video call with David Nolen (Clojure/ClojureScript core, ex-DRW). Scarlet's first live demo of the current product. Covers value moments, rough moments, the developer-blinders audience question, and post-call demo design lessons." .

    # ── Narrative: Show vs. Try — value proven by showing, not by trying ──
    narr:Narrative_ShowVsDemoProof a narr:Narrative ;
      skos:broader narr:FrictionFailure ;
      narr:theme "Value is proven by showing clearly; their-own-data is the conversion deepener, not the proof" ;
      skos:note "The transcript inverts the 'you have to try it' hedge: David understood provenance, dates, citations, archaeology, and knows-what-it-doesn't-know from being shown — not from trying. The rough parts obscured value that is fully showable. Correction: the felt/shown crux is not a structural truth about needing one's own data to see value; it is a stale-demo hedge. Their-own-data deepens conversion after value has already landed." ;
      dct:source narr:Sample_DavidNolenDemoCall_20260625 ;
      skos:related narr:Narrative_TwoPurchaseTriggers, narr:Claim_UnderstandingNeverSells .

    # ── Narrative: The money answer — decision-archaeology form ──
    narr:Narrative_MoneyAnswerDecisionArchaeology a narr:Narrative ;
      skos:broader narr:Differentiators ;
      narr:theme "The money answer is a real concrete question whose answer comes back grounded in dated cited conversational provenance — strongest form is the decision-archaeology answer" ;
      skos:note "Strongest single demo form: the decision-archaeology answer ('how did we get to X, and why?') → a dated trail with citations you click open. Anti-pattern (learned from the slop): never demo the product explaining its own mechanism (e.g., 'how does aswritten do compression' → abstraction); demo it doing the user's work on real content." ;
      dct:source narr:Sample_DavidNolenDemoCall_20260625 ;
      skos:related narr:Narrative_ProvenanceCitationMoment, narr:Narrative_CitationEngineNotSynthesis .

    # ── Narrative: Self-serve demo on aswritten's own perspective ──
    narr:Narrative_SelfServeDemoOnOwnPerspective a narr:Narrative ;
      skos:broader narr:SolutionArchetypes ;
      narr:theme "The self-serve demo should run on aswritten's own perspective from a trial session: solves cold-start, is self-demonstrating, and the honesty beats are the least-fakeable material" ;
      skos:note "Running the self-serve demo on aswritten's own perspective (from a trial session the same day) solves cold-start with the richest real perspective that exists, is self-demonstrating, and the honesty beats — the product flagging its own uncommitted areas and its own data anomalies — are the least-fakeable, most credible material. Lead with the honesty, not the positive answer. Lands on task-276.01 (self-serve web try / digest browser) as the demo design." ;
      dct:source narr:Sample_DavidNolenDemoCall_20260625 ;
      skos:related  narr:Narrative_DigestBrowserProductSurface .

    # ── Claim: Felt-vs-shown — own data is deepener, not proof ──
    narr:Claim_FeltVsShownOwnDataIsDeepener a narr:Claim ;
      narr:aboutNode narr:Narrative_ShowVsDemoProof ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Narrative_ShowVsDemoProof ;
      skos:note "Their-own-data is the conversion deepener, not the proof. The proof is a clear show. The rough parts in the David Nolen demo obscured value that is fully showable — the fix list is the bugs between David and the value he already saw." ;
      dct:source narr:Sample_DavidNolenDemoCall_20260625 .

    # ── Claim: Developer blinders — audience question ──
    narr:Claim_DeveloperBlindersAudienceQuestion a narr:Claim ;
      narr:aboutNode narr:Narrative_TierContinuumNotDistinctMarkets ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      skos:note "David's microservices/blinders point is real: for siloed dev teams, cross-org context is a non-feature. What landed regardless of role: provenance / anti-hallucination / 'how did we get here.' Lead every surface with the role-agnostic hook and let people self-select the frame. The resonant dev frame is 'developers like me — involved in product / running an org,' and that team shape is increasingly common. Resist over-narrowing to 'cross-repo memory for dev teams' before deciding. This is the B2C↔org continuum live." ;
      dct:source narr:Sample_DavidNolenDemoCall_20260625 .

