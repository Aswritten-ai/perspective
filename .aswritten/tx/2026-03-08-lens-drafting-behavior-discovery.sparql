    oa:hasSelector [ a oa:TextPositionSelector ; oa:start 5180 ; oa:end 5780 ] ;
    prov:wasGeneratedBy narr:Transaction_LensDrafting_20260308 ;
    prov:wasGeneratedBy narr:Tx_20260308T214552Z .

