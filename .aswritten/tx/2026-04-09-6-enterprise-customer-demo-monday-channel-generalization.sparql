# Transaction Provenance
INSERT DATA {
  narr:Tx_20260411T120000Z a prov:Activity ;
    prov:generatedAtTime "2026-04-11T12:00:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith "aswritten.ai" ;
    prov:wasAttributedTo "n8n.aswritten.ai" ;
    narr:originPath ".aswritten/memories/2026-04-11-the enterprise customer-demo-prep.md" ;
    narr:originRef "research/goal-directed-agents" ;
    prov:generated  
                   narr:Narrative_V0_ChannelAgnostic,
                   narr:Narrative_ImplicitGoalForcingFunction,
                   narr:Narrative_MCP_InstallationBarrier,
