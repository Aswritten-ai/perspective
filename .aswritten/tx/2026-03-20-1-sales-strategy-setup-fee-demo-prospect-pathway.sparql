    # ── SAMPLE ──────────────────────────────────────────────────────────────
    narr:Sample_SetupFeeDemoProspectPathway_20260319
      a narr:Sample ;
      dct:title "Sales Strategy: Setup Fee Model and a demo-call prospect's Sales Pathway (2026-03-19)" ;
      dct:created "2026-03-19"^^xsd:date ;
      dct:description "End-of-day extension of the strategy session. Scarlet identified that the 'expertise on demand' reframe creates a natural professional service layer: converting static expertise into the AI-native distribution format. Covers two conversion models (we-do-it vs self-service), the [amount] org-tier catalogue setup, and a demo-call prospect's two-step sales path from individual asset conversion to organizational catalogue." ;
      narr:inputLength 2847 .

    # ── NARRATIVES ──────────────────────────────────────────────────────────

    narr:Narrative_SetupFeeAsConversionService

      dct:source narr:Sample_SetupFeeDemoProspectPathway_20260319 ;
      skos:broader narr:PackagingPricing ;
      skos:prefLabel "Setup Fee Reframed as Conversion Service, Not an Onboarding Tax" ;
      skos:note "The 'expertise on demand' reframe creates a natural professional service at the publisher tier. The setup fee is not called a setup fee — it IS the core value proposition of the conversion service: turning a static book, course, training, or consulting package into the AI-native distribution format. Two models: (1) We do it — extraction, module build, curation, hand-off of living installable module; revenue = upfront conversion fee + ongoing marketplace percentage. (2) They do it — expert creates module themselves using remember/review tools; revenue = marketplace percentage only. Both models are viable and can coexist." ;
      narr:theme "The setup fee is the conversion service — turning static expertise into an installable AI module is the core value proposition, not an onboarding cost" .

    narr:Narrative_DemoProspectTwoStepSalesPath

      dct:source narr:Sample_SetupFeeDemoProspectPathway_20260319 ;
      skos:broader narr:OperatingModelShifts ;
      skos:prefLabel "a demo-call prospect's Two-Step Sales Path: Individual Asset → Publisher, Then Org Catalogue → Organization" ;
      skos:note "Step 1: Target experts and small businesses with a single distributable asset (book, course, consulting methodology). Pitch: 'Your book is a snapshot. We'll turn it into a living AI module. Your expertise becomes installable, citable, and generates revenue through the marketplace.' Close: Publisher tier ([amount]/mo) + conversion fee + marketplace revenue share. Step 2: Upsell to Organization tier. Trigger: 'You've published one module. Now imagine every role in your organization has one.' Close: Organization tier ([amount]/mo + [amount] setup) + on-prem add-ons. Scarlet: 'There's a clear pathway for a demo-call prospect to go after both individuals and small businesses who can package a single book or asset and also to convert them and larger orgs to the org plan.'" ;
      narr:theme "a demo-call prospect has a clean two-step sales path: individual asset conversion to Publisher tier, then upsell to Organization tier via the catalogue concept" .

    narr:Narrative_CatalogueInternalMarketplace

      dct:source narr:Sample_SetupFeeDemoProspectPathway_20260319 ;
      skos:broader narr:NamingConventions ;
      skos:prefLabel "'Catalogue' as the Term for the Internal Organizational Expertise Marketplace" ;
      skos:note "Scarlet proposed calling the internal marketplace of organizational expertise a 'catalogue.' The [amount] organization-tier setup creates the initial roles and packages that populate this internal catalogue. The catalogue is the scoped engagement version of the conversion service at enterprise scale — not a global marketplace but an org-owned internal marketplace of expertise modules." ;
      narr:theme "The organization tier's internal marketplace is a 'catalogue' — a curated set of installable expertise modules scoped to the org" .

    # ── CLAIMS ──────────────────────────────────────────────────────────────

    narr:Claim_WeDoItConversionModel
      a narr:Claim ;
      dct:source narr:Sample_SetupFeeDemoProspectPathway_20260319 ;
      skos:note "Professional conversion model: aswritten takes the expert's book, course, training materials, or consulting package; runs extraction; builds the module; curates the perspective; hands them a living, installable, citable module ready for distribution. Revenue model: upfront conversion fee + ongoing marketplace percentage. This is the high-touch, high-value path." ;
      narr:aboutNode narr:Narrative_SetupFeeAsConversionService ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:PackagingPricing .

    narr:Claim_TheyDoItConversionModel
      a narr:Claim ;
      dct:source narr:Sample_SetupFeeDemoProspectPathway_20260319 ;
      skos:note "Self-service conversion model: the expert creates the module themselves using the remember/review tools. aswritten provides the platform and extraction pipeline. Revenue model: marketplace percentage only — no upfront conversion fee. Scarlet: 'They could create one without our help, then it's definitely percentage, but we could also charge a fee to do the work. I think both is viable.'" ;
      narr:aboutNode narr:Narrative_SetupFeeAsConversionService ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:PackagingPricing .

    narr:Claim_OrgTierCatalogueSetup
      a narr:Claim ;
      dct:source narr:Sample_SetupFeeDemoProspectPathway_20260319 ;
      skos:note "The [amount] organization-tier setup fee creates the initial roles and packages that populate the internal catalogue — the org's internal marketplace of expertise. This is the scoped engagement version of the conversion service at enterprise scale. The catalogue concept is the enterprise-facing articulation of the organization tier's value." ;
      narr:aboutNode narr:Narrative_CatalogueInternalMarketplace ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_NewTierStructure_20260319 .

    narr:Claim_DemoProspectStep1PublisherTier
      a narr:Claim ;
      dct:source narr:Sample_SetupFeeDemoProspectPathway_20260319 ;
      skos:note "a demo-call prospect's Step 1 target: experts and small businesses with a single distributable asset (book, course, consulting methodology). The pitch is approachable, bounded, and delivers clear value: 'Your book is a snapshot. We'll turn it into a living AI module. Your expertise becomes installable, citable, and generates revenue through the marketplace.' Close: Publisher tier ([amount]/mo) + conversion fee + marketplace revenue share." ;
      narr:aboutNode narr:Narrative_DemoProspectTwoStepSalesPath ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_DirectVsInfluenceSales .

    narr:Claim_DemoProspectStep2OrgTier
      a narr:Claim ;
      dct:source narr:Sample_SetupFeeDemoProspectPathway_20260319 ;
      skos:note "a demo-call prospect's Step 2 target: larger orgs or publishers who want multiple modules or an internal expertise marketplace. Upsell trigger: 'You've published one module. Now imagine every role in your organization has one.' Close: Organization tier ([amount]/mo + [amount] setup) + on-prem add-ons as applicable. The compliance, on-prem, and data sovereignty hooks all apply at this tier." ;
      narr:aboutNode narr:Narrative_DemoProspectTwoStepSalesPath ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
