    # ── Narrative: April 1 Soft Launch ──────────────────────────────────────
    narr:Narrative_April1SoftLaunch a narr:Narrative ;

      skos:broader narr:Milestones ;
      skos:prefLabel "April 1 Soft Launch: Beta Done, Public Marketing Begins" ;
      skos:note "After April 1, beta testing is done. Public-facing marketing, outreach, push with tiers (free trial → paid). Above the line (must ship by April 1): landing page redo with clear funnel, e2e demo GIFs, dev branch merged to main, language pass, MVP slimming, initial modules/perspectives shipped, GitHub abstraction for initial users (provisioned personal repo, no GitHub account needed), aswritten perspective set defined and available to all users, doc site updated, sales assets (playbook, commission structure, one-sheet, onboarding materials), intro deck. Below the line (important but not launch-blocking): content site, full naming decision on 'module', marketplace browse/search UX, module forking, revenue share infrastructure." ;
      narr:theme "April 1 is the forcing function: beta ends, public marketing begins, above-the-line items must ship" .

    narr:Claim_April1ForcingFunction a narr:Claim ;

      skos:note "April 1 is set as a forcing function for launch readiness. After April 1, beta testing is done. Public-facing marketing, outreach, and push with tiers (free trial → paid) begins. Advisors confirmed setting April 1 as the forcing function." ;
      narr:aboutNode narr:Narrative_April1SoftLaunch ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:FocusSequencing .

    narr:Claim_AboveTheLine_April1 a narr:Claim ;

      skos:note "Must ship by April 1: landing page redo (clear funnel into product, docs, content; heavy on e2e demo GIFs), dev branch merged to main, language pass (product glossary as source of truth), MVP slimming (disambiguate org tools from user-facing product), initial modules/perspectives shipped (starter set), GitHub abstraction for initial users (provisioned personal repo, no GitHub account needed), aswritten perspective set defined and available to all users, doc site updated, sales assets (playbook, commission structure, one-sheet, onboarding materials), intro deck." ;
      narr:aboutNode narr:Narrative_April1SoftLaunch ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
