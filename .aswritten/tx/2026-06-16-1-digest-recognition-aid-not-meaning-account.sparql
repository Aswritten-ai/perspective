    narr:Obs_RecognitionPrecedesCreationQuote a narr:Observation ;
      dct:source narr:Sample_DigestRecognitionAid_20260616 ;
      skos:broader narr:NarrativeAnchor ;
      skos:note "Scarlet's verbatim resolution: recognition through old association precedes creative reading." ;
      oa:hasTarget [
