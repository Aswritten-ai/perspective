INSERT DATA {
  GRAPH narr:Tx_20260616T120000Z {

    narr:Sample_DigestRecognitionAid_20260616 a narr:Sample ;
      dct:title "The digest is a recognition aid over a lossless store; the index never gates the store" ;
      dct:created "2026-06-15"^^xsd:date ;
      narr:inputLength 6842 .

    narr:Narrative_DigestAsRecognitionAid a narr:Narrative ;
      dct:source narr:Sample_DigestRecognitionAid_20260616 ;
      skos:broader narr:ArchitectureOverview ;
      skos:prefLabel "Digest as Recognition Aid Over Lossless Store" ;
      skos:note "The digest accelerates the recognized path to raw material; it does not host meaning itself. Compression-is-the-only-projection applies: compress the handle, never destroy the material. The interpretive theme is acceptable only because the novel reading is always one expand away. Nothing is foreclosed; the recognized path is just faster." ;
      narr:theme "The digest is a lossy index over a lossless store; the index never gates the store; it accelerates the recognized path without foreclosing novel readings" .

    narr:Narrative_RecognitionPrecedesCreation a narr:Narrative ;
      dct:source narr:Sample_DigestRecognitionAid_20260616 ;
      skos:broader narr:PositioningThesis ;
      skos:prefLabel "Recognition Precedes Creation" ;
      skos:note "If we find raw material through an old association before we can be creative with it, then the index was never the place the new reading would happen. It happens in the mind, downstream, once you are holding the material. The digest feeds creativity; it does not host it." ;
      narr:theme "Recognition (old association) is the retrieval-shaped part; creative reading is the steering/perspective part and lives in the mind on expanded material" .

    narr:Narrative_StatelessDedupCursor a narr:Narrative ;
      dct:source narr:Sample_DigestRecognitionAid_20260616 ;
      skos:broader narr:TechnicalExplainers ;
      skos:prefLabel "Stateless Deduplicating Cursor for Expand" ;
      skos:note "expand(want, have) returns want minus have. Every response hands back a served manifest the agent forwards verbatim on the next call. Reliability comes from the return carrying the manifest forward, not from trusting agent memory. Same principle as guidance-in-the-tool-surface-not-the-prompt. Effect: union of all expands serves each node once; pulling the whole graph converges to approximately 1x the graph; over-navigation bounded at 1x rather than 3x." ;
      narr:theme "expand becomes a stateless deduplicating cursor: expand(want, have) returns want minus have; the served manifest travels in the return, not in agent memory" .

    narr:Claim_IndexNeverGatesStore a narr:Claim ;
      dct:source narr:Sample_DigestRecognitionAid_20260616 ;
      skos:note "The index must never gate the store. Steering requires compression but compression via fixed themes is exactly the reductionism the discourse-act ontology exists to refuse. A claim is not about something; it is available to be read as many things. The digest does not have to anticipate the novel reading. It has to get you close enough via an old association that you expand and encounter the material." ;
      narr:aboutNode narr:Narrative_DigestAsRecognitionAid ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_DigestAsRecognitionAid .

    narr:Claim_AbsenceIsNoRecognizedAssociation a narr:Claim ;
      dct:source narr:Sample_DigestRecognitionAid_20260616 ;
      skos:note "Absence is no recognized association, never nothing here. Targeted grounding may trust recognized-absence; creative exploration deliberately distrusts it and expands past the recognized. Creative reading costs expansion by design. A cheap legible-absence is dangerous precisely because the encounters it lets you skip are where novelty would have struck. Mitigation: honesty about scope (recognition aid, never account of meaning) and the always-reachable store." ;
      narr:aboutNode narr:Narrative_DigestAsRecognitionAid ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_DigestAsRecognitionAid .

    narr:Claim_ExpansionIsSteering a narr:Claim ;
      dct:source narr:Sample_DigestRecognitionAid_20260616 ;
      skos:note "Expansion is steering, not just quoting. Expanding a subtree you genuinely lean on is the product working: you get the trajectory and variance, not just a verbatim quote. The bad case is expanding to discover whether anything is there; the good case is expanding onto material you have already decided is relevant. Route to the subtree, not the child." ;
      narr:aboutNode narr:Narrative_DigestAsRecognitionAid ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_DigestAsRecognitionAid .

    narr:Claim_MultiplicityInVariation a narr:Claim ;
      dct:source narr:Sample_DigestRecognitionAid_20260616 ;
      skos:note "Multiplicity lives in variation, not a theme label. The digest already refuses single-theme reduction via the variation block: it surfaces reads as X, and as Y, and the road not taken. That is the anti-reductionist mechanism and it stays load-bearing." ;
      narr:aboutNode narr:Narrative_DigestAsRecognitionAid ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_DigestAsRecognitionAid .

    narr:Obs_ThemeIsInterpretiveQuote a narr:Observation ;
      dct:source narr:Sample_DigestRecognitionAid_20260616 ;
      skos:broader narr:DesignTradeoffs ;
      skos:note "Scarlet's verbatim articulation of the theme-is-interpretive trap and the anti-reductionist resolution." ;
      oa:hasTarget [
