    narr:StyleMetrics_DigestRecognitionAid a narr:StyleMetrics ;
      dct:source narr:Sample_DigestRecognitionAid_20260616 ;
      skos:broader narr:StyleMetrics ;
      skos:note "Philosophical-analytical register with embedded verbatim blockquotes from Scarlet. Mixed: structured markdown with H2 section headers (memo genre) vs. first-person blockquoted speech. Antithesis-heavy structure (recognition vs. creation, index vs. store, recognized-absence vs. nothing-here, bad-expand vs. good-expand). Active voice dominant in editorial prose. Jargon density moderate: product terms (expand, digest, variation block, ZDR-pure, served manifest) used without definition, implying internal audience. Sentence length elevated by blockquoted speech; prose sections are shorter and punchier." ;
      narr:AverageSentenceLength "22"^^xsd:integer ;
