    narr:Obs_StatelessDedupDesign a narr:Observation ;
      dct:source narr:Sample_DigestRecognitionAid_20260616 ;
      skos:broader narr:TechnicalExplainers ;
      skos:note "Scarlet chose stateless dedup over server-side session tracking to keep the read path a pure function (ZDR-pure, no session store, composable). The reliability comes from the return carrying the manifest forward, not from trusting the agent's memory." ;
