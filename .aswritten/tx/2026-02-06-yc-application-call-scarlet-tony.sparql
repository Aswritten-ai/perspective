    narr:Narrative_ConvictionFramework a narr:Narrative ;
        dct:source narr:Sample_YC_Call_2026_02_05 ;
        skos:broader narr:Conviction ;
        narr:theme "Conviction levels: notion → stake → boulder → grave" ;
        skos:note "Notion: can be changed easily. Stake: planted but needs validation. Boulder: hard to move without others involved. Grave: done, settled. Memories can increase/decrease conviction with provenance tracking." ;
