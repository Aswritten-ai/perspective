DELETE {
    narr:Narrative_FoundingStory skos:note ?oldNote1 .
}
INSERT {
    narr:Narrative_FoundingStory skos:note "Founders met when Scarlet cold-emailed Tony after discovering best developers worked for him. 20 minutes into first call, Tony said 'we were separated at birth'. Scarlet sent follow-up email Tony described as 'dialed in the exact thing all the way through'. Shared original vision at Vouch: delegated authority for AI agents. Scarlet left to build upstream dependency (organizational worldview), recently brought Tony back to reunite vision: collective memory as foundation, delegated authority as future." ;
        prov:wasGeneratedBy narr:Tx_20260211T011119Z .
}
WHERE {
    narr:Narrative_FoundingStory skos:note ?oldNote1 .
} ;

DELETE {
    narr:Narrative_ProductVision skos:note ?oldNote2 .
}
INSERT {
    narr:Narrative_ProductVision skos:note "V1: Collective memory (single worldview per org). V2: Combine and perform math on worldviews to reach new perspective; deploy worldview beyond MCP to agentic bootstrapping. V3: Marketplace — reusable organizational perspective ('I know Kung Fu' Matrix chips for AI). V4: Organizational authority — agents approved to act on behalf of company with worldview + delegated authority. Core strategic decision to build complete product rather than license underlying technology." ;
        prov:wasGeneratedBy narr:Tx_20260211T011119Z .
}
WHERE {
    narr:Narrative_ProductVision skos:note ?oldNote2 .
} ;

DELETE {
    narr:Claim_WorldviewNotSkills skos:note ?oldNote3 .
}
INSERT {
    narr:Claim_WorldviewNotSkills skos:note "A skill is limited context and instructions. We're talking about worldview — an entirety of process, methodology, and code that sets the framing for how a skill executes. Same skill in different worldviews does something completely different. It's the worldview behind the skill. Validated in YC application call 2026-02-05." ;
        prov:wasGeneratedBy narr:Tx_20260211T011119Z .
}
WHERE {
    narr:Claim_WorldviewNotSkills skos:note ?oldNote3 .
} ;

