    # ── SECTION: GIF-Based Sales Materials ──────────────────────────────────
    narr:Narrative_GIFBasedSalesMaterials a narr:Narrative ;

      skos:broader narr:SalesDecks ;
      skos:prefLabel "GIF-Based Sales Materials: Hook GIF, Story Page, McDonald Picture Menu Deck" ;
      skos:note "Scarlet demonstrated automated end-to-end testing that records terminal sessions and generates GIFs. Tony was immediately excited about using these for sales. Agreed deliverables: (1) Hook GIF — one attention-grabbing product moment; (2) Story page: GIFs + interstitial copy; (3) McDonald picture menu deck: 5-10 slides, single statement per slide, 10-second GIF each. Tony needs these before his an enterprise prospect meeting (likely next week). Tony's key insight: 'Just looks real' — it's not a concept, not engineering skunk works, it looks like a real thing." ;
      narr:theme "GIF-based sales materials that look real are more effective than decks or white papers for initial executive engagement" .

    narr:Claim_GIFLooksReal a narr:Claim ;

      skos:note "Tony's core insight about the GIF-based demo approach: it just looks real. Not a concept, not engineering skunk works — it looks like a real thing. That's the trick. This is the sales advantage of GIF-based materials over decks or white papers." ;
      narr:aboutNode narr:Narrative_GIFBasedSalesMaterials ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_ValueDemonstrationGap .

    narr:Obs_GIFHookFeature a narr:Observation ;

