INSERT DATA {
  GRAPH narr:Tx_20260701T221214Z {

    # ── Actors ──────────────────────────────────────────────────
    # Actor_Scarlet already exists — no new entity needed.
    # Claude (Fable session) is a session participant, not a persistent actor node.

    # ── Narratives ──────────────────────────────────────────────
    narr:Narrative_PerspectiveResponseOrderedByVolatility a narr:Narrative ;
      skos:broader narr:ArchitectureOverview ;

      narr:theme "Perspective response ordered by volatility: stable skeleton leads, per-call focus appended last" ;
      skos:note "The perspective response is now structured in four fixed sections ordered by volatility: (1) the map — richest areas at steering grain, canonical order that never changes with the caller's focus; (2) the area index — every other area, named, one line each; (3) the active surface — recent and load-bearing witnesses, moves only when knowledge lands or recency window rolls; (4) the focus section, last — the only per-call material. The map is never reordered per call. Focus selects what to append, never what to move. A no-focus orientation call is byte-stable for a given graph state. Decided 2026-07-01 by Scarlet Dame during the collapse/expand recovery arc design review." ;
      skos:related narr:Narrative_NavigationReplacesEmbeddedSnapshot, narr:Narrative_DigestAsRecognitionAid .

    # ── Claims ──────────────────────────────────────────────────
    narr:Claim_FocusAppendedNeverReordered a narr:Claim ;
      narr:aboutNode narr:Narrative_PerspectiveResponseOrderedByVolatility ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;

      narr:supports narr:Narrative_PerspectiveResponseOrderedByVolatility ;
      skos:note "Focus selects what to append to the perspective response, never what to move or reorder. The map section is invariant across calls for a given graph state. This is a settled design decision from the 2026-07-01 review." .

    narr:Claim_SortVsRankTensionResolved a narr:Claim ;
      narr:aboutNode narr:Narrative_PerspectiveResponseOrderedByVolatility ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;

      narr:supports narr:Narrative_PerspectiveResponseOrderedByVolatility ;
      skos:note "The ordering decision dissolved the long-standing sort-vs-rank tension in the compression-only projection principle. Order is unavoidable — hubs emit in some sequence — but under this decision the order is a fixed property of the graph state, not a per-call judgment. The projection still never suppresses, promotes, or hides availability; focus adaptivity lives entirely in an appended section. The perspective's own introspection had flagged map ordering stability, prompt-caching optimization, sort-vs-rank policy, and umbrella selection as high-severity missing specifications; this decision closes all four." .

    narr:Claim_FocusAtEndClosestToGeneration a narr:Claim ;
      narr:aboutNode narr:Narrative_PerspectiveResponseOrderedByVolatility ;
      narr:hasConvictionLevel narr:Conviction_Stake ;

      narr:supports narr:Narrative_PerspectiveResponseOrderedByVolatility ;
      skos:note "A second consequence noted approvingly by Scarlet: focus-relevant material now sits at the end of the tool result, closest to generation — the steering content is the last thing the model reads before it writes." .

    narr:Obs_PerspectiveOrderFourSections a narr:Observation ;
      skos:broader narr:ArchitectureOverview ;

      skos:note "The four-section canonical ordering of the perspective response, as decided 2026-07-01." ;
      oa:hasSelector [
        a oa:SpecificResource ;

        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 656 ; oa:end 776
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "1. **The map** — the richest areas at steering grain, in one canonical order that never changes with the caller's focus." ;
          oa:prefix "The perspective response is now ordered by volatility — the stable part leads, the per-call part trails:\n\n" ;
          oa:suffix "\n2. **The area index** — every other area, named, one line each."
        ]
      ] .

    # ── Style Observations ───────────────────────────────────────
    narr:StyleObs_PerspectiveOrdering_Antithesis a narr:StyleObservation ;
      skos:broader narr:Antithesis ;

      rdf:value true ;
      skos:note "Antithesis structures the core design argument throughout: stable vs. per-call, append vs. reorder, precondition vs. benefit, sort vs. rank. The antithetic framing is the primary rhetorical device for articulating the ordering decision." ;
      oa:hasTarget [
        a oa:SpecificResource ;

        oa:hasSelector [
