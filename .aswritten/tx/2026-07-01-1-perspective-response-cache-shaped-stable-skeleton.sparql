          oa:start 1143 ; oa:end 1194
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "Focus selects what to *append*, never what to move." ;
          oa:prefix "The map is never reordered per call. " ;
          oa:suffix " A no-focus orientation call is byte-stable for a given graph state."
        ]
      ] .

    narr:StyleObs_PerspectiveOrdering_TechnicalRegister a narr:StyleObservation ;
      skos:broader narr:RegisterFormality ;

      rdf:value true ;
      skos:note "High technical register throughout: 'byte-stable', 'cache_control', 'cache-hostile', 'per-call material', 'volatility ordering'. Engineering vocabulary applied to describe a product design decision. Consistent with Scarlet's idiom of borrowing infrastructure terminology to make architectural choices legible." ;
      oa:hasTarget [
        a oa:SpecificResource ;

        oa:hasSelector [
