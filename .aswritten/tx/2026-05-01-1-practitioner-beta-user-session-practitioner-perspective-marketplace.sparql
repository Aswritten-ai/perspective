      skos:note "Healthcare-specific jargon (pelvic floor, HIPAA, intake, handoff criteria, referring physician, concierge medicine, IPS documents) used without definition, implying internal audience. Product jargon (CPC, goal URL, perspective, escalation, Front) also used without definition. Jargon density moderate-high for a session memo. Consistent with the pattern of internal-audience memos across the perspective." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_PractitionerBetaUserBarber_20260430 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 8680 ;
          oa:end 8820
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "visit cadence, evaluation timing, billing, handoff criteria, what intake produces" ;
          oa:prefix "Engagement logistics: " ;
          oa:suffix ", what they expect of the patient"
        ]
      ] .

    # ── STYLE METRICS ────────────────────────────────────────────────────────

    narr:Metrics_PractitionerBetaUserBarber_20260430 a narr:StyleMetrics ;
      dct:source narr:Sample_PractitionerBetaUserBarber_20260430 ;
      skos:broader narr:StyleMetrics ;
      skos:note "Strategic session memo with embedded verbatim blockquotes from Scarlet. Mixed register: structured markdown with H2 section headers (memo genre) vs. conversational first-person in blockquoted speech. Active voice dominant in editorial prose; blockquoted speech is run-on and filler-heavy. Antithesis-heavy structure (cold patient vs. introducer-mediated, citation engine vs. synthesis engine, treatment plan vs. proposal, methodology density vs. content density). Jargon density moderate-high — healthcare terms (pelvic floor, HIPAA, handoff criteria, concierge medicine) and product terms (CPC, goal URL, perspective, escalation) used without definition, implying internal audience. Sentence length elevated by blockquoted speech; prose sections are shorter and punchier. Consistent with the Scarlet session-memo idiolect across the perspective." ;
      narr:AverageSentenceLength "19"^^xsd:integer ;
      narr:ActiveVoiceRatio "0.82"^^xsd:decimal ;
