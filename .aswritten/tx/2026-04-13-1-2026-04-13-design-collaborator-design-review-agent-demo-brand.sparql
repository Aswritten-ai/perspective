# Updates to existing entities
DELETE {
  GRAPH ?g {
    narr:Narrative_ActivationGap skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260323T120000Z {
    narr:Narrative_ActivationGap skos:note "The activation gap is the distance between understanding a concept and knowing how to use it. a design collaborator confirmed the agent deployment layer closes this gap by providing a demonstrable application." .
  }
