    narr:Obs_ScarletDenseProductLanguageQuote a narr:Observation ;
      skos:broader narr:Quotes ;

      skos:note "Scarlet on dense product language as intentional narrative architecture reinforcement" ;
      oa:hasSelector [
        a oa:SpecificResource ;

        oa:hasSelector [
