          oa:prefix "> " ;
          oa:suffix "\n\nThe three principles as they landed:"
        ]
      ] .

    narr:Obs_ScarletNarrativeArchitectureMethodQuote a narr:Observation ;
      skos:broader narr:Quotes ;

      skos:note "Scarlet's verbatim statement of the narrative architecture method" ;
