          oa:exact "these are mostly fine, but it's definitely not 1:1, an incentive could be implicated in many flows and visa versa, you're trying to reduce this to a mapping and it's an interconnected architecture" ;
          oa:prefix "Scarlet: \"" ;
          oa:suffix ". flows are situational"
        ]
      ] .

    narr:Obs_ScarletNarrativeDefinitionQuote a narr:Observation ;
      skos:broader narr:Quotes ;

