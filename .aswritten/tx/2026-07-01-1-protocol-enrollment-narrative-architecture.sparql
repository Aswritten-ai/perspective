    narr:StyleMetrics_ProtocolTrustEnrollment_20260701 a narr:StyleMetrics ;
      skos:broader narr:StyleMetrics ;

      narr:AverageSentenceLength 22 ;
      narr:ActiveVoiceRatio "0.82"^^xsd:decimal ;
