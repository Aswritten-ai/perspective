          oa:prefix "> regardless, " ;
          oa:suffix "\n\nSo the prompt is not authored"
        ]
      ] .

    narr:Obs_ScarletWebNotMappingQuote a narr:Observation ;
      skos:broader narr:Quotes ;

      skos:note "Scarlet's correction: the architecture is a web, not a 1:1 mapping" ;
      oa:hasSelector [
        a oa:SpecificResource ;

        oa:hasSelector [
