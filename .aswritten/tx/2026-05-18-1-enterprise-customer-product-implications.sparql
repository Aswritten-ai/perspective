# ── UPDATE: narr:Narrative_CiteIntrospectAnalyticsGoldmine — add roadmap framing ──
DELETE {
  GRAPH ?g {
    narr:Narrative_CiteIntrospectAnalyticsGoldmine skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260516T120000Z {
    narr:Narrative_CiteIntrospectAnalyticsGoldmine skos:note "Introspect responses surface explicit named gaps (what the customer is asking about); cite responses surface uncommitted claims (gaps in the perspective exposed by writing). Together they reveal both what the perspective is used for and where it falls short — a richer signal than authoring metrics alone. After nine days of the enterprise customer use, introspect had surfaced 62 specific named gaps and 76 recommended actions, of which 15+ were P1 high-impact. These were surfaced by the team asking the perspective what it knew — not by interviews. This is a product capability worth foregrounding in positioning and sales: aswritten tells you what you don't know yet." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_CiteIntrospectAnalyticsGoldmine skos:note ?oldNote .
  }
} ;

