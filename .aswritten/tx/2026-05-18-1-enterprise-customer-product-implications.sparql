    # Sample
    narr:Sample_EnterpriseCustomerPilotReveals_20260516 a narr:Sample ;
      dct:title "What the the enterprise customer Pilot Reveals About the Product" ;
      dct:created "2026-05-16"^^xsd:date ;
      dct:description "Post-pilot review after first nine days of real the enterprise customer customer use (Phase 1, paying customer). Three moment-in-time product observations plus two surfaced product frictions." ;
      narr:inputLength 4821 .

    # ── Narrative 1: Agent-as-interface for analytics ──────────────────────
    narr:Narrative_AgentAsAnalyticsInterface a narr:Narrative ;
      dct:source narr:Sample_EnterpriseCustomerPilotReveals_20260516 ;
      skos:broader narr:ProductOverview ;
      skos:prefLabel "Agent-as-Interface Is the Right Shape for Analytics" ;
      skos:note "the customer's CTO asked for 'usage visibility' during the 2026-05-07 kickoff. A traditional product would respond by building a dashboard. The path actually being implemented — the aswritten_usage MCP tool, gated to Outseta billing contacts, returning structured rollups directly through the same MCP interface the customer's CTO already uses for everything else — is the dogfood version of 'your agent is your operations interface.' Consumption visibility is just another knowledge surface, gated to the right roles, accessed through the same tool-calling pattern. This validates the broader thesis that the agent IS the operations interface for organizational knowledge work." ;
      narr:theme "Usage analytics delivered through the agent interface rather than a dashboard validates the thesis that the agent is the operations interface for organizational knowledge work" .

    # ── Narrative 2: Product surfaces its own roadmap ──────────────────────
    narr:Narrative_ProductSurfacesOwnRoadmap a narr:Narrative ;
      dct:source narr:Sample_EnterpriseCustomerPilotReveals_20260516 ;
      skos:broader narr:Differentiators ;
      skos:prefLabel "The Product Surfaces Its Own Roadmap Through Use" ;
      skos:note "Introspect doesn't just return what's documented in the perspective — it returns a structured list of named gaps and prioritized recommendations. After nine days of the enterprise customer use, the tool had surfaced 62 specific named gaps and 76 recommended actions, of which 15+ were P1 high-impact. These weren't surfaced by interviews — they were surfaced by the team asking the perspective what it knew. The framing: aswritten tells you what you don't know yet. It's not a passive knowledge store; it's an active surface that points at its own thin spots. This is a product capability worth foregrounding in positioning and sales." ;
      narr:theme "aswritten tells you what you don't know yet — introspect is an active surface that points at its own thin spots, not a passive knowledge store" .

    # ── Claims ─────────────────────────────────────────────────────────────
    narr:Claim_AswrittenUsageMCPTool a narr:Claim ;
      dct:source narr:Sample_EnterpriseCustomerPilotReveals_20260516 ;
      skos:note "The aswritten_usage MCP tool — gated to Outseta billing contacts, returning structured rollups through the same MCP interface already in use — is the implementation of 'your agent is your operations interface' for analytics. Instead of 'log into the aswritten admin portal,' it's 'ask your agent — the answer comes back through the same surface you already trust.' The Feltron-style PDF report exists as a hand-curated artifact for now, but the underlying signal will be queryable on demand once Phase 4 lands." ;
      narr:aboutNode narr:Narrative_AgentAsAnalyticsInterface ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Narrative_AgentAsAnalyticsInterface .

    narr:Claim_FourToolLoopEngagedUserPattern a narr:Claim ;
      dct:source narr:Sample_EnterpriseCustomerPilotReveals_20260516 ;
      skos:note "Two distinct usage patterns emerged organically across the enterprise customer's first nine days without prompting: (1) the customer's chief architect's full-loop pattern — perspective → introspect → remember → cite, distributed across all four core tools; the 'expert' archetype who captures, asks, reads, and grounds. (2) a collaborator's reader-grounder pattern — perspective → cite, repeatedly; pulls captured context, grounds her work against it via citation; zero authoring yet. The tools-as-a-set seem to be coherent in practice, not just in design. Worth confirming on subsequent customer engagements before treating as a settled finding — but it's a much better signal than 'users are calling tools' alone." ;
      narr:aboutNode narr:ModulesCapabilities ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Narrative_CiteIntrospectAnalyticsGoldmine .

    # ── Observations ───────────────────────────────────────────────────────
    narr:Obs_CustomerCTOUsageVisibilityRequest a narr:Observation ;
