    # ── SAMPLE ──────────────────────────────────────────────────────────────
    narr:Sample_ConsultingFramingDecision_20260610 a narr:Sample ;
      dct:title "The framing decision: consulting is me using the product" ;
      dct:created "2026-06-10"^^xsd:date ;
      dct:description "Part 2 of the consulting-engagement session record (June 10-12, 2026). Scarlet Dame and Claude working session. Resolves the central tension from the June 10 consulting-engagement-framing handoff: consulting is Scarlet using the product to do something useful for the client, not getting the client to use the product. Covers adoption burden removal, conversion model flip (keeping beats starting), own-from-day-one ownership structure, and entity/traction consequences." ;
      narr:inputLength 1821 .

    # ── NARRATIVES ──────────────────────────────────────────────────────────

    narr:Narrative_ConsultingIsMeUsingProduct a narr:Narrative ;
      dct:source narr:Sample_ConsultingFramingDecision_20260610 ;
      skos:broader narr:PositioningThesis ;
      skos:prefLabel "Consulting Is Me Using the Product, Not Getting Them to Use It" ;
      skos:note "Resolves the personal-services vs. product-engagement vs. hybrid tension from the June 10 handoff. The client never learns a tool, changes behavior, or believes in software. The product is Scarlet's infrastructure, visible only as the continuity and quality of what she delivers. This removes the adoption burden entirely and reframes consulting as a product-powered service delivery model." ;
      narr:theme "Consulting is the founder using the product as infrastructure to deliver value — the client never touches the tool, never adopts it, never believes in it" .

    narr:Narrative_KeepingBeatsStarting a narr:Narrative ;
      dct:source narr:Sample_ConsultingFramingDecision_20260610 ;
      skos:broader narr:SalesDecks ;
      skos:prefLabel "Keeping Beats Starting: The Conversion Model Flip" ;
      skos:note "The install-the-tool model ends an engagement by asking the client to start something ('adopt this'). The consulting-is-me-using-the-product model ends by asking them to keep something that already works — the agent their team has been using. Keeping beats starting as a conversion ask." ;
      narr:theme "The conversion ask flips from 'start adopting this tool' to 'keep the agent your team has already been using' — keeping beats starting" .

    narr:Narrative_OwnFromDayOne a narr:Narrative ;
      dct:source narr:Sample_ConsultingFramingDecision_20260610 ;
      skos:broader narr:PackagingPricing ;
      skos:prefLabel "Own-From-Day-One: Client Owns Repo via Team Plan" ;
      skos:note "Ownership simplified during the June 10 discussion: the client can own their repo from day one by paying for the product (Team plan) and adding Scarlet as a team member. Consulting then continues or stops independently of repo ownership — the consulting relationship and the product subscription are separate decisions. This makes the product subscription company revenue from day one, making the consulting wedge visible to the fundraising traction story." ;
      narr:theme "Client owns their repo from day one via Team plan; consulting relationship and product subscription are separate, independent decisions" .

    # ── CLAIMS ──────────────────────────────────────────────────────────────

    narr:Claim_ConsultingAdoptionBurdenRemoved a narr:Claim ;
      dct:source narr:Sample_ConsultingFramingDecision_20260610 ;
      skos:note "The framing 'consulting is me using the product' removes the adoption burden entirely. The client never learns a tool, changes behavior, or believes in software. The product is Scarlet's infrastructure, visible only as the continuity and quality of what she delivers. This resolves the central tension the June 10 consulting-engagement-framing handoff left open." ;
      narr:aboutNode narr:Narrative_ConsultingIsMeUsingProduct ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_SalesAsDelivery .

