INSERT DATA {
  GRAPH narr:Tx_20260501T180000Z {

    # ── SAMPLE ──────────────────────────────────────────────────
    narr:Sample_OnboardingMethodology_20260501 a narr:Sample ;
      dct:title "Onboarding Methodology: Code-Base Review + Topic Analysis, Not Direct Historical Ingestion" ;
      dct:created "2026-05-01"^^xsd:date ;
      dct:description "Scarlet articulates a three-part seeding pattern for Phase 1 the enterprise customer onboarding on the 2026-05-01 call with the customer's chief architect. Explicitly rejects direct historical transcript ingestion as an anti-pattern that introduces drift. Generalizes to any ARB-shape customer with historical recordings." ;
      narr:inputLength 4821 ;
      narr:styleProfile "narr:ToneDirectPersonal narr:Antithesis narr:SpeakerIdiolects narr:RegisterFormality" .

    # ── DOCUMENT-LEVEL NARRATIVE ─────────────────────────────────
    narr:Narrative_ThreePartSeedingPattern a narr:Narrative ;
      dct:source narr:Sample_OnboardingMethodology_20260501 ;
      skos:broader narr:SolutionArchetypes ;
      skos:prefLabel "Three-Part Seeding Pattern: Code-Base Review, Topic Analysis, Ongoing Iteration" ;
      skos:note "Scarlet's recommended onboarding methodology for Phase 1 the enterprise customer: (1) code-base review with targeted prompts via Claude/Copilot CLI connected to aswritten.ai; (2) topic analysis of historical transcripts rather than direct ingestion — surface domains, open questions, frequently covered things, then add user domain commentary before persisting; (3) ongoing iteration using new ARB transcripts as diagnostics, with 30-minute voice memos to fill gaps. The methodology explicitly rejects direct historical ingestion as a trap. Generalizes to any domain expertise codified in historical recordings." ;
      narr:theme "Seeding organizational perspective requires code-base review, topic-analyzed transcript distillation with domain commentary, and ongoing diagnostic iteration — not direct historical ingestion" .

    narr:Narrative_DirectIngestionAntiPattern a narr:Narrative ;
      dct:source narr:Sample_OnboardingMethodology_20260501 ;
      skos:broader narr:RiskGuardrails ;
      skos:prefLabel "Direct Historical Transcript Ingestion Is a Trap" ;
      skos:note "Direct ingestion of historical transcripts fails because: (1) conversations mix real, speculative, and future-state content without marking; (2) volume overwhelms reviewer attention; (3) drift accumulates and reviewers stop noticing inaccuracies; (4) the system encodes confused or contradictory positions as settled. Scarlet: 'If you are not watching the output of every single one of those transcripts and doing a fully fledged sort of review process, you're going to introduce error and drift over time.'" ;
      narr:theme "Direct historical transcript ingestion encodes drift and contradiction as settled knowledge — the volume and mixed-state nature of conversations makes unreviewed ingestion a trap" .

    # ── SECTION 1: CODE-BASE REVIEW ─────────────────────────────
    narr:Claim_CodeBaseReviewStep1 a narr:Claim ;
      dct:source narr:Sample_OnboardingMethodology_20260501 ;
      skos:note "Step 1 of the three-part seeding pattern: use Claude / Copilot CLI connected to aswritten.ai to read the code base with structured questions ('read the code base, understand what the core pre-built workflows are and write a paragraph about each one and persist that paragraph to collective memory'), with iteration. The MCP aswritten_remember tool plus the connected perspective's context guides the memory-creation flow. the customer's chief architect's framing: 'I have a plan, so that's easy. I think I'm pretty set on how to do that.'" ;
      narr:aboutNode narr:Narrative_ThreePartSeedingPattern ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      .

    # ── SECTION 2: TOPIC ANALYSIS ────────────────────────────────
    narr:Claim_TopicAnalysisStep2 a narr:Claim ;
      dct:source narr:Sample_OnboardingMethodology_20260501 ;
      skos:note "Step 2 of the three-part seeding pattern: rather than ingesting six months of ARB transcripts directly, use Claude to perform a topic analysis across the corpus — 'what are these talking about? what are the open questions? what are frequently covered things?' — then create memories scoped to the surfaced domains, with the user's domain commentary added before persisting. The user (the customer's chief architect, as the only person with architectural context) must validate or correct what the topic analysis surfaces. Without domain experts who can review and annotate, seeding will produce sparse or wrong knowledge." ;
      narr:aboutNode narr:Narrative_ThreePartSeedingPattern ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      .

    # ── SECTION 3: ONGOING ITERATION ────────────────────────────
    narr:Claim_OngoingIterationStep3 a narr:Claim ;
      dct:source narr:Sample_OnboardingMethodology_20260501 ;
      skos:note "Step 3 of the three-part seeding pattern: as ARB meetings happen, ingest each transcript with active review. The transcript is the diagnostic, not the memory. When the system fails to answer a question well, the user does a 30-minute voice memo unpacking the missing context, which becomes the gap-filling memory. Scarlet: 'After every ARB, you might spend 30 minutes on a voice memo like talking through that whole system. Dump the transcript into aswritten and over the course of a couple weeks or even a couple months, you'll converge on having pretty much everything covered.'" ;
      narr:aboutNode narr:Narrative_ThreePartSeedingPattern ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      .

    # ── SECTION 4: ANTI-PATTERN ──────────────────────────────────
    narr:Claim_DirectIngestionIsTrap a narr:Claim ;
      dct:source narr:Sample_OnboardingMethodology_20260501 ;
      skos:note "Direct ingestion of historical transcripts is an explicit anti-pattern because: conversations mix real, speculative, and future-state content without marking; volume overwhelms reviewer attention; drift accumulates and reviewers stop noticing inaccuracies after a few transcripts; the system encodes confused or contradictory positions as if they were settled. This is a stated onboarding guardrail for the Enterprise tier." ;
      narr:aboutNode narr:Narrative_DirectIngestionAntiPattern ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_DirectIngestionAntiPattern .

    # ── SECTION 5: PRODUCT IMPLICATIONS ─────────────────────────
    narr:Claim_TopicAnalysisPlatformFeature a narr:Claim ;
      dct:source narr:Sample_OnboardingMethodology_20260501 ;
      skos:note "The topic analysis step (Step 2) is currently entirely operator-driven and is a high-value activity that could become a Platform feature. The anti-pattern (direct historical ingestion) should be reflected in onboarding documentation and possibly enforced via UX (e.g., warn when uploading multiple raw transcripts without review pacing)." ;
      narr:aboutNode narr:Narrative_ThreePartSeedingPattern ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:NarrativeDrivenRoadmap .

    narr:Claim_OnboardingMethodologyGeneralizes a narr:Claim ;
      dct:source narr:Sample_OnboardingMethodology_20260501 ;
      skos:note "The three-part seeding methodology generalizes beyond the enterprise customer: any domain expertise codified in historical recordings (sales calls, customer interviews, OKR retrospectives) is a candidate for the same pattern. This is a stated onboarding playbook for the Enterprise tier that does not require building new tooling — it is a sequencing of existing capabilities." ;
      narr:aboutNode narr:Narrative_ThreePartSeedingPattern ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      .

    narr:Claim_UserDomainCommentaryRequired a narr:Claim ;
      dct:source narr:Sample_OnboardingMethodology_20260501 ;
      skos:note "The methodology assumes the customer has domain experts who can review and annotate the topic analysis output. The user — not aswritten.ai staff — provides the architectural commentary at Step 2. Without that, the seeding will produce sparse or wrong knowledge. the customer's chief architect is the only person with the architectural context to validate or correct what the topic analysis surfaces at the enterprise customer." ;
      narr:aboutNode narr:Narrative_ThreePartSeedingPattern ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      .

    # ── OBSERVATIONS (GROUNDED QUOTES) ───────────────────────────
    narr:Obs_ScarletTopicAnalysisQuote a narr:Observation ;
