    narr:aboutNode narr:DesignTradeoffs ;
    narr:hasConvictionLevel narr:Conviction_Foundation ;
    narr:assertsStatement [ rdf:value "Analysis (gaps, tensions) is for picking the lens; content (claims, convictions, provenance) is for drafting from; mixing them makes both harder to use" ] ;
    dct:source narr:Sample_LensArchRevision ;
    prov:wasGeneratedBy narr:Tx_20260309T152827Z .

  narr:Claim_ScopeDefinition a narr:Claim ;
    narr:aboutNode narr:Primitives ;
    narr:hasConvictionLevel narr:Conviction_Foundation ;
    narr:assertsStatement [ rdf:value "scope takes arbitrary focus + context (both free text); the text defines the scope; no keywords, no predefined domain buckets" ] ;
    dct:source narr:Sample_LensArchRevision ;
    prov:wasGeneratedBy narr:Tx_20260309T152827Z .

  narr:Claim_RefractDefinition a narr:Claim ;
    narr:aboutNode narr:Primitives ;
    narr:hasConvictionLevel narr:Conviction_Foundation ;
    narr:assertsStatement [ rdf:value "refract takes a document and a TX (or arbitrary prompt) and returns focus areas for shifts in the document; it is change detection + focus generation, not content retrieval" ] ;
    dct:source narr:Sample_LensArchRevision ;
    prov:wasGeneratedBy narr:Tx_20260309T152827Z .

  narr:Claim_RegistrySimplification a narr:Claim ;
    narr:aboutNode narr:DataModelLifecycle ;
    narr:hasConvictionLevel narr:Conviction_Boulder ;
    narr:assertsStatement [ rdf:value "Registry is now just paths; no focus or intent metadata; checking for changes against focus is brittle, it should check against actual text" ] ;
    dct:source narr:Sample_LensArchRevision ;
    prov:wasGeneratedBy narr:Tx_20260309T152827Z .

  narr:Claim_ScopeBuildFirst a narr:Claim ;
    narr:aboutNode narr:NarrativeDrivenRoadmap ;
    narr:hasConvictionLevel narr:Conviction_Stake ;
    narr:assertsStatement [ rdf:value "Build order: scope → refract → register → lens → enhanced start_review; scope is the foundation — everything else depends on it" ] ;
    dct:source narr:Sample_LensArchRevision ;
    prov:wasGeneratedBy narr:Tx_20260309T152827Z .

  narr:Claim_ScopeFragility a narr:Claim ;
    narr:aboutNode narr:RiskGuardrails ;
    narr:hasConvictionLevel narr:Conviction_Stake ;
    narr:assertsStatement [ rdf:value "Scope with narrow keywords risks excluding relevant material; passing a full document as context mitigates this; better than compressed worldview" ] ;
    dct:source narr:Sample_LensArchRevision ;
    prov:wasGeneratedBy narr:Tx_20260309T152827Z .

