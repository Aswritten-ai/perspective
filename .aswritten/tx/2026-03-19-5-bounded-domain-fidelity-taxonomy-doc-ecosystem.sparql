    # ── Sample ──────────────────────────────────────────────────────────────
    narr:Sample_BoundedDomainFidelity_20260319 a narr:Sample ;
      dct:title "Bounded-Domain Fidelity, Collaboration Taxonomy, and Document Ecosystem (2026-03-19)" ;
      dct:created "2026-03-19"^^xsd:date ;
      dct:description "End-of-session brain dump following V1 strategy document creation. Captures the bounded-domain fidelity argument (expertise modules are higher fidelity than org memory), the collaboration taxonomy missing from the strategy doc, open product ideas (SMS entry, AI voice interviews), and the full document ecosystem to be derived from the strategy doc." ;
      narr:inputLength 3421 .

    # ── Scale 1: Document-level Narratives ──────────────────────────────────

    narr:Narrative_BoundedDomainFidelityArgument a narr:Narrative ;
      dct:source narr:Sample_BoundedDomainFidelity_20260319 ;
      skos:broader narr:PositioningThesis ;
      skos:prefLabel "Bounded-Domain Fidelity: Expertise Modules Are Higher Fidelity Than Org Memory" ;
      skos:note "Expertise modules (courses, books, consulting deliverables) are bounded and intentionally updated — each update is a deliberate act by the expert. Organizational memory is inherently lossy because it tracks a moving target. The bounded case is structurally higher fidelity. This is a compelling argument for leading with the expertise module vertical rather than the organizational memory use case. Danger: stale graph + citations = worse than no citations at all." ;
      narr:theme "Expertise modules are higher fidelity than org memory because they are bounded, intentionally curated, and do not drift without the expert's knowledge" .

    narr:Narrative_CollaborationTaxonomy a narr:Narrative ;
      dct:source narr:Sample_BoundedDomainFidelity_20260319 ;
      skos:broader narr:SolutionArchetypes ;
      skos:prefLabel "Collaboration Shape Taxonomy: Individual→Self, Individual→Team, Individual→Many, Team→Many" ;
      skos:note "The strategy doc has three archetypes but is missing the collaboration shape taxonomy. Four shapes: Individual→Self (creating expertise for own AI consumption), Individual→Team (expertise consumed by a team), Individual→Many (publishing expertise to many — the publisher), Team→Many (a team publishing expertise to many). The Salon archetype from the original Solo/Parallel/Hub/Salon/Teams taxonomy has been reclassified as the review behavior — collaborative review IS the salon." ;
      narr:theme "The collaboration shape taxonomy (Individual→Self / →Team / →Many, Team→Many) is the missing structural layer in the strategy doc's archetype model" .

    narr:Narrative_DocumentEcosystem a narr:Narrative ;
      dct:source narr:Sample_BoundedDomainFidelity_20260319 ;
      skos:broader narr:NarrativeDrivenRoadmap ;
      skos:prefLabel "Document Ecosystem: Strategy Doc as Internal Source of Truth for All Derived Documents" ;
      skos:note "The strategy document is the internal source of truth. From it, multiple documents need to be derived: product doc (internal, users/tools/flows/actor stories), F&F fundraising doc (family, plain language, split from existing brief), VC/Angels doc (investors, no raise amount), intro deck (first meeting, forwards to follow-up), white paper (external/thought leadership), sales playbook (internal/a demo-call prospect), one sheet (external), public docs (user-facing), case studies (external/sales — need audit). Scarlet also wants a product doc following her original consulting framework (ontology contains the progression: users, incentives, org profiles, actions, components, tools, flows, actor stories)." ;
      narr:theme "The strategy document is the single internal source of truth; all audience-specific documents are derived from it, not the other way around" .

    # ── Scale 2: Section-level Claims ───────────────────────────────────────

    narr:Claim_BoundedDomainHigherFidelity a narr:Claim ;
      dct:source narr:Sample_BoundedDomainFidelity_20260319 ;
      skos:note "Expertise modules (courses, books, consulting deliverables) are bounded and intentionally updated — each update is a deliberate act by the expert. Org memory is inherently lossy because it tracks a moving target. The bounded case is actually higher fidelity than the org case. This is a structural advantage for leading with the expertise module vertical." ;
      narr:aboutNode narr:Narrative_BoundedDomainFidelityArgument ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:PositioningThesis .

    narr:Claim_StaleGraphCitationsWorse a narr:Claim ;
      dct:source narr:Sample_BoundedDomainFidelity_20260319 ;
      skos:note "The danger with organizational memory: stale graph + citations = worse than having no citations at all. If the graph is inaccurate and someone is delegating work to AI that cites collective memory, the result is work with citations to something that is wrong. That is worse than generic AI with no citations." ;
      narr:aboutNode narr:Narrative_BoundedDomainFidelityArgument ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:GovernanceSafetyTrust .

    narr:Claim_FounderAsPoorUserExample a narr:Claim ;
      dct:source narr:Sample_BoundedDomainFidelity_20260319 ;
      skos:note "Scarlet noted: 'Because my using the product is the central use case, I'm a poor user. I'm a poor example of a user because I am the power user par excellence. My memories are going to stay about as current as you may ever get.' Most users will not maintain their graph the way the founder does. This is a product design and user research implication." ;
      narr:aboutNode narr:Narrative_BoundedDomainFidelityArgument ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:PersonasJTBD .

    narr:Claim_SalonReclassifiedAsReviewBehavior a narr:Claim ;
      dct:source narr:Sample_BoundedDomainFidelity_20260319 ;
      skos:note "The Salon archetype from the original solution archetypes (Solo/Parallel/Hub/Salon/Teams) has been reclassified as the review behavior — collaborative review IS the salon. This supersedes the prior treatment of Salon as a fifth deployment pattern." ;
      narr:aboutNode narr:Narrative_CollaborationTaxonomy ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_CollaborationTaxonomy .

    narr:Claim_SMSEntryOpenProductIdea a narr:Claim ;
