      narr:aboutNode narr:Narrative_CollaborationTaxonomy ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:challenges narr:Narrative_CollaborationTaxonomy .

    narr:Claim_BirchVoiceInterviewModel a narr:Claim ;
