# ── UPDATE 1: Correct SMS-first product description ──────────────────────────
# Memory explicitly states: "currently described in the graph as 'SMS-first' product,
# which is an overstatement — it's an open product idea, not the current product."
# This contradicts the existing narr:Product_SMSCollectiveMemory positioning.
DELETE {
  GRAPH ?g {
    narr:Product_SMSCollectiveMemory skos:prefLabel ?oldLabel .
    narr:Positioning_SMSProduct skos:prefLabel ?oldPositioningLabel .
  }
}
INSERT {
  GRAPH narr:Tx_20260319T230000Z {
    narr:Product_SMSCollectiveMemory skos:prefLabel "SMS-First Collective Memory (Open Product Idea, Not Current Product)" ;
      skos:note "CORRECTION 2026-03-19: Previously described as the current product direction. Scarlet clarified this is an open product idea, not the current product. The 'SMS-first' framing is an overstatement. This is the salon case in the collaboration taxonomy." .
    narr:Positioning_SMSProduct skos:prefLabel "SMS-First Collective Memory Positioning (Open Idea)" .
  }
}
WHERE {
  GRAPH ?g {
    narr:Product_SMSCollectiveMemory skos:prefLabel ?oldLabel .
  }
  OPTIONAL {
    GRAPH ?g {
      narr:Positioning_SMSProduct skos:prefLabel ?oldPositioningLabel .
    }
  }
} ;

