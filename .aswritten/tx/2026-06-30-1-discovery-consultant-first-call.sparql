    # ── S2: Core thesis — artifacts lose the *why* ───────────────
    narr:Narrative_ArtifactsLoseTheWhy a narr:Narrative ;
      dct:source narr:Sample_DiscoveryConsultantCall_20260604 ;
      narr:theme "Artifacts lose the reasoning behind their creation" ;
      skos:broader narr:NarrativeAnchor ;
      skos:note "Scarlet's central framing: existing code/content does not capture the reason behind why it exists. Artifacts are downstream of a decision-making process and always miss the mark some, with assumptions made by coding agents or humans coming into projects." .

    narr:Obs_ArtifactsLoseWhy a narr:Observation ;
      skos:broader narr:WhatIsIt ;
