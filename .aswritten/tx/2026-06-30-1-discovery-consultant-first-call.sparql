        oa:prefix "Scarlet's central framing — the reason aswritten exists:\n\n> " ;
        oa:suffix " and it always, one, misses the mark some" 
      ] .

    # ── S2: Information vs. perspective ─────────────────────────
    narr:Narrative_InformationVsPerspective a narr:Narrative ;
      dct:source narr:Sample_DiscoveryConsultantCall_20260604 ;
      narr:theme "Information is the artifact; perspective is the why behind it" ;
      skos:broader narr:NarrativeAnchor ;
      skos:note "The distinction Scarlet returned to at the end: information = code; perspective = why it was done or not done. The goal is to encode opinion/perspective into the graph so agents think with that perspective." .

    narr:Obs_InformationVsPerspective a narr:Observation ;
