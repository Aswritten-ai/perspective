          oa:suffix " to move forward with that?"
        ]
      ] .

    # Style Metrics
    narr:StyleMetrics_CustomerArchitectSponsorNotChampion
      a narr:StyleMetrics ;
      dct:source narr:Sample_CustomerArchitectSponsorNotChampion_20260421 ;
      skos:broader narr:StyleMetrics ;
      skos:note "Call transcript register with heavy embedded verbatim quotes from two speakers. Tony's quoted speech is short, directive, filler-heavy ('Right. Right. Blah, blah, blah.') averaging ~14 words. Scarlet's speech is more analytical (~22 words avg). Antithesis-heavy structure (sponsor vs. champion, sequential vs. parallel, Team vs. Enterprise). Timestamp citation convention throughout. Active voice dominant in editorial prose. Jargon density low-moderate — product terms (MSA, POC, Team plan, MCP) used without definition, implying internal audience. Numbered list structure for playbook steps. Short punchy declaratives at conviction peaks ('Sponsor ≠ champion.')." ;
      narr:AverageSentenceLength "16"^^xsd:integer ;
