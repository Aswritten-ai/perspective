          oa:suffix " Right. So what my advice there is"
        ]
      ] .

    narr:StyleObs_Antithesis_SponsorChampion
      a narr:StyleObservation ;
      skos:broader narr:Antithesis ;
      dct:source narr:Sample_CustomerArchitectSponsorNotChampion_20260421 ;
      skos:note "Antithesis-heavy structure throughout: sponsor vs. champion, excited vs. rams it through, POC sequential vs. parallel, Team credit card vs. Enterprise MSA. The document's core argument is built on a series of binary contrasts that sharpen the tactical prescription." ;
