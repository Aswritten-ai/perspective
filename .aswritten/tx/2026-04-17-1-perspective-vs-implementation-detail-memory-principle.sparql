          oa:prefix "On what IS appropriate:\n\n> " ;
          oa:suffix " That's different than 60 pixels of padding around a particular thing or even a direct multiple."
        ]
      ] .

    # ── STYLE OBSERVATIONS ───────────────────────────────────────
    narr:StyleObs_AntithesisStructure a narr:StyleObservation ;
