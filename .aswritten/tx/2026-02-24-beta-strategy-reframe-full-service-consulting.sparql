  # --- Sample ---
  narr:Sample_BetaStrategyReframe a narr:Sample ;
    dct:title              "Beta Strategy Reframe: Full-Service Consulting as Product Validation" ;
    narr:inputLength       5800 ;
    .

  # --- Narratives ---
  narr:Narrative_BetaAsConsulting a narr:Narrative ;
    dct:source             narr:Sample_BetaStrategyReframe ;
    narr:theme             "Full-service consulting engagement as the mechanism for beta product validation" ;
    skos:broader           narr:StrategyOverview ;
    skos:note              "Beta is not self-service onboarding; it is delivering the full consulting engagement so the product is tested under real load with real organizational knowledge." ;
    .

  narr:Narrative_FullEngagementUnlocksTesting a narr:Narrative ;
    dct:source             narr:Sample_BetaStrategyReframe ;
    narr:theme             "Withholding engagement from unpaid relationships undermines product validation; inverting this is the beta strategy" ;
    skos:broader           narr:NarrativeAnchor ;
    skos:note              "Scarlet previously identified a pattern of holding back engagement with unpaid relationships. The beta reframe explicitly inverts this: give the full [amount] engagement to beta users because that is the only way to test whether the product works at production scale." ;
    .

  narr:Narrative_SalonAsCapability a narr:Narrative ;
    dct:source             narr:Sample_BetaStrategyReframe ;
    narr:theme             "Salon is a per-memory capability, not a fifth deployment pattern" ;
    skos:broader           narr:CoreNarratives ;
    skos:note              "The reviewers frontmatter on any memory turns it into a Salon. Every org gets Salon for free as a feature of the memory primitive, not a deployment choice." ;
    .

  narr:Narrative_BetaFeedbackLoopIsSalon a narr:Narrative ;
    dct:source             narr:Sample_BetaStrategyReframe ;
    narr:theme             "The product tests itself: beta feedback loop is itself a Salon" ;
    skos:broader           narr:CoreNarratives ;
    skos:note              "Scarlet runs Salon across the beta cohort to synthesize feedback. The beta feedback loop IS a Salon — the product testing its own product." ;
    .

  narr:Narrative_MultiTenantHub a narr:Narrative ;
    dct:source             narr:Sample_BetaStrategyReframe ;
    narr:theme             "Directory inheritance enables multi-tenant Hub deployment for consultants working across multiple clients" ;
    skos:broader           narr:ArchitectureOverview ;
    skos:note              "a beta user from outside tech's case maps to a multi-tenant Hub. The compile tool's dir parameter supports directory-scoped compilation with inheritance, allowing methodology to compound across clients." ;
    .

  # --- Claims ---
  narr:Claim_BetaIsConsulting a narr:Claim ;
    narr:hasConvictionLevel narr:Conviction_Foundation ;
    narr:aboutNode          narr:Narrative_BetaAsConsulting ;
