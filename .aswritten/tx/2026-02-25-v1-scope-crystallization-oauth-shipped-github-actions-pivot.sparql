  narr:Obs_V1UXVision a narr:Observation ;
    skos:broader narr:WhatDoesItDo ;
    dct:source   narr:Sample_1 ;
    skos:note    "Scarlet's articulated V1 UX: MCP endpoint + notifications; GitHub is infrastructure, not interface." ;
    oa:hasSelector [
