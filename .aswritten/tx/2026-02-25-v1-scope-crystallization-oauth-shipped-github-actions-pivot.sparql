      oa:start 5230 ;
      oa:end   5480
    ] ;
    oa:hasSelector [
      a oa:TextQuoteSelector ;
      oa:exact  "The only time a user touches GitHub is to install the GitHub App. Everything else happens through MCP tools and notifications. Add memories → branches created → extraction runs → PR opened → notification sent → user reviews from their channel → confirms → merged. Solo scope with single reviewer." ;
      oa:prefix "Scarlet articulated the target user experience:\n\n> " ;
      oa:suffix "\n\nThis is the product surface"
    ] ;
    .

