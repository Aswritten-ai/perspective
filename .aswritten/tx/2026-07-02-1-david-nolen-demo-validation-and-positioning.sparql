INSERT DATA {
  GRAPH narr:Tx_20260702T023158Z {

    # ── Sample ──────────────────────────────────────────────────
    narr:Sample_DavidNolenDemo_20260625 a narr:Sample ;
      dct:title "David Nolen demo: skeptical senior engineer validates provenance + archaeology, contests dev-vs-strategy positioning" ;
      dct:created "2026-06-25"^^xsd:date ;
      narr:inputLength 11007 ;
      dct:description "Scarlet ↔ David Nolen video call, June 25 2026 (~1 hr). Product demo + advisor feedback. David is a senior Clojure engineer (ex-DRW) who probed positioning, validated provenance/archaeology/introspect differentiators, and contested the developer ICP." .

    # ── Narratives ──────────────────────────────────────────────

    narr:Narrative_WhiteSpaceMechanism a narr:Narrative ;
      dct:source narr:Sample_DavidNolenDemo_20260625 ;
      narr:theme "White space: the organizational perspective fills in what the model decides by default" ;
      skos:broader narr:NarrativeAnchor ;
      skos:note "Scarlet's coinage for the core mechanism: whatever you don't specify, the model decides — those decisions come from the model's default. The more specific your prompt, the less white space. aswritten preloads an organizational perspective that fills in white space before you do anything. David sharpened it: 'that white space is also non-deterministic.'" .

    narr:Narrative_ModelAsOS a narr:Narrative ;
      dct:source narr:Sample_DavidNolenDemo_20260625 ;
      narr:theme "Model as operating system; perspective as application that runs on top" ;
      skos:broader narr:PositioningThesis ;
      skos:note "Prompted by David's Sonnet-vs-Opus workflow discussion: the model is just the operating system and the perspective is an application that runs on top of it — a program that bootstraps the model to think in a certain way, portable across any individual model. Expresses the model-independence / installable-program thesis." .

    narr:Narrative_StoreDecisionProcessNotArtifact a narr:Narrative ;
      dct:source narr:Sample_DavidNolenDemo_20260625 ;
      narr:theme "Store the decision process, not the half-baked artifact" ;
      skos:broader narr:Differentiators ;
      skos:note "Most systems store facts; aswritten steps upstream and stores the discussion and decision-making process that got there, because AI makes new decisions based on what was previously decided, not replicating what's already there. Vivid version: AI 'looks at the codebase and says I see you do it this way, when that way is some half-baked version of the thing we tried three different ways three different times and got 60% of the way.'" .

    narr:Narrative_ArchaeologyQueryUseCase a narr:Narrative ;
      dct:source narr:Sample_DavidNolenDemo_20260625 ;
      narr:theme "Archaeology query: show how it was originally done and all the conversations that led to this moment" ;
      skos:broader narr:Differentiators ;
      skos:note "David constructed this use case himself — unprompted — asking whether he could query 'show me how it was originally done and all the conversations that led to this moment where it was decided to implement it this new way with a different set of trade-offs.' He then answered his own excitement: 'that's the classic — any organization you walk in and you're like, how did we end up here? And your ability to find out how you got to a place is almost impossible.' Reached for his DRW maze-of-Confluence-documents trauma. This was the emotional peak of the demo, and the prospect generated it, not the pitch." .

    # ── Claims ──────────────────────────────────────────────────

    narr:Claim_DavidNolenProvenanceValidation a narr:Claim ;
      narr:aboutNode narr:Narrative_ProvenanceCitationMoment ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_ProvenanceCitationMoment ;
      dct:source narr:Sample_DavidNolenDemo_20260625 ;
      skos:note "David Nolen — a credible senior technical evaluator — independently validated the provenance/citation differentiator: 'that part is really cool, the provenance stuff… getting back answers grounded in some truth' [35:37], and unprompted: 'the fact that it has dates… the date thing is awesome, a nice reference point for doing research. All the citations at the bottom is really cool' [53:02]. External-validation data point, not Scarlet's pitch." .

    narr:Claim_DavidNolenArchaeologyValidation a narr:Claim ;
      narr:aboutNode narr:Narrative_ArchaeologyQueryUseCase ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_ArchaeologyQueryUseCase ;
      dct:source narr:Sample_DavidNolenDemo_20260625 ;
      skos:note "David constructed the archaeology use case himself — unprompted — and reached emotional peak describing his DRW Confluence-documents trauma. The prospect generated the use case, not the pitch. This is the strongest independent validation signal in the call." .

    narr:Claim_IntrospectFixesHallucination a narr:Claim ;
      narr:aboutNode narr:Differentiators ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Differentiators ;
      dct:source narr:Sample_DavidNolenDemo_20260625 ;
      skos:note "David independently validated introspect-as-escalation: 'that fixes one huge problem with LLMs — once you're in unknown territory it just makes up plausible stuff, it doesn't stop and claim it doesn't know something' [01:12:31]. External-validation data point on the 'it knows what it doesn't know' differentiator." .

    narr:Claim_ConvictionTemporalityExternalValidation a narr:Claim ;
      narr:aboutNode narr:Narrative_ConvictionFramework ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Narrative_ConvictionFramework ;
      dct:source narr:Sample_DavidNolenDemo_20260625 ;
      skos:note "David asked the exact question the conviction model answers — facts 'set in stone' vs. the evolving 'frontier' [42:57] — and the stepwise-conviction answer (notion → decision → foundational, incremented/decremented on re-extraction) landed. External validation of the conviction stack's user-legibility." .

    narr:Claim_DeveloperLikeMeICPNarrowing a narr:Claim ;
      narr:aboutNode narr:Narrative_TierContinuumNotDistinctMarkets ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Narrative_TierContinuumNotDistinctMarkets ;
      dct:source narr:Sample_DavidNolenDemo_20260625 ;
      skos:note "Scarlet's load-bearing resolution to David's four-times-repeated positioning challenge: 'When I say it's really useful for developers, I mean it's really useful for developers like me — developers who are involved in the product process or who are running an organization themselves. And I actually think that team shape is becoming a lot more prevalent.' [01:17:15]. This narrows the ICP rather than defending 'everyone' — held against a credible challenge, consistent with the continuum thesis, and sharpens (rather than resolves) the standing 'coding tool vs. strategy tool — it's the middle point' tension." .

    narr:Claim_DemoLegibilityOwnDataRequired a narr:Claim ;
      narr:aboutNode narr:Narrative_ActivationGap ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Narrative_ActivationGap ;
      dct:source narr:Sample_DavidNolenDemo_20260625 ;
      skos:note "Scarlet: 'it's hard to have the moment with it that isn't your stuff… until it cites you in a way that's meaningful, and until it tells you it's missing something in a way that's actually true, it's kind of all theoretical. So I really encourage people to try it.' [01:13:12]. Corroborates the activation-gap / two-sided-legibility material. David's exit was 'give it a try myself,' not 'I'm sold from the demo.'" .

