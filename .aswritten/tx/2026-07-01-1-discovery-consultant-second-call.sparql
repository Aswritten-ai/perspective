INSERT DATA {
  GRAPH narr:Tx_20260630T150000Z {

    # ── SAMPLE ──────────────────────────────────────────────────────────────
    narr:Sample_DiscoveryConsultant_20260630
      a narr:Sample ;
      dct:title "Second Call with a consultant who ran enterprise discovery engagements for fifteen years — Live Demo, the Discovery-Tool Wedge, and a Warming Relationship" ;
      dct:created "2026-06-30"^^xsd:date ;
      dct:description "Second call (first was Jun 4). a consultant who ran enterprise discovery engagements for fifteen years is co-founder building an adjacent RDF org-knowledge system (JUXT). Scarlet ran a live demo. a consultant who ran enterprise discovery engagements for fifteen years named the clearest sellable use case: aswritten as a consulting discovery tool. Covers relationship framing, technical convergence on navigation vs. query, Chinese Whispers provenance thesis, GTM discovery-tool wedge, expert-network market segment, anti-Conway clustering vision, general vs. sellable tension, adoption friction, and meta-loop demo problem." ;
      narr:inputLength 9847 .

    # ── NARRATIVES ──────────────────────────────────────────────────────────
    narr:Narrative_DiscoveryToolGTMWedge

      dct:source narr:Sample_DiscoveryConsultant_20260630 ;
      skos:broader narr:FocusSequencing ;
      skos:prefLabel "Discovery Tool as GTM Wedge: Consulting Discovery Powered by aswritten" ;
      skos:note "a consultant who ran enterprise discovery engagements for fifteen years (15 years at JUXT) named a bounded, sellable use case: aswritten as the infrastructure for consulting discovery engagements. The model: go into an org with a problem-child system, interview every stakeholder, produce a report where every claim traces to a specific person's statement. The economics: a discovery is a 'battering ram' — a loss-leader ([amount]-20K) whose real value is getting the consultancy in the door, after which 'you become a super valuable consultant because you know all the problems.' aswritten's provenance model is the differentiator: 'you'd not just get the transcript, and you wouldn't be getting oh, Claude thinks you should do this — which would be terrible, because why does Claude think that? You want: well, Bob, the previous senior developer, said the reason this goes down every night is it garbage collects and runs out of memory.' This is the clearest sellable use case anyone has offered Scarlet." ;
      narr:theme "aswritten as the infrastructure for consulting discovery engagements — provenance-backed reports where every claim traces to a named stakeholder" ;
      narr:supports narr:Narrative_EnterpriseShapePrimaryFocus .

    narr:Narrative_ChineseWhispersProvenance

      dct:source narr:Sample_DiscoveryConsultant_20260630 ;
      skos:broader narr:PositioningThesis ;
      skos:prefLabel "Chinese Whispers: What aswritten Fights" ;
      skos:note "a consultant who ran enterprise discovery engagements for fifteen years's framing of the core problem aswritten solves, which Scarlet affirmed as 'spot on': 'I'd call it Chinese Whispers... even if every actor is trying honestly to retain the fidelity of the message, it is surprising how bad humans are... how the message gets distorted.' Scarlet's response: 'we're abstracting concrete statements into directional nodes — directional vectors that guide LLM thinking... narrative... paralinguistic, how it was said... the emotional content... conviction. And we have full provenance down to the source memory for every node.' The Chinese Whispers frame is a strong, accessible articulation of the provenance thesis for non-technical audiences." ;
      narr:theme "aswritten fights Chinese Whispers — the inevitable distortion of meaning as it passes through human intermediaries — by preserving full provenance from source statement to derived insight" .

    narr:Narrative_NarrativeStrategyReport

      dct:source narr:Sample_DiscoveryConsultant_20260630 ;
      skos:broader narr:SolutionArchetypes ;
      skos:prefLabel "Narrative-Strategy Report: Productized Consulting Engagement" ;
      skos:note "Scarlet's productized extension of a consultant who ran enterprise discovery engagements for fifteen years's discovery-tool framing, mapped onto her pre-aswritten consulting (business + 'narrative strategy' — crafting the directional-vector statements a company works from). Proposed deliverable: 'I'll take the last four to six months of your conversations, sign an NDA, and write this beautiful report about not only how your ideas have been changing over that time, but how they're shared across different teams, where there's dissenting opinion... and where you need to go to converge on the things you're actually trying to do.' A 2-4 week, NDA'd, fixed-deliverable engagement that rides alongside a pilot. The most concrete initial-services offering Scarlet has articulated, and a direct answer to 'what do I hand them in two-to-four weeks.'" ;
      narr:theme "A 2-4 week NDA'd narrative-strategy report — showing how ideas have changed over time, where they're shared across teams, and where dissenting opinion lives — is the most concrete initial consulting deliverable" ;
      narr:supports narr:Narrative_ConsultingIsMeUsingProduct .

    narr:Narrative_ExpertNetworkTranscriptMarket

      dct:source narr:Sample_DiscoveryConsultant_20260630 ;
      skos:broader narr:Segmentation ;
      skos:prefLabel "Expert Networks and Transcript-Rich Research Firms as Market Segment" ;
      skos:note "a consultant who ran enterprise discovery engagements for fifteen years raised the market of transcript-based research firms — Third Bridge, Gartner, Forrester — that hold 'millions of transcripts' and sell subscription access. 'These are pretty substantial — [amount] a year... multiple offices around the world.' His framing: 'you become one of these companies, or you sell into one,' and 'anywhere there are already existing transcripts' is a candidate market. He also flagged compliance/audit as transcript-rich: SOC 2 / QSA audits, PwC-style financial audits, UK R&D tax-credit interviews (XTDB qualified as novel), and patent-attorney interviews. a consultant who ran enterprise discovery engagements for fifteen years offered a warm intro to a collaborator at a collaborator a collaborator re: Third Bridge relationship." ;
      narr:theme "Transcript-rich research firms (Third Bridge, Gartner, Forrester) and compliance/audit processes are candidate markets — anywhere existing transcripts accumulate is a candidate for aswritten" ;
      narr:supports narr:Narrative_TranscriptBootstrappingUnderplayed .

    narr:Narrative_AntiConwayClusteringVision

      dct:source narr:Sample_DiscoveryConsultant_20260630 ;
      skos:broader narr:MarketContext ;
      skos:prefLabel "Anti-Conway Clustering: Finding Duplication of Work Across Large Orgs" ;
      skos:note "a consultant who ran enterprise discovery engagements for fifteen years's recurring obsession: finding duplication of work across large orgs (investment banks with many people solving the same problem). He tied it to a rejection of Conway's Law: 'the point of information technology is to provide the tools so that we don't default to Conway's Law... this allows you to have multidimensional organizations [rather than] physically located teams.' He contrasted aswritten with Obsidian/Roam — 'those are around people getting their own personal thoughts together... your tool is all around the shared conversations that people have.' Organizational and collaborative, not personal knowledge management." ;
      narr:theme "aswritten enables anti-Conway multidimensional organizations by surfacing duplication of work across teams — organizational and collaborative, not personal knowledge management" .

    narr:Narrative_GeneralVsSellableTension

      dct:source narr:Sample_DiscoveryConsultant_20260630 ;
      skos:broader narr:StrategyOverview ;
      skos:prefLabel "General vs. Sellable: The Tricky Rope to Walk" ;
      skos:note "a consultant who ran enterprise discovery engagements for fifteen years: 'what you do is so general, it's hard for me to wrap my head around it... you've got to package it in different wrapping paper for different industries.' And: 'as an engineer you always want to... not restrict your product too early. You don't want to clip the wings of the raven — it won't fly if you do that.' Scarlet: 'it's really hard to sell if you don't have a specific focus.' Both agreed it's 'a tricky rope to walk, and not many do.' This is the same abstract-vs-focus knot the perspective already carries — the discovery-tool wedge is attractive precisely because it offers a focus without amputating the general capability." ;
      narr:theme "The general capability is the moat; the sellable focus is the wedge — the discovery-tool framing offers focus without clipping the wings of the raven" ;
      narr:supports narr:Narrative_EnterpriseShapePrimaryFocus .

    narr:Claim_DiscoveryToolBatteringRam
      a narr:Claim ;
      dct:source narr:Sample_DiscoveryConsultant_20260630 ;
      skos:note "a consultant who ran enterprise discovery engagements for fifteen years's intel on discovery economics: a discovery is a 'battering ram' — a loss-leader, [amount]-20K, whose real value is getting the consultancy in the door, after which 'you become a super valuable consultant because you know all the problems.' This is the economic model that makes the discovery-tool wedge attractive: the discovery pays for itself in relationship value, not in direct revenue." ;
      narr:aboutNode narr:Narrative_DiscoveryToolGTMWedge ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_SalesAsDelivery .

    narr:Claim_ThirdBridgeMarketSegment
      a narr:Claim ;
      dct:source narr:Sample_DiscoveryConsultant_20260630 ;
      skos:note "a consultant who ran enterprise discovery engagements for fifteen years's brother uses Third Bridge-style reports for equity research. a consultant who ran enterprise discovery engagements for fifteen years's framing: 'you become one of these companies, or you sell into one.' Third Bridge and similar firms hold millions of transcripts and sell subscription access at ~[amount]/year revenue scale. This is a candidate market for aswritten — either as a product sold to these firms or as a competitor in the same space." ;
      narr:aboutNode narr:Narrative_ExpertNetworkTranscriptMarket ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Narrative_ExpertNetworkTranscriptMarket .

    narr:Claim_DiscoveryConsultantClipWingsRaven
      a narr:Claim ;
      dct:source narr:Sample_DiscoveryConsultant_20260630 ;
      skos:note "a consultant who ran enterprise discovery engagements for fifteen years's articulation of the general-vs-sellable tension: 'as an engineer you always want to... not restrict your product too early. You don't want to clip the wings of the raven — it won't fly if you do that.' This is the strongest articulation of the risk of over-focusing that the perspective has received from an external peer. The discovery-tool wedge is the proposed resolution: focus without restriction." ;
      narr:aboutNode narr:Narrative_GeneralVsSellableTension ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_GeneralVsSellableTension .

    narr:Claim_DiscoveryConsultantHATEOASParallel
      a narr:Claim ;
      dct:source narr:Sample_DiscoveryConsultant_20260630 ;
      skos:note "a consultant who ran enterprise discovery engagements for fifteen years independently arrived at the same navigation-over-query instinct as aswritten, framed through link relations / HATEOAS / RFC 8288: 'the primary way of navigating any information base... is through discovery and navigation, going link by link... It's like surfing the web in the 90s. I'm going to find something out, I click on a blue link, it turns purple... traversing a graph rather than asking big SPARQL queries of it.' He noted the layer difference: 'every traversal in your world is a very small operation; in my world it's actually a network call' — but with HEAD requests returning link relations, 'with 50 network calls you're going to get quite a lot.' Same instinct — traverse, don't big-query — at two layers." ;
      narr:aboutNode narr:Narrative_NavigationReplacesEmbeddedSnapshot ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_NavigationReplacesEmbeddedSnapshot .

    narr:Claim_NarrativeStrategyReportDeliverable
      a narr:Claim ;
      dct:source narr:Sample_DiscoveryConsultant_20260630 ;
      skos:note "The narrative-strategy report is the most concrete initial-services offering Scarlet has articulated: a 2-4 week, NDA'd, fixed-deliverable engagement that rides alongside a pilot. It directly answers 'what do I hand them in two-to-four weeks.' The deliverable shows how ideas have changed over time, how they're shared across teams, where dissenting opinion lives, and where convergence is needed. This is Scarlet's pre-aswritten consulting practice (business + narrative strategy) productized through aswritten." ;
      narr:aboutNode narr:Narrative_NarrativeStrategyReport ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_ConsultingIsMeUsingProduct .

