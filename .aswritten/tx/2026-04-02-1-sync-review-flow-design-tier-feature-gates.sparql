# ── NEW ENTITIES ─────────────────────────────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20250714T160000Z {

    # ── Narrative: Warm-Start vs Cold-Start Review ──────────────────────────
    narr:Narrative_WarmStartVsColdStart a narr:Narrative ;
      dct:source narr:Sample_DesignSession_20260331 ;
      skos:broader narr:QualityReviewGates ;
      skos:prefLabel "Warm-Start vs Cold-Start Review: Two Entry Points into Shared Core" ;
      skos:note "The current monolithic review prompt splits into a shared core and two entry points. Shared core (both paths): (1) test document selection, (2) baseline comparison (before vs after) — 'super important' per Scarlet, (3) shifts (2-4 pairs, improvement/counter), (4) fact review (conviction levels, relationships), (5) wrap-up (corrections → another remember; done → offer merge if applicable). Warm-start entry (from remember's return, same session): skips intro, skips TX summary (already shown), skips zone identification as separate step (already shown), agent suggests test document from session context rather than asking open-ended, goes directly into shared core. Cold-start entry (from review tool, PR-based, different session/person): full intro, TX summary (reviewer hasn't seen it), zone identification (reviewer picks focus areas), test document full negotiation, then into shared core." ;
      narr:theme "Review splits into warm-start (same session, skips intro/summary) and cold-start (different session, full intro) entry points feeding a shared core protocol" .

    # ── Narrative: Prompting in Return Values as Product-Wide Shift ─────────
    narr:Narrative_ReviewReturnValuePattern a narr:Narrative ;
      dct:source narr:Sample_DesignSession_20260331 ;
      skos:broader narr:ProcessPolicyUpdates ;
      skos:prefLabel "Prompting in Return Values: Product-Wide Shift in Agent Communication" ;
      skos:note "The review_instructions field in remember's return is the first implementation of a product-wide pattern: reinforce agent behavior at the point of tool return, not just in upfront tool descriptions and server instructions. The pattern will be adopted incrementally across tools. It is not a blocking initiative. The instructions tell the agent: present the shift summary, offer review, and if accepted, run the warm-start protocol. They should explicitly not block future work if the user declines review." ;
      narr:theme "Tool return values become a third reinforcement point for agent behavior, complementing tool descriptions and server instructions" .

    # ── Narrative: Two-Axis Tier Model ──────────────────────────────────────
    narr:Narrative_TierAxisGitHubTeamSize a narr:Narrative ;
      dct:source narr:Sample_DesignSession_20260331 ;
      skos:broader narr:PackagingEntitlement ;
      skos:prefLabel "Tier Feature Architecture: GitHub Connection × Team Size as the Real Axes" ;
      skos:note "Tiers don't directly determine flow. Two independent axes determine capability: (1) GitHub connected or not; (2) Single user or team. These axes drive branch policy, review flow, and PR aggregation. No GitHub + single user = main only, sync self-review. No GitHub + team = shared provisioned perspective on main, each user reviews own memories. GitHub + single user = main default, branches available. GitHub + team = topic branch default, PRs aggregate memories, cold-start review for teammates. Feature gates: Free→Expert = save and curate own perspective, sync review after every save. Expert→Team = multiple people contributing to same worldview. +GitHub (any paid tier) = branches, PRs, structured cross-user review, formal consensus flow, multi-repo for Expert." ;
      narr:theme "GitHub connectivity and team size are the two real axes determining flow — tiers are a packaging layer on top of these capability dimensions" .

    # ── Narrative: Review Is Just Another Remember ───────────────────────────
    narr:Narrative_ReviewLoopIsRemember a narr:Narrative ;
      dct:source narr:Sample_DesignSession_20260331 ;
      skos:broader narr:CoreWorkflows ;
      skos:prefLabel "Review Is Just Another Remember: The Natural Loop" ;
      skos:note "Review corrections produce a new memory, which triggers extraction, which produces new transactions. The loop is natural: remember → extraction → review → corrections? → remember (review memory) → extraction → review → ... → done. Scarlet: 'Any review does is produce another memory, right? It's not a special type of memory; it may have a specific type of content in it because it's a review, but it's just another memory.' Each remember in the chain commits to the same location. In Team + GitHub, the PR accumulates all rounds. Merge is offered at the end but never automatic. Authority to merge is a GitHub concern, not an aswritten concern. No automated consensus — humans decide when they're done." ;
      narr:theme "Review corrections are just another remember — the review loop is the same pipeline recursively applied, not a special flow" .

    # ── Claims: Warm-Start / Cold-Start ─────────────────────────────────────
    narr:Claim_WarmStartSkipsIntro a narr:Claim ;
      dct:source narr:Sample_DesignSession_20260331 ;
      skos:note "Warm-start entry (from remember's return, same session) skips: intro (just explained in the offer), TX summary (already shown in shift summary), zone identification as separate step (already shown). Test document: agent suggests from session context rather than asking open-ended — the agent was in the session when the memory was written and knows what content was being worked on. Goes directly into shared core." ;
      narr:aboutNode narr:Narrative_WarmStartVsColdStart ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_SynchronousReviewIntegration .

    narr:Claim_ColdStartFullIntro a narr:Claim ;
      dct:source narr:Sample_DesignSession_20260331 ;
      skos:note "Cold-start entry (from review tool, PR-based, different session/person) includes: full intro ('How this review works'), TX summary (reviewer hasn't seen it), zone identification (reviewer picks focus areas), test document full negotiation (registered docs, draft from perspective, or bring your own), then into shared core. This is the path for teammates reviewing a PR they were not present for." ;
      narr:aboutNode narr:Narrative_WarmStartVsColdStart ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_WarmStartVsColdStart .

    # ── Claims: Tier Definitions ─────────────────────────────────────────────
    narr:Claim_FreeTierReadOnly_DesignSession a narr:Claim ;
      dct:source narr:Sample_DesignSession_20260331 ;
      skos:note "Free tier: read-only. Can load and use perspectives. Cannot save memories. Cannot review. This is the capability gate that drives the Free→Expert upgrade." ;
      narr:aboutNode narr:PackagingEntitlement ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_TierAxisGitHubTeamSize .

    narr:Claim_ExpertTierSyncReview a narr:Claim ;
      dct:source narr:Sample_DesignSession_20260331 ;
      skos:note "Expert tier default: provisioned repo under aswritten org. Commits to main. No branches, no PRs. Sync self-review after every save. With GitHub connected (power user opt-in): multi-repo. Default still main. Branches available but not the default flow. Scarlet on Expert + GitHub: 'In the Expert case, it actually makes most sense to always commit to main. In the single-user case, it usually makes sense to commit to main by default and to have synchronous review.'" ;
      narr:aboutNode narr:PackagingEntitlement ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_TierAxisGitHubTeamSize .

    narr:Claim_TeamTierGitHubBranch a narr:Claim ;
      dct:source narr:Sample_DesignSession_20260331 ;
      skos:note "Team tier without GitHub: multiple authenticated users push to the same provisioned perspective on main. Each user reviews their own memories. No structured cross-user review. Scarlet: 'In Team without GitHub, a user reviews their own memories, and we're just working against the same thing. That is decidedly not as clean as with GitHub, but that's the whole point.' Team tier with GitHub: default to topic branch. PRs aggregate memories. Author gets sync review. Teammates get notified (transaction side effect, already implemented). Teammates do cold-start review off the PR. Back and forth until human consensus. Merge offered but never automatic." ;
      narr:aboutNode narr:PackagingEntitlement ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_TierAxisGitHubTeamSize .

    # ── Claims: Remember Return Fields ──────────────────────────────────────
    narr:Claim_RememberReturnThreeFields a narr:Claim ;
      dct:source narr:Sample_DesignSession_20260331 ;
      skos:note "Three new fields in remember's return value: (1) tx_summary — plain-language summary of what shifted in the worldview; (2) zones — domains/areas affected by the extraction; (3) review_instructions — prompt fragment telling the agent the warm-start review protocol. These fields enable the agent to immediately offer review in the same session without a separate async operation." ;
      narr:aboutNode narr:Narrative_SynchronousReviewIntegration ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_ReviewReturnValuePattern .

    narr:Claim_TxSummaryNoLatency a narr:Claim ;
      dct:source narr:Sample_DesignSession_20260331 ;
      skos:note "The tx_summary is generated during extraction so it adds no latency to remember. It is not a post-processing step — it is produced as part of the extraction pipeline run." ;
      narr:aboutNode narr:Narrative_SynchronousReviewIntegration ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Claim_RememberReturnThreeFields .

    narr:Claim_ReviewInstructionsNotBlocking a narr:Claim ;
      dct:source narr:Sample_DesignSession_20260331 ;
      skos:note "The review_instructions in remember's return should explicitly not block future work if the user declines review. Scarlet: 'We don't want to bombard the user with a giant block of text at the back end. We want a clear summary of the shift and a clear presentation of do you want to review this? with a quick statement of what that means. You can say yes, but you can also just keep working.' Review is strongly offered, not mandatory." ;
      narr:aboutNode narr:Process ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Claim_RememberReturnThreeFields .

    # ── Claims: Notification and Terminology ────────────────────────────────
    narr:Claim_NotificationTransactionSideEffect a narr:Claim ;
      dct:source narr:Sample_DesignSession_20260331 ;
      skos:note "Notification fires when transactions land, triggered by tx/post-commit. It is not part of the review flow. It already works. Not being redesigned. Teammates get notified when new knowledge is extracted regardless of whether the author has reviewed it. Notification is a transaction side effect, not a review mechanism." ;
      narr:aboutNode narr:Process ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_ReviewLoopIsRemember .

    narr:Claim_ShiftsTerminology a narr:Claim ;
      dct:source narr:Sample_DesignSession_20260331 ;
      skos:note "'Shifts' is the user-facing term (not 'lenses'). 'Optometrist model' is an internal abstraction for the test-through-reaction review approach. These should remain distinct in documentation — shifts is what users see; optometrist model is how the system is designed internally." ;
      narr:aboutNode narr:TerminologyControl ;
      narr:hasConvictionLevel narr:Conviction_Foundation .

    # ── Observations ────────────────────────────────────────────────────────
    narr:Obs_ScarletReviewKickoffQuote a narr:Observation ;
      dct:source narr:Sample_DesignSession_20260331 ;
      skos:broader narr:QualityReviewGates ;
      skos:note "Scarlet's verbatim articulation of the desired review kickoff behavior after remember returns." ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_DesignSession_20260331 ;
        oa:hasSelector [
