          oa:exact "If I save a memory after remember returns, I want to have a review immediately started, or it offered to immediately start review." ;
          oa:prefix "let's do the immediate kickoff of review after remember returns. " ;
          oa:suffix " I want to be forced into that."
        ]
      ] .

    narr:Obs_ScarletReturnValueShiftQuote a narr:Observation ;
