# Extracted entities (named graph)
INSERT DATA {
  GRAPH narr:Tx_20260408T143000Z {
    narr:Sample_DesignSession_20260408 a narr:Sample ;
      dct:title "The trigger, the mechanism, the archetypes, and the warm cold start" ;
      narr:inputLength 6450 .

    narr:Narrative_ExhaustedExpertTrigger a narr:Narrative ;
      dct:source narr:Sample_DesignSession_20260408 ;
      narr:theme "The Exhausted-Expert Purchase Trigger" ;
      skos:broader narr:PositioningThesis ;
      skos:note "A third purchase trigger based on social-cost pain (exhaustion from repeating oneself) rather than work-productivity pain." .

    narr:Claim_Trigger3ExhaustedExpert a narr:Claim ;
      narr:aboutNode narr:Narrative_ExhaustedExpertTrigger ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:PositioningThesis ;
      dct:source narr:Sample_DesignSession_20260408 ;
      skos:note "Trigger 3: 'I don't want to be their only option for this anymore.' Closes the activation gap by addressing social pain." .

    narr:Claim_BidirectionalCostMechanism a narr:Claim ;
      narr:aboutNode narr:ValueExchange ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      dct:source narr:Sample_DesignSession_20260408 ;
      skos:note "The trigger fires when bidirectional cost (social currency for asker, attention for expert) blocks interaction entirely." .

    narr:Actor_Scarlet_AW a narr:Actor ;
      skos:prefLabel "Scarlet" ;
      skos:note "Designer and 'first exhausted expert' for aswritten." .

    narr:Observation_BreadBakingGifter a narr:Observation ;
      skos:broader narr:ExampleStoryboard ;
      dct:source narr:Sample_DesignSession_20260408 ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 1010 ;
        oa:end 1220
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "my friend just asked me about bread baking, call me and we'll talk it through and then text them and now they have my perspective" ;
        oa:prefix "something like " ;
        oa:suffix "\""
      ] .

    narr:StyleObservation_CasualArchetypeVoice a narr:StyleObservation ;
      skos:broader narr:ToneDirectPersonal ;
      dct:source narr:Sample_DesignSession_20260408 ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_DesignSession_20260408 ;
        oa:hasSelector [ a oa:TextPositionSelector ; oa:start 1225 ; oa:end 1350 ] ;
        oa:hasSelector [ a oa:TextQuoteSelector ; oa:exact "The bread baking example is the foundational illustration of the gifter archetype and should be preserved in its exact casual phrasing" ]
      ] .

    narr:StyleObservation_OneLinerRhetoric a narr:StyleObservation ;
      skos:broader narr:ShortPunchyCadence ;
      dct:source narr:Sample_DesignSession_20260408 ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_DesignSession_20260408 ;
        oa:hasSelector [ a oa:TextPositionSelector ; oa:start 3050 ; oa:end 3150 ] ;
        oa:hasSelector [ a oa:TextQuoteSelector ; oa:exact "I don't want to be their only option for this anymore, and I don't want them to have to wait until I'm free." ]
      ] .

    narr:StyleObservation_StructuralAnalogy a narr:StyleObservation ;
      skos:broader narr:Analogy ;
      dct:source narr:Sample_DesignSession_20260408 ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_DesignSession_20260408 ;
        oa:hasSelector [ a oa:TextPositionSelector ; oa:start 5200 ; oa:end 5350 ] ;
        oa:hasSelector [ a oa:TextQuoteSelector ; oa:exact "Scarlet is the most exhausted version of the exhausted-expert archetype for aswritten itself." ]
      ] .

    narr:StyleMetrics_DesignSession_20260408 a narr:StyleMetrics ;
