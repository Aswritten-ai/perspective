          oa:prefix "On what matters: \"" ;
          oa:suffix "\""
        ]
      ] .

    # ── STYLE METRICS ────────────────────────────────────────────
    narr:Metrics_SessionReflection_20260416 a narr:StyleMetrics ;
      dct:source narr:Sample_SessionReflection_20260416 ;
      skos:broader narr:StyleMetrics ;
      skos:note "Retrospective reflection format. Mixed register: structured markdown with H2/H3 section headers (analytical memo genre) and embedded verbatim Scarlet quotes in first person (personal voice). Antithesis-heavy structure (product-out vs. installable expertise, smaller vs. enormous, private vs. public). Short punchy declaratives at emotional peaks; longer analytical sentences in trajectory sections. Active voice dominant. Jargon density low — product terms (transactions, E2E tests, perspectives) used without definition, implying internal audience. The four closing quotes function as conviction anchors, each under 25 words." ;
      narr:AverageSentenceLength "17"^^xsd:integer ;
      narr:ActiveVoiceRatio "0.85"^^xsd:decimal ;
      narr:JargonDensity "0.07"^^xsd:decimal .

