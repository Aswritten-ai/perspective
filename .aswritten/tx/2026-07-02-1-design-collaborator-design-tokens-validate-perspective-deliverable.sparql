INSERT DATA {
  GRAPH narr:Tx_20260702T023756Z {

    # ── Sample ──────────────────────────────────────────────────────────────
    narr:Sample_DesignCollaboratorTokens_20260629 a narr:Sample ;
      dct:title "a design collaborator's Design-Token Practice Independently Validates Perspective-as-Deliverable and Brand-as-AI-Identity" ;
      dct:created "2026-06-29"^^xsd:date ;
      narr:inputLength 4898 ;
      dct:description "Second documented session with a design collaborator (first: 2026-03-23). a design collaborator describes his extraction→tokens→AI-applied surfaces process; Scarlet recognises it as the Vouch text-process precursor; both converge on the lens as the irreducible part and on brand-as-AI-identity as the endpoint." .

    # ── Narrative: Design-Token ↔ Perspective Parallel ──────────────────────
    narr:Narrative_DesignTokenPerspectiveParallel a narr:Narrative ;
      dct:source narr:Sample_DesignCollaboratorTokens_20260629 ;
      narr:theme "Design-token extraction process is structurally identical to perspective extraction: both tokenise a lens, apply it through AI to surfaces, and break without the lens" ;
      skos:broader narr:Differentiators ;
      skos:note "a design collaborator independently arrived at the same architecture as aswritten: extract a design language, tokenise it, apply tokens via AI to surfaces. The parallel was explicitly missing from the graph before this call. The irreducible part in both cases is the lens — without it the output collapses to generic AI." .

    # ── Narrative: Brand-as-AI-Identity ─────────────────────────────────────
    narr:Narrative_BrandAsAIIdentity a narr:Narrative ;
      dct:source narr:Sample_DesignCollaboratorTokens_20260629 ;
      narr:theme "AI identities have the opportunity to be the brand's identity — an AI shaped to think, design, and talk like the brand, deployable across the org" ;
      skos:broader narr:PositioningThesis ;
      skos:note "Scarlet's endpoint for the design-token parallel: instead of a brand style guide, deliver an AI that IS the brand identity. Anyone in the org can use it; it designs and talks like the brand. Contrasted with the current default of one-shotting a generic Claude website. The Coca-Cola example is the target state." .

    # ── Claim: The lens is the irreducible part ──────────────────────────────
    narr:Claim_LensIsIrreduciblePart a narr:Claim ;
      narr:aboutNode narr:Narrative_DesignTokenPerspectiveParallel ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_PerspectiveVsInformation ;
      dct:source narr:Sample_DesignCollaboratorTokens_20260629 ;
      skos:note "a design collaborator: 'without my input through my own lens, it breaks, it falls down. So that shows that the actual unique part is by [my] lens — is applying the lens, which I suppose is effectively what you've built there... it is the lens that controls all of that.' Independent practitioner validation that the lens/perspective is the non-commodifiable core — the AI output is generic without it." .

    # ── Claim: Design-token parallel validates perspective-as-deliverable ────
    narr:Claim_DesignTokenParallelValidation a narr:Claim ;
      narr:aboutNode narr:Narrative_DesignTokenPerspectiveParallel ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_PerspectiveVsInformation ;
      dct:source narr:Sample_DesignCollaboratorTokens_20260629 ;
      skos:note "a design collaborator's extraction→tokens→AI-applied surfaces process is structurally identical to aswritten's extraction→perspective→AI-applied outputs. He arrived at it independently through his own design practice. This is convergent validation from outside aswritten of the core architecture." .

    # ── Claim: Vouch text process is the product precursor ───────────────────
    narr:Claim_VouchTextProcessPrecursor a narr:Claim ;
      narr:aboutNode narr:Narrative_DesignTokenPerspectiveParallel ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      dct:source narr:Sample_DesignCollaboratorTokens_20260629 ;
      skos:note "Scarlet recognised a design collaborator's process as the same thing she built at Vouch with text: a bunch of files representing how the team was thinking — the equivalent of design tokens for product language — put at the top of the chat to generate new work. This is the first explicit identification of the Vouch text process as the product's precursor." .

    # ── Claim: Perspective-as-deck-alternative is unexecuted ────────────────
    narr:Claim_PerspectiveDeckAlternativeUnexecuted a narr:Claim ;
      narr:aboutNode narr:Narrative_ConsultingIsMeUsingProduct ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      dct:source narr:Sample_DesignCollaboratorTokens_20260629 ;
      skos:note "Status note from Scarlet (June 29, 2026): 'I haven't delivered an AI perspective as an alternative to a deck to a consulting client yet.' The thesis is settled (boulder-level since March 19) but the use case has not been executed in practice. This is an open product move." .

    # ── Claim: Static asset dependency model is what clients pay for today ───
    narr:Claim_StaticAssetDependencyModel a narr:Claim ;
      narr:aboutNode narr:Narrative_ConsultingIsMeUsingProduct ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:challenges narr:Narrative_ConsultingIsMeUsingProduct ;
      dct:source narr:Sample_DesignCollaboratorTokens_20260629 ;
      skos:note "What consulting clients pay for today: a static asset that makes them dependent on the consultant to execute, or requires an expensive in-house person to do a lossy interpretation and continue forward. This is the status quo the perspective-as-deliverable model replaces." .

    # ── Claim: Brand AI identity deployable org-wide ─────────────────────────
    narr:Claim_BrandAIIdentityOrgWide a narr:Claim ;
      narr:aboutNode narr:Narrative_BrandAsAIIdentity ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Narrative_HowManyVoicesInSuperintelligence ;
      dct:source narr:Sample_DesignCollaboratorTokens_20260629 ;
      skos:note "Scarlet's endpoint: shape an AI that thinks like the brand, then let anyone use it across the org — it designs like the brand, talks like the brand, has the brand's narratives and understandings. The Coca-Cola example: ask it to one-shot a website and it looks like Coca-Cola, not like Claude." .

    # ── Observations (verbatim grounding) ────────────────────────────────────

    narr:Obs_DesignCollaboratorTokenProcessQuote a narr:Observation ;
