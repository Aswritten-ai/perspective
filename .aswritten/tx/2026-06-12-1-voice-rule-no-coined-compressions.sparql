    # ── Sample ──────────────────────────────────────────────────────────────
    narr:Sample_ScarletVoiceRule_20260612
      a narr:Sample ;
      dct:title "Voice rule: keep Scarlet's conversational phrasing, not coined compressions" ;
      dct:created "2026-06-12"^^xsd:date ;
      narr:inputLength 762 ;
      skos:note "Working session between Scarlet Dame and Claude on June 12, 2026. Establishes a durable voice rule: offering language, deck copy, and published material must keep Scarlet's conversational phrasing verbatim. Compressions that sound like slogans read as AI-generated and fail her outreach test." .

    # ── Narrative ───────────────────────────────────────────────────────────
    narr:Narrative_ConversationalPhrasingRule

      dct:source narr:Sample_ScarletVoiceRule_20260612 ;
      skos:broader narr:SpeakerIdiolects ;
      skos:prefLabel "Keep Scarlet's Conversational Phrasing Verbatim — No Coined Compressions" ;
      skos:note "Offering language, deck copy, and published material must preserve Scarlet's own conversational phrasing. Tighten grammar, not diction. Compressions that sound like slogans read as AI-generated and fail the test she applies to all outreach language: whether she can say it out loud on a call comfortably. Coined compressions — even accurate ones — are rejected if they sound like AI." ;
      narr:theme "Scarlet's voice rule: conversational phrasing is preserved verbatim in all outreach material; coined compressions that sound like slogans are rejected as AI-generated" .

    # ── Claim ───────────────────────────────────────────────────────────────
    narr:Claim_NoCompressionToSlogan
      a narr:Claim ;
      dct:source narr:Sample_ScarletVoiceRule_20260612 ;
      skos:note "Compressions of Scarlet's conversational descriptions into coined phrases or slogans are explicitly rejected. The specific example: her phrase 'it speaks to, references, and works from what was already said' was compressed to 'It speaks from the record.' Scarlet rejected the compression because it 'just sounds like AI.' The rule applies to offering language, deck copy, and published material. The test: can she say it out loud on a call comfortably?" ;
      narr:aboutNode narr:Narrative_ConversationalPhrasingRule ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:IdiolectPhrasing .

    # ── Observation (verbatim quote) ─────────────────────────────────────────
    narr:Obs_ScarletRejectsAIPhrasing
      a narr:Observation ;
      dct:source narr:Sample_ScarletVoiceRule_20260612 ;
      skos:broader narr:SpeakerIdiolects ;
      skos:note "Scarlet's verbatim rejection of the coined compression 'speaks from the record' — the founding evidence for the conversational phrasing rule." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 454 ;
        oa:end 620
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "I really don't like your term \"speaks from the record\" versus what I had. I had something much more conversational. \"Speaks from the record\" just sounds like AI." ;
        oa:prefix "> " ;
        oa:suffix "\n\nThe rule:"
      ] .

    # ── Style Observations ───────────────────────────────────────────────────

    narr:StyleObs_ConversationalVsCompressed
