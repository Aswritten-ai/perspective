# ── New Narrative: Founder as Authority Layer ────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260702T024632Z {
    narr:Narrative_FounderAsAuthorityLayer a narr:Narrative ;

      narr:theme "The founder's personal vision is a distinct authority layer that cyclically builds credibility for both the person and the business" ;
      skos:broader narr:NarrativeAnchor ;
      skos:note "a design collaborator's brand-strategy counsel from the June 29 2026 call: a business needs a human character at its center, and for aswritten that character is Scarlet herself. The vision/manifesto is not part of the product but a separate authoritative space that cyclically builds credibility for both the person and the business. The through-line — the durable asset across whatever Scarlet builds next — is Scarlet, not any one product. Prescription: a Scarlet Vision manifesto linked to the website, decks, and brochures, reinforced cyclically. Rooted in 'branding 101': give the business an image of a person that people can connect to (Mailchimp chimp, Tony as face of Vouch)." .
  }
} ;

# ── New Claims ───────────────────────────────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260702T024632Z {

    narr:Claim_B2BDefaultCareerArtifact a narr:Claim ;
      narr:aboutNode narr:Narrative_FounderFitB2CTurn ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_B2CPivot ;

      skos:note "Scarlet's self-diagnosis from the June 29 2026 call: her B2B default is an artifact of her career history — she worked for so many B2B companies that she adopted a default stance toward B2B without it being a considered fit. Her actual selling style (narrative-driven, vision-led) is native to B2C. This is the causal explanation for the B2C pivot, adding to the existing 'founder-fit' framing." .

    narr:Claim_FounderIsConsistentThroughLine a narr:Claim ;
      narr:aboutNode narr:Narrative_FounderAsAuthorityLayer ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_FounderAsAuthorityLayer ;

      skos:note "a design collaborator's counsel: the durable asset across whatever Scarlet builds next is Scarlet herself, not any one product. She can talk about a moonshot all day because she has been ahead of the AI game. The thing that stays consistent is her. This frames the personal vision/manifesto as the through-line that survives product pivots." .
  }
} ;

