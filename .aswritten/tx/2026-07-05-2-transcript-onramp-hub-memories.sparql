      narr:hasConvictionLevel narr:Conviction_Boulder ;
      skos:note "The live interview is now the no-transcripts alternative, not the primary onramp. Docs home page, Quick Start, and ASWRITTEN.md all lead with transcripts. The interview is offered only when the user has no transcripts to provide. Implemented July 5, 2026 (PRs #405, #406)." ;
      .
  }
} ;

