# ── NEW: Narrative_DemoVsProductOnramp ──────────────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260705T152327Z {
    narr:Narrative_DemoVsProductOnramp a narr:Narrative ;
      skos:prefLabel "Demo vs. Product: The Share Demo Is a Demo; the Product Is Your Own Perspective" ;
      narr:theme "The perspective share demo shows aswritten reading aswritten's mind; the product is your AI reading yours" ;
      skos:broader narr:NarrativeAnchor ;
      skos:note "The docs home page leads with a try-it-now callout: load aswritten's own public perspective and ask it questions. This is a demo — your AI reading aswritten's mind. The product is your AI reading yours. The raw material is not writing — it is conversations the user is already having: call transcripts (Fireflies, Zoom, Meet, Gemini) and AI working-session history (coding sessions, planning chats). The demo moment and the product moment are categorically different and must be framed as such in onboarding." ;
      .
  }
} ;

# ── NEW: Narrative_HubCollectionMethodAtVolume ───────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260705T152327Z {
    narr:Narrative_HubCollectionMethodAtVolume a narr:Narrative ;
      skos:prefLabel "Hub-Collection Method at Volume: One Memory Per Hub, Not Per Transcript" ;
      narr:theme "At volume, analyze the whole set first and draft one hub memory per recurring topic cluster — not one review per transcript" ;
      skos:broader narr:SolutionArchetypes ;
      skos:note "With months of recordings, per-transcript review is the wrong unit of work. The method: analyze the whole set first — surface recurring topics, open questions, pivotal moments — then draft a small collection of memories, one per hub in the collection, each summarizing that theme with key quotes pulled from across the set. The user reviews the collection once, not every transcript. This is the self-serve, operator-driven form of the topic-analysis step from the three-part seeding methodology (May 1, the enterprise customer onboarding). Operates within the May 21 correction: bulk ingestion via AI summarization is valid; the trap is unreviewed raw ingestion, not bulk per se. Now written into the Onboarding Mode prompt for any user's agent to run." ;
      narr:supports narr:Narrative_BulkIngestionValidMethod ;
      .
  }
} ;

# ── NEW: Narrative_HubMemoryProvenanceNonNegotiable ─────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20260705T152327Z {
    narr:Narrative_HubMemoryProvenanceNonNegotiable a narr:Narrative ;
      skos:prefLabel "Provenance Survives Summarization: Hub Memories Must Contain Primary Source Material" ;
      narr:theme "A hub memory is still primary source material — verbatim excerpts attributed to speaker and date, referencing the original transcript file" ;
      skos:broader narr:GovernanceSafetyTrust ;
      skos:note "The risk in hub summarization is losing the chain back to the source. A hub memory is not an abstract: it must contain extended verbatim excerpts from the pivotal moments, each attributed to speaker and date, referencing the original transcript file it came from. Every claim extracted from a hub memory keeps full provenance back to the source recording, even though the memory summarizes across many files. Summarization compresses the reading; it must never compress the receipts. This is a non-negotiable constraint, stated explicitly by Scarlet and now carried in the Onboarding Mode prompt." ;
      narr:supports narr:Narrative_ProvenanceCitationMoment ;
      .
  }
} ;

