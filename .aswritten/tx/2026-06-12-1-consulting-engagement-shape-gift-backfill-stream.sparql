# Update narr:Narrative_ConsultingIsMeUsingProduct to add engagement arc detail
DELETE {
  GRAPH ?g {
    narr:Narrative_ConsultingIsMeUsingProduct skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20250715T200000Z {
    narr:Narrative_ConsultingIsMeUsingProduct skos:note "Resolves the personal-services vs. product-engagement vs. hybrid tension from the June 10 handoff. The client never learns a tool, changes behavior, or believes in software. The product is Scarlet's infrastructure, visible only as the continuity and quality of what she delivers. This removes the adoption burden entirely and reframes consulting as a product-powered service delivery model. The engagement arc has three phases: (1) 48-hour gift (free, built only from calls Scarlet participated in); (2) backfill diagnostic (client's recorded history, processed, bounded, priced, with a finish line); (3) ongoing stream (webhook left on). Two earlier candidate containers — bounded report engagement and advisory retainer — collapsed into phases of one thing." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_ConsultingIsMeUsingProduct skos:note ?oldNote .
  }
} 