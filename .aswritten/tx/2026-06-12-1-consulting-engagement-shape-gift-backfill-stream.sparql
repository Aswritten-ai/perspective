# New Narratives
INSERT DATA {
  GRAPH narr:Tx_20250715T200000Z {

    narr:Narrative_EngagementArcThreePhase a narr:Narrative ;
      dct:source narr:Sample_EngagementShape_20260610 ;
      skos:broader narr:SolutionArchetypes ;
      skos:prefLabel "Three-Phase Consulting Engagement Arc: Gift → Backfill Diagnostic → Ongoing Stream" ;
      skos:note "The consulting engagement arc collapses two earlier candidate containers (bounded report engagement and advisory retainer) into phases of one thing: (1) 48-hour gift — free, built only from calls Scarlet participated in; (2) backfill diagnostic — the client's recorded history, processed, bounded, priced, with a finish line; (3) ongoing stream — the webhook left on. Each phase is distinct in scope, pricing logic, and deliverable." ;
      narr:theme "A consulting engagement is three sequential phases — gift, bounded diagnostic, and ongoing stream — not a single undifferentiated service" .

    narr:Narrative_CalibrationAsStaffWork a narr:Narrative ;
      dct:source narr:Sample_EngagementShape_20260610 ;
      skos:broader narr:OperatingModelShifts ;
      skos:prefLabel "Calibration Calls Are Staff-Work, Not Friendship" ;
      skos:note "Required bi-weekly calls were dropped on June 10 because many executives expect ongoing conversations for free. They were restored as calibration: supervision of a now-central system plus reading the metrics together. Calibration is staff-work, not friendship; the call is the management meeting for the AI layer. This reframe resolves the free-conversation problem by repositioning the cadence as operational management rather than relationship maintenance." ;
      narr:theme "Bi-weekly calibration calls are the management meeting for the AI layer — staff-work, not friendship, and therefore billable" .

    narr:Narrative_PriceTheAccumulation a narr:Narrative ;
      dct:source narr:Sample_EngagementShape_20260610 ;
      skos:broader narr:PackagingPricing ;
      skos:prefLabel "Price the Accumulation, Not the Conversation" ;
      skos:note "The pricing answer to the free-conversation problem: price the accumulation, not the conversation. Executives are accustomed to ongoing conversations for free. The value is in the accumulated perspective graph, not in any individual call. This principle resolves the cadence pricing tension and aligns with the three-phase arc where the gift is free but the backfill diagnostic and ongoing stream are priced." ;
      narr:theme "The billable unit is the accumulated perspective graph, not the individual conversation — price the accumulation" .

  }
} ;

# New Claims
INSERT DATA {
  GRAPH narr:Tx_20250715T200000Z {

    narr:Claim_RepoPerClient a narr:Claim ;
      dct:source narr:Sample_EngagementShape_20260610 ;
      skos:note "Repo per client. The consulting version of the participant loop is 'actually just me' — the salon-model idea with the participant loop deferred. Each client gets their own repo, isolating their perspective graph from other clients and from Scarlet's own repo." ;
      narr:aboutNode narr:ArchitectureOverview ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_OwnFromDayOne .

    narr:Claim_SourceSideScopeGate a narr:Claim ;
      dct:source narr:Sample_EngagementShape_20260610 ;
      skos:note "A source-side scope gate (internal calls only, exclusion rules) is what makes 'send me your transcripts' sayable to a client, given that client calls include their own customers, NDAs, and employees. Without the scope gate, the ask is ethically and legally untenable. The scope gate is a prerequisite for the backfill diagnostic phase." ;
      narr:aboutNode narr:GovernanceSafetyTrust ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_EngagementArcThreePhase .

    narr:Claim_48HourGiftConstraint a narr:Claim ;
      dct:source narr:Sample_EngagementShape_20260610 ;
      skos:note "The gift is built only from calls Scarlet participated in. Client bulk transcripts flow only post-contract, into the client's own repo. This constraint is both ethical (consent) and practical (quality — Scarlet's framing judgment is required for the gift to be representative). It is a standing constraint, not a temporary limitation." ;
      narr:aboutNode narr:Narrative_GenerosityAsDemonstration ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_EngagementArcThreePhase .

  }
} ;

