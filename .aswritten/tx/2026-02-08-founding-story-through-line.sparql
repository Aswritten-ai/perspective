  narr:Narrative_GenerativeSystems a narr:Narrative ;
    dct:source narr:Sample_FoundingStory_2026_02_08 ;
    narr:theme "Generative systems as conceptual foundation" ;
    skos:broader narr:TechnologiesSocialSystems ;
    skos:note "Simulated flocking behavior (birds, fish) with simple local rules producing emergent complexity; primed understanding of physics, movement of companies in ecosystems, and movement of concepts within frameworks creating emergent steering patterns in organizations." ;
