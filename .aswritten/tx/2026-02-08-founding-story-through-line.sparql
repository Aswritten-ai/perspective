    prov:wasGeneratedBy narr:Tx_20260208T211414Z .

  narr:Narrative_NarrativeAsVector a narr:Narrative ;
    dct:source narr:Sample_FoundingStory_2026_02_08 ;
    narr:theme "Narrative as velocity/acceleration vector in embedding space" ;
    skos:broader narr:NarrativeAnchor ;
    skos:note "For any concept in embedding space, there is a strength or movement vector toward related concepts; those vectors produce emergent behavior that looks and feels like thought; narrative is the strong steering vector within that emergence; you can create a physics around that." ;
    skos:related narr:Narrative_LLMsContinuation ;
    prov:wasGeneratedBy narr:Tx_20260208T211414Z .

  narr:Narrative_Aspen a narr:Narrative ;
    dct:source narr:Sample_FoundingStory_2026_02_08 ;
    narr:theme "Language as code: a collaborator analytics platform" ;
    skos:broader narr:TechnologiesSocialSystems ;
    skos:note "Analytics platform for sentiment analysis of email data and social listening into U.S. congressional offices; tracked correlations between news events and sentiment spikes; analyzed what people wanted and whether official communications achieved intended effects; primed understanding of language as code—analyzable actors within a system." ;
    prov:wasGeneratedBy narr:Tx_20260208T211414Z .

  narr:Narrative_Populous a narr:Narrative ;
    dct:source narr:Sample_FoundingStory_2026_02_08 ;
    narr:theme "Populous: medium-agnostic communication system" ;
    skos:broader narr:Product ;
    skos:note "First startup, raised venture money through Human Ventures; started as communication across channels (text/email translation, scheduling, payment); later pivoted to platform for hourly workers and became Clark (acquired after Scarlet's departure); Scarlet left due to co-founder differences and personal life challenges (getting clean and sober)." ;

    prov:wasGeneratedBy narr:Tx_20260208T211414Z .

  narr:Narrative_ElephantCollective a narr:Narrative ;
    dct:source narr:Sample_FoundingStory_2026_02_08 ;
    narr:theme "Elephant Collective: narrative as founder's weapon" ;
    skos:broader narr:NarrativeAnchor ;
    skos:note "Bootstrapped in-person events venue in New Orleans; scaled from zero to [amount]per event within six months; recruited ~20 full-time artists-in-residence with micro art grants; built 1,000-2,000 person events with 3-10 individual artists curating spaces; per-event volunteer crews of 100-200 people recruited via mass SMS; slogan: 'dream bigger'; closed due to insurmountable conflict with permitting; taught hard lessons about legal authority and doing things right the first time; critical lesson: power of narrative as a founder—sold a dream that we could build something bigger together than we could have separately." ;
    skos:related narr:Tagline ;
    prov:wasGeneratedBy narr:Tx_20260208T211414Z .

  narr:Narrative_LLMsContinuation a narr:Narrative ;
    dct:source narr:Sample_FoundingStory_2026_02_08 ;
    narr:theme "LLMs as continuation machines (2019 Clojure talk)" ;
    skos:broader narr:TechnologiesSocialSystems ;
    skos:note "Core claim: LLMs are not thinking machines—they're continuation machines; they continue what was given to them, picking up on word choice, ideas, and the fundamental unit of narrative; there is a resulting vector that LLMs follow, and that vector is best described as narrative; you don't just get continuation based on logic—you get continuation based on narrative; how you phrase something makes a massive difference in the outcome; sparked reciprocal collaboration with the planned engineering/architecture hire." ;
    skos:related narr:Narrative_NarrativeAsVector ;
    prov:wasGeneratedBy narr:Tx_20260208T211414Z .

  narr:Narrative_HarmonyLabs a narr:Narrative ;
    dct:source narr:Sample_FoundingStory_2026_02_08 ;
    narr:theme "Harmony Labs: narrative analysis at scale" ;
    skos:broader narr:TechnologiesSocialSystems ;
    skos:note "Connected with Michael Slaby (ex-CTO Obama campaign, chief strategist at Harmony Labs); helped architect initial infrastructure of Narrative Observatory: massive ingestion pipeline and narrative classification project for Gates Foundation, focused on narratives around poverty; significance: seeing what narrative analysis looked like at scale; bridge between theoretical understanding of narrative-as-vector and industrial-scale implementation." ;
    prov:wasGeneratedBy narr:Tx_20260208T211414Z .

  narr:Narrative_TheOutwork a narr:Narrative ;
    dct:source narr:Sample_FoundingStory_2026_02_08 ;
    narr:theme "The Outwork: personal narrative engine" ;
    skos:broader narr:Product ;
    skos:note "Online course and process for creating personal narrative, serving artists, entrepreneurs, and nonprofits; first productization of narrative engineering, focused on individuals rather than organizations; combined understanding of narrative from Harmony Labs with personal narrative arc of being a notional founder and then a cofounder." ;
    prov:wasGeneratedBy narr:Tx_20260208T211414Z .

  narr:Narrative_Capitol a narr:Narrative ;
    dct:source narr:Sample_FoundingStory_2026_02_08 ;
    narr:theme "Capitol: automated insight extraction" ;
    skos:broader narr:Product ;
    skos:note "Run by original CTO of a collaborator; YC Fellow (summer 2024); Scarlet was first engineering hire; mission: automated extraction of insight from datasets, where an insight becomes a narrative about a dataset that assembles into a story suggesting actions and outcomes; same pattern: creation of vector that creates an outcome, a larger outcome within a system." ;
    prov:wasGeneratedBy narr:Tx_20260208T211414Z .

  narr:Narrative_Vouch a narr:Narrative ;
    dct:source narr:Sample_FoundingStory_2026_02_08 ;
    narr:theme "Vouch: the manual prototype" ;
    skos:broader narr:Product ;
    skos:note "Scarlet joined as strategist to reposition company from OEM automotive supplier into larger enterprise-facing sales organization; created what was called a narrative source of truth for the organization out of a process done manually at the time: seeding AI conversations with not only past constructions, but the context required organizationally—narrative statements that were intended and sanctioned as steering vectors; instead of AI defaulting to training-set narratives, it defaulted to organizational narratives; created a single source of truth that allowed others to replicate this AI context for content generation across the organization; key transition: from individual use to organizational replication." ;
    skos:related narr:Narrative_aswritten ;
    prov:wasGeneratedBy narr:Tx_20260208T211414Z .

  narr:Narrative_aswritten a narr:Narrative ;
    dct:source narr:Sample_FoundingStory_2026_02_08 ;
    narr:theme "aswritten.ai: automating the manual process" ;
    skos:broader narr:Product ;
    skos:note "Created as the automation of the Vouch process—an ingestion pipeline for arbitrary content that extracts narrative information, creates a narrative architecture, and serves as the seed for agentic work across different contexts; taking a single data source and making it context-agnostic." ;
    skos:related narr:Narrative_Vouch ;
    prov:wasGeneratedBy narr:Tx_20260208T211414Z .

  narr:Narrative_ThroughLine a narr:Narrative ;
    dct:source narr:Sample_FoundingStory_2026_02_08 ;
    narr:theme "The through-line: physics never changed, substrate did" ;
    skos:broader narr:StrategyOverview ;
    skos:note "Each phase follows the same pattern—the physics never changed, the substrate did: generative systems → local actors, simple rules, emergent behavior; a collaborator → language as analyzable actors within systems; Populous → cross-channel communication as medium-agnostic translation; Elephant Collective → narrative as mass steering force for human groups; 2019 Clojure talk → LLMs as continuation machines steered by narrative vectors; Harmony Labs → narrative analysis at industrial scale (Gates Foundation); The Outwork → personal narrative engine (first productization); Capitol → automated insight extraction as narrative (YC Fellow, summer 2024); Vouch → manual narrative source of truth for organizational AI; aswritten → automated collective memory for AI-native teams." ;
    prov:wasGeneratedBy narr:Tx_20260208T211414Z .

