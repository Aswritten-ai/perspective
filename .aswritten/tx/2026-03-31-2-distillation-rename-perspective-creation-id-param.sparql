    # ── Style Observations ───────────────────────────────────────────────────
    narr:StyleObs_DirectPersonalRegister_Distillation
      a narr:StyleObservation ;
      dct:source narr:Sample_DistillationPerspectiveCreation_20260331 ;
      skos:broader narr:ToneDirectPersonal ;
      skos:note "Scarlet's voice is captured in direct first-person quotes embedded in a structured decision memo. The register is founder-internal: no hedging, declarative, immediate." ;
      rdf:value true ;
