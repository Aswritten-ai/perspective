    narr:StyleObs_BulletedDecisionFormat_Distillation
      a narr:StyleObservation ;
      dct:source narr:Sample_DistillationPerspectiveCreation_20260331 ;
      skos:broader narr:InformationArchitecture ;
      skos:note "Decisions are structured as bulleted 'What changed' / 'What didn't change' lists under bold headers, a consistent pattern in aswritten design session memos. Parallelism is enforced within each list." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
