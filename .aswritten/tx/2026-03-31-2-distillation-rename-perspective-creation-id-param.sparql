INSERT DATA {
  GRAPH narr:Tx_20260331T120000Z {

    # ── Sample ──────────────────────────────────────────────────────────────
    narr:Sample_DistillationPerspectiveCreation_20260331
      a narr:Sample ;
      dct:created "2026-03-31"^^xsd:date ;
      dct:title "Distillation → Perspective Creation, and the ID Parameter Rename" ;
      dct:description "Follow-up decisions from the GitHub abstraction and tool naming design session (2026-03-30/31). Two additional naming changes: (1) distillation → perspective creation for the professional service and related terminology; (2) perspective parameter → id parameter to eliminate redundancy in perspective(perspective=ID)." ;
      narr:inputLength 2041 .

    # ── Actors (already in snapshot; referenced for completeness) ───────────
    # narr:Actor_ScarletDame_StrategyV1, narr:Actor_Claude_AICoworker,
    # narr:Actor_OutsideTechBetaUser_Fiance all exist — no new actor entities needed.

    # ── Narrative 1: Distillation → Perspective Creation ────────────────────
    narr:Narrative_DistillationToPerspectiveCreation

      dct:source narr:Sample_DistillationPerspectiveCreation_20260331 ;
      skos:broader narr:NamingConventions ;
      skos:prefLabel "Distillation → Perspective Creation: Professional Service Rename" ;
      skos:note "The professional service formerly called 'distillation' is renamed to 'perspective creation.' Rationale: 'distillation' is a metaphor that needs explaining; 'perspective creation' is what it literally is — we create a perspective for you. It also parallels the self-service path naturally: you can create your own perspective (Expert, DIY) or we can create it for you (service). Cascading renames: distillation specialist → perspective creator; distillation fee → creation fee; individuation pipeline → perspective pipeline. Historical uses of 'distill' in memories and footnotes are citations, not active terminology. Internal pipeline code names can stay as-is." ;
      narr:theme "'Distillation' replaced by 'perspective creation' as the name for the professional service — a literal description that parallels the self-service path and needs no metaphor explanation" .

    # ── Narrative 3: Cognition Model Simplification ──────────────────────────
    narr:Narrative_CognitionModelSimplification

      dct:source narr:Sample_DistillationPerspectiveCreation_20260331 ;
      skos:broader narr:TerminologyControl ;
      skos:prefLabel "Cognition Model Simplified: remember → process → perspective" ;
      skos:note "The cognition model was simplified. Before: remember → internalize → individuate → consult. After: remember → process → perspective. 'Individuate' and 'internalize' were Jungian psychology terms borrowed as metaphors — accurate for what the pipeline does, but not worth naming as distinct steps when the user never sees them. 'Consult' was freed as a general word when it was no longer a tool name." ;
      narr:theme "The cognition model drops Jungian metaphor steps (individuate, internalize) in favor of a plain three-step arc: remember → process → perspective" .

    # ── Claims ───────────────────────────────────────────────────────────────
    narr:Claim_PerspectiveCreationServiceRename
      a narr:Claim ;
      dct:source narr:Sample_DistillationPerspectiveCreation_20260331 ;
      skos:note "'Distillation' is renamed to 'perspective creation' for the professional service. Scarlet: 'I don't like the word distillation. Let's just call it perspective creation?' Rationale: 'Perspective creation' is what it literally is — we create a perspective for you. It parallels the self-service path naturally. Cascading renames: distillation specialist → perspective creator; distillation fee → creation fee; individuation pipeline → perspective pipeline." ;
      narr:aboutNode narr:Narrative_DistillationToPerspectiveCreation ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_ToolNamesLeakImplementation .

    narr:Claim_ConsultTermFreed
      a narr:Claim ;
      dct:source narr:Sample_DistillationPerspectiveCreation_20260331 ;
      skos:note "With 'consult' no longer a tool name, it was freed as a general word. The 'avoid: Consult' note was removed from the Leaders/executives audience guidance in the glossary. The word is no longer reserved terminology." ;
      narr:aboutNode narr:NamingConventions ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_UserFacingVsInternalLanguageSplit .

    narr:Claim_CuratedDroppedFromCategory
      a narr:Claim ;
      dct:source narr:Sample_DistillationPerspectiveCreation_20260331 ;
      skos:note "'Expertise installation' (without 'curated') is the category name. Scarlet identified that 'curated' wasn't adding meaning — the installation itself implies curation. This supersedes the 'curated expertise installation' framing from Strategy Document V1." ;
      narr:aboutNode narr:Narrative_CategoryCuratedExpertiseInstallation ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_CategoryCuratedExpertiseInstallation .

    narr:Claim_CognitionModelSimplified
      a narr:Claim ;
      dct:source narr:Sample_DistillationPerspectiveCreation_20260331 ;
      skos:note "Cognition model simplified from four steps to three. Before: remember → internalize → individuate → consult. After: remember → process → perspective. 'Individuate' and 'internalize' were Jungian psychology terms — accurate for the pipeline but not worth naming as user-visible steps. 'Consult' dropped because it was a tool name that has since been freed." ;
      narr:aboutNode narr:Narrative_CognitionModelSimplification ;
      narr:hasConvictionLevel narr:Conviction_Foundation ;
      narr:supports narr:Narrative_NamingConstraints .

    # ── Observations (grounded quotes) ───────────────────────────────────────
    narr:Obs_DistillationQuote
      a narr:Observation ;
      dct:source narr:Sample_DistillationPerspectiveCreation_20260331 ;
      skos:broader narr:NamingConventions ;
      skos:note "Scarlet's verbatim rationale for the distillation → perspective creation rename." ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_DistillationPerspectiveCreation_20260331 ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
