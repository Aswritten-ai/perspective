    # ── Style Metrics ────────────────────────────────────────────────────────
    narr:StyleMetrics_DistillationPerspectiveCreation
      a narr:StyleMetrics ;
      dct:source narr:Sample_DistillationPerspectiveCreation_20260331 ;
      skos:broader narr:StyleMetrics ;
      skos:note "Design decision memo format. Mixed register: structured markdown with bold headers and bullet lists for decisions; embedded verbatim Scarlet quotes in first person. Antithesis-heavy (before → after pairs). Active voice dominant. Jargon density low-moderate — product terms (perspective, id param, proxy, mcp-generic, individuation pipeline) used without definition, implying internal audience. Short punchy sentences at decision moments; longer analytical sentences in rationale sections." ;
      narr:AverageSentenceLength 15 ;
