# Extracted entities and relationships
INSERT DATA {
  narr:Sample_ProductArchSMS a narr:Sample ;
    dct:title "Product Architecture: SMS-First Collective Memory" ;
    narr:inputLength 6847 ;
    dct:created "2026-02-17"^^xsd:date ;
    skos:note "Architecture session with Scarlet Dame and Claude following Tony Maley weekly call; exploring shared agent memory concept evolved into standalone product direction." ;
    prov:wasGeneratedBy narr:Tx_20260217T235453Z .

  narr:Product_SMSCollectiveMemory a narr:Product ;
    skos:broader narr:ProductOverview ;
    dct:source narr:Sample_ProductArchSMS ;
    skos:prefLabel "SMS-First Collective Memory" ;
    skos:definition "Text a Twilio number. State your topic. Name your contacts. The AI interviews everyone asynchronously over SMS (and eventually Discord, Slack, email). It synthesizes perspectives, surfaces contradictions with provenance, and notifies you when consensus forms or shifts." ;
    skos:note "No app. No install. No login. No git. The product is a phone number." ;
    prov:wasGeneratedBy narr:Tx_20260217T235453Z .

  narr:Module_V1Spike a narr:ModulesCapabilities ;
    skos:broader narr:Product_SMSCollectiveMemory ;
    dct:source narr:Sample_ProductArchSMS ;
    skos:prefLabel "V1 Spike (n8n only, no new infrastructure)" ;
    skos:definition "Webhook on Fireflies (or Crisp, or manual SMS) detects a call/event. n8n receives webhook, runs novelty check against current snapshot (introspect). If novel: DM interview over Discord/Slack/SMS using existing interview skill protocol. Memory committed via existing remember tool. Post-extraction: notification of worldview shift to topic initiator. Role/interest-specific interpretation notifications sent to other group members." ;
    prov:wasGeneratedBy narr:Tx_20260217T235453Z .

  narr:Module_V11GroupConsensus a narr:ModulesCapabilities ;
    skos:broader narr:Product_SMSCollectiveMemory ;
    dct:source narr:Sample_ProductArchSMS ;
    skos:prefLabel "V1.1: Group Consensus / Async Deliberation" ;
    skos:definition "Create a topic. Assign N people. AI interviews each privately and asynchronously. Synthesizes perspectives. Surfaces contradictions with provenance. Iterates until resolution or explicit decision. Like a meeting that happens over days, where everyone gets heard without scheduling conflicts, and the AI maintains the thread of argument." ;
    prov:wasGeneratedBy narr:Tx_20260217T235453Z .

  narr:Positioning_SMSProduct a narr:PositioningThesis ;
    skos:broader narr:StrategyOverview ;
    dct:source narr:Sample_ProductArchSMS ;
    skos:prefLabel "SMS-First Collective Memory Positioning" ;
    skos:definition "Zero friction acquisition via SMS. Every interview recipient experiences the product for free. First topic free. Recipients become initiators. They've seen what the AI does, they want it for their own questions." ;
    skos:note "SMS is acquisition, platform is expansion. Power users graduate to the full aswritten platform (Claude Code integration, MCP, stories, etc.). Both exist: SMS product and developer platform share the same backend (graph, extraction, compilation). Different UIs for different users." ;
    prov:wasGeneratedBy narr:Tx_20260217T235453Z .

  narr:Moat_SharedBackend a narr:MoatLeverage ;
    skos:broader narr:StrategyOverview ;
    dct:source narr:Sample_ProductArchSMS ;
    skos:prefLabel "Shared Backend Moat" ;
    skos:definition "Same graph, same ontology, same SPARQL transactions. Same compile, same introspect (different LLM backing). Same memory format, same ingestion pipeline. Compile is free and local. Anyone can clone a public aswritten repo and compile it. That's the V3 marketplace — 'reusable organizational perspective.' But you can't produce a graph to compile without paid extraction." ;
    prov:wasGeneratedBy narr:Tx_20260217T235453Z .

  narr:Sequencing_SMSProduct a narr:FocusSequencing ;
    skos:broader narr:StrategyOverview ;
    dct:source narr:Sample_ProductArchSMS ;
    skos:prefLabel "SMS Product Sequencing" ;
    skos:definition "V1: SMS-first collective memory — text a number, interview flow, worldview synthesis. V1.1: Group consensus — async deliberation with synthesis and provenance. V2: Multi-channel (Slack, Discord, email, web) + OpenClaw or similar local agent runtime. V3: Marketplace — public aswritten repos as reusable organizational perspective (compile free, extract paid). V4: Delegated authority — agents approved to act on behalf of org with worldview + authority." ;
    prov:wasGeneratedBy narr:Tx_20260217T235453Z .

  narr:Arch_GroupAsRepo a narr:SystemTopology ;
    skos:broader narr:ArchitectureOverview ;
    dct:source narr:Sample_ProductArchSMS ;
    skos:prefLabel "Group = Repo" ;
    skos:definition "You pay for a 'collective memory' (a named group, e.g., 'aswritten advisory group'). Service account (bot) owns all repos — users never touch GitHub. One repo per group. GitHub supports 100K repos per org — plenty for now." ;
    prov:wasGeneratedBy narr:Tx_20260217T235453Z .

  narr:Arch_IdentityViaPhone a narr:SecurityPrivacyModel ;
    skos:broader narr:ArchitectureOverview ;
    dct:source narr:Sample_ProductArchSMS ;
    skos:prefLabel "Identity = Phone Number" ;
    skos:definition "No accounts, no passwords, no OAuth for end users. Phone number is the identity. Stripe payment links for billing (SMS-delivered)." ;
    prov:wasGeneratedBy narr:Tx_20260217T235453Z .

  narr:Arch_ParticipantsFree a narr:ValueExchange ;
    skos:broader narr:ActorIncentiveAnalysis ;
    dct:source narr:Sample_ProductArchSMS ;
    skos:prefLabel "Participants are free" ;
    skos:definition "You pay monthly per group. You invite people to topics within your group. Once someone is part of a group, they see it as a venue for their own topics. 'Is this for the aswritten advisory group?' not 'is this the group with those 3 names?'" ;
    prov:wasGeneratedBy narr:Tx_20260217T235453Z .

  narr:Arch_PaywallBoundary a narr:ArchitectureOverview ;
    skos:broader narr:Architecture ;
    dct:source narr:Sample_ProductArchSMS ;
    skos:prefLabel "Paywall Architecture" ;
    skos:definition "Clean line between deterministic and LLM operations. Remember (commit) and Compile (assemble graph) are free (deterministic). Extract (memory → RDF), Introspect (gap analysis), Lens (scoped compile via LLM), Stories (content generation), and Notifications (per-actor interpretation) are paid (LLM operations)." ;
    prov:wasGeneratedBy narr:Tx_20260217T235453Z .

  narr:Pricing_PerGroupSubscription a narr:PackagingEntitlement ;
    skos:broader narr:ProductOverview ;
    dct:source narr:Sample_ProductArchSMS ;
    skos:prefLabel "Per-group monthly subscription" ;
    skos:definition "Per-group monthly subscription (back to pay-per-repo). First topic free (viral acquisition). Participants free (removes friction from the viral loop). Topic lists are dynamic within a group." ;
    prov:wasGeneratedBy narr:Tx_20260217T235453Z .

  narr:Tagline_SMSProduct a narr:Tagline ;
