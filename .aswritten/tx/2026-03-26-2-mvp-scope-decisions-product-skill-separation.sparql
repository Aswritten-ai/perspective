      narr:hasConvictionLevel narr:Conviction_Boulder ;
      dct:source narr:Sample_MVPScopingSession_20260326 ;
      skos:note "Admin tier eliminated. Everything formerly admin-only (stories, register, refract, memories/source) is now either an org-repo Claude Code skill or 'read the files.' No separate admin tier needed. Ontology (raw access) moves to Team/Org tier." .

    # ── Claims: What's Added / Elevated ─────────────────────────────────────

