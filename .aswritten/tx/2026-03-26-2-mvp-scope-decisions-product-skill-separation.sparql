    # ── Sample ──────────────────────────────────────────────────────────────
    narr:Sample_MVPScopingSession_20260326 a narr:Sample ;
      dct:title "MVP Scoping Session: What Ships, What's Cut, and Why" ;
      dct:description "Walking voice memo → session with Scarlet reviewing above/below-the-line features for April 1 launch. Driven by synchronous extraction pipeline change (Mar 24)." ;
      dct:created "2026-03-26"^^xsd:date ;
      narr:inputLength 12847 .

    # ── Narratives ──────────────────────────────────────────────────────────

    narr:Narrative_FocusAsGoverningPrinciple a narr:Narrative ;
      dct:source narr:Sample_MVPScopingSession_20260326 ;
      narr:theme "Radical product focus: bounded behaviors done extremely well" ;
      skos:broader narr:PositioningThesis ;
      skos:note "The governing principle for all MVP scoping decisions: the product does a bounded set of behaviors that perform a bounded set of tasks extremely well. Modeled on Apple's opinionated workflow, not Microsoft's everything-tool." .

    narr:Narrative_SeparationProductVsOrgAutomation a narr:Narrative ;
      dct:source narr:Sample_MVPScopingSession_20260326 ;
      narr:theme "Product features vs. org automation must be separated" ;
      skos:broader narr:FocusSequencing ;
      skos:note "A recurring insight throughout the session: capabilities useful for aswritten-ai the org (changelog, graph health, refract, blog post generation) are not product features. They become local Claude Code skills or scheduled crons. The product ships only the bounded set." .

    narr:Narrative_ExpertSingleStreamWorldview a narr:Narrative ;
      dct:source narr:Sample_MVPScopingSession_20260326 ;
      narr:theme "Expert plan uses single-stream worldview: no branching, no PRs" ;
      skos:broader narr:OperatingModelShifts ;
      skos:note "Major architectural decision: Expert tier memories save to main by default. Eliminates PRs, branches, merge-via-MCP, concurrent branch handling, rebase bugs. The remember→review→merge cycle becomes remember→get TX→optionally review→done." .

    narr:Narrative_PlanGatedInstructions a narr:Narrative ;
      dct:source narr:Sample_MVPScopingSession_20260326 ;
      narr:theme "Compile returns plan-gated instructions as the feature-gating mechanism" ;
      skos:broader narr:PackagingEntitlement ;
      skos:note "Feature gating across plans is implemented via compile returning different instruction sets based on authenticated plan level — not separate tool sets. Different prompts guide agent behavior per plan." .

    # ── Claims: Hard Removes ─────────────────────────────────────────────────

    narr:Claim_StoriesRemoved a narr:Claim ;
      narr:aboutNode narr:CoreWorkflows ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      dct:source narr:Sample_MVPScopingSession_20260326 ;
      skos:note "Entire Stories system removed from product. TX summaries now returned from synchronous remember; blog post ideas, changelog, graph health become on-demand local skills. Workflows to delete: stories-list, story-draft, story-write, story-backfill, story-narrate-diff. Strip story calls from tx-post-commit (keep PR comment)." .

    narr:Claim_NotificationsRemoved a narr:Claim ;
      narr:aboutNode narr:CoreWorkflows ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      dct:source narr:Sample_MVPScopingSession_20260326 ;
      skos:note "Entire Notifications system removed. Synchronous remember eliminates primary notification use case. Secondary case (review requests) handled by GitHub natively. Workflows to delete: review-notify, msg-review-notify. Keep msg-send and front-webhook for feedback/help tool." .

    narr:Claim_DiscoveriesRemoved a narr:Claim ;
      narr:aboutNode narr:CoreWorkflows ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      dct:source narr:Sample_MVPScopingSession_20260326 ;
      skos:note "Discoveries fully removed (not just disabled). Already disabled but artifacts remain. Full deletion required." .

    narr:Claim_RefractRegistryRemoved a narr:Claim ;
      narr:aboutNode narr:CoreWorkflows ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      dct:source narr:Sample_MVPScopingSession_20260326 ;
      skos:note "Refract tool and Registry removed from product. Registry is just the docs folder. Refract becomes a local Claude Code skill. Workflows to delete: graph-refract, graph-scope (scope rolling into introspect). Remove from mcp-generic tool routing. Eliminates need to separate tools between org and everyone else — now one tool set for everyone." .

    narr:Claim_TXSummariesOnPRRemoved a narr:Claim ;
      narr:aboutNode narr:CoreWorkflows ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      dct:source narr:Sample_MVPScopingSession_20260326 ;
      skos:note "TX summaries on PR removed as auto-generated feature. Agent provides this from the returned transaction. PR comment mechanism in tx-post-commit kept — not hurting anything." .

    narr:Claim_MemoriesSourceToolRemoved a narr:Claim ;
      narr:aboutNode narr:CoreWorkflows ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      dct:source narr:Sample_MVPScopingSession_20260326 ;
      skos:note "Memories/Source tool removed from product. Memories are just files in the repo — anyone with a coding agent can read them directly. Org-only skill at most." .

    narr:Claim_AdminTierEliminated a narr:Claim ;
