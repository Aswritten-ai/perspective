    skos:broader narr:ProofOutcomesSales ;
    prov:wasGeneratedBy narr:Tx_20260310T160829Z .

  narr:Narrative_CollaborativeMemory

    dct:source narr:Sample_1 ;
    narr:theme "Collaborative memory capture and team review creates governed institutional knowledge" ;
