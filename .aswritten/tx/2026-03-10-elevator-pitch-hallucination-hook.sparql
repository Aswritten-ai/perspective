    skos:broader narr:CoreWorkflows ;
    prov:wasGeneratedBy narr:Tx_20260310T160829Z .

  narr:Narrative_CompoundingValue

    dct:source narr:Sample_1 ;
    narr:theme "The system teaches itself and explains the org to new hires, implying compounding value over time" ;
    skos:note "Closing beat of the five-beat arc. Warm, concrete, implies the system becomes more valuable as it grows. Annotated at foundation-level against Onboarding Elimination Archetype (Jan 7, 2026)." ;
    skos:broader narr:ExpansionPathway ;
    prov:wasGeneratedBy narr:Tx_20260310T160829Z .

  narr:Narrative_ProspectPerspective

    dct:source narr:Sample_1 ;
    narr:theme "Every sentence is written from the prospect's experience, not the product's architecture" ;
    skos:note "Structural principle: no git, no MCP, no RDF, no GitHub Actions, no narrative architecture. Enables the pitch to work across elevator, deck intro, and demo intro formats simultaneously." ;
    skos:broader narr:AudienceFrames ;
    prov:wasGeneratedBy narr:Tx_20260310T160829Z .

