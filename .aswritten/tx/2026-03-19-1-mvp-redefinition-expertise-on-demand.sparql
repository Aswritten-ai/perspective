# ── UPDATE: GitHub abstraction claim — open question → resolved direction ────
DELETE {
  GRAPH ?g {
    narr:Claim_GitHubAbstractionHighPriority skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260319T120000Z {
    narr:Claim_GitHubAbstractionHighPriority
      skos:note "How to abstract GitHub from signup is high priority — SMB users won't have GitHub accounts. This is an open question flagged as high priority for the SMB market. As of 2026-03-19 MVP session: resolved direction — Individual tier uses org-managed repos (no GitHub account required); Publisher tier requires GitHub. Free tier is read-only with no GitHub account needed. The abstraction is now a tier design feature, not an open blocker." ;
      narr:hasConvictionLevel narr:Conviction_Boulder .
  }
}
WHERE {
  GRAPH ?g {
    narr:Claim_GitHubAbstractionHighPriority skos:note ?oldNote .
