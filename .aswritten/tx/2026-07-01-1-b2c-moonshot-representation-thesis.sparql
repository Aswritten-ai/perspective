          oa:exact "it's how many voices in super intelligence are there going to be?" ;
          oa:prefix "it's not, are we going to get to super intelligence, " ;
          oa:suffix " She concedes the consensus"
        ]
      ] .

    # ── STYLE METRICS ───────────────────────────────────────────────────────

    narr:StyleMetrics_Moonshot_20260701
      a narr:StyleMetrics ;
      dct:source narr:Sample_Moonshot_VoicesSuperintelligence_20260701 ;
      skos:broader narr:StyleMetrics ;
      skos:note "Voice memo / morning pages register. Mixed: raw first-person stream-of-consciousness in blockquoted speech (run-on, filler-heavy, ~35 words avg per sentence) vs. editorial framing prose (structured, shorter, ~18 words avg). Active voice dominant throughout. Jargon density low — product terms (perspective, module, escalation) used without definition, implying internal audience. Antithesis-heavy structure (monoculture vs. diversity, uniformity vs. amplification, profile vs. perspective, escalation vs. implication). First-person singular dominant. Profanity used as rhetorical intensifier at conviction peaks. Consistent with Scarlet voice-memo idiolect." ;
      narr:AverageSentenceLength "22"^^xsd:integer ;
      narr:ActiveVoiceRatio "0.82"^^xsd:decimal ;
      narr:JargonDensity "0.06"^^xsd:decimal .

  }
