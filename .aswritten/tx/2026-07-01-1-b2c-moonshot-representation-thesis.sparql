          oa:exact "I'm a trans woman — there's an opportunity here to do something specifically about queer representation" ;
          oa:prefix "and " ;
          oa:suffix "... can I create a perspective that represents"
        ]
      ] .

    narr:StyleObs_RhetoricalQuestionAsFramingDevice
      a narr:StyleObservation ;
      skos:broader narr:RhetoricalQuestion ;
      dct:source narr:Sample_Moonshot_VoicesSuperintelligence_20260701 ;
      skos:note "The moonshot is framed as a rhetorical question: 'how many voices in superintelligence are there going to be?' This is the clearest, most ownable version of the pitch. The question form is used throughout: 'does it become a diverse voice? Does it represent difference? Does it represent you? Is there representation?' Rhetorical questions as a structuring device for the anti-monoculture argument." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_Moonshot_VoicesSuperintelligence_20260701 ;
