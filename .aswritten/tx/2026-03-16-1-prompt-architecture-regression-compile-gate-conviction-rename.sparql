          oa:exact "The confusion is with stake and boulder without prior explanation." ;
          oa:prefix "Scarlet: \"" ;
          oa:suffix "\""
        ]
      ] .

  }
} ;

# ── UPDATE: Narrative_ConvictionFramework — rename from grave to principle ─────
# Snapshot narr:Narrative_ConvictionFramework mentions "notion → stake → boulder → grave".
# Memory asserts the rename: stake→claim, boulder→decision, foundation→principle.
# The snapshot also uses "Foundation" not "grave" in most places.
# We update the ConvictionFramework note to reflect the new plain-English labels.

DELETE {
  GRAPH ?g {
    narr:Narrative_ConvictionFramework skos:note ?oldNote .
  }
}
INSERT {
  GRAPH narr:Tx_20260316T120000Z {
    narr:Narrative_ConvictionFramework skos:note "Conviction framework renamed to plain English as of March 16, 2026: notion (unchanged, easily moved, early thinking), claim (was stake, asserted, still validating), decision (was boulder, settled, hard to revisit), principle (was foundation, bedrock, career-arc level). Backend (n8n extraction, SPARQL, compiled snapshots) still emits old enum values (Notion/Stake/Boulder/Foundation); update tracked in Notion. Frontend labels updated in CLAUDE.md, claude-prepend.md, and ASWRITTEN.md. Prior label: notion → stake → boulder → foundation (grave was an earlier variant)." .
  }
}
WHERE {
  GRAPH ?g {
    narr:Narrative_ConvictionFramework skos:note ?oldNote .
    FILTER(CONTAINS(STR(?oldNote), "stake") || CONTAINS(STR(?oldNote), "boulder") || CONTAINS(STR(?oldNote), "grave"))
  }
} 