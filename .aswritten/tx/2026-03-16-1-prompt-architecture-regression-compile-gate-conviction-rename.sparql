# ── NARRATIVES ────────────────────────────────────────────────────────────────

INSERT DATA {
  GRAPH narr:Tx_20260316T120000Z {

    narr:Narrative_ConvictionLevelRename a narr:Narrative ;

      skos:broader narr:TerminologyControl ;
      skos:prefLabel "Conviction Level Rename: Metaphorical to Plain English" ;
      skos:note "Conviction levels renamed from metaphorical to plain English: notion (unchanged), claim (was stake), decision (was boulder), principle (was foundation). Rationale: stake and boulder required a key to decode; the new labels form a natural progression — all nouns, all self-explanatory. Backend (n8n extraction, SPARQL, compiled snapshots) still emits old enum values; update tracked in Notion. Frontend labels updated in CLAUDE.md, claude-prepend.md, and ASWRITTEN.md." ;
      narr:theme "Conviction level labels renamed from metaphors (stake, boulder, foundation) to plain English (claim, decision, principle) to eliminate the need for a decoding key" .

  }
} ;

# ── OBSERVATIONS ──────────────────────────────────────────────────────────────

INSERT DATA {
  GRAPH narr:Tx_20260316T120000Z {

    narr:Obs_ConvictionLabelPlainEnglish a narr:Observation ;

      skos:broader narr:TerminologyControl ;
      skos:note "Conviction level rename rationale: notion and foundation already worked as plain English; stake and boulder were metaphors requiring a key to decode. New labels: notion (unchanged), claim (was stake), decision (was boulder), principle (was foundation). All nouns, all self-explanatory, forming a natural progression." ;
      oa:hasTarget [
        a oa:SpecificResource ;

        oa:hasSelector [
