@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__TimingThesis> {
  <https://aswritten.ai/narrative#Digest_ns__TimingThesis> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#TimingThesis> ;
    narr:childCount "10"^^xsd:integer ;
    narr:generatedFrom "e077f065177423d09a6eff0bb42bec11d953a02d" ;
    narr:narration """The timing thesis for the venture is currently structured around three primary drivers of urgency. The first is an [existential IP crisis](narr:Narrative_IPCrisis), where [heavy AI adoption](narr:Observation_TimingThesis_AIAdoption) is framed as a systematic transfer of competitive moats into training data, a position supported by [existential-crisis rhetoric](narr:Observation_ExistentialCrisis) and a call for [quantifiable risk assessment](narr:Position_IPCrisisExistential). The second driver centers on [organizational context fragmentation](narr:TimingThesis_AIContextFragmentation), where the [proliferation of AI agents](narr:Narrative_timing) operating in isolation creates [strategy-execution gaps](narr:TimingThesis_ADR002) and knowledge silos that impede onboarding. A third, distinct thread shifts the focus to [prompt-engineering maturity](narr:Narrative_SIC_TimingThesis_1), suggesting that the industry's transition toward plan-then-execute workflows provides the necessary technical substrate for these solutions. While these arguments establish the 'why now,' the narrative remains anchored by an [open quantification gap](narr:Question_ProblemQuantification) regarding the specific economic cost of these risks.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_IPCrisis> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_SIC_TimingThesis_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_TimingThesis_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_timing> ;
    narr:covers <https://aswritten.ai/ns/narrative#Observation_ExistentialCrisis> ;
    narr:covers <https://aswritten.ai/ns/narrative#Observation_TimingThesis_AIAdoption> ;
    narr:covers <https://aswritten.ai/ns/narrative#Position_IPCrisisExistential> ;
    narr:covers <https://aswritten.ai/ns/narrative#Question_ProblemQuantification> ;
    narr:covers <https://aswritten.ai/ns/narrative#TimingThesis_ADR002> ;
    narr:covers <https://aswritten.ai/ns/narrative#TimingThesis_AIContextFragmentation> ;
    narr:keyPhrase [ narr:text "This is the existential crisis of modern business" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_ExistentialCrisis> ] ;
    narr:keyPhrase [ narr:text "Every employee tells state secrets to AI; models lift IP into training data; existential business risk" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_IPCrisis> ] ;
    narr:keyPhrase [ narr:text "New hires take 3-6 months to build AI context senior employees have." ; narr:phraseSource <https://aswritten.ai/ns/narrative#TimingThesis_AIContextFragmentation> ] ;
    narr:keyPhrase [ narr:text "Strategy-execution gaps caused by separate tools with no shared context create urgency for unified worldview layer." ; narr:phraseSource <https://aswritten.ai/ns/narrative#TimingThesis_ADR002> ] ;
    narr:keyPhrase [ narr:text "Common pattern in prompt engineering is to ask a model to create a plan before executing." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_SIC_TimingThesis_1> ] ;
    narr:variation [ narr:text "The urgency is framed as a technical maturity milestone rather than a crisis of risk." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_SIC_TimingThesis_1> ] ;
    narr:variation [ narr:text "The narrative lacks a concrete financial metric, potentially weakening the executive-level case." ; narr:over <https://aswritten.ai/ns/narrative#Question_ProblemQuantification> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}