@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__TimingThesis> {
  <https://aswritten.ai/narrative#Digest_ns__TimingThesis> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#TimingThesis> ;
    narr:childCount "8"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """This hub gathers the \"why now\" arguments for the venture, running along two distinct rails. The first is **IP leakage as crisis**: heavy AI adoption creates acute pain now, with [companies transferring their moat into training data](narr:Observation_TimingThesis_AIAdoption) and the [existential IP crisis framing](narr:Narrative_IPCrisis) elevated to [existential-crisis rhetoric](narr:Observation_ExistentialCrisis). The second rail is **context fragmentation**: [AI agent proliferation without shared memory](narr:Narrative_timing), [agents operating in isolation needing a unified worldview layer](narr:TimingThesis_ADR002), and [every employee accumulating siloed AI context](narr:TimingThesis_AIContextFragmentation) with knowledge inequality and onboarding cost. A third, structurally distinct thread frames timing around [prompt-engineering maturity](narr:Narrative_SIC_TimingThesis_1) — plan-then-execute and detailed specs becoming standard practice. Cutting against the urgency rhetoric, an [open quantification gap](narr:Question_ProblemQuantification) flags that the exec narrative still lacks a concrete dollar figure. No witness dates are present, so no trajectory is dated here.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_IPCrisis> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_SIC_TimingThesis_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_timing> ;
    narr:covers <https://aswritten.ai/ns/narrative#Observation_ExistentialCrisis> ;
    narr:covers <https://aswritten.ai/ns/narrative#Observation_TimingThesis_AIAdoption> ;
    narr:covers <https://aswritten.ai/ns/narrative#Question_ProblemQuantification> ;
    narr:covers <https://aswritten.ai/ns/narrative#TimingThesis_ADR002> ;
    narr:covers <https://aswritten.ai/ns/narrative#TimingThesis_AIContextFragmentation> ;
    narr:keyPhrase [ narr:text "This is the existential crisis of modern business" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_ExistentialCrisis> ] ;
    narr:keyPhrase [ narr:text "What's the '[amount]' equivalent for IP leakage risk? How to measure erosion of competitive moat?" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Question_ProblemQuantification> ] ;
    narr:keyPhrase [ narr:text "New hires take 3-6 months to build AI context senior employees have. Knowledge walks out door on departure." ; narr:phraseSource <https://aswritten.ai/ns/narrative#TimingThesis_AIContextFragmentation> ] ;
    narr:keyPhrase [ narr:text "companies investing in AI are systematically transferring competitive moat." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_TimingThesis_AIAdoption> ] ;
    narr:keyPhrase [ narr:text "AI agents are proliferating; each operates in isolation with brittle personas and scattered context; strategy-execution gaps cost startups millions" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_timing> ] ;
    narr:variation [ narr:text "Two competing \"why now\" framings coexist: IP/moat leakage as threat vs. context fragmentation / agent alignment as operational gap — different problems, different buyers." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_IPCrisis> ; narr:over <https://aswritten.ai/ns/narrative#TimingThesis_AIContextFragmentation> ] ;
    narr:variation [ narr:text "Existential-crisis rhetoric runs ahead of evidence; an unresolved demand for concrete dollar/risk quantification pushes back on the urgency claim." ; narr:over <https://aswritten.ai/ns/narrative#Observation_ExistentialCrisis> ; narr:over <https://aswritten.ai/ns/narrative#Question_ProblemQuantification> ] ;
    narr:variation [ narr:text "A structurally distinct timing rationale — prompt-engineering / spec-writing maturity — sits apart from the market-pain narratives and could be a road not taken." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_SIC_TimingThesis_1> ] ;
    narr:writer "claude (subscription)" .
}