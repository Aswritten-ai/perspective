    narr:covers <https://aswritten.ai/narrative#StyleObs_MoonshotVoiceMemoRegister> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_OnboardingMethodology_BlockquoteVoice> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_PractitionerBetaUserBlockquoteRegister> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Protocol_VerbatimBlockquotes> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RunOnVoiceMemoRegister> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ScarletAnnotateQuote> ;
