    narr:covers <https://aswritten.ai/narrative#StyleObs_ScarletTierContinuumQuote> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ScarletVerbatimQuotes> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TemporalityValidation_BlockquoteVoice> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TranscriptBootstrap_ConversationalRegister> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_VerbatimBlockquote> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_VerbatimBlockquote_20260521> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_VerbatimQuoteStyle_BDF> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_VisionFrameDirectQuote> ;
    narr:covers <https://aswritten.ai/narrative#Style_VerbatimQuotePattern> ;
    narr:keyPhrase [ narr:text "Compressions that sound like slogans read as AI-generated and fail the test she applies to all outreach language: whether she can say it out loud on a call comfortably." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ConversationalPhrasingRule> ] ;
    narr:keyPhrase [ narr:text "it speaks to, references, and works from what was already said" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ConversationalVsCompressed> ] ;
    narr:keyPhrase [ narr:text "Recorded here in an engineering manager at the customer's words, because it is the sharpest customer-language version aswritten has:" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ForgettingBottleneck_DirectQuote> ] ;
    narr:keyPhrase [ narr:text "very very different from everything I've been sending about aswritten lately — much more vulnerable about my personal situation, much more connected to individuals related to the company" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_VulnerabilityTenorQuote> ] ;
    narr:keyPhrase [ narr:text "the problem becomes that theme is interpretive" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_VerbatimBlockquote> ] ;
    narr:keyPhrase [ narr:text "vetting is a beachhead to create a perspective that represents an individual" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_VisionFrameDirectQuote> ] ;
    narr:keyPhrase [ narr:text "Send us six months of transcripts and get a perspective tomorrow is absolutely a promise the product can make." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_VerbatimBlockquote_20260521> ] ;
    narr:keyPhrase [ narr:text "link relations / HATEOAS / RFC 8288" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DiscoveryConsultantCallRegister> ] ;
    narr:keyPhrase [ narr:text "'compression anxiety' — Scarlet's idiolect; a coined compound noun naming a specific psychological state tied to her Enneagram 4 pattern." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_10> ] ;
    narr:keyPhrase [ narr:text "Scarlet, verbatim from this session:" ; narr:phraseSource <https://aswritten.ai/narrative#Style_VerbatimQuotePattern> ] ;
    narr:variation [ narr:text "One memory breaks the stream-of-consciousness pattern: Scarlet's blockquotes are unusually aphoristic and axiom-like, functioning as philosophical premises rather than conversational evidence — a structural outlier against the dominant filler-heavy register." ; narr:over <https://aswritten.ai/narrative#StyleObs_VerbatimBlockquote> ] ;
    narr:variation [ narr:text "The identity-as-architecture observation (Enneagram frame, identity downstream of narrative context) sits under this hub but is not a register or idiolect observation — it is a conceptual claim about selfhood, making it a thematic outlier." ; narr:over <https://aswritten.ai/narrative#Observation_5> ] ;
    narr:variation [ narr:text "StyleObs_10 introduces document-level meta-transparency markers (explicit conviction/confidence labels) and a coined compound ('compression anxiety') as idiolect — these are editorial conventions as much as speaker features, blurring the hub's register-observation frame." ; narr:over <https://aswritten.ai/narrative#StyleObs_10> ] ;
    narr:variation [ narr:text "The vulnerability-tenor quote (Jul 2026) characterizes Scarlet's Vouch outreach as structurally different from her aswritten outreach — a register distinction within her own voice that cuts against the single-idiolect framing." ; narr:over <https://aswritten.ai/narrative#Obs_VulnerabilityTenorQuote> ] ;
    narr:variation [ narr:text "Tony and Scarlet share filler-heavy conversational register but diverge in structure: Tony is shorter and declarative, Scarlet longer and architecturally organized — the hub covers both but the rule (preserve verbatim) is articulated only for Scarlet." ; narr:over <https://aswritten.ai/narrative#StyleObs_ConversationalRegisterTonyScarlet> ; narr:over <https://aswritten.ai/narrative#StyleObs_DirectSpeechPlaybook> ; narr:over <https://aswritten.ai/narrative#StyleObs_RunOnVoiceMemoRegister> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
