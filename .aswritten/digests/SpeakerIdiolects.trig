    narr:keyPhrase [ narr:text "conversational phrasing is preserved verbatim in all outreach material; coined compressions that sound like slogans are rejected as AI-generated" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ConversationalPhrasingRule> ] ;
    narr:keyPhrase [ narr:text "it speaks to, references, and works from what was already said" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ConversationalVsCompressed> ] ;
    narr:keyPhrase [ narr:text "very very different from everything I've been sending about aswritten lately — much more vulnerable about my personal situation, much more connected to individuals related to the company" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_VulnerabilityTenorQuote> ] ;
    narr:keyPhrase [ narr:text "Recorded here in an engineering manager at the customer's words, because it is the sharpest customer-language version aswritten has:" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ForgettingBottleneck_DirectQuote> ] ;
    narr:keyPhrase [ narr:text "Board guys were pretty interested in aswritten." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_BoardInterestQuote> ] ;
    narr:keyPhrase [ narr:text "'compression anxiety' — Scarlet's idiolect; a coined compound noun naming a specific psychological state tied to her Enneagram 4 pattern." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_10> ] ;
    narr:keyPhrase [ narr:text "sorry to be clear i need to approve before we merge dev->main" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ScarletLowercaseDirectQuote> ] ;
    narr:keyPhrase [ narr:text "the problem becomes that theme is interpretive" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_VerbatimBlockquote> ] ;
    narr:keyPhrase [ narr:text "Transcribed locally (whisper.cpp large-v3-turbo) with per-token confidence and paralinguistic signals" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_VoiceMemoDeliveryAnnotations> ] ;
    narr:variation [ narr:text "Scarlet's blockquotes usually function as supporting evidence, but in one memo they operate as axioms the document derives from — a structurally distinct rhetorical mode borrowed from philosophical argument, not voice-memo transcription." ; narr:over <https://aswritten.ai/narrative#StyleObs_VerbatimBlockquote> ; narr:over <https://aswritten.ai/narrative#StyleObs_OnboardingMethodology_BlockquoteVoice> ] ;
    narr:variation [ narr:text "The new acoustic rich-transcription format (Jul 2026) introduces per-span delivery signals — pitch, energy, pause, rate — that go beyond verbatim text preservation; this is a different and newer paradigm than the plain blockquote convention documented everywhere else in the hub." ; narr:over <https://aswritten.ai/narrative#StyleObs_VoiceMemoDeliveryAnnotations> ; narr:over <https://aswritten.ai/narrative#StyleObs_ScarletDeliberateWordSearching> ] ;
    narr:variation [ narr:text "The phrasing rule rejects coined compressions as AI-sounding, yet the hub also documents 'compression anxiety' as a legitimate Scarlet idiolect coinage — a coined compound noun that names a psychological state; the boundary between acceptable coinage and rejected compression is not resolved here." ; narr:over <https://aswritten.ai/narrative#Narrative_ConversationalPhrasingRule> ; narr:over <https://aswritten.ai/narrative#StyleObs_10> ] ;
    narr:variation [ narr:text "a consultant who ran enterprise discovery engagements for fifteen years's idiolect (RFC/IETF vocabulary, HATEOAS, historical computing metaphors) is structurally unlike every other speaker catalogued — technical-philosophical rather than conversational-strategic — and stands as an outlier to the dominant Scarlet/the customer's chief architect/Tony register cluster." ; narr:over <https://aswritten.ai/narrative#StyleObs_DiscoveryConsultantCallRegister> ] ;
    narr:variation [ narr:text "Scarlet's high-stakes authorization speech (lowercase, imperative, no hedging in chat) contrasts with her analytical, self-interrupting spoken register in calls — the same speaker presents two distinct idiolect modes depending on channel." ; narr:over <https://aswritten.ai/narrative#StyleObs_ScarletLowercaseDirectQuote> ; narr:over <https://aswritten.ai/narrative#StyleObs_VisionFrameDirectQuote> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
