@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__VerbChoice> {
  <https://aswritten.ai/narrative#Digest_ns__VerbChoice> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#VerbChoice> ;
    narr:childCount "6"^^xsd:integer ;
    narr:generatedFrom "77c2500aa8cfdfcafe4414ac5a0505a939804cce" ;
    narr:narration """This hub tracks the evolution of verb choice within aswritten.ai’s messaging, where technical precision meets organizational process. The core lexicon leans heavily on [git-adjacent metaphors](narr:StyleObs_verb_compile) and [process-oriented technicality](narr:StyleObs_3), framing organizational change as a series of iterative, high-speed compilations. This technical register is anchored by a [strictly active-voice syntax](narr:StyleObs_ActiveVoice) that eliminates hedging, favoring direct agency through verbs like \"eliminate\" and \"make.\" Complementing this, the messaging employs [concrete economic and operational verbs](narr:StyleObs_VerbChoice_ActionVerbs) to ground abstract strategy in measurable outcomes, a pattern mirrored in the [quantified, direct phrasing](narr:StyleObs_ICPQuote) found in ICP-facing communications. While the dominant tone is one of technical confidence, the register remains porous, occasionally admitting [colloquial validation phrases](narr:StyleObs_2) to bridge the gap between high-level process and informal, hands-on testing.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_2> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_3> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_ActiveVoice> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_ICPQuote> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_VerbChoice_ActionVerbs> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_verb_compile> ;
    narr:keyPhrase [ narr:text "recompiles everything and gets us, you know, closer and closer to where we want to go" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_3> ] ;
    narr:keyPhrase [ narr:text "We eliminate the 3-6 month AI onboarding tax. We make knowledge loss on departure impossible." ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_ActiveVoice> ] ;
    narr:keyPhrase [ narr:text "compile" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_verb_compile> ] ;
    narr:keyPhrase [ narr:text "kick the tires" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_2> ] ;
    narr:keyPhrase [ narr:text "You're looking for a dev shop that's got 10 to 50 people, probably something like 10 to [amount] in revenue." ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_ICPQuote> ] ;
    narr:variation [ narr:text "The colloquial 'kick the tires' introduces an informal register that contrasts with the rigid, technical 'compile' metaphor." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_2> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_verb_compile> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}