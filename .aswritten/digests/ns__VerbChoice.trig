GRAPH <https://aswritten.ai/narrative#Digest_ns__VerbChoice> {
  <https://aswritten.ai/narrative#Digest_ns__VerbChoice> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#VerbChoice> ;
    narr:childCount "10"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """This hub gathers style observations on **verb choice** across aswritten.ai's pitch and messaging. The dominant pattern is a deliberate import of code/git vocabulary into organizational process: [recompiles as org-iteration](narr:StyleObs_3), the bare power verb [compile](narr:StyleObs_verb_compile), and the [notices/draft/commit/review/update sequence](narr:StyleObs_5) that runs git-parallel without demanding git knowledge. Alongside this runs a strong [active-voice, no-hedge register](narr:StyleObs_ActiveVoice) — \"We eliminate,\" \"We make\" — and clusters of [strong SVO action verbs](narr:StyleObs_ActiveVerbs) (unlocks, triggers, propagates) and [concrete economic verbs](narr:StyleObs_VerbChoice_ActionVerbs) (investing, leaking, cutting). The brand signature lands as a [phrasal verb, \"remember as written\"](narr:StyleObs_verb_1). Countervailing the technical register, a [colloquial validation phrase, \"kick the tires\"](narr:StyleObs_2) keeps the voice informal, and an [ICP quote](narr:StyleObs_ICPQuote) carries quantified, active phrasing.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_2> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_3> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_5> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_ActiveVerbs> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_ActiveVoice> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_ICPQuote> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_Institutionalize> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_VerbChoice_ActionVerbs> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_verb_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_verb_compile> ;
    narr:keyPhrase [ narr:text "kick the tires" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_2> ] ;
    narr:keyPhrase [ narr:text "recompiles everything and gets us, you know, closer and closer to where we want to go" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_3> ] ;
    narr:keyPhrase [ narr:text "When your AI notices something important in your work, you draft a memory together, commit it to the witness repository, review with your team" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_5> ] ;
    narr:keyPhrase [ narr:text "We eliminate the 3-6 month AI onboarding tax. We make knowledge loss on departure impossible." ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_ActiveVoice> ] ;
    narr:keyPhrase [ narr:text "How do you institutionalize that for like that architect example?" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_Institutionalize> ] ;
    narr:keyPhrase [ narr:text "remember as written" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_verb_1> ] ;
    narr:keyPhrase [ narr:text "compile" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_verb_compile> ] ;
    narr:variation [ narr:text "Register split: technical/code verbs (recompile, compile, commit) sit against the colloquial \"kick the tires\" — precision vs. informality in the same voice." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_verb_compile> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_3> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_2> ] ;
    narr:variation [ narr:text "\"Institutionalize\" comes from Tony (an interlocutor), not the brand's own copy — an externally-sourced verb rather than the house vocabulary." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_Institutionalize> ] ;
    narr:variation [ narr:text "Two distinct action-verb families coexist: systems/mechanism verbs (unlocks, triggers, propagates, collapses) vs. plain economic verbs (investing, leaking, cutting)." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_ActiveVerbs> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_VerbChoice_ActionVerbs> ] ;
    narr:variation [ narr:text "Outlier evidence: the ActionVerbs child asserts strong verbs but carries no verbatim quotes to witness them." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_VerbChoice_ActionVerbs> ] ;
    narr:variation [ narr:text "Lone attachment by skos:related (not broader): the active-voice observation is linked associatively, not as a sub-type of verb choice." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_ActiveVoice> ] ;
    narr:writer "claude (subscription)" .
}