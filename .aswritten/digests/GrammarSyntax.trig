@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_GrammarSyntax> {
  <https://aswritten.ai/narrative#Digest_GrammarSyntax> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#GrammarSyntax> ;
    narr:childCount "11"^^xsd:integer ;
    narr:generatedFrom "a2fd073d60e04942bcc868e2b10e574c782d2885" ;
    narr:narration """Scarlet’s writing architecture is defined by a rigorous commitment to [active-voice](narr:StyleObs_10) construction and procedural clarity, designed to convey logical inevitability. Her prose relies on [deliberate antithesis](narr:StyleObs_9) to sharpen conceptual distinctions, often pairing these with [bold lead-phrase formatting](narr:StyleObs_10) or [hybrid inline-bold headers](narr:StyleObs_BoldHeadingStructure) to separate labels from elaboration. This structural discipline extends into [imperative-mood numbered lists](narr:StyleObs_ImperativeNumberedList) and [parallel bullet structures](narr:StyleObs_BulletParallelism) that enforce a taxonomic mode of thought. A distinct technical register emerges through [arrow-flow notation](narr:StyleObs_ArrowFlowNotation) and [arrow-linked verb chains](narr:StyleObs_ArrowParallelism), which compress complex sequential processes into linear, readable paths. Pedagogical intent is signaled by [three-column classification tables](narr:StyleObs_TableClassification) that force the reader to apply abstract rules to concrete cases. Throughout, her idiolect—marked by [coined mechanical metaphors](narr:StyleObs_5)—frames the extraction pipeline as an active, ideological apparatus. The writing often shifts between high-level architectural abstraction and [quoted direct speech](narr:StyleObs_6), using the latter to ground systemic claims in human-centric UX failure or internal dialogue.""" ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_10> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_5> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_6> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_9> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ArrowFlowNotation> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ArrowParallelism> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_BoldHeadingStructure> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_BulletParallelism> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_BulletedConsequences> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ImperativeNumberedList> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TableClassification> ;
    narr:keyPhrase [ narr:text "I built aswritten to feather our arrows, that our first attempt may always take us further in the direction we're headed." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_5> ] ;
    narr:keyPhrase [ narr:text "extract → lens → micro-telltale → human feedback → modify triples → re-lens → repeat" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ArrowParallelism> ] ;
    narr:keyPhrase [ narr:text "The physics never changed. The substrate did" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_6> ] ;
    narr:keyPhrase [ narr:text "This makes annotation a knowledge growth driver, not just a verification tool." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_9> ] ;
    narr:keyPhrase [ narr:text "This is my life's work." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_9> ] ;
    narr:keyPhrase [ narr:text "| Content | Classification | Why |" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TableClassification> ] ;
    narr:variation [ narr:text "The use of 'meta-transparency' devices like explicit confidence labels pushes against the otherwise purely procedural tone." ; narr:over <https://aswritten.ai/narrative#StyleObs_10> ] ;
    narr:variation [ narr:text "The inclusion of dramatic internal dialogue (Enneagram-based) introduces a subjective, psychological layer that contrasts with the mechanical metaphors." ; narr:over <https://aswritten.ai/narrative#StyleObs_6> ] ;
    narr:variation [ narr:text "The 'asymptotic approach' metaphor suggests a progressive, non-binary convergence that challenges the rigid, gate-based taxonomy found elsewhere." ; narr:over <https://aswritten.ai/narrative#StyleObs_5> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}