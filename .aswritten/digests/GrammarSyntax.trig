@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_GrammarSyntax> {
  <https://aswritten.ai/narrative#Digest_GrammarSyntax> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#GrammarSyntax> ;
    narr:childCount "11"^^xsd:integer ;
    narr:generatedFrom "7eb643eea3e64e8b7582c344ab0465f5ca686f43" ;
    narr:narration """Scarlet’s writing is defined by a rigorous, [active-voice](narr:StyleObs_10) architecture that prioritizes scannability and procedural clarity. The prose relies on [deliberate antithesis](narr:StyleObs_9) ('not X but Y') to sharpen conceptual distinctions, often anchored by [bold lead-phrase formatting](narr:StyleObs_10) that separates labels from elaboration. This structural discipline extends into [imperative-mood numbered lists](narr:StyleObs_ImperativeNumberedList) and [parallel bullet structures](narr:StyleObs_BulletParallelism) designed to convey logical inevitability. A distinct technical register emerges through [arrow-flow notation](narr:StyleObs_ArrowFlowNotation) and [arrow-linked verb chains](narr:StyleObs_ArrowParallelism), which compress complex sequential processes into linear, readable paths. Pedagogical intent is frequently signaled by [three-column classification tables](narr:StyleObs_TableClassification) and [hybrid inline-bold headers](narr:StyleObs_BoldHeadingStructure), which force the reader to apply abstract rules to concrete cases. Throughout, her idiolect—marked by [coined mechanical metaphors](narr:StyleObs_5) like 'opinion machine' and 'bootload a worldview'—serves to frame the extraction pipeline as an active, ideological apparatus rather than a neutral tool.""" ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_10> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_5> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_6> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_9> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ArrowFlowNotation> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ArrowParallelism> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_BoldHeadingStructure> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_BulletParallelism> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_BulletedConsequences> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ImperativeNumberedList> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TableClassification> ;
    narr:keyPhrase [ narr:text "I built aswritten to feather our arrows, that our first attempt may always take us further in the direction we're headed." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_5> ] ;
    narr:keyPhrase [ narr:text "annotation augments the agent's response — it doesn't replace it" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_6> ] ;
    narr:keyPhrase [ narr:text "This makes annotation a knowledge growth driver, not just a verification tool." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_9> ] ;
    narr:keyPhrase [ narr:text "extract → lens → micro-telltale → human feedback → modify triples → re-lens → repeat" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ArrowParallelism> ] ;
    narr:keyPhrase [ narr:text "The physics never changed. The substrate did" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_6> ] ;
    narr:variation [ narr:text "The use of 'Conviction' and 'Confidence' labels introduces a layer of meta-transparency that contrasts with the otherwise purely procedural tone." ; narr:over <https://aswritten.ai/narrative#StyleObs_10> ] ;
    narr:variation [ narr:text "The 'optometrist' model uses biological and spatial metaphors to describe UX, diverging from the dominant mechanical/engineering register." ; narr:over <https://aswritten.ai/narrative#StyleObs_5> ] ;
    narr:variation [ narr:text "Embedded first-person testimony and dramatic internal dialogue occasionally break the authoritative, declarative flow." ; narr:over <https://aswritten.ai/narrative#StyleObs_6> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}