    narr:keyPhrase [ narr:text "I sold a dream" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_5> ] ;
    narr:keyPhrase [ narr:text "The physics never changed. The substrate did" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_6> ] ;
    narr:keyPhrase [ narr:text "extract → lens → micro-telltale → human feedback → modify triples → re-lens → repeat" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ArrowParallelism> ] ;
    narr:keyPhrase [ narr:text "**n8n executions API**" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_BoldBulletStructure> ] ;
    narr:keyPhrase [ narr:text "**SQLite single-writer lock**" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_BulletedFailureModeStructure> ] ;
    narr:keyPhrase [ narr:text "Cents, not dollars." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_9> ] ;
    narr:keyPhrase [ narr:text "| Content | Classification | Why |" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TableClassification> ] ;
    narr:variation [ narr:text "Register split: personal/essayistic voice (em-dash elaboration, first-person declarative) coexists with a technical/engineering register (arrow notation, inline code backticks, classification tables) — the same author switches modes by document." ; narr:over <https://aswritten.ai/narrative#StyleObs_5> ; narr:over <https://aswritten.ai/narrative#StyleObs_ArrowFlowNotation> ; narr:over <https://aswritten.ai/narrative#StyleObs_TableClassification> ; narr:over <https://aswritten.ai/narrative#StyleObs_BoldBulletStructure> ] ;
    narr:variation [ narr:text "Hybrid heading structures push against clean hierarchy: bold numbered/labeled phrases used inline as section headers instead of full H3s — parallel structure signaled without the heading machinery." ; narr:over <https://aswritten.ai/narrative#StyleObs_BoldHeadingStructure> ; narr:over <https://aswritten.ai/narrative#StyleObs_BulletParallelism> ] ;
    narr:variation [ narr:text "Coined idiolect metaphors ('compression anxiety', 'bootload a new worldview', 'opinion machine') are an outlier layer over the otherwise plain structural patterns — signature, not template." ; narr:over <https://aswritten.ai/narrative#StyleObs_10> ; narr:over <https://aswritten.ai/narrative#StyleObs_6> ; narr:over <https://aswritten.ai/narrative#StyleObs_5> ] ;
    narr:variation [ narr:text "Explicit meta-transparency devices — document-level conviction/confidence labels and self-aware commentary on document placement — are an unusual framing move not reducible to ordinary grammar/syntax." ; narr:over <https://aswritten.ai/narrative#StyleObs_10> ; narr:over <https://aswritten.ai/narrative#StyleObs_9> ] ;
