@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Calibration> {
  <https://aswritten.ai/narrative#Digest_Calibration> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Calibration> ;
    narr:childCount "9"^^xsd:integer ;
    narr:generatedFrom "8ac1da43cb2b54f00119480edfd6e1eb98fef709" ;
    narr:narration """Calibration gathers how aswritten validates its own quality. The optometric strand persists: [eye chart as fixed reference](narr:Position_8) holds that \"lens changes, eye chart stays constant,\" and the [\"Better through A or B?\" idiom](narr:StyleObs_BetterThroughAOrB) encapsulates the convergence-testing mechanism. [Soak testing](narr:Narrative_SoakTestQuality) insists quality \"requires sustained real-world use, not unit tests\" — a timescale argument against premature sign-off. The sharpest new addition (Jul 2, 2026) is the [cold sub-agent test](narr:Narrative_ColdSubAgentTest): spawn a zero-knowledge agent with only a goal and a URL and see whether it can discover everything from first principles — Boolean, re-runnable, zero-state, and proposed as a candidate eval for aswritten's own digest navigability. Supporting quote-nodes from the same session elaborate the [breadcrumbs criterion](narr:Obs_DiscoveryConsultantBreadcrumbsQuote) and the [falsifiability framing](narr:Obs_DiscoveryConsultantFalsifiableQuote). Style observations sit alongside as craft notes on rhetorical devices used in calibration-adjacent writing.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ColdSubAgentTest> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_SoakTestQuality> ;
    narr:covers <https://aswritten.ai/narrative#Obs_DiscoveryConsultantBreadcrumbsQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_DiscoveryConsultantFalsifiableQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_DiscoveryConsultantOnlyTestQuote> ;
    narr:covers <https://aswritten.ai/narrative#Position_8> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_2> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_7> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_BetterThroughAOrB> ;
    narr:keyPhrase [ narr:text "lens changes, eye chart stays constant" ; narr:phraseSource <https://aswritten.ai/narrative#Position_8> ] ;
    narr:keyPhrase [ narr:text "Quality validation requires sustained real-world use, not unit tests" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_SoakTestQuality> ] ;
    narr:keyPhrase [ narr:text "Is it possible for an agent, given a goal and given a website, to discover everything it needs from first principles to do that thing?" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ColdSubAgentTest> ] ;
    narr:keyPhrase [ narr:text "That's the only test that counts." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ColdSubAgentTest> ] ;
    narr:keyPhrase [ narr:text "Cold sub-agent test: spawn a zero-knowledge sub-agent with only a goal and URL; the only test that counts" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ColdSubAgentTest> ] ;
    narr:keyPhrase [ narr:text "Optometrist idiom used as a rhetorical device to frame convergence testing: 'Better through A or B?' encapsulates the entire lens comparison mechanism." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_BetterThroughAOrB> ] ;
    narr:keyPhrase [ narr:text "'Quality gate theater' — compound noun coinage; dismissive framing of a failed process pattern" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_7> ] ;
    narr:variation [ narr:text "Soak testing (sustained real-world use over days/weeks) and the cold sub-agent test (Boolean, immediate, re-runnable) represent competing timescale assumptions about what valid calibration requires." ; narr:over <https://aswritten.ai/narrative#Narrative_SoakTestQuality> ; narr:over <https://aswritten.ai/narrative#Narrative_ColdSubAgentTest> ] ;
    narr:variation [ narr:text "The cold sub-agent test is framed as a candidate eval for aswritten's own navigability — a self-referential application not present in the optometric or soak-testing strands." ; narr:over <https://aswritten.ai/narrative#Narrative_ColdSubAgentTest> ] ;
    narr:variation [ narr:text "Style observations carry calibration-adjacent craft content (rhetorical devices, conviction-level markers, 'quality gate theater') that sits obliquely to the testing-method frame — related but not subordinate to it." ; narr:over <https://aswritten.ai/narrative#StyleObs_7> ; narr:over <https://aswritten.ai/narrative#StyleObs_2> ; narr:over <https://aswritten.ai/narrative#StyleObs_BetterThroughAOrB> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}