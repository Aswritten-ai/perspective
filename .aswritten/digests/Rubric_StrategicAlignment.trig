    narr:covers <https://aswritten.ai/narrative#Rubric_StrategicAlignment_YC_Call> ;
    narr:keyPhrase [ narr:text "collective memory as foundation for AI-native teams" ; narr:phraseSource <https://aswritten.ai/narrative#Assessment_StrategicAlignment_YC> ] ;
    narr:keyPhrase [ narr:text "'narrative as vector' is both the story and the product thesis" ; narr:phraseSource <https://aswritten.ai/narrative#RubricAssess_StrategicAlignment> ] ;
    narr:keyPhrase [ narr:text "side-door GTM, strategic capability as moat, high-touch delivery model" ; narr:phraseSource <https://aswritten.ai/narrative#RubricAssess_StrategicAlignment_Sample1> ] ;
    narr:keyPhrase [ narr:text "knowledge extraction beachhead" ; narr:phraseSource <https://aswritten.ai/narrative#RubricAssess_StrategicAlignment_WeeklyCall> ] ;
    narr:keyPhrase [ narr:text "surfaces new ICP (operations persona)" ; narr:phraseSource <https://aswritten.ai/narrative#Rubric_StrategicAlignment_FounderBetaUser> ] ;
    narr:keyPhrase [ narr:text "AI-to-AI provenance (moat)" ; narr:phraseSource <https://aswritten.ai/narrative#Rubric_StrategicAlignment_CustomerArchitect> ] ;
    narr:keyPhrase [ narr:text "narrative as steering vector" ; narr:phraseSource <https://aswritten.ai/narrative#Rubric_StrategicAlignment_ScarletDame> ] ;
    narr:variation [ narr:text "ICP is not settled: architecture-teams beachhead vs. a newly surfaced operations persona — different buyers under the same thesis." ; narr:over <https://aswritten.ai/narrative#RubricAssess_StrategicAlignment_WeeklyCall> ; narr:over <https://aswritten.ai/narrative#Rubric_StrategicAlignment_FounderBetaUser> ] ;
    narr:variation [ narr:text "GTM motion diverges: high-touch consultant-led/side-door delivery vs. a VC channel opportunity flagged in the a founder beta user call." ; narr:over <https://aswritten.ai/narrative#RubricAssess_Strategy_GTM> ; narr:over <https://aswritten.ai/narrative#RubricAssess_StrategicAlignment_Sample1> ; narr:over <https://aswritten.ai/narrative#Rubric_StrategicAlignment_FounderBetaUser> ] ;
    narr:variation [ narr:text "Enterprise/on-prem, compliance, and AI-to-AI provenance frame the moat narrowly, against the broader org-level 'collective memory' framing elsewhere." ; narr:over <https://aswritten.ai/narrative#Rubric_StrategicAlignment_CustomerArchitect> ; narr:over <https://aswritten.ai/narrative#Rubric_StrategicAlignment_PilotPlan> ] ;
