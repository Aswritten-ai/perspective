@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_ContentCommentarySplit> {
  <https://aswritten.ai/narrative#Digest_Narrative_ContentCommentarySplit> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ;
    narr:childCount "4"^^xsd:integer ;
    narr:generatedFrom "7b7c8bb9c6f73b5bfe4063008256f42e095034df" ;
    narr:narration """The hub frames a structural distinction between two layers of knowledge representation: [per-message primary source material](narr:https://aswritten.ai/narrative#Position_ContentLayerPerMessage) transacted individually as it happens, and [authored reconciliation as commentary](narr:https://aswritten.ai/narrative#Position_ReconciliationIsCommentaryLayer) written over a referent set after the fact. As of July 1 2026, the read model already honors this split — digests render primary-source grounding separately from a RECONCILED conclusion — but the write practice has not caught up, conflating the two by requiring memories to carry primary source content themselves. [Reconciliation as set transaction](narr:https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction) develops the structural form: select a set of nodes, author something about them, surface which nodes the system is reasoning from — the legibility differentiator. By July 4, the principle had been extended outward: [the landing page IA](narr:https://aswritten.ai/narrative#Narrative_LandingPageEpistemicArchitecture) mirrors the product's own epistemics, applying the content/commentary split to the marketing surface itself.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_LandingPageEpistemicArchitecture> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction> ;
    narr:covers <https://aswritten.ai/narrative#Position_ContentLayerPerMessage> ;
    narr:covers <https://aswritten.ai/narrative#Position_ReconciliationIsCommentaryLayer> ;
    narr:keyPhrase [ narr:text "Per-message integration is the content layer. Each message's primary source material is transacted individually as it happens." ; narr:phraseSource <https://aswritten.ai/narrative#Position_ContentLayerPerMessage> ] ;
    narr:keyPhrase [ narr:text "The read model already separates primary-source grounding from authored reconciliation (the digest renders a position grounded in source plus a separate RECONCILED conclusion)." ; narr:phraseSource <https://aswritten.ai/narrative#Position_ReconciliationIsCommentaryLayer> ] ;
    narr:keyPhrase [ narr:text "Reconciliation is a transaction about a set of transactions or nodes — the design of correction and commentary about the past" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction> ] ;
    narr:keyPhrase [ narr:text "Disambiguate, never permission — the prompt rule." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction> ] ;
    narr:keyPhrase [ narr:text "The landing page's information architecture mirrors the product's own epistemics: primary source material plus commentary and framing" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_LandingPageEpistemicArchitecture> ] ;
    narr:variation [ narr:text "Write practice has not caught up to read model: the split is implemented on read but conflated on write, with memories still required to carry primary source content themselves — an unresolved asymmetry as of July 1." ; narr:over <https://aswritten.ai/narrative#Position_ReconciliationIsCommentaryLayer> ; narr:over <https://aswritten.ai/narrative#Position_ContentLayerPerMessage> ] ;
    narr:variation [ narr:text "The legibility claim — that aswritten surfaces the referent set explicitly unlike current AI use — is asserted but not yet demonstrated by a write-path implementation, leaving the differentiator as design intent rather than shipped behavior." ; narr:over <https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}