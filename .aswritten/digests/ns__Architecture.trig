@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__Architecture> {
  <https://aswritten.ai/narrative#Digest_ns__Architecture> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#Architecture> ;
    narr:childCount "7"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """The Architecture hub frames an organization's worldview as the single source of truth from which everything else is rendered. The mainline is a compilation model: [worldview as source, outputs as compiled targets](narr:Narrative_CompilationTargets) treats content, apps, and code as renders from worldview state. This rests on a [Git-centric repo of record](narr:Narrative_RepoAsSourceOfTruth) — content committed before extraction, GitHub Actions for async processing, append-only transactions — and is made legible by [branchable worldview](narr:Narrative_BranchingWorldview), where direction changes are explicit, reviewable, testable like code. Two feedback/interface mechanisms sit alongside: [telltales as drift detectors](narr:Narrative_Telltales), recompiled stories that surface worldview drift, and a [dual chat/Discourse interface](narr:Narrative_TwoInterfaceModel) splitting fast iteration from async collaboration. The motivating premise is the [white-space argument](narr:Narrative_WhiteSpace): absent an explicit worldview, AI agents default to their training distribution, so worldview engineering prevents drift — and the payoff named is [agents that code with business strategy](narr:ValueProp_4).""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_BranchingWorldview> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_CompilationTargets> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_RepoAsSourceOfTruth> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_Telltales> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_TwoInterfaceModel> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_WhiteSpace> ;
    narr:covers <https://aswritten.ai/ns/narrative#ValueProp_4> ;
    narr:keyPhrase [ narr:text "Content, apps, code as renders from worldview; functional transformation from worldview state to outputs" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_CompilationTargets> ] ;
    narr:keyPhrase [ narr:text "All content committed to Git before extraction; GitHub Actions handle async processing; append-only transactions" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_RepoAsSourceOfTruth> ] ;
    narr:keyPhrase [ narr:text "Automatically recompiled stories serve as sensitive instruments for detecting worldview drift." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_Telltales> ] ;
    narr:keyPhrase [ narr:text "Without organizational worldview, AI agents default to training distribution; worldview engineering prevents drift." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_WhiteSpace> ] ;
    narr:keyPhrase [ narr:text "Worldview becomes branchable like code; direction changes are explicit, reviewable, testable." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_BranchingWorldview> ] ;
    narr:keyPhrase [ narr:text "Coding agents that understand business strategy while implementing" ; narr:phraseSource <https://aswritten.ai/ns/narrative#ValueProp_4> ] ;
    narr:variation [ narr:text "Two children attach as skos:related rather than broader (branching, white-space) plus ValueProp_4 — motivating premises and value claims, not structural components; they justify the architecture rather than constitute it." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_BranchingWorldview> ; narr:over <https://aswritten.ai/ns/narrative#Narrative_WhiteSpace> ; narr:over <https://aswritten.ai/ns/narrative#ValueProp_4> ] ;
    narr:variation [ narr:text "Telltales and the dual interface are runtime/feedback concerns (drift detection, human collaboration workflow) sitting beside the build-time compilation pipeline — a distinct layer that could be read as observability rather than core architecture." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_Telltales> ; narr:over <https://aswritten.ai/ns/narrative#Narrative_TwoInterfaceModel> ] ;
    narr:variation [ narr:text "The compile-everything-from-worldview thesis and the append-only Git-of-record thesis both claim source-of-truth status; whether worldview or the repo is the true ground is left implicit." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_CompilationTargets> ; narr:over <https://aswritten.ai/ns/narrative#Narrative_RepoAsSourceOfTruth> ] ;
    narr:writer "claude (subscription)" .
}