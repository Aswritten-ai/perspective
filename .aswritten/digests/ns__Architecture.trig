@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__Architecture> {
  <https://aswritten.ai/narrative#Digest_ns__Architecture> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#Architecture> ;
    narr:childCount "6"^^xsd:integer ;
    narr:generatedFrom "0e5879a376195ee142e60cdad54aa1d9bb528726" ;
    narr:narration """The Architecture hub defines an organization's worldview as the primary source of truth, treating all outputs—content, applications, and code—as [functional renders from worldview state](narr:Narrative_CompilationTargets). This framework relies on a [Git-centric architecture](narr:Narrative_RepoAsSourceOfTruth) where all content is committed prior to extraction, enabling append-only transactions and automated asynchronous processing. To maintain alignment, the system employs [version-controlled worldview evolution](narr:Narrative_BranchingWorldview), allowing strategic shifts to be managed with the same rigor as software changes. The model is guarded by [drift detection via recompiled stories](narr:Narrative_Telltales) and a [dual interface architecture](narr:Narrative_TwoInterfaceModel) that separates rapid chat-based iteration from structured, asynchronous collaboration. The core motivation remains the [prevention of training-distribution drift](narr:Narrative_WhiteSpace), ensuring that AI agents operate within the bounds of explicit organizational strategy rather than defaulting to generic training priors.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_BranchingWorldview> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_CompilationTargets> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_RepoAsSourceOfTruth> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_Telltales> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_TwoInterfaceModel> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_WhiteSpace> ;
    narr:keyPhrase [ narr:text "functional transformation from worldview state to outputs" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_CompilationTargets> ] ;
    narr:keyPhrase [ narr:text "All content committed to Git before extraction" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_RepoAsSourceOfTruth> ] ;
    narr:keyPhrase [ narr:text "Worldview becomes branchable like code" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_BranchingWorldview> ] ;
    narr:keyPhrase [ narr:text "Automatically recompiled stories serve as sensitive instruments for detecting worldview drift." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_Telltales> ] ;
    narr:keyPhrase [ narr:text "Without organizational worldview, AI agents default to training distribution" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_WhiteSpace> ] ;
    narr:variation [ narr:text "The model assumes a high-friction 'commit-first' workflow, which may conflict with needs for extreme low-latency, un-versioned experimentation." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_RepoAsSourceOfTruth> ] ;
    narr:variation [ narr:text "The dual-interface model implies a potential fragmentation between 'fast' and 'async' knowledge, risking a disconnect between chat-based insights and the source-of-truth repo." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_TwoInterfaceModel> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}