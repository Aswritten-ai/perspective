    narr:keyPhrase [ narr:text "Narrative as steering vector for generative systems" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_SteeringVector> ] ;
    narr:keyPhrase [ narr:text "institutional knowledge at the cursor" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_StockPhrase_InstitutionalKnowledge> ] ;
    narr:keyPhrase [ narr:text "senior expert bottleneck" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_StockPhrase_SeniorExpertBottleneck> ] ;
    narr:keyPhrase [ narr:text "collective memory" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_CollectiveMemory> ] ;
    narr:keyPhrase [ narr:text "It's both an amazing product and not a product at all" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AmazingProductNotProduct> ] ;
    narr:keyPhrase [ narr:text "You're not selling panacea. You're selling a topical solution for a specific problem." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_NotSellingPanacea> ] ;
    narr:keyPhrase [ narr:text "where you've been, what you've decided, and where you're headed" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_RuleOfThree_Direction> ] ;
    narr:variation [ narr:text "Memorability vs operational clarity: punchy taglines ('think like your org') compete against precise technical-buyer framing ('cited or flagged as ungrounded'), which trades memorability for legibility." ; narr:over <https://aswritten.ai/narrative#StyleObs_ThinkLikeYourOrg> ; narr:over <https://aswritten.ai/narrative#StyleObs_CitedOrFlagged> ] ;
    narr:variation [ narr:text "Unresolved strategic antithesis surfaced as a genuine tension: 'what we're testing' vs. 'what we sell.'" ; narr:over <https://aswritten.ai/narrative#StyleObs_TestingVsSelling> ] ;
    narr:variation [ narr:text "The opening hook is not stable — the hallucination question and 'context engineering' are framed as replacing/reframing the earlier enterprise opening." ; narr:over <https://aswritten.ai/narrative#Obs_KeyPhrase_Hallucinating> ; narr:over <https://aswritten.ai/narrative#Obs_KeyPhrase_ContextEngineering> ] ;
    narr:variation [ narr:text "Grand worldview/infrastructure framing pulls against deliberately narrow scoping: 'topical solution for a specific problem,' not a panacea." ; narr:over <https://aswritten.ai/narrative#StyleObs_NotSellingPanacea> ; narr:over <https://aswritten.ai/narrative#StyleObs_WorldviewFraming> ] ;
    narr:variation [ narr:text "Product-identity paradox left open: an 'amazing product and not a product at all' — celebrated yet unvalidated." ; narr:over <https://aswritten.ai/narrative#StyleObs_AmazingProductNotProduct> ] ;
    narr:variation [ narr:text "Register split in the corpus: formal conviction-labeled taxonomy vs. verbatim lowercase brain-dump idiolect — two coexisting voices, not one." ; narr:over <https://aswritten.ai/narrative#StyleObs_8> ; narr:over <https://aswritten.ai/narrative#StyleObs_ScarletVerbatimQuotes> ] ;
