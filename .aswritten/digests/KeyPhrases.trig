    narr:keyPhrase [ narr:text "aswritten's vocabulary — \"collective memory,\" \"worldview layer,\" \"knowledge extraction\" — differentiates clearly while speaking to the same buyer pain." ; narr:phraseSource <https://aswritten.ai/narrative#Observation_KeyPhrases_1> ] ;
    narr:keyPhrase [ narr:text "I treated the models themselves like a computer, and a narrative architecture - an interconnected web of narratives that define a way of thinking - like a program that can be installed onto their hardware." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:keyPhrase [ narr:text "I built aswritten to feather our arrows, that our first attempt may always take us further in the direction we're headed. That our work is to adjust our heading so that all arrows find target, not spend our time moving the ones that already missed." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_5> ] ;
    narr:keyPhrase [ narr:text "It's both an amazing product and not a product at all" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AmazingProductNotProduct> ] ;
    narr:keyPhrase [ narr:text "System generates micro-telltales — small content artifacts that exercise the triples in a given lens." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_LensMicroTelltale> ] ;
    narr:variation [ narr:text "Tension between 'testing' vs 'selling' as a strategic boundary for the product's identity." ; narr:over <https://aswritten.ai/narrative#StyleObs_TestingVsSelling> ] ;
    narr:variation [ narr:text "The paradox of a product that is simultaneously 'amazing' and 'not a product at all'." ; narr:over <https://aswritten.ai/narrative#StyleObs_AmazingProductNotProduct> ] ;
    narr:variation [ narr:text "The shift from enterprise-framing to 'hallucination' as the primary hook, potentially alienating legacy buyers." ; narr:over <https://aswritten.ai/narrative#Obs_KeyPhrase_Hallucinating> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
