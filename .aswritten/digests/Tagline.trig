    narr:keyPhrase [ narr:text "Expertise from humans you trust. Cited by AI, aswritten." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_TaglineFinalized> ] ;
    narr:keyPhrase [ narr:text "The product is curated expertise installation." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_TaglineSupersession> ] ;
    narr:keyPhrase [ narr:text "'AI native teams' is WHO, not WHAT or WHY. Missing the 'oh, I want that' factor." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_TaglineGap> ] ;
    narr:keyPhrase [ narr:text "I'm not buying it because it's git native. That may be how you make it happen for me, but that's not why I'm buying it." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_GitNativeNotTagline> ] ;
    narr:keyPhrase [ narr:text "reachability without interruptability" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ReachabilityPhrase> ] ;
    narr:keyPhrase [ narr:text "The Demo IS the Delivery" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_NarrativeAnchor_Tagline> ] ;
    narr:keyPhrase [ narr:text "dream bigger" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_4> ] ;
    narr:variation [ narr:text "Explicit supersession (28 Apr): 'The product is a phone number' deleted in favor of 'curated expertise installation,' with the phone number demoted to enterprise distribution channel — and the deletion must be executed in the same transaction." ; narr:over <https://aswritten.ai/narrative#Claim_TaglineSupersession> ] ;
    narr:variation [ narr:text "No single tagline is crowned: 'Demo IS the Delivery,' 'think like your org' (which explicitly competes with trust-mechanism clarity framing), and 'reachability without interruptability' all coexist as live candidates." ; narr:over <https://aswritten.ai/narrative#Obs_NarrativeAnchor_Tagline> ; narr:over <https://aswritten.ai/narrative#StyleObs_ThinkLikeYourOrg> ; narr:over <https://aswritten.ai/narrative#StyleObs_ReachabilityPhrase> ] ;
    narr:variation [ narr:text "Critique strand pushes against weak taglines — naming WHO over WHAT/WHY, and rejecting git-native as a buying reason despite it being the mechanism." ; narr:over <https://aswritten.ai/narrative#Obs_TaglineGap> ; narr:over <https://aswritten.ai/narrative#Obs_GitNativeNotTagline> ] ;
    narr:variation [ narr:text "Cadence is not uniform: the finalized line is two-beat (trust/proof), while other anchors are three-beat imperative or all-caps 'IS' equation forms." ; narr:over <https://aswritten.ai/narrative#Observation_Tagline> ; narr:over <https://aswritten.ai/narrative#StyleObs_RuleOfThree_Tagline> ; narr:over <https://aswritten.ai/narrative#StyleObs_AllCapsEmphasis> ] ;
    narr:variation [ narr:text "Most children here are style/brand observations (lowercase 'aswritten', em-dash causal pivots, rhetorical 'IS' equations), not tagline candidates — a query for the actual product tagline should route to the finalized/superseded claims, not the StyleObs cluster." ; narr:over <https://aswritten.ai/narrative#StyleObs_BrandName> ; narr:over <https://aswritten.ai/narrative#StyleObs_EmDashCausal> ; narr:over <https://aswritten.ai/narrative#StyleObs_RhetoricalEquation> ] ;
    narr:writer "claude (subscription)" .
