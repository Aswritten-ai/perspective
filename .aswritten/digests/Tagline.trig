    narr:keyPhrase [ narr:text "Expertise from humans you trust. Cited by AI, aswritten." ; narr:phraseSource <https://aswritten.ai/narrative#Position_TaglineFinalized> ] ;
    narr:keyPhrase [ narr:text "Vouch — be recognized" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_DeliStoryQuote3> ] ;
    narr:keyPhrase [ narr:text "reachability without interruptability" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ReachabilityPhrase> ] ;
    narr:keyPhrase [ narr:text "I'm not buying it because it's git native. That may be how you make it happen for me, but that's not why I'm buying it." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_GitNativeNotTagline> ] ;
    narr:keyPhrase [ narr:text "not general, individual. not lab owned. individually owned. not artificial sentience, something that evolves relationally via your conversations/input." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_SII_ThreeAxisAntithesis> ] ;
    narr:variation [ narr:text "Critique of current taglines as identifying the 'who' but failing to communicate the 'why' or value proposition." ; narr:over <https://aswritten.ai/narrative#Obs_TaglineGap> ] ;
    narr:variation [ narr:text "Tension between technical differentiation (git native) and customer-facing value." ; narr:over <https://aswritten.ai/narrative#Obs_GitNativeNotTagline> ] ;
    narr:variation [ narr:text "Alternative tagline candidates like 'think like your org' competing with the trust-mechanism framing." ; narr:over <https://aswritten.ai/narrative#StyleObs_ThinkLikeYourOrg> ] ;
