    narr:keyPhrase [ narr:text "Git native is implementation detail, not customer value." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_GitNativeNotTagline> ] ;
    narr:variation [ narr:text "Critique argues that \"AI native\" taglines identify the WHO but fail to convey the WHAT or WHY." ; narr:over <https://aswritten.ai/narrative#Obs_TaglineGap> ] ;
    narr:variation [ narr:text "Tension exists between technical differentiators (e.g., git-native) and customer-facing value propositions." ; narr:over <https://aswritten.ai/narrative#Obs_GitNativeNotTagline> ] ;
    narr:variation [ narr:text "Alternative tagline candidates like \"think like your org\" persist alongside the finalized trust-proof structure." ; narr:over <https://aswritten.ai/narrative#StyleObs_ThinkLikeYourOrg> ] ;
