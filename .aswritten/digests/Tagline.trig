    narr:keyPhrase [ narr:text "Until someone buys it, it doesn't exist." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_UntilSomeoneBuys> ] ;
    narr:variation [ narr:text "Critique that early taglines focused on 'WHO' (AI-native teams) rather than the 'WHAT/WHY' value proposition." ; narr:over <https://aswritten.ai/narrative#Obs_TaglineGap> ] ;
    narr:variation [ narr:text "Dissenting view that 'git-native' is an implementation detail, not a core customer value." ; narr:over <https://aswritten.ai/narrative#Obs_GitNativeNotTagline> ] ;
    narr:variation [ narr:text "Competing tagline candidates like 'think like your org' and 'reachability without interruptability' remain active alternatives." ; narr:over <https://aswritten.ai/narrative#StyleObs_ThinkLikeYourOrg> ; narr:over <https://aswritten.ai/narrative#StyleObs_ReachabilityPhrase> ] ;
