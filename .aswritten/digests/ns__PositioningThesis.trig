@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__PositioningThesis> {
  <https://aswritten.ai/narrative#Digest_ns__PositioningThesis> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#PositioningThesis> ;
    narr:childCount "13"^^xsd:integer ;
    narr:generatedFrom "09ccbae3b3ef3da10e9f87f2fcd6c9f86b7c171a" ;
    narr:narration """This hub tracks the evolution of aswritten.ai’s strategic identity, centering on the shift from a tool-based narrative to a [worldview-as-product](narr:Narrative_WorldviewAsProduct) thesis. The core positioning, codified in [ADR-002](narr:PositioningThesis_ADR002), defines the platform as a \"worldview layer for AI agents\" rather than a semantic memory API. This is reinforced by a [unified worldview](narr:Narrative_positioning) strategy that contrasts sharply with the [individual-focused memory tools](narr:PositioningThesis_OrgMemory) currently dominating the market. The trajectory emphasizes a [platform-first approach](narr:Narrative_ProductVision), aiming to [extend software development rigor](narr:Narrative_SIC_Mission_1) into broader organizational operations. While the [customer architect's pitch](narr:Narrative_CustomerArchitectPitch) frames the value as an expert-knowledge extraction engine, the [strategic framing table](narr:Insight_FramingTable) suggests that enterprise-level adoption may require a distinct vocabulary—moving from \"AI memory\" to \"institutional methodology.\" The current focus remains on [Seed/Series A CEOs](narr:Observation_PositioningThesis_SeedSeriesA), leveraging the advisor network to establish the platform's [strategic alignment](narr:RubricAssess_Strategy_ADR001).""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Insight_FramingTable> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_CustomerArchitectPitch> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_ProductVision> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_SIC_Mission_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_WorldviewAsProduct> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_positioning> ;
    narr:covers <https://aswritten.ai/ns/narrative#Observation_PositioningThesis_SeedSeriesA> ;
    narr:covers <https://aswritten.ai/ns/narrative#Position_WorldviewAsPrimaryProduct> ;
    narr:covers <https://aswritten.ai/ns/narrative#PositioningThesis_ADR002> ;
    narr:covers <https://aswritten.ai/ns/narrative#PositioningThesis_OrgMemory> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Strategy_ADR001> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_KeyPhrase_PMF> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_PlatformVsInfra> ;
    narr:keyPhrase [ narr:text "Market positioning: \"Worldview layer for AI agents\" (not \"semantic memory API\")" ; narr:phraseSource <https://aswritten.ai/ns/narrative#PositioningThesis_ADR002> ] ;
    narr:keyPhrase [ narr:text "We want to be a platform (complete product users adopt), not infrastructure (low-margin vendor others build on)" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_PlatformVsInfra> ] ;
    narr:keyPhrase [ narr:text "product market fit" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_KeyPhrase_PMF> ] ;
    narr:variation [ narr:text "Enterprise-resonant framing shifts the focus from 'AI memory' to 'institutional methodology' and 'expert bottleneck' resolution." ; narr:over <https://aswritten.ai/ns/narrative#Insight_FramingTable> ] ;
    narr:variation [ narr:text "The tension between 'platform' and 'infrastructure' remains a critical strategic boundary for long-term margin and adoption." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_ProductVision> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_PlatformVsInfra> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}