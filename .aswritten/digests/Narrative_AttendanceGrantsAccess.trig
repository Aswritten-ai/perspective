    narr:keyPhrase [ narr:text "Attendance is the membership primitive; cross-links resolve only with access to the target call; digest narrations of connected nodes are provisionally visible because the digest is the abstraction, not the source." ; narr:phraseSource <https://aswritten.ai/narrative#Expr_1MvpV2ConcisionOneProductRulings_110> ] ;
    narr:keyPhrase [ narr:text "Access falls out of navigation semantics — attendance grants the page." ; narr:phraseSource <https://aswritten.ai/narrative#Expr_1MvpV2ConcisionOneProductRulings_107> ] ;
    narr:keyPhrase [ narr:text "stripped/anonymized/actor-scoped/tiered shares become v2 work." ; narr:phraseSource <https://aswritten.ai/narrative#Expr_1MvpV2ConcisionOneProductRulings_121> ] ;
    narr:keyPhrase [ narr:text "The flagged counterpoint for the deeper pass: digest narrations embed verbatim witness excerpts, which weakens \"not showing the source.\"" ; narr:phraseSource <https://aswritten.ai/narrative#Expr_1MvpV2ConcisionOneProductRulings_111> ] ;
    narr:keyPhrase [ narr:text "full depth for now, it's explicit share and this is a demo. only send it to people i want to see full depth" ; narr:phraseSource <https://aswritten.ai/narrative#Expr_1MvpV2ConcisionOneProductRulings_120> ] ;
    narr:variation [ narr:text "The concern that verbatim excerpts in digests undermine the 'abstraction' defense of access control." ; narr:over <https://aswritten.ai/narrative#Expr_1MvpV2ConcisionOneProductRulings_111> ] ;
    narr:variation [ narr:text "The tension between 'full depth' demo sharing and the desire for stripped/anonymized access." ; narr:over <https://aswritten.ai/narrative#Expr_1MvpV2ConcisionOneProductRulings_120> ; narr:over <https://aswritten.ai/narrative#Expr_1MvpV2ConcisionOneProductRulings_121> ] ;
    narr:variation [ narr:text "The proposal to treat orphaned nodes as CTA placeholders rather than just empty states." ; narr:over <https://aswritten.ai/narrative#Expr_1MvpV2ConcisionOneProductRulings_37> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
