@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__Opportunity> {
  <https://aswritten.ai/narrative#Digest_ns__Opportunity> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#Opportunity> ;
    narr:childCount "5"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """The opportunity is framed through three distinct problem lenses, none crowned. The [strategy-execution disconnect](narr:Narrative_FragmentationProblem) casts it as fragmented coordination across isolated tools where developers lack strategic context. The [existential IP crisis](narr:Narrative_IPCrisis) reframes harder — a paradigm shift from developer convenience to a threat-level business problem, where every employee tells state secrets to AI and models lift IP into training data. The [AI context-quality problem](narr:Narrative_SIC_Opportunity_1) frames it as output quality: high-quality AI work needs extensive context that models currently chase through search. Two related value props attach as outcomes rather than problem framings: [day-1 productivity for new hires](narr:ValueProp_1) and [zero knowledge loss on departure](narr:ValueProp_2). The hub holds coordination, security, and context-quality framings side by side; the value props read across all three.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_FragmentationProblem> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_IPCrisis> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_SIC_Opportunity_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#ValueProp_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#ValueProp_2> ;
    narr:keyPhrase [ narr:text "Strategy-Execution Disconnect" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_FragmentationProblem> ] ;
    narr:keyPhrase [ narr:text "Paradigm shift from developer convenience to threat-level business problem" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_IPCrisis> ] ;
    narr:keyPhrase [ narr:text "Every employee tells state secrets to AI; models lift IP into training data; existential business risk" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_IPCrisis> ] ;
    narr:keyPhrase [ narr:text "Creating high quality output with AI requires extensive context. Currently models are trying to do that with search." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_SIC_Opportunity_1> ] ;
    narr:keyPhrase [ narr:text "Day 1 productivity for new hires" ; narr:phraseSource <https://aswritten.ai/ns/narrative#ValueProp_1> ] ;
    narr:keyPhrase [ narr:text "Zero knowledge loss when people leave" ; narr:phraseSource <https://aswritten.ai/ns/narrative#ValueProp_2> ] ;
    narr:variation [ narr:text "Three competing problem framings, not one: coordination/strategy gap vs. security/IP threat vs. AI output quality — they motivate different products." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_FragmentationProblem> ; narr:over <https://aswritten.ai/ns/narrative#Narrative_IPCrisis> ; narr:over <https://aswritten.ai/ns/narrative#Narrative_SIC_Opportunity_1> ] ;
    narr:variation [ narr:text "IP framing explicitly escalates the stakes — recasting a 'developer convenience' problem as existential business risk, a sharper register than the other two." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_IPCrisis> ] ;
    narr:variation [ narr:text "Structural split: three problem framings attach as broader, while the two value props attach as related outcomes rather than the opportunity itself." ; narr:over <https://aswritten.ai/ns/narrative#ValueProp_1> ; narr:over <https://aswritten.ai/ns/narrative#ValueProp_2> ] ;
    narr:writer "claude (subscription)" .
}