    narr:keyPhrase [ narr:text "structure IS the argument" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DirectListFormat> ] ;
    narr:keyPhrase [ narr:text "the definitive statement of the architecture, not the prose" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TableDrivenArchitecture> ] ;
    narr:keyPhrase [ narr:text "Markdown table used as canonical architecture definition: Tool | Question | Input | Output — four-column single-responsibility matrix" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_FiveToolTable> ] ;
    narr:keyPhrase [ narr:text "This is my life's work." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_9> ] ;
    narr:keyPhrase [ narr:text "Pipeline organized in 9 rings." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_PipelineRings> ] ;
    narr:variation [ narr:text "StyleObs_9 documents a first-person narrative voice (antithesis, active constructions, 'This is my life's work') — a prose-register concern distinct from the structural-formatting mainline." ; narr:over <https://aswritten.ai/narrative#StyleObs_9> ] ;
    narr:variation [ narr:text "Not all-structure: documents shift register by section — strategic prose for funding, checklist for launch, table for timeline — so 'structure is the argument' is qualified, not absolute." ; narr:over <https://aswritten.ai/narrative#StyleObs_BulletedLaunchList> ; narr:over <https://aswritten.ai/narrative#StyleObs_9> ] ;
    narr:variation [ narr:text "PipelineRings uses a concentric-ring spatial metaphor for organization — a structural outlier against the table/list scaffolding everything else relies on." ; narr:over <https://aswritten.ai/narrative#StyleObs_PipelineRings> ] ;
    narr:variation [ narr:text "Attachment split: StyleObs_9 and BoldEmphasis attach via skos:related; every other child via skos:broader — a structurally distinct grouping worth noting." ; narr:over <https://aswritten.ai/narrative#StyleObs_9> ; narr:over <https://aswritten.ai/narrative#StyleObs_BoldEmphasis> ] ;
    narr:variation [ narr:text "ARB_TaxonomicStructure goes beyond formatting to a cross-referencing convention (backtick claim IRIs, numbered pain-point taxonomy) and flags a brand-new domain seed not yet in the perspective." ; narr:over <https://aswritten.ai/narrative#StyleObs_ARB_TaxonomicStructure> ] ;
    narr:variation [ narr:text "ActionItemList is contentless (quote only, no observation body) — a thin child that may not support recognition on its own." ; narr:over <https://aswritten.ai/narrative#StyleObs_ActionItemList> ] ;
    narr:writer "claude (subscription)" .
