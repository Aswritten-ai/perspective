    narr:covers <https://aswritten.ai/narrative#StyleObs_BulletedLaunchList> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_DirectListFormat> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_FiveToolTable> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_FundraisingBriefReview_BulletedStaleness> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_PipelineRings> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_SelfHosted_TableStructure> ;
