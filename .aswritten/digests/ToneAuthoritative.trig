    narr:keyPhrase [ narr:text "A business that doesn't need venture money is the best kind to give venture money to." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_CalibratedGrowth_ToneAuthoritative> ] ;
    narr:keyPhrase [ narr:text "The leaning is recorded; it is not yet a decision. This distinction must be preserved through extraction." ; narr:phraseSource <https://aswritten.ai/narrative#Style_EpistemicPrecision> ] ;
    narr:keyPhrase [ narr:text "I've been conflating processes that I could automate manually or for the org, with the product, and it's really important to separate those." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ConflatingProcessesRetraction> ] ;
    narr:keyPhrase [ narr:text "The PE angle is bigger than the enterprise customer." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_PEAngleBiggerThanEnterpriseCustomer> ] ;
    narr:keyPhrase [ narr:text "Catastrophic failure. Extracted one narrative" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DirectEvaluativeVoice> ] ;
    narr:keyPhrase [ narr:text "political alignment filter is non-negotiable" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DisqualificationTone> ] ;
    narr:keyPhrase [ narr:text "I appreciate you're kind of on a critical time thing, an engineering manager at the customer, but I do think we should guard these pull requests a little bit." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_CustomerCTOGuardPullRequests_Imperative> ] ;
    narr:variation [ narr:text "Authority coexists with — not replaces — a deliberately informal lowercase 'brain-dump' voice; several docs code-switch between formal analytical and colloquial registers." ; narr:over <https://aswritten.ai/narrative#StyleObs_12> ; narr:over <https://aswritten.ai/narrative#StyleObs_8> ; narr:over <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:variation [ narr:text "The unhedged tone is qualified by explicit epistemic calibration — 'leaning' vs 'decision', conviction/confidence labels — so authority is graded, not absolute." ; narr:over <https://aswritten.ai/narrative#Style_EpistemicPrecision> ; narr:over <https://aswritten.ai/narrative#StyleObs_10> ] ;
    narr:variation [ narr:text "A self-corrective counter-current: authority asserted by naming one's own prior errors and correcting stale claims, rather than by never being wrong." ; narr:over <https://aswritten.ai/narrative#StyleObs_ConflatingProcessesRetraction> ; narr:over <https://aswritten.ai/narrative#StyleObs_FundraisingBriefReview_CorrectiveRegister> ; narr:over <https://aswritten.ai/narrative#StyleObs_DirectCorrectionRegister_20260521> ] ;
    narr:variation [ narr:text "The authoritative voice is not uniquely Scarlet's — it is observed in and attributed to the customer's CTO, a design collaborator, a beta user from outside tech and Tony, sometimes via a two-register blockquote device separating source voice from commentary." ; narr:over <https://aswritten.ai/narrative#StyleObs_CustomerCTOGuardPullRequests_Imperative> ; narr:over <https://aswritten.ai/narrative#StyleObs_DesignCollaborator_Directness> ; narr:over <https://aswritten.ai/narrative#StyleObs_BrutalHonestyTone> ; narr:over <https://aswritten.ai/narrative#StyleObs_BlockquoteCorrections> ] ;
    narr:variation [ narr:text "Tone leans on typographic/structural signals (caps, bold, tables, numbers) as much as on word choice — a presentation-layer authority that several observations isolate from the prose itself." ; narr:over <https://aswritten.ai/narrative#StyleObs_TableTierStructure> ; narr:over <https://aswritten.ai/narrative#StyleObs_NumbersAsAuthority> ; narr:over <https://aswritten.ai/narrative#StyleObs_BoldConviction> ] ;
    narr:writer "claude (subscription)" .
