    narr:keyPhrase [ narr:text "I treated the models themselves like a computer, and a narrative architecture - an interconnected web of narratives that define a way of thinking - like a program that can be installed onto their hardware." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:keyPhrase [ narr:text "The physics never changed. The substrate did" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:keyPhrase [ narr:text "aswritten is its own first user — the rigor of the evaluation is the product validation, the same discipline the product sells." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_FirstUserPositioning> ] ;
    narr:keyPhrase [ narr:text "Recognition precedes creation. If we find raw material through an old association before we can be creative with it, then the index was never the place the new reading would happen" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_EpistemologicalRegister> ] ;
    narr:keyPhrase [ narr:text "If a metric falls short, iterate — don't narrate around it." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ImperativeVoice_HoldIt> ] ;
    narr:keyPhrase [ narr:text "The Twilio rejection context is load-bearing here, not incidental." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_OutsideTechBetaUserChannel_LoadBearing> ] ;
    narr:variation [ narr:text "While the mainline is authoritative and declarative, there is a deliberate 'code-switching' into informal, lowercase conversational registers to contrast with analytical prose." ; narr:over <https://aswritten.ai/narrative#StyleObs_12> ] ;
    narr:variation [ narr:text "The use of strikethrough and deprecation markers introduces a visual 'enactment' of change that pushes against the static nature of authoritative text." ; narr:over <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:variation [ narr:text "Some authoritative claims are explicitly superseded by later entries, suggesting the 'finality' of the tone is a snapshot rather than a permanent state." ; narr:over <https://aswritten.ai/narrative#StyleObs_Tone_MCP> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
