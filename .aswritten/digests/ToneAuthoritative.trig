    narr:keyPhrase [ narr:text "I treated the models themselves like a computer, and a narrative architecture - an interconnected web of narratives that define a way of thinking - like a program that can be installed onto their hardware." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:keyPhrase [ narr:text "aswritten is its own first user — the rigor of the evaluation is the product validation, the same discipline the product sells." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_FirstUserPositioning> ] ;
    narr:keyPhrase [ narr:text "Recognition precedes creation. If we find raw material through an old association before we can be creative with it, then the index was never the place the new reading would happen" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_EpistemologicalRegister> ] ;
    narr:keyPhrase [ narr:text "The leaning is recorded; it is not yet a decision. This distinction must be preserved through extraction." ; narr:phraseSource <https://aswritten.ai/narrative#Style_EpistemicPrecision> ] ;
    narr:keyPhrase [ narr:text "If a metric falls short, iterate — don't narrate around it." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ImperativeVoice_HoldIt> ] ;
    narr:variation [ narr:text "Tension between 'analytical' and 'conversational' registers, often resolved by block-quoting the founder's raw voice." ; narr:over <https://aswritten.ai/narrative#StyleObs_12> ; narr:over <https://aswritten.ai/narrative#StyleObs_4> ] ;
    narr:variation [ narr:text "Explicit deprecation of prior models (e.g., 'Five-Tool Model') versus the desire to preserve 'leanings' as historical context." ; narr:over <https://aswritten.ai/narrative#StyleObs_Tone_MCP> ; narr:over <https://aswritten.ai/narrative#Style_EpistemicPrecision> ] ;
    narr:variation [ narr:text "The use of 'load-bearing' as a technical idiolect marker for structural importance versus incidental commentary." ; narr:over <https://aswritten.ai/narrative#StyleObs_OutsideTechBetaUserChannel_LoadBearing> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
