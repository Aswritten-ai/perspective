    narr:keyPhrase [ narr:text "intellectual property as code" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_IPAsCode> ] ;
    narr:keyPhrase [ narr:text "narrative source of truth" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_StockPhrase_1> ] ;
    narr:keyPhrase [ narr:text "every single employee in your company, CEO included, is telling state secrets to AI" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_StateSecrets> ] ;
    narr:keyPhrase [ narr:text "the deepest lever we've ever had that reaches from CEO strategist every single, you know, strategic sales customer service role all the way into the core of the development process and back" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_DeepestLever> ] ;
    narr:keyPhrase [ narr:text "This eliminates strategy-execution disconnect - the \"[amount] mistake\" in startups where engineering builds features customers don't want." ; narr:phraseSource <https://aswritten.ai/ns/narrative#KeyPhrase_StrategyExecutionGap> ] ;
    narr:variation [ narr:text "The 'no network problem' framing asserts utility for a single user, countering the emphasis on multiplayer collaborative effects." ; narr:over <https://aswritten.ai/ns/narrative#Observation_NoNetworkProblem> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_KeyPhrase_NetworkEffects> ] ;
    narr:variation [ narr:text "The 'You can't' impossibility framing suggests a hard architectural limit, contrasting with the product's promise of seamless integration." ; narr:over <https://aswritten.ai/ns/narrative#KeyPhrase_YouCant> ] ;
    narr:variation [ narr:text "The 'Tony Interruption' voice introduces a visceral, profane, and informal register that diverges from the polished 'IP-as-code' corporate framing." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_TonyInterruption> ] ;
