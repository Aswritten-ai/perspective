    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_keyphrase_1> ;
    narr:keyPhrase [ narr:text "collective memory" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_keyphrase_1> ] ;
    narr:keyPhrase [ narr:text "intellectual property as code" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_IPAsCode> ] ;
    narr:keyPhrase [ narr:text "every single employee in your company, CEO included, is telling state secrets to AI" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_StateSecrets> ] ;
    narr:keyPhrase [ narr:text "This eliminates strategy-execution disconnect - the \"[amount] mistake\" in startups where engineering builds features customers don't want." ; narr:phraseSource <https://aswritten.ai/ns/narrative#KeyPhrase_StrategyExecutionGap> ] ;
    narr:keyPhrase [ narr:text "There is actually no network problem here. This is just as useful for one person, but it is even more useful for two people" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_NoNetworkProblem> ] ;
    narr:keyPhrase [ narr:text "narrative is not only the backdoor to the models, it's the steering wheel, it's the fault lines" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_Metaphor_Steering> ] ;
    narr:keyPhrase [ narr:text "See, just not having to stop what I'm doing to tell somebody something all the fucking time. Yeah, I'm in." ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_TonyInterruption> ] ;
    narr:variation [ narr:text "Internal tension on where value lives: 'no network problem — useful for one person' vs the 'network effects: more people = more value' multiplier framing." ; narr:over <https://aswritten.ai/ns/narrative#Observation_NoNetworkProblem> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_KeyPhrase_NetworkEffects> ] ;
    narr:variation [ narr:text "A distinct speculative/far-future register — storyTWIN, individuation pipeline, evolved variant, collective memory marketplace — sits apart from the grounded pitch vocabulary." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_SIC_KeyPhrases_1> ] ;
    narr:variation [ narr:text "'update their worldview' is deliberately chosen to replace passive 'query' — yet the customer's chief architect's pitch still describes the product as something 'everybody else can query'." ; narr:over <https://aswritten.ai/ns/narrative#KeyPhrase_5> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_CustomerArchitectPitch_DirectSpeech> ] ;
    narr:variation [ narr:text "Two divergent voices in the corpus: Tony's blunt, profane, snap-decision register vs the customer's chief architect's measured outcome-first conversational framing." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_TonyInterruption> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_CustomerArchitectPitch_DirectSpeech> ] ;
    narr:variation [ narr:text "An internal technical lexicon (Memory, Transaction, tool signatures, snapshot, ontology) runs beneath the market-facing brand terms — different audience, different vocabulary." ; narr:over <https://aswritten.ai/ns/narrative#Obs_MemoryDefinition> ; narr:over <https://aswritten.ai/ns/narrative#Obs_TransactionDefinition> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_TechTerms> ] ;
