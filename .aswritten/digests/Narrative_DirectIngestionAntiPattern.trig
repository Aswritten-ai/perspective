    narr:generatedFrom "5786de2df2d326b098ff4d57bba21729807253e2" ;
    narr:narration """This hub's framing has been explicitly corrected. What was once positioned as an anti-pattern — direct historical transcript ingestion as a trap discovered by failing — was overturned on 2026-05-21: [the direct ingestion framing is overplayed and bulk AI-summarization ingestion is valid and effective](narr:Position_DirectIngestionIsTrap), with Scarlet advising the customer's chief architect to use it for enterprise customer ARB transcripts precisely because it was faster. The prior Foundation-level conviction is marked superseded. What the children actually witness is a narrower, documented failure: [unmarked speculation pollution during demo prep](narr:Position_CustomerArchitectDemoPollutionProductEvidence), where mixing real and speculative capabilities in conversation convinced Claude that the enterprise customer had features that never existed — a production failure on the first paying enterprise customer. Because memories carried no temporal or speculative markers, [the only available corrective action was full deletion and restart](narr:Position_FullDeletionOnlyRemedy): wipe all demo-prep memories, retaining only two foundational overviews. The region's center of gravity now sits on 'speculation without temporality markers is dangerous,' not 'ingestion is dangerous.'""" ;
    narr:covers <https://aswritten.ai/narrative#Position_CustomerArchitectDemoPollutionProductEvidence> ;
    narr:covers <https://aswritten.ai/narrative#Position_DirectIngestionIsTrap> ;
    narr:covers <https://aswritten.ai/narrative#Position_FullDeletionOnlyRemedy> ;
    narr:keyPhrase [ narr:text "The direct ingestion framing is overplayed. It is not an explicit anti-pattern." ; narr:phraseSource <https://aswritten.ai/narrative#Position_DirectIngestionIsTrap> ] ;
    narr:keyPhrase [ narr:text "Prior Foundation-level conviction is superseded." ; narr:phraseSource <https://aswritten.ai/narrative#Position_DirectIngestionIsTrap> ] ;
    narr:keyPhrase [ narr:text "Claude became convinced the enterprise customer had capabilities that do not exist and never existed in the project." ; narr:phraseSource <https://aswritten.ai/narrative#Position_CustomerArchitectDemoPollutionProductEvidence> ] ;
    narr:keyPhrase [ narr:text "The failure mode is not hypothetical — it happened to the first paying enterprise customer during the first real use of the product." ; narr:phraseSource <https://aswritten.ai/narrative#Position_CustomerArchitectDemoPollutionProductEvidence> ] ;
    narr:keyPhrase [ narr:text "the only available corrective action when speculation pollution occurs is full deletion of the affected memories and starting over." ; narr:phraseSource <https://aswritten.ai/narrative#Position_FullDeletionOnlyRemedy> ] ;
    narr:keyPhrase [ narr:text "This is a destructive, high-cost remedy that would not be necessary if memories carried explicit temporal/speculative markers at creation time." ; narr:phraseSource <https://aswritten.ai/narrative#Position_FullDeletionOnlyRemedy> ] ;
    narr:variation [ narr:text "The hub's own label ('ingestion is a trap') is now contradicted by its most-recently-dated child — the label is a superseded framing, not the current position." ; narr:over <https://aswritten.ai/narrative#Position_DirectIngestionIsTrap> ] ;
    narr:variation [ narr:text "The pollution failure is attributed to missing temporality/speculation markers, not to ingestion method — so the remedy points toward marker discipline at creation time, not ingestion avoidance." ; narr:over <https://aswritten.ai/narrative#Position_FullDeletionOnlyRemedy> ; narr:over <https://aswritten.ai/narrative#Position_CustomerArchitectDemoPollutionProductEvidence> ] ;
    narr:variation [ narr:text "Full deletion was the only remedy available given the current system, but the child explicitly frames this as a contingent limitation, not a permanent constraint — implying the problem is solvable by design." ; narr:over <https://aswritten.ai/narrative#Position_FullDeletionOnlyRemedy> ] ;
