    narr:covers <https://aswritten.ai/narrative#Position_ConsentEthicsAdvisorRecording> ;
    narr:covers <https://aswritten.ai/narrative#Position_PaymentResolvesEthicsQuestion> ;
    narr:covers <https://aswritten.ai/narrative#Position_ProposalRegulatorySafeguard> ;
    narr:covers <https://aswritten.ai/narrative#Position_SourceSideScopeGate> ;
    narr:covers <https://aswritten.ai/narrative#Position_StaleGraphCitationsWorse> ;
    narr:covers <https://aswritten.ai/narrative#Principle_AppropriatenessGate> ;
    narr:covers <https://aswritten.ai/narrative#Principle_DisclosureDefault> ;
    narr:keyPhrase [ narr:text "stale graph + citations = worse than having no citations" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_StaleGraphDanger> ] ;
    narr:keyPhrase [ narr:text "A hub memory is not an abstract: it must contain extended verbatim excerpts from the pivotal moments" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_HubMemoryProvenanceNonNegotiable> ] ;
    narr:keyPhrase [ narr:text "it might be to read a contract, or to increment a salary — but it's for one task and one task only kind of token." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PerTaskScopedPermissions> ] ;
    narr:keyPhrase [ narr:text "gap-awareness ('is this contained within the graph? the answer is binary') as the structural mechanism for an agent that knows the bounds of its own worldview." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_AgentBoundsAndEscalation> ] ;
    narr:keyPhrase [ narr:text "Payment transforms the relationship from extraction to compensation" ; narr:phraseSource <https://aswritten.ai/narrative#Position_PaymentResolvesEthicsQuestion> ] ;
    narr:variation [ narr:text "The risk that citations on a stale graph create a false sense of authority more dangerous than generic AI." ; narr:over <https://aswritten.ai/narrative#Obs_StaleGraphDanger> ; narr:over <https://aswritten.ai/narrative#Position_StaleGraphCitationsWorse> ] ;
    narr:variation [ narr:text "The tension between ingesting narrative for organizational memory and maintaining strict RBAC for sensitive data." ; narr:over <https://aswritten.ai/narrative#Position_ConsentAttributionRBAC> ; narr:over <https://aswritten.ai/narrative#Position_SourceSideScopeGate> ] ;
    narr:variation [ narr:text "The debate over whether to treat advisor contributions as extraction-via-payment or as collaborative training." ; narr:over <https://aswritten.ai/narrative#Position_ConsentEthicsAdvisorRecording> ; narr:over <https://aswritten.ai/narrative#Position_PaymentResolvesEthicsQuestion> ] ;
