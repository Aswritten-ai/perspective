    narr:keyPhrase [ narr:text "stale graph + citations = worse than having no citations" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_StaleGraphDanger> ] ;
    narr:keyPhrase [ narr:text "A hub memory is still primary source material — verbatim excerpts attributed to speaker and date, referencing the original transcript file" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_HubMemoryProvenanceNonNegotiable> ] ;
    narr:keyPhrase [ narr:text "Per-task scoped permissions: OAuth scope narrowed to single-use grants for agentic operations" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PerTaskScopedPermissions> ] ;
    narr:keyPhrase [ narr:text "Agent self-knowledge: defining the bounds of task, intent, and world limits so an agent knows when it cannot finish and must escalate" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_AgentBoundsAndEscalation> ] ;
    narr:variation [ narr:text "Tension between open-source standard vs. enterprise product for identity security" ; narr:over <https://aswritten.ai/narrative#Narrative_VouchIdentityForAgents> ] ;
