    narr:covers <https://aswritten.ai/narrative#Obs_FundraisingStory> ;
    narr:covers <https://aswritten.ai/narrative#Obs_GitHubActionsPivotQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_TwoCallStructure> ;
    narr:covers <https://aswritten.ai/narrative#Observation_3> ;
    narr:covers <https://aswritten.ai/narrative#Observation_TaxonomyRevision> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Anaphora_HereIs> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RuleOfThree_Layers> ;
    narr:keyPhrase [ narr:text "The next bottleneck in AI productivity is not LLM capability but the absence of a versioned, coherent organizational context." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_WorldviewBottleneck> ] ;
    narr:keyPhrase [ narr:text "The most consequential organizational knowledge was never written down and cannot be retrieved — it must be extracted" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_CreationGap> ] ;
    narr:keyPhrase [ narr:text "Organizational worldview as git-native code at the core of CI/CD enables agentic automations, multi-player contribution, and composable distribution" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_InfrastructureGap> ] ;
    narr:keyPhrase [ narr:text "Salon is a per-memory capability, not a fifth deployment pattern" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_SalonAsCapability> ] ;
    narr:keyPhrase [ narr:text "it is an opinion machine whose editorial choices become invisible once compiled" ; narr:phraseSource <https://aswritten.ai/narrative#Observation_3> ] ;
    narr:keyPhrase [ narr:text "Citations are constellations, not single claims" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_CiteConstellationModel> ] ;
    narr:keyPhrase [ narr:text "The zero-context framing is a liability with sophisticated buyers who already have context solutions; replacement framing acknowledges the industry and positions against it" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_RetireZeroContext> ] ;
    narr:variation [ narr:text "Salon was reclassified: not a fifth deployment pattern but a per-memory capability triggered by the reviewers frontmatter — a taxonomy correction, not the original framing." ; narr:over <https://aswritten.ai/narrative#Narrative_SalonAsCapability> ; narr:over <https://aswritten.ai/narrative#Claim_SalonIsPerMemory> ; narr:over <https://aswritten.ai/narrative#Observation_TaxonomyRevision> ] ;
    narr:variation [ narr:text "Demo framing shifted: Reviewable Worldview supersedes Demo 1 / After the Call, which is demoted to a waypoint within it rather than a standalone demo." ; narr:over <https://aswritten.ai/narrative#Claim_ReviewableWorldviewSupersedesDemo1> ; narr:over <https://aswritten.ai/narrative#Narrative_ReviewableWorldview> ] ;
    narr:variation [ narr:text "The rigid two-call sales structure is being questioned as too prescriptive; the an early prospect call evidenced a fluid hybrid with the write path running in the background during Call One." ; narr:over <https://aswritten.ai/narrative#Obs_TwoCallStructure> ; narr:over <https://aswritten.ai/narrative#Narrative_HybridSalesMotion> ] ;
    narr:variation [ narr:text "Counter to the clean 'infrastructure' positioning: the extraction pipeline is framed as a non-neutral opinion machine whose editorial choices vanish once compiled." ; narr:over <https://aswritten.ai/narrative#Observation_3> ] ;
    narr:variation [ narr:text "A self-reflexive thread claims the product tests itself — the beta feedback loop IS a Salon — distinct from the outward-facing positioning narratives." ; narr:over <https://aswritten.ai/narrative#Narrative_BetaFeedbackLoopIsSalon> ] ;
    narr:variation [ narr:text "Cite matching is reframed from 'what is THE claim' to 'what bears on this text', plus a dedup invariant — a structural outlier from the positioning claims." ; narr:over <https://aswritten.ai/narrative#Narrative_CiteConstellationModel> ; narr:over <https://aswritten.ai/narrative#Narrative_CiteDeduplicationInvariant> ] ;
    narr:writer "claude (subscription)" .
