    narr:keyPhrase [ narr:text "The interview elicits thinking not yet in collective memory; save captures it; draft synthesizes it; annotation proves it — the product demonstrates itself through the process" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_InterviewSaveDraftAnnotatePattern> ] ;
    narr:keyPhrase [ narr:text "The user's corrections to your hypotheses are more valuable than your initial hypotheses — interview before synthesizing, never write strategy from the worldview alone" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_InterviewBeforeSynthesis> ] ;
    narr:keyPhrase [ narr:text "Any review does is produce another memory, right? It's not a special type of memory; it may have a specific type of content in it because it's a review, but it's just another memory." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ReviewIsRememberQuote> ] ;
    narr:keyPhrase [ narr:text "Feedback/help tool is above the line for launch. MCP tool that sends user a confirmation message (phone or email) and forwards request text to Scarlet." ; narr:phraseSource <https://aswritten.ai/narrative#Position_FeedbackHelpAboveLine> ] ;
    narr:keyPhrase [ narr:text "Entire Stories system removed from product. TX summaries now returned from synchronous remember; blog post ideas, changelog, graph health become on-demand local skills." ; narr:phraseSource <https://aswritten.ai/narrative#Position_StoriesRemoved> ] ;
    narr:keyPhrase [ narr:text "Refract tool and Registry removed from product. Registry is just the docs folder. Refract becomes a local Claude Code skill." ; narr:phraseSource <https://aswritten.ai/narrative#Position_RefractRegistryRemoved> ] ;
    narr:keyPhrase [ narr:text "Correction 1: Show before vs new (PR state) as a single comparison first; offer shifts as pairs only after baseline is established. Not three versions simultaneously." ; narr:phraseSource <https://aswritten.ai/narrative#Position_BaselineFirst> ] ;
    narr:keyPhrase [ narr:text "After every ARB, you might spend 30 minutes on a voice memo like talking through that whole system." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletVoiceMemoQuote> ] ;
    narr:variation [ narr:text "Two overlapping pipeline descriptions exist without explicit reconciliation: a six-step commit-to-PR-to-story flow vs. a five-step review-as-optometrist flow — the step counts and framing differ." ; narr:over <https://aswritten.ai/narrative#Obs_PipelineSteps> ; narr:over <https://aswritten.ai/narrative#Observation_Pipeline> ] ;
    narr:variation [ narr:text "Refract is simultaneously described as fully removed from the product and as a surviving local Claude Code skill — the boundary between 'removed' and 'demoted to skill' is not resolved." ; narr:over <https://aswritten.ai/narrative#Position_RefractRegistryRemoved> ; narr:over <https://aswritten.ai/narrative#Position_RefractBecomesLocalSkill> ; narr:over <https://aswritten.ai/narrative#Obs_RefractSkillQuote> ] ;
    narr:variation [ narr:text "Changelog/story generation appears in two nearly identical positions (cron-based local skill) without differentiation — possible duplication or staged refinement." ; narr:over <https://aswritten.ai/narrative#Position_ChangelogStoryBecomesLocalSkill> ; narr:over <https://aswritten.ai/narrative#Position_ChangelogStoryLocalSkillCron> ] ;
    narr:variation [ narr:text "The two-pass ARB pattern (Phase 1 exploratory, Phase 2 finalization) introduces a customer-side workflow rhythm that sits in tension with the single-session Interview→Save→Draft→Annotate arc." ; narr:over <https://aswritten.ai/narrative#Observation_TwoPassPattern> ; narr:over <https://aswritten.ai/narrative#Narrative_InterviewSaveDraftAnnotatePattern> ] ;
    narr:variation [ narr:text "Voice memo as gap-filling mechanism after each ARB suggests an informal capture path outside the governed pipeline — a parallel or supplementary workflow not fully integrated." ; narr:over <https://aswritten.ai/narrative#Obs_ScarletVoiceMemoQuote> ] ;
    narr:variation [ narr:text "Sales flows (influence-first, two-call, nine-phase consulting) are structurally distinct from the write-path core and may belong to a different thematic region — their presence here is associative, not operational." ; narr:over <https://aswritten.ai/narrative#Narrative_InfluenceSales> ; narr:over <https://aswritten.ai/narrative#Observation_TwoCallStructure> ; narr:over <https://aswritten.ai/narrative#Obs_NinePhaseStructure> ; narr:over <https://aswritten.ai/narrative#Workflow_ConsultingEngagement> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}