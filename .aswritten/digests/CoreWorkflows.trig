    narr:keyPhrase [ narr:text "Any review does is produce another memory, right? It's not a special type of memory; it may have a specific type of content in it because it's a review, but it's just another memory." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ReviewIsRememberQuote> ] ;
    narr:keyPhrase [ narr:text "Every session registers in a gitignored SESSIONS.md." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_LedgerQuarterbackPattern> ] ;
    narr:keyPhrase [ narr:text "Compile isn't a session start ritual. It's the organizational context that gates all work." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_CompileGateMustLiveInCoreProtocol> ] ;
    narr:keyPhrase [ narr:text "Maximum comparison unit is a few sentences." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_ComparisonScale> ] ;
    narr:keyPhrase [ narr:text "Push after every major artifact. Do not accumulate uncommitted work." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_PushAfterEveryArtifact> ] ;
    narr:keyPhrase [ narr:text "After every ARB, you might spend 30 minutes on a voice memo like talking through that whole system." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletVoiceMemoQuote> ] ;
    narr:variation [ narr:text "A competing document-generation workflow (brief → compile → outline → pull → write → annotate) is filed as a challenge to the Interview→Save→Draft→Annotate mainline." ; narr:over <https://aswritten.ai/narrative#Claim_6> ; narr:over <https://aswritten.ai/narrative#Narrative_InterviewSaveDraftAnnotatePattern> ] ;
    narr:variation [ narr:text "The March 26 simplification is a deliberate reversal of the richer earlier pipelines — full removal of Stories, Notifications, Refract/Registry, Memories, Discoveries, and auto TX-summaries, not deprecation." ; narr:over <https://aswritten.ai/narrative#Claim_StoriesRemoved> ; narr:over <https://aswritten.ai/narrative#Claim_NotificationsRemoved> ; narr:over <https://aswritten.ai/narrative#Claim_RefractRegistryRemoved> ; narr:over <https://aswritten.ai/narrative#Claim_DiscoveriesRemoved> ; narr:over <https://aswritten.ai/narrative#Claim_TXSummariesOnPRRemoved> ] ;
    narr:variation [ narr:text "Compile placement is contested: it must live in Core Protocol, not in the /start project skill, or the gate disappears for beta repos." ; narr:over <https://aswritten.ai/narrative#Claim_CompileGateMustLiveInCoreProtocol> ] ;
    narr:variation [ narr:text "Review comparison was corrected away from three-versions-simultaneously toward baseline-first, labeled improvement-vs-counter shifts, and few-sentence chunks." ; narr:over <https://aswritten.ai/narrative#Claim_BaselineFirst> ; narr:over <https://aswritten.ai/narrative#Claim_LabelShiftIntent> ; narr:over <https://aswritten.ai/narrative#Claim_ComparisonScale> ] ;
    narr:variation [ narr:text "Multi-session coordination was explicitly chosen over ledger-only and quarterback-only alternatives; the gitignored ledger is a contested design choice." ; narr:over <https://aswritten.ai/narrative#Claim_LedgerQuarterbackPattern> ; narr:over <https://aswritten.ai/narrative#Narrative_QuarterbackCoordination> ] ;
    narr:variation [ narr:text "Sales/consulting workflows (two-call, influence-first, two-week engagement) form a structurally distinct cluster from the product/session machinery, with an open pilot→full-engagement trigger question." ; narr:over <https://aswritten.ai/narrative#Observation_TwoCallStructure> ; narr:over <https://aswritten.ai/narrative#Narrative_InfluenceSales> ; narr:over <https://aswritten.ai/narrative#Workflow_ConsultingEngagement> ; narr:over <https://aswritten.ai/narrative#Question_PilotTriggers> ] ;
    narr:writer "claude (subscription)" .
