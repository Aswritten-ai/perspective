@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_CoreWorkflows> {
  <https://aswritten.ai/narrative#Digest_CoreWorkflows> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#CoreWorkflows> ;
    narr:childCount "43"^^xsd:integer ;
    narr:generatedFrom "cfcb3bea7a76d348360a7e3dd14606bd1b4671b6" ;
    narr:narration """This hub gathers the operational patterns aswritten runs on. The flagship is the session-to-document arc: [Interview → Save → Draft → Annotate](narr:https://aswritten.ai/narrative#Narrative_InterviewSaveDraftAnnotatePattern), grounded by [save before drafting](narr:https://aswritten.ai/narrative#Narrative_SaveBeforeDrafting), disciplined by [one question at a time](narr:https://aswritten.ai/narrative#Narrative_OneQuestionAtATime), and generalized as a [replicable pattern](narr:https://aswritten.ai/narrative#Position_SessionPatternReplicable). The principle that [user corrections outweigh initial hypotheses](narr:https://aswritten.ai/narrative#Narrative_InterviewBeforeSynthesis) (dated Mar 19) anchors why the interview phase precedes synthesis. Review is treated as recursion, not a special flow — [review is just another remember](narr:https://aswritten.ai/narrative#Narrative_ReviewLoopIsRemember), with Scarlet's canonical statement as witness. A dated March 26 simplification collapses standalone tools into on-demand local skills: [Stories](narr:https://aswritten.ai/narrative#Position_StoriesRemoved), [Notifications](narr:https://aswritten.ai/narrative#Position_NotificationsRemoved), [Refract/Registry](narr:https://aswritten.ai/narrative#Position_RefractRegistryRemoved), and [Memories/Source](narr:https://aswritten.ai/narrative#Position_MemoriesSourceToolRemoved) all removed, keeping only the [feedback/help tool above the line](narr:https://aswritten.ai/narrative#Position_FeedbackHelpAboveLine). The [six-step pipeline](narr:https://aswritten.ai/narrative#Obs_PipelineSteps) and [six-step review flow](narr:https://aswritten.ai/narrative#Obs_ReviewFlowSteps) specify the mechanics. Review-comparison corrections insist on [baseline-first](narr:https://aswritten.ai/narrative#Position_BaselineFirst), [labeled shifts](narr:https://aswritten.ai/narrative#Position_LabelShiftIntent), and [small chunks](narr:https://aswritten.ai/narrative#Position_ComparisonScale). Sales/consulting flows — [two-call structure](narr:https://aswritten.ai/narrative#Observation_TwoCallStructure), [influence-first](narr:https://aswritten.ai/narrative#Narrative_InfluenceSales), [two-week engagement](narr:https://aswritten.ai/narrative#Workflow_ConsultingEngagement) — sit alongside. A May 2026 [two-pass ARB pattern](narr:https://aswritten.ai/narrative#Observation_TwoPassPattern) and a voice-memo gap-filling practice (May 1) extend the workflow into ongoing iteration.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_CollaborativeMemory> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_InfluenceSales> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_InterviewBeforeSynthesis> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_InterviewSaveDraftAnnotatePattern> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_OneQuestionAtATime> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ReviewLoopIsRemember> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_SaveBeforeDrafting> ;
    narr:covers <https://aswritten.ai/narrative#Obs_NinePhaseStructure> ;
    narr:covers <https://aswritten.ai/narrative#Obs_PipelineSteps> ;
    narr:covers <https://aswritten.ai/narrative#Obs_RefractSkillQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ReviewFlowSteps> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ReviewIsRememberQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletVoiceMemoQuote> ;
    narr:covers <https://aswritten.ai/narrative#Observation_BaselineFlow> ;
    narr:covers <https://aswritten.ai/narrative#Observation_Pipeline> ;
    narr:covers <https://aswritten.ai/narrative#Observation_TwoCallStructure> ;
    narr:covers <https://aswritten.ai/narrative#Observation_TwoPassPattern> ;
    narr:covers <https://aswritten.ai/narrative#Observation_VerificationCycle> ;
    narr:covers <https://aswritten.ai/narrative#Observation_WritePathOffline> ;
    narr:covers <https://aswritten.ai/narrative#Position_BaselineFirst> ;
    narr:covers <https://aswritten.ai/narrative#Position_BlogPostIdeasLocalSkill> ;
    narr:covers <https://aswritten.ai/narrative#Position_ChangelogStoryBecomesLocalSkill> ;
    narr:covers <https://aswritten.ai/narrative#Position_ChangelogStoryLocalSkillCron> ;
    narr:covers <https://aswritten.ai/narrative#Position_ComparisonScale> ;
    narr:covers <https://aswritten.ai/narrative#Position_DiscoveriesRemoved> ;
    narr:covers <https://aswritten.ai/narrative#Position_FeedbackHelpAboveLine> ;
    narr:covers <https://aswritten.ai/narrative#Position_GraphHealthLocalSkill> ;
    narr:covers <https://aswritten.ai/narrative#Position_LabelShiftIntent> ;
    narr:covers <https://aswritten.ai/narrative#Position_MemoriesSourceToolRemoved> ;
    narr:covers <https://aswritten.ai/narrative#Position_NotificationsRemoved> ;
    narr:covers <https://aswritten.ai/narrative#Position_RefractBecomesLocalSkill> ;
    narr:covers <https://aswritten.ai/narrative#Position_RefractRegistryRemoved> ;
    narr:covers <https://aswritten.ai/narrative#Position_ReviewEyeChartsSkillPrompt> ;
    narr:covers <https://aswritten.ai/narrative#Position_ScarletDrivesUserTalks> ;
    narr:covers <https://aswritten.ai/narrative#Position_SessionPatternReplicable> ;
    narr:covers <https://aswritten.ai/narrative#Position_StoriesRemoved> ;
    narr:covers <https://aswritten.ai/narrative#Position_TXSummariesOnPRRemoved> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_EmDashDefinition> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ImperativeNumberedList> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NumberedCheckSteps> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NumberedFlow> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ProcessEnumeration> ;
    narr:covers <https://aswritten.ai/narrative#Workflow_ConsultingEngagement> ;
    narr:keyPhrase [ narr:text "The interview elicits thinking not yet in collective memory; save captures it; draft synthesizes it; annotation proves it — the product demonstrates itself through the process" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_InterviewSaveDraftAnnotatePattern> ] ;
    narr:keyPhrase [ narr:text "The user's corrections to your hypotheses are more valuable than your initial hypotheses — interview before synthesizing, never write strategy from the worldview alone" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_InterviewBeforeSynthesis> ] ;
    narr:keyPhrase [ narr:text "Any review does is produce another memory, right? It's not a special type of memory; it may have a specific type of content in it because it's a review, but it's just another memory." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ReviewIsRememberQuote> ] ;
    narr:keyPhrase [ narr:text "Feedback/help tool is above the line for launch. MCP tool that sends user a confirmation message (phone or email) and forwards request text to Scarlet." ; narr:phraseSource <https://aswritten.ai/narrative#Position_FeedbackHelpAboveLine> ] ;
    narr:keyPhrase [ narr:text "Memories/Source tool removed from product. Memories are just files in the repo — anyone with a coding agent can read them directly. Org-only skill at most." ; narr:phraseSource <https://aswritten.ai/narrative#Position_MemoriesSourceToolRemoved> ] ;
    narr:keyPhrase [ narr:text "Correction 1: Show before vs new (PR state) as a single comparison first; offer shifts as pairs only after baseline is established. Not three versions simultaneously." ; narr:phraseSource <https://aswritten.ai/narrative#Position_BaselineFirst> ] ;
    narr:keyPhrase [ narr:text "After every ARB, you might spend 30 minutes on a voice memo like talking through that whole system." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletVoiceMemoQuote> ] ;
    narr:keyPhrase [ narr:text "Six-step pipeline: memory commit → GitHub Action → SPARQL transaction → PR with comment → story draft regeneration → PR diff as telltale." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_PipelineSteps> ] ;
    narr:variation [ narr:text "The March 26 simplification removes Stories, Notifications, Refract/Registry, and Memories/Source as product tools — but several children describe these same capabilities surviving as local Claude Code skills on cron or demand, leaving open whether 'removed' means gone or just repositioned." ; narr:over <https://aswritten.ai/narrative#Position_StoriesRemoved> ; narr:over <https://aswritten.ai/narrative#Position_RefractRegistryRemoved> ; narr:over <https://aswritten.ai/narrative#Position_RefractBecomesLocalSkill> ; narr:over <https://aswritten.ai/narrative#Position_ChangelogStoryBecomesLocalSkill> ; narr:over <https://aswritten.ai/narrative#Position_BlogPostIdeasLocalSkill> ] ;
    narr:variation [ narr:text "Pipeline step counts are inconsistent across children: one node describes a five-step pipeline (Memory→extraction→TX→PR→review→merge), another a six-step pipeline (memory commit→GitHub Action→SPARQL→PR→story draft→PR diff) — the canonical sequence is not settled." ; narr:over <https://aswritten.ai/narrative#Obs_PipelineSteps> ; narr:over <https://aswritten.ai/narrative#Observation_Pipeline> ] ;
    narr:variation [ narr:text "Sales entry point is contested: influence-first (Tony's approach via content and intros) sits alongside a two-call demo structure and a nine-phase consulting call — these are not obviously the same motion." ; narr:over <https://aswritten.ai/narrative#Narrative_InfluenceSales> ; narr:over <https://aswritten.ai/narrative#Observation_TwoCallStructure> ; narr:over <https://aswritten.ai/narrative#Obs_NinePhaseStructure> ] ;
    narr:variation [ narr:text "First-session ownership is split: one child says the first session is consultant-led with users driving later, while the Interview Before Synthesis pattern implies the AI leads via structured questioning from the start." ; narr:over <https://aswritten.ai/narrative#Position_ScarletDrivesUserTalks> ; narr:over <https://aswritten.ai/narrative#Narrative_InterviewBeforeSynthesis> ] ;
    narr:variation [ narr:text "Collaborative memory is framed as a team governance mechanism (extraction pipeline + PR review) in one child, while the core workflow children treat it as a solo session arc — the multi-person coordination layer is present but not integrated into the main sequence." ; narr:over <https://aswritten.ai/narrative#Narrative_CollaborativeMemory> ; narr:over <https://aswritten.ai/narrative#Narrative_InterviewSaveDraftAnnotatePattern> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}