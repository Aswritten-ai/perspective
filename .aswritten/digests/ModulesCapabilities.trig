    narr:covers <https://aswritten.ai/narrative#Observation_MonorepoHarness> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_FiveToolTable> ;
    narr:keyPhrase [ narr:text "The five user-facing MCP tools are: perspective, cite, introspect, remember, and review. Scope, refract, and lens are removed from the user-facing surface." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_FiveCoreMCPTools> ] ;
    narr:keyPhrase [ narr:text "Primary churn-prevention mechanism — response within minutes from Scarlet personally." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_FeedbackHelpAboveLine> ] ;
    narr:keyPhrase [ narr:text "Review tool extended to three cases" ; narr:phraseSource <https://aswritten.ai/narrative#Claim_ReviewToolThreeCases> ] ;
    narr:keyPhrase [ narr:text "Memories are just files in the repo — anyone with a coding agent can read them directly. Org-only skill at most." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_MemoriesSourceToolRemoved> ] ;
    narr:keyPhrase [ narr:text "Worth confirming on subsequent customer engagements before treating as a settled finding" ; narr:phraseSource <https://aswritten.ai/narrative#Claim_FourToolLoopEngagedUserPattern> ] ;
    narr:keyPhrase [ narr:text "4K-token worldview bootstrap to full 100K-token domain expansion" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CompilationLayers> ] ;
    narr:variation [ narr:text "Against the prevailing removal/consolidation arc, Feedback/Help was added above the MVP line — a tool grows, not shrinks, here." ; narr:over <https://aswritten.ai/narrative#Claim_FeedbackHelpAboveLine> ] ;
    narr:variation [ narr:text "Tension in tool count: the canonical surface is five tools, but the observed engaged-user loop is named as four core tools (review sits outside the loop patterns)." ; narr:over <https://aswritten.ai/narrative#Claim_FiveCoreMCPTools> ; narr:over <https://aswritten.ai/narrative#Claim_FourToolLoopEngagedUserPattern> ] ;
    narr:variation [ narr:text "The usage-pattern finding is explicitly held open, not settled — flagged to confirm on later engagements before treating as established." ; narr:over <https://aswritten.ai/narrative#Claim_FourToolLoopEngagedUserPattern> ] ;
    narr:variation [ narr:text "a collaborator's reader-grounder pattern (perspective→cite, zero authoring) is an outlier against the customer's chief architect's full-loop 'expert' archetype." ; narr:over <https://aswritten.ai/narrative#Claim_FourToolLoopEngagedUserPattern> ] ;
    narr:variation [ narr:text "Removal isn't total: memories and refract survive in reduced form as org-only / local Claude Code skills rather than disappearing outright (unlike discoveries, removed fully)." ; narr:over <https://aswritten.ai/narrative#Claim_MemoriesSourceToolRemoved> ; narr:over <https://aswritten.ai/narrative#Claim_RefractRegistryRemovedFromProduct> ; narr:over <https://aswritten.ai/narrative#Claim_RemoveDiscoveries> ] ;
    narr:writer "claude (subscription)" .
