@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ModulesCapabilities> {
  <https://aswritten.ai/narrative#Digest_ModulesCapabilities> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#ModulesCapabilities> ;
    narr:childCount "18"^^xsd:integer ;
    narr:generatedFrom "1948db70c61961957447ffe29d1a37b69e2696cc" ;
    narr:narration """This hub gathers the product's tool surface and capability decisions, mostly dated March–May 2026. The dominant arc is aggressive consolidation: a March–April sweep settled the [five user-facing MCP tools](narr:Position_FiveCoreMCPTools) — perspective, cite, introspect, remember, review — confirmed also in the [narrative-level tool surface record](narr:Narrative_MCPToolSurface_FiveTools) where scope absorbed into introspect and refract/lens moved to the product repo only. Removed in the same sweep: [refract and its registry](narr:Position_RefractRegistryRemovedFromProduct), the [memories/source tool](narr:Position_MemoriesSourceToolRemoved), [discoveries](narr:Position_RemoveDiscoveries), the [notifications system](narr:Position_RemoveNotificationsSystem), and [auto-generated TX summaries](narr:Position_TXSummariesAutoGenRemoved). Against that removal current, the [Feedback/Help tool](narr:Position_FeedbackHelpAboveLine) was pulled *above* the line as primary churn prevention. The [review tool was widened to three cases](narr:Position_ReviewToolThreeCases). Capability framing runs alongside: [compilation layers](narr:Obs_CompilationLayers) from 4K bootstrap to 100K expansion, [perspective layering](narr:Obs_ChineseHerbalismLayeringExample) across multiple expertise voices, [transcript bootstrapping](narr:Position_TranscriptBootstrapOnramp) as a lighter onramp, and a [public perspective module](narr:Narrative_PublicPerspectiveModule) as a sibling repo with a hard 40-memory cap. Early usage (May) showed [two organic loop patterns](narr:Position_FourToolLoopEngagedUserPattern) across the enterprise customer's first nine days. A [four-column tool matrix](narr:StyleObs_FiveToolTable) serves as canonical architecture definition.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_MCPToolSurface_FiveTools> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PublicPerspectiveModule> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ChineseHerbalismLayeringExample> ;
    narr:covers <https://aswritten.ai/narrative#Obs_CompilationLayers> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ModulesCapabilities> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ReviewToolQuote> ;
    narr:covers <https://aswritten.ai/narrative#Position_CompileRename> ;
    narr:covers <https://aswritten.ai/narrative#Position_FeedbackHelpAboveLine> ;
    narr:covers <https://aswritten.ai/narrative#Position_FiveCoreMCPTools> ;
    narr:covers <https://aswritten.ai/narrative#Position_FourToolLoopEngagedUserPattern> ;
    narr:covers <https://aswritten.ai/narrative#Position_MemoriesSourceToolRemoved> ;
    narr:covers <https://aswritten.ai/narrative#Position_RefractRegistryRemovedFromProduct> ;
    narr:covers <https://aswritten.ai/narrative#Position_RemoveDiscoveries> ;
    narr:covers <https://aswritten.ai/narrative#Position_RemoveNotificationsSystem> ;
    narr:covers <https://aswritten.ai/narrative#Position_ReviewToolThreeCases> ;
    narr:covers <https://aswritten.ai/narrative#Position_TXSummariesAutoGenRemoved> ;
    narr:covers <https://aswritten.ai/narrative#Position_TranscriptBootstrapOnramp> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_FiveToolTable> ;
    narr:keyPhrase [ narr:text "The five user-facing MCP tools are: perspective, cite, introspect, remember, and review. Scope, refract, and lens are removed from the user-facing surface." ; narr:phraseSource <https://aswritten.ai/narrative#Position_FiveCoreMCPTools> ] ;
    narr:keyPhrase [ narr:text "Feedback/help tool is above the line for launch. MCP tool that sends user a confirmation message (phone or email) and forwards request text to Scarlet. Front stays active to support this — only use of Front going forward. Prompt user to add phone to Outseta." ; narr:phraseSource <https://aswritten.ai/narrative#Position_FeedbackHelpAboveLine> ] ;
    narr:keyPhrase [ narr:text "Refract tool and registry removed from product. Registry is just the docs folder. Refract becomes a local Claude Code skill. Eliminates need to separate tools between org and everyone else — now one tool set for everyone." ; narr:phraseSource <https://aswritten.ai/narrative#Position_RefractRegistryRemovedFromProduct> ] ;
    narr:keyPhrase [ narr:text "Memories/source tool removed from product. Memories are just files in the repo — anyone with a coding agent can read them directly. Org-only skill at most." ; narr:phraseSource <https://aswritten.ai/narrative#Position_MemoriesSourceToolRemoved> ] ;
    narr:keyPhrase [ narr:text "The public perspective is a separate sibling repo (aswritten-public), hand-written in external voice, with a hard size cap of ~40 memories and no content above decision-level conviction." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PublicPerspectiveModule> ] ;
    narr:keyPhrase [ narr:text "Call transcript bootstrapping (Fireflies/Gemini/Zoom) is a lighter onramp that allows for an immediate working perspective without a live interview." ; narr:phraseSource <https://aswritten.ai/narrative#Position_TranscriptBootstrapOnramp> ] ;
    narr:keyPhrase [ narr:text "Two distinct usage patterns emerged organically across the enterprise customer's first nine days without prompting" ; narr:phraseSource <https://aswritten.ai/narrative#Position_FourToolLoopEngagedUserPattern> ] ;
    narr:keyPhrase [ narr:text "Notifications system removed; synchronous remember eliminates primary use case." ; narr:phraseSource <https://aswritten.ai/narrative#Position_RemoveNotificationsSystem> ] ;
    narr:variation [ narr:text "Memories/source tool removed on the grounds that memories are just repo files any coding agent can read — but this leaves an open question about whether org-only access patterns are adequately served." ; narr:over <https://aswritten.ai/narrative#Position_MemoriesSourceToolRemoved> ] ;
    narr:variation [ narr:text "Review tool cases 2 and 3 (named transaction vs. arbitrary content) are explicitly flagged as possibly the same — the boundary remains unresolved." ; narr:over <https://aswritten.ai/narrative#Position_ReviewToolThreeCases> ; narr:over <https://aswritten.ai/narrative#Obs_ReviewToolQuote> ] ;
    narr:variation [ narr:text "The two organic usage loops are a promising signal but explicitly held open — 'worth confirming on subsequent customer engagements before treating as a settled finding.'" ; narr:over <https://aswritten.ai/narrative#Position_FourToolLoopEngagedUserPattern> ] ;
    narr:variation [ narr:text "TX summaries removed as auto-generated but the PR comment mechanism is explicitly kept — a partial removal that leaves residual infrastructure in place." ; narr:over <https://aswritten.ai/narrative#Position_TXSummariesAutoGenRemoved> ] ;
    narr:variation [ narr:text "Public perspective module imposes a hard 40-memory cap and bars sub-decision-level content — a structural constraint absent from the internal perspective, creating a two-tier capability split." ; narr:over <https://aswritten.ai/narrative#Narrative_PublicPerspectiveModule> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}