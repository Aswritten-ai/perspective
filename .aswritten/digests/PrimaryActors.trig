@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_PrimaryActors> {
  <https://aswritten.ai/narrative#Digest_PrimaryActors> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#PrimaryActors> ;
    narr:childCount "12"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """This hub gathers the people and buyer-profiles orbiting aswritten.ai's go-to-market. The human network is dense with ex-Vouch ties — [a collaborator](narr:Actor_Curlew), [a design collaborator](narr:Actor_DesignCollaborator) and [a technical collaborator](narr:Actor_TechCollaborator) (the latter two now on a collaborator), plus [Tony Maley](narr:Actor_TonyMaley), whose forcing-function playbook was articulated 2026-04-21 and executed as written. [the customer's chief architect](narr:Actor_CustomerArchitect_TinkererRef) supplied the intro for the first paying customer (Mar 2026). On the demand side the digest spans wildly different scales: [Series A operations people](narr:Claim_OperationsICP) as high-value ICP, [architecture/standards teams as beachhead](narr:Narrative_ArchitectureTeamsBeachhead), [10-50 person dev shops](narr:Actor_InfraAdvisor) validated by an infrastructure advisor (Jan 27), a recurring [inbound-bottleneck pattern](narr:Obs_EarlyProspectInboundBottleneck) seen even in a 5-person practice (Apr 21), and [Fortune 500 enterprise buyers](narr:Observation_PrimaryActors_1). [an engineering manager at the customer](narr:Narrative_CustomerEngManagerChampionLeaner) shows champion-leaning behavior (May 7), explicitly logged as a signal, not a conclusion. Note two distinct Tony entries — [Tony Maley](narr:Actor_TonyMaley) the advisor and a separate sales-contact [Tony](narr:Actor_Tony).""" ;
    narr:covers <https://aswritten.ai/narrative#Actor_Curlew> ;
    narr:covers <https://aswritten.ai/narrative#Actor_InfraAdvisor> ;
    narr:covers <https://aswritten.ai/narrative#Actor_DesignCollaborator> ;
    narr:covers <https://aswritten.ai/narrative#Actor_TechCollaborator> ;
    narr:covers <https://aswritten.ai/narrative#Actor_CustomerArchitect_TinkererRef> ;
    narr:covers <https://aswritten.ai/narrative#Actor_Tony> ;
    narr:covers <https://aswritten.ai/narrative#Actor_TonyMaley> ;
    narr:covers <https://aswritten.ai/narrative#Claim_OperationsICP> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ArchitectureTeamsBeachhead> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_CustomerEngManagerChampionLeaner> ;
    narr:covers <https://aswritten.ai/narrative#Obs_EarlyProspectInboundBottleneck> ;
    narr:covers <https://aswritten.ai/narrative#Observation_PrimaryActors_1> ;
    narr:keyPhrase [ narr:text "Series A operations people have acute pain: fragmented context (Notion hodgepodge), high decision velocity, CEO chaos, already live in ChatGPT." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_OperationsICP> ] ;
    narr:keyPhrase [ narr:text "Architecture/standards teams identified as ideal beachhead: they influence everyone but nobody understands them." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ArchitectureTeamsBeachhead> ] ;
    narr:keyPhrase [ narr:text "validated ICP of 10-50 person dev shops at [amount]-50M revenue" ; narr:phraseSource <https://aswritten.ai/narrative#Actor_InfraAdvisor> ] ;
    narr:keyPhrase [ narr:text "Fortune 500 companies (Intuit, State Farm, Uber) are primary actors committing budgets to AI agent infrastructure." ; narr:phraseSource <https://aswritten.ai/narrative#Observation_PrimaryActors_1> ] ;
    narr:keyPhrase [ narr:text "The acupuncturist that I'm trying to work with actually does have the same pattern of being someone that fields inbound, you know, customer service and sort of inquiry constantly about his expertise" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_EarlyProspectInboundBottleneck> ] ;
    narr:variation [ narr:text "Target buyer scale is unresolved and spans three orders of magnitude — Fortune 500 enterprises vs. 10-50 person dev shops vs. a 5-person practice — never reconciled into one ICP." ; narr:over <https://aswritten.ai/narrative#Observation_PrimaryActors_1> ; narr:over <https://aswritten.ai/narrative#Actor_InfraAdvisor> ; narr:over <https://aswritten.ai/narrative#Obs_EarlyProspectInboundBottleneck> ] ;
    narr:variation [ narr:text "Two competing beachhead theses sit side by side: operations persona (intersection of customer knowledge and internal process) vs. architecture/standards teams (high influence, low legibility)." ; narr:over <https://aswritten.ai/narrative#Claim_OperationsICP> ; narr:over <https://aswritten.ai/narrative#Narrative_ArchitectureTeamsBeachhead> ] ;
    narr:variation [ narr:text "The inbound-bottleneck pattern is claimed to generalize across org sizes (the enterprise customer to a solo acupuncturist) — a unifying signal that cuts against the scale-divergence above." ; narr:over <https://aswritten.ai/narrative#Obs_EarlyProspectInboundBottleneck> ; narr:over <https://aswritten.ai/narrative#Actor_CustomerArchitect_TinkererRef> ] ;
    narr:variation [ narr:text "an engineering manager at the customer is explicitly flagged as a worth-watching signal, not a settled second-champion finding — don't read it as confirmed." ; narr:over <https://aswritten.ai/narrative#Narrative_CustomerEngManagerChampionLeaner> ] ;
    narr:variation [ narr:text "Two separate 'Tony' actors risk conflation: Tony Maley the ex-Vouch advisor vs. an unspecified sales-contact Tony ('trusted but painful')." ; narr:over <https://aswritten.ai/narrative#Actor_TonyMaley> ; narr:over <https://aswritten.ai/narrative#Actor_Tony> ] ;
    narr:writer "claude (subscription)" .
}