@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_NavigationReplacesEmbeddedSnapshot> {
  <https://aswritten.ai/narrative#Digest_Narrative_NavigationReplacesEmbeddedSnapshot> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_NavigationReplacesEmbeddedSnapshot> ;
    narr:childCount "6"^^xsd:integer ;
    narr:generatedFrom "3176929ab93d860c6daf7a67e590f4aab0954d66" ;
    narr:narration """The architectural shift toward navigation-first interaction, initiated in mid-June 2026, centers on replacing monolithic snapshots with a [digest-driven traversal model](narr:https://aswritten.ai/narrative#Position_NavigationDropsContextOrderOfMagnitude). This move, which reduced per-call context by an order of magnitude, aligns with [independent industry parallels](narr:https://aswritten.ai/narrative#Position_DiscoveryConsultantHATEOASParallel) that favor link-based discovery over large-scale queries. By July 2026, this philosophy matured into a [standardized perspective response](narr:https://aswritten.ai/narrative#Narrative_PerspectiveResponseOrderedByVolatility) structured by volatility, ensuring that stable maps remain constant while per-call focus is relegated to the end. To maintain graph integrity, the system adopted [synchronous per-message integration](narr:https://aswritten.ai/narrative#Narrative_SynchronousPerMessageIntegration), rejecting asynchronous patterns to prevent state drift. The user experience now mirrors this machine-centric logic, with the [digest browser](narr:https://aswritten.ai/narrative#Narrative_DigestBrowserProductSurface) serving as the primary interface for both human and agent. Finally, the team has defined a [content/commentary split](narr:https://aswritten.ai/narrative#Narrative_ContentCommentarySplit) to distinguish between raw source material and authored reconciliation, though the write-side implementation remains a pending task.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DigestBrowserProductSurface> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PerspectiveResponseOrderedByVolatility> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_SynchronousPerMessageIntegration> ;
    narr:covers <https://aswritten.ai/narrative#Position_DiscoveryConsultantHATEOASParallel> ;
    narr:covers <https://aswritten.ai/narrative#Position_NavigationDropsContextOrderOfMagnitude> ;
    narr:keyPhrase [ narr:text "Navigation drops per-call context by an order of magnitude" ; narr:phraseSource <https://aswritten.ai/narrative#Position_NavigationDropsContextOrderOfMagnitude> ] ;
    narr:keyPhrase [ narr:text "the primary way of navigating any information base... is through discovery and navigation, going link by link" ; narr:phraseSource <https://aswritten.ai/narrative#Position_DiscoveryConsultantHATEOASParallel> ] ;
    narr:keyPhrase [ narr:text "Perspective response ordered by volatility: stable skeleton leads, per-call focus appended last" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PerspectiveResponseOrderedByVolatility> ] ;
    narr:keyPhrase [ narr:text "Integration is synchronous, per-message, and silent" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_SynchronousPerMessageIntegration> ] ;
    narr:keyPhrase [ narr:text "Content/commentary split: per-message integration is the content layer; reconciliation is the authored commentary layer" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ] ;
    narr:variation [ narr:text "Potential conflict between synchronous integration and MCP client limitations requiring a hybrid model." ; narr:over <https://aswritten.ai/narrative#Narrative_SynchronousPerMessageIntegration> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}