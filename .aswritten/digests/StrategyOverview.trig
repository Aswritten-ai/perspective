    narr:covers <https://aswritten.ai/narrative#Position_NoSecretsRequired> ;
    narr:covers <https://aswritten.ai/narrative#Position_QualityOfEngagementIsValidation> ;
    narr:covers <https://aswritten.ai/narrative#Position_ThreeLayerConvergence> ;
    narr:covers <https://aswritten.ai/narrative#Position_YC_Application_1> ;
    narr:covers <https://aswritten.ai/narrative#Positioning_SMSProduct> ;
    narr:covers <https://aswritten.ai/narrative#Sequencing_SMSProduct> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_WhyYC> ;
    narr:keyPhrase [ narr:text "team sizing and pricing are calibrated to validated demand, not venture timelines" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_CalibratedGrowthDiscipline> ] ;
    narr:keyPhrase [ narr:text "you don't want to clip the wings of the raven — it won't fly if you do that." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_DiscoveryConsultantClipWingsQuote> ] ;
    narr:keyPhrase [ narr:text "this business is built on a business model that expects repeatability and profitability early." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletProfitableByDefaultQuote> ] ;
    narr:keyPhrase [ narr:text "It's not actually required to hit profitability at each stair step, or is that even necessarily the goal" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletStaircaseQuote> ] ;
    narr:keyPhrase [ narr:text "The tools for developing the org that develops the product are conflated with the product itself — they must be cleanly separated" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_CoreConflationProductVsTooling> ] ;
    narr:variation [ narr:text "Enterprise consulting is treated as a revenue stream, not as the core strategic positioning or fundraising frame." ; narr:over <https://aswritten.ai/narrative#Narrative_EnterpriseAsRevenueNotPositioning> ] ;
    narr:variation [ narr:text "The 'staircase' model of growth does not strictly require profitability at every individual step." ; narr:over <https://aswritten.ai/narrative#Obs_ScarletStaircaseQuote> ] ;
    narr:variation [ narr:text "Product development is driven by the active rejection of metadata and conflation, rather than feature addition." ; narr:over <https://aswritten.ai/narrative#Narrative_DesignByRejection> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
