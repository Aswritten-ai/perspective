    narr:keyPhrase [ narr:text "The quality of the engagement IS the product validation." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_QualityOfEngagementIsValidation> ] ;
    narr:keyPhrase [ narr:text "I don't want to say the contingency plan is the plan. YC is the other pathway. There are two parallel pathways." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_TwoParallelPathwaysQuote> ] ;
    narr:keyPhrase [ narr:text "team sizing and pricing are calibrated to validated demand, not venture timelines" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_CalibratedGrowthDiscipline> ] ;
    narr:keyPhrase [ narr:text "Tranche 1 [amount] bridge SAFE + Shared Earnings Letter, close end of August 2026." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_TwoTrancheRaiseEnvelope> ] ;
    narr:keyPhrase [ narr:text "only a single round will ever need to be raised" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_OneRoundEver> ] ;
    narr:keyPhrase [ narr:text "this business is built on a business model that expects repeatability and profitability early." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletProfitableByDefaultQuote> ] ;
    narr:keyPhrase [ narr:text "like Git for software, aswritten.ai is for AI collaboration" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_WhyYC> ] ;
    narr:variation [ narr:text "Tranche 2 size is unresolved across sources: [amount] milestone raise (Q1 2027) in the May 17-18 envelope vs. [amount]-4M institutional round in the May 27 sharpening, which claims to supersede it." ; narr:over <https://aswritten.ai/narrative#Claim_TwoTrancheRaiseEnvelope> ; narr:over <https://aswritten.ai/narrative#Narrative_TwoTrancheRaiseStructure> ] ;
    narr:variation [ narr:text "a founder beta user (May 22) argued for a single [amount]-4M VC round now; his points were absorbed into the calibration reframe but the two-tranche, calm-company structure was deliberately preserved, not adopted." ; narr:over <https://aswritten.ai/narrative#Narrative_FounderBetaUserAbsorptionReframe> ] ;
    narr:variation [ narr:text "Enterprise vs SMB positioning pulls in two directions: enterprise consulting is declared 'revenue path, not positioning' and sales target SMB — yet the the enterprise customer PE-backed enterprise shape is the converting template, and SMS-first targets zero-friction self-serve." ; narr:over <https://aswritten.ai/narrative#Narrative_EnterpriseAsRevenueNotPositioning> ; narr:over <https://aswritten.ai/narrative#Narrative_EnterpriseCustomerShapeArchetypeConverting> ; narr:over <https://aswritten.ai/narrative#Positioning_SMSProduct> ] ;
    narr:variation [ narr:text "Pilot/consulting price points diverge: pilot revised [amount]→[amount]consulting framed at [amount], executive track pilot [amount], and profitability math assumes [amount]/mo." ; narr:over <https://aswritten.ai/narrative#Narrative_PricingDecision> ; narr:over <https://aswritten.ai/narrative#Claim_BetaIsConsulting> ; narr:over <https://aswritten.ai/narrative#ExpansionTrack_Executive> ; narr:over <https://aswritten.ai/narrative#Narrative_ProfitabilityAsMathCheck> ] ;
    narr:variation [ narr:text "Profitability framing shifted from a destination ('profitable by default') to a math check on team sizing — raises may happen before profitability for acceleration, not survival." ; narr:over <https://aswritten.ai/narrative#Narrative_ProfitabilityAsMathCheck> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletStaircaseQuote> ] ;
    narr:variation [ narr:text "Revenue model shapes coexist uneasily: implementation [amount]-100K + [amount]/user/mo + usage billing vs. SMS first-topic-free acquisition funnel." ; narr:over <https://aswritten.ai/narrative#Narrative_RevenueModel> ; narr:over <https://aswritten.ai/narrative#Sequencing_SMSProduct> ] ;
    narr:writer "claude (subscription)" .
