    narr:covers <https://aswritten.ai/narrative#Obs_DiscoveryConsultantClipWingsQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletProfitableByDefaultQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletStaircaseQuote> ;
