GRAPH <https://aswritten.ai/narrative#Digest_VoiceActive> {
  <https://aswritten.ai/narrative#Digest_VoiceActive> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#VoiceActive> ;
    narr:childCount "11"^^xsd:integer ;
    narr:generatedFrom "edb9f6070d05850ea732b36518ceed0603f28d08" ;
    narr:narration """This hub tracks the [prescriptive active-voice mandate](narr:Position_ActiveVoice) governing Scarlet’s prose, which prioritizes direct subject-verb-object constructions to eliminate perceived pandering. The style is defined by [agent-first syntax](narr:StyleObs_ActiveVoice) where subjects perform concrete actions, rejecting modal-passive phrasing like 'had to explain' in favor of [direct, punchy verbs](narr:StyleObs_ActiveVoiceRule) such as [onboards](narr:StyleObs_ActiveVoice_1) and [translates](narr:StyleObs_TranslatesFeedback). Beyond sentence-level mechanics, the documentation employs [meta-framing devices](narr:StyleObs_10) like conviction labels and coined idiolects to signal epistemic honesty. The rhetorical structure frequently utilizes [antithesis](narr:StyleObs_9) to sharpen architectural distinctions, alternating between long explanatory prose and short, clinching verdicts. A notable [code-switching pattern](narr:StyleObs_12) persists, contrasting a formal analytical register with informal, unpunctuated personal asides, while metaphors like 'collective memory' serve to humanize the underlying technical system.""" ;
    narr:covers <https://aswritten.ai/narrative#Observation_ActiveVoiceQuote> ;
    narr:covers <https://aswritten.ai/narrative#Position_ActiveVoice> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_10> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_12> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_9> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ActiveVoice> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ActiveVoice1> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ActiveVoiceRule> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ActiveVoice_1> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Onboards> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TranslatesFeedback> ;
    narr:keyPhrase [ narr:text "Always use active voice. Cut 'had to explain', 'needed to figure out', 'tried to communicate'. Use 'explained', 'figured out', 'said'. 'had feels pandering.'" ; narr:phraseSource <https://aswritten.ai/narrative#Position_ActiveVoice> ] ;
    narr:keyPhrase [ narr:text "This validates the MCP-agnostic architecture claim" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ActiveVoice1> ] ;
    narr:keyPhrase [ narr:text "The model translates feedback into triple modifications." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TranslatesFeedback> ] ;
    narr:keyPhrase [ narr:text "This is my life's work." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_9> ] ;
    narr:keyPhrase [ narr:text "compression anxiety" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_10> ] ;
    narr:variation [ narr:text "Passive voice is explicitly permitted as a functional exception for describing bugs." ; narr:over <https://aswritten.ai/narrative#StyleObs_ActiveVoice> ] ;
    narr:variation [ narr:text "The register oscillates between formal analytical rigor and raw, unpunctuated personal expression." ; narr:over <https://aswritten.ai/narrative#StyleObs_12> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}