GRAPH <https://aswritten.ai/narrative#Digest_VoiceActive> {
  <https://aswritten.ai/narrative#Digest_VoiceActive> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#VoiceActive> ;
    narr:childCount "10"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """This hub gathers style observations witnessing Scarlet's [predominantly active, agent-first voice](narr:StyleObs_ActiveVoice): subjects act ('Scarlet refactored', 'buyers apply', 'This validates') with passive reserved mostly for bug descriptions. The voice runs [first-person and declarative](narr:StyleObs_9), alternating long explanatory sentences with short punchy verdicts, and surfaces named commitments. [Imperative active flow](narr:StyleObs_ImperativeFlow) sharpens call-flow steps into staccato commands. Domain verbs like [onboards](narr:StyleObs_ActiveVoice_1) and [translates](narr:StyleObs_TranslatesFeedback) keep the register concrete. [Document-level meta-framing](narr:StyleObs_10) — explicit conviction/confidence labels and coined idiolect like 'compression anxiety' — sits atop the active prose as an epistemic-honesty device.""" ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_10> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_12> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_9> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ActiveVoice> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ActiveVoice1> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ActiveVoice_1> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ImperativeFlow> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Onboards> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Profanity> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TranslatesFeedback> ;
    narr:keyPhrase [ narr:text "Predominantly active voice throughout. Subjects act: 'Scarlet refactored', 'The refactor separates', 'Flows orchestrate'. Passive used only for bug descriptions." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ActiveVoice> ] ;
    narr:keyPhrase [ narr:text "Listen. Don't demo. Don't explain architecture." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ImperativeFlow> ] ;
    narr:keyPhrase [ narr:text "The model translates feedback into triple modifications." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TranslatesFeedback> ] ;
    narr:keyPhrase [ narr:text "This validates the MCP-agnostic architecture claim" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ActiveVoice1> ] ;
    narr:keyPhrase [ narr:text "compression anxiety" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_10> ] ;
    narr:keyPhrase [ narr:text "This is my life's work." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_9> ] ;
    narr:variation [ narr:text "Not uniformly active/formal: deliberate code-switching drops into lowercase, unpunctuated informal register as contrast." ; narr:over <https://aswritten.ai/narrative#StyleObs_12> ] ;
    narr:variation [ narr:text "Unguarded register coexists with the clean voice — profanity used as authenticity marker and intensifier in spoken transcript." ; narr:over <https://aswritten.ai/narrative#StyleObs_Profanity> ] ;
    narr:variation [ narr:text "Active voice is not absolute: passive appears, scoped to bug descriptions — the one admitted exception." ; narr:over <https://aswritten.ai/narrative#StyleObs_ActiveVoice> ] ;
    narr:variation [ narr:text "Three children attach as 'related' not 'broader' (onboards, profanity, translates-feedback) — adjacent style markers, not core active-voice instances." ; narr:over <https://aswritten.ai/narrative#StyleObs_Onboards> ; narr:over <https://aswritten.ai/narrative#StyleObs_Profanity> ; narr:over <https://aswritten.ai/narrative#StyleObs_TranslatesFeedback> ] ;
    narr:writer "claude (subscription)" .
}