@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Process> {
  <https://aswritten.ai/narrative#Digest_Process> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Process> ;
    narr:childCount "5"^^xsd:integer ;
    narr:generatedFrom "ff795e335a68f7de99d4fd45d165b85c1c14b1d8" ;
    narr:narration """The process architecture has evolved from a singular focus on [correcting foundational misunderstandings](narr:Narrative_CorrectBeforeBuilding) toward a more structured, multi-pass operational framework. The current trajectory emphasizes the [Two-Pass ARB Pattern](narr:Narrative_Phase1Phase2Pattern), which bifurcates work into exploratory and finalization phases to manage the lag between intent and execution. This is supported by an [iterative review process](narr:Narrative_ReviewProcess) that prioritizes baseline stability and explicit intent labeling. Crucially, the system distinguishes between review mechanisms and automated side effects; [notifications are treated as post-commit transactions](narr:Position_NotificationTransactionSideEffect) that operate independently of the review flow. To maintain velocity, [review instructions are explicitly non-blocking](narr:Position_ReviewInstructionsNotBlocking), ensuring that users can decline review and continue work without systemic friction.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_CorrectBeforeBuilding> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_Phase1Phase2Pattern> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ReviewProcess> ;
    narr:covers <https://aswritten.ai/narrative#Position_NotificationTransactionSideEffect> ;
    narr:covers <https://aswritten.ai/narrative#Position_ReviewInstructionsNotBlocking> ;
    narr:keyPhrase [ narr:text "Foundational misunderstandings must be corrected before any building begins" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_CorrectBeforeBuilding> ] ;
    narr:keyPhrase [ narr:text "ARB sessions work in two passes: Phase 1 (exploratory) and Phase 2 (finalization)." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_Phase1Phase2Pattern> ] ;
    narr:keyPhrase [ narr:text "Notification is a transaction side effect, not a review mechanism." ; narr:phraseSource <https://aswritten.ai/narrative#Position_NotificationTransactionSideEffect> ] ;
    narr:keyPhrase [ narr:text "Review is strongly offered, not mandatory." ; narr:phraseSource <https://aswritten.ai/narrative#Position_ReviewInstructionsNotBlocking> ] ;
    narr:variation [ narr:text "The tension between mandatory review for quality and non-blocking review for velocity remains a central design constraint." ; narr:over <https://aswritten.ai/narrative#Narrative_ReviewProcess> ; narr:over <https://aswritten.ai/narrative#Position_ReviewInstructionsNotBlocking> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}