    narr:covers <https://aswritten.ai/narrative#StyleObservation_BrandName_1> ;
    narr:covers <https://aswritten.ai/narrative#StyleObservation_LowercaseSignal> ;
    narr:keyPhrase [ narr:text "Lowercase 'aswritten' signals a code-adjacent, anti-corporate identity." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_LowercaseBrandStylization> ] ;
    narr:keyPhrase [ narr:text "aswritten.ai" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_1> ] ;
    narr:keyPhrase [ narr:text "Aswritten.ai" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_1> ] ;
    narr:keyPhrase [ narr:text "Lowercase aswritten and aswritten.ai" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObservation_LowercaseSignal> ] ;
    narr:keyPhrase [ narr:text "so her intern's work can cite her words, aswritten. Annotate your work." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AswrittenModeMarker> ] ;
    narr:keyPhrase [ narr:text "aswritten/remember" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Lenses> ] ;
    narr:variation [ narr:text "Capitalization is NOT uniform: against the lowercase rule sit a capital-A 'Aswritten.ai', a title-case 'As Written' with quotation marks, and a title-case one-word 'Aswritten' paired with 'a collaborator'." ; narr:over <https://aswritten.ai/narrative#StyleObs_1> ; narr:over <https://aswritten.ai/narrative#StyleObs_BrandName_AsWritten> ; narr:over <https://aswritten.ai/narrative#StyleObs_BrandNames> ] ;
    narr:variation [ narr:text "One/two-word split: most render 'aswritten' as one word, but one child reads it as two lowercase words 'as written'." ; narr:over <https://aswritten.ai/narrative#StyleObs_AsWrittenBrandName> ; narr:over <https://aswritten.ai/narrative#StyleObs_AswrittenLowercase> ] ;
    narr:variation [ narr:text "'aswritten' is read not only as a name but as a mode-switch command/suffix — simultaneously brand, command, and rhetorical marker." ; narr:over <https://aswritten.ai/narrative#StyleObs_AswrittenModeMarker> ] ;
    narr:variation [ narr:text "Distinct brand concepts surface that aren't the aswritten name at all: a hedged 'sorta rich' brand and 'worldview' as a product term." ; narr:over <https://aswritten.ai/narrative#StyleObs_SortaRichBrand> ; narr:over <https://aswritten.ai/narrative#StyleObs_WorldviewBrandTerm> ] ;
    narr:variation [ narr:text "Many children under this hub carry no brand-name content — they document register, fragments, formatting, or conviction labels — so 'brand stylization' under-describes the bucket." ; narr:over <https://aswritten.ai/narrative#StyleObs_3> ; narr:over <https://aswritten.ai/narrative#StyleObs_7> ; narr:over <https://aswritten.ai/narrative#StyleObs_CodeBlockPrimitive> ; narr:over <https://aswritten.ai/narrative#StyleObs_ConvictionLabel> ] ;
    narr:writer "claude (subscription)" .
