    narr:variation [ narr:text "The use of all-caps as a formal conviction marker (BOULDER) versus its use as a logo wordmark." ; narr:over <https://aswritten.ai/narrative#StyleObs_ConvictionLabel> ; narr:over <https://aswritten.ai/narrative#Position_AswrittenAICompanyized> ] ;
