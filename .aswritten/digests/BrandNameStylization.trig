    narr:keyPhrase [ narr:text "'Aswritten' is always capitalized in body prose, narratives, and anywhere it is the subject." ; narr:phraseSource <https://aswritten.ai/narrative#Position_AswrittenAICompanyized> ] ;
    narr:keyPhrase [ narr:text "BOULDER used as an inline conviction label in all-caps" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ConvictionLabel> ] ;
    narr:keyPhrase [ narr:text "Provisional — from research/agent-memory-architecture exploration branch, not yet promoted to main." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AgentSim_ProvisionalFlag> ] ;
    narr:keyPhrase [ narr:text "I treated the models themselves like a computer, and a narrative architecture - an interconnected web of narratives that define a way of thinking - like a program that can be installed onto their hardware." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:keyPhrase [ narr:text "perspective + goal + termination criteria + escalation criteria = a bounded autonomous agent" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_CodeBlockPrimitive> ] ;
