    narr:keyPhrase [ narr:text "Cut the 'X, not Y' pattern. It lands the plane. If contrast carries load-bearing meaning, rebuild it through momentum (belief, specifics, belief). Active sentences only." ; narr:phraseSource <https://aswritten.ai/narrative#Position_NoXNotY> ] ;
    narr:keyPhrase [ narr:text "Decay is automatic and temporal... Depreciation is human-driven and semantic" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AgentSim_Antithesis> ] ;
    narr:keyPhrase [ narr:text "canon-in-conviction but canon-soon in temporality" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AntithesisConvictionTemporality> ] ;
    narr:keyPhrase [ narr:text "not general, individual. not lab owned. individually owned. not artificial sentience, something that evolves relationally via your conversations/input." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_SII_ThreeAxisAntithesis> ] ;
    narr:keyPhrase [ narr:text "The pattern lands the plane. Cut *\"Both are tools the AI uses during the work, not reports you read after\"* to *\"The AI calls both during the work.\"*" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_NoXNotYAntithesis> ] ;
    narr:keyPhrase [ narr:text "Intelligence is quick, perspective is hard won." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_IntelligenceVsPerspective> ] ;
    narr:keyPhrase [ narr:text "The bottleneck is not scarce expertise. It is scarce *memory* at the decision junction." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ForgettingBottleneck_Antithesis> ] ;
    narr:keyPhrase [ narr:text "Sponsor ≠ champion. A sponsor is excited and aligned; a champion rams it through internally." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Antithesis_SponsorChampion> ] ;
    narr:keyPhrase [ narr:text "The digest is a lossy index over a lossless store, and the index never gates the store" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AntithesisStructure> ] ;
    narr:keyPhrase [ narr:text "dissolved rather than rejected" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_FableWindowAntithesisPattern> ] ;
    narr:variation [ narr:text "The June 2026 prohibition on 'X, not Y' as sentence-closer creates a direct tension with the many earlier children that treat this exact pattern as the corpus's primary rhetorical strength — the rule bans the device at the sentence level while structural antithesis continues unrestricted." ; narr:over <https://aswritten.ai/narrative#Position_NoXNotY> ; narr:over <https://aswritten.ai/narrative#StyleObs_NoXNotYAntithesis> ; narr:over <https://aswritten.ai/narrative#StyleObs_AntithesisTriggers> ; narr:over <https://aswritten.ai/narrative#StyleObs_MVPRedef_Antithesis> ] ;
    narr:variation [ narr:text "One child flags antithesis as 'overplayed / not an explicit anti-pattern' — a self-aware meta-critique of the device's overuse, distinct from all children that treat it as unambiguously effective." ; narr:over <https://aswritten.ai/narrative#StyleObs_AntithesisOverplayed_20260521> ] ;
    narr:variation [ narr:text "The design-collaborator children show antithesis deployed to argue for AI diversity ('AI more different, not less') — a use case where the device carries a normative claim about product philosophy, not just rhetorical sharpening." ; narr:over <https://aswritten.ai/narrative#StyleObs_DesignCollaboratorCall_Antithesis> ; narr:over <https://aswritten.ai/narrative#StyleObs_DesignCollaboratorTokensAntithesis> ] ;
    narr:variation [ narr:text "The skeptic-preservation child treats antithesis structurally as a way to hold dissent verbatim rather than resolve it — a use of the device that resists the usual resolution-toward-one-pole pattern seen elsewhere." ; narr:over <https://aswritten.ai/narrative#StyleObs_DavidNolen_SkepticalVoiceContrast> ] ;
    narr:variation [ narr:text "The tier-continuum child uses antithesis to dissolve an apparent opposition (B2C vs. enterprise) rather than sustain it — antithesis as resolution device, not contrast-maintenance device." ; narr:over <https://aswritten.ai/narrative#StyleObs_TierContinuumAntithesis> ] ;
    narr:variation [ narr:text "Two MCP/TriG children carry antithesis only in quoted form with no content elaboration, leaving their structural role in the hub ambiguous — outliers in a set where most children provide explicit rhetorical analysis." ; narr:over <https://aswritten.ai/narrative#StyleObs_Antithesis_MCP> ; narr:over <https://aswritten.ai/narrative#StyleObs_Antithesis_TriG> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
