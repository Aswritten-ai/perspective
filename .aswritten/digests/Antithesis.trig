    narr:keyPhrase [ narr:text "The pattern lands the plane. Cut *\"Both are tools the AI uses during the work, not reports you read after\"* to *\"The AI calls both during the work.\"*" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_NoXNotYAntithesis> ] ;
    narr:keyPhrase [ narr:text "Decay is automatic and temporal... Depreciation is human-driven and semantic" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AgentSim_Antithesis> ] ;
    narr:keyPhrase [ narr:text "canon-in-conviction but canon-soon in temporality" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AntithesisConvictionTemporality> ] ;
    narr:keyPhrase [ narr:text "Intelligence is quick, perspective is hard won." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_IntelligenceVsPerspective> ] ;
    narr:keyPhrase [ narr:text "The bottleneck is not scarce expertise. It is scarce *memory* at the decision junction." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ForgettingBottleneck_Antithesis> ] ;
    narr:keyPhrase [ narr:text "Sponsor ≠ champion. A sponsor is excited and aligned; a champion rams it through internally." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Antithesis_SponsorChampion> ] ;
    narr:keyPhrase [ narr:text "trial activity was strong validation; payment is the first actual revenue event and the first contractual obligation in either direction" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AntithesisTrialVsPayment> ] ;
    narr:keyPhrase [ narr:text "The digest is a lossy index over a lossless store, and the index never gates the store" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AntithesisStructure> ] ;
    narr:keyPhrase [ narr:text "citations are constellations, not single claims" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Antithesis_ConstellationVsSingle> ] ;
    narr:keyPhrase [ narr:text "not general, individual. not lab owned. individually owned. not artificial sentience, something that evolves relationally via your conversations/input." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_SII_ThreeAxisAntithesis> ] ;
    narr:variation [ narr:text "The 'X, not Y' form is simultaneously the corpus's dominant rhetorical device and explicitly prohibited as a sentence-closer — the rule bans one specific deployment of the device it elsewhere endorses as structural spine." ; narr:over <https://aswritten.ai/narrative#StyleObs_NoXNotYAntithesis> ; narr:over <https://aswritten.ai/narrative#Claim_NoXNotY> ; narr:over <https://aswritten.ai/narrative#StyleObs_AntithesisStructure> ; narr:over <https://aswritten.ai/narrative#StyleObs_DesignCollaboratorCall_Antithesis> ] ;
    narr:variation [ narr:text "Some children treat antithesis as a descriptive style observation; others assert the rhetorical structure IS the argument — the antithesis does not illustrate the design heuristic, it constitutes it." ; narr:over <https://aswritten.ai/narrative#StyleObs_MCPSession_KeyAxisAntithesis> ; narr:over <https://aswritten.ai/narrative#StyleObs_Protocol_Antithesis> ; narr:over <https://aswritten.ai/narrative#StyleObs_AntithesisRhetoric> ] ;
    narr:variation [ narr:text "One child flags antithesis as 'overplayed / not an explicit anti-pattern' and calls for reconciliation — a self-aware correction against the device's own overuse, sitting alongside dozens of children that celebrate it." ; narr:over <https://aswritten.ai/narrative#StyleObs_AntithesisOverplayed_20260521> ] ;
    narr:variation [ narr:text "Before/after rename antithesis (old term → new term) and rejected-path-named-first antithesis are structurally distinct from binary-choice antithesis (Path 1 vs Path 2) — children conflate these under one label but they serve different epistemic functions." ; narr:over <https://aswritten.ai/narrative#StyleObs_AntithesisBeforeAfter_Distillation> ; narr:over <https://aswritten.ai/narrative#StyleObs_AntithesisReplaces> ; narr:over <https://aswritten.ai/narrative#StyleObs_AntithesisParallelPaths> ; narr:over <https://aswritten.ai/narrative#StyleObs_WriteFlow_AntithesisStructure> ] ;
    narr:variation [ narr:text "The 'achieved by not building' paradox inverts the antithesis form itself — the stronger outcome comes from negation of the expected action, not from choosing between two named poles." ; narr:over <https://aswritten.ai/narrative#StyleObs_AntithesisNotBuilding> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
