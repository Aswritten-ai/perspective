    narr:keyPhrase [ narr:text "The digest is a lossy index over a lossless store, and the index never gates the store" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AntithesisStructure> ] ;
    narr:keyPhrase [ narr:text "Intelligence is quick, perspective is hard won." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_IntelligenceVsPerspective> ] ;
    narr:keyPhrase [ narr:text "The transcript is not the memory; the transcript is the diagnostic." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_OnboardingMethodology_Antithesis> ] ;
    narr:keyPhrase [ narr:text "Smokes prove the mechanism; the battery proves quality." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Antithesis_SmokesVsBattery> ] ;
    narr:keyPhrase [ narr:text "The demo is your AI reading aswritten's mind; the product is your AI reading yours." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TranscriptOnramp_Antithesis> ] ;
    narr:variation [ narr:text "The 'X, not Y' pattern is explicitly prohibited as momentum-killing, yet remains the dominant structural spine elsewhere." ; narr:over <https://aswritten.ai/narrative#StyleObs_NoXNotYAntithesis> ; narr:over <https://aswritten.ai/narrative#Position_NoXNotY> ] ;
    narr:variation [ narr:text "Antithesis is used to preserve skeptical voices verbatim, contrasting with its use as a tool for authoritatively closing strategic reframes." ; narr:over <https://aswritten.ai/narrative#StyleObs_DavidNolen_SkepticalVoiceContrast> ; narr:over <https://aswritten.ai/narrative#StyleObs_AntithesisReplaces> ] ;
    narr:variation [ narr:text "Some antitheses are presented as permanent design constraints, while others are treated as temporary pivots to be superseded." ; narr:over <https://aswritten.ai/narrative#StyleObs_AntithesisStructure> ; narr:over <https://aswritten.ai/narrative#StyleObs_AntithesisBeforeAfter_Distillation> ] ;
