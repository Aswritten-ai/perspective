@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_ExpertiseOnDemandReframe> {
  <https://aswritten.ai/narrative#Digest_Narrative_ExpertiseOnDemandReframe> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_ExpertiseOnDemandReframe> ;
    narr:childCount "6"^^xsd:integer ;
    narr:generatedFrom "97dfe8ff762b59ff40ae6a12e9bb07db3c0a7fda" ;
    narr:narration """The narrative trajectory has shifted from an ambient, session-based intelligence model toward [installable expertise](narr:Position_CoreValuePropInstallExpertise) triggered at the point of need. This reframe, solidified in March 2026, positions the AI as a capability-driven tool where users [invoke modules mid-task](narr:Position_AmbientVsOnDemandBehavior) to bridge specific knowledge gaps. The core value proposition emphasizes [perspectives over raw information](narr:Position_PerspectiveNotInformation), distinguishing the product from general-purpose AI by treating the underlying model as hardware and the [installed expertise as the software](narr:Position_ModelAsHardwarePerspectiveAsSoftware) that dictates how information is framed and applied. While the [Knowledge Packager archetype](narr:Archetype_KnowledgePackager) provides a clear commercial anchor—targeting bottlenecked experts who need to scale their context—the operational reality remains in flux. Specifically, the reliance on [voice memos and call transcripts](narr:Position_VoiceMemosAndTranscriptsPrimaryInputs) as primary inputs remains a friction point, as this high-utility behavior is currently under-communicated in the standard pitch.""" ;
    narr:covers <https://aswritten.ai/narrative#Archetype_KnowledgePackager> ;
    narr:covers <https://aswritten.ai/narrative#Position_AmbientVsOnDemandBehavior> ;
    narr:covers <https://aswritten.ai/narrative#Position_CoreValuePropInstallExpertise> ;
    narr:covers <https://aswritten.ai/narrative#Position_ModelAsHardwarePerspectiveAsSoftware> ;
    narr:covers <https://aswritten.ai/narrative#Position_PerspectiveNotInformation> ;
    narr:covers <https://aswritten.ai/narrative#Position_VoiceMemosAndTranscriptsPrimaryInputs> ;
    narr:keyPhrase [ narr:text "installable expertise" ; narr:phraseSource <https://aswritten.ai/narrative#Position_CoreValuePropInstallExpertise> ] ;
    narr:keyPhrase [ narr:text "not intelligence is capability" ; narr:phraseSource <https://aswritten.ai/narrative#Position_CoreValuePropInstallExpertise> ] ;
    narr:keyPhrase [ narr:text "treating the model like hardware that we install the program of perspective on top of" ; narr:phraseSource <https://aswritten.ai/narrative#Position_ModelAsHardwarePerspectiveAsSoftware> ] ;
    narr:keyPhrase [ narr:text "I keep repeating myself / my knowledge doesn't scale / I can't be in every room." ; narr:phraseSource <https://aswritten.ai/narrative#Archetype_KnowledgePackager> ] ;
    narr:keyPhrase [ narr:text "Modules load a set of perspectives, narratives, approaches, processes, and opinions" ; narr:phraseSource <https://aswritten.ai/narrative#Position_PerspectiveNotInformation> ] ;
    narr:variation [ narr:text "The 'Sales-as-Delivery' model for onboarding experts is proposed but remains untested and prone to execution delays." ; narr:over <https://aswritten.ai/narrative#Archetype_KnowledgePackager> ] ;
    narr:variation [ narr:text "The pitch emphasizes 'installable expertise' while downplaying the actual, high-frequency input methods (voice/transcripts) used by the founder." ; narr:over <https://aswritten.ai/narrative#Position_VoiceMemosAndTranscriptsPrimaryInputs> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}