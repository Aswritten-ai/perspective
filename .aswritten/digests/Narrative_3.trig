@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_3> {
  <https://aswritten.ai/narrative#Digest_Narrative_3> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_3> ;
    narr:childCount "5"^^xsd:integer ;
    narr:generatedFrom "75095ac1d69196914bb4f5d010de7d57a4acd0ce" ;
    narr:narration """This hub explores the intersection of [narrative as software](narr:Narrative_4) and the technical constraints of AI steering. The core thesis posits that narrative architecture functions as a program installed onto model hardware, a concept supported by the [eye chart instrument](narr:Position_8)—a fixed-format document designed to maintain consistency while the underlying lens changes. This architecture is not merely descriptive; it is a [strategic vector](narr:RubricAssess_StrategicAlignment) that maps intellectual through-lines from generative systems to collective memory. The substrate metaphor is further elaborated through [typographic and rhetorical style observations](narr:StyleObs_3) that treat narrative as a deployable, versioned asset, and [Matrix-inspired skill-download analogies](narr:StyleObs_4) that frame the AI coworker as a programmable entity. While the hub focuses on the mechanics of this installation, the tension remains between the prescriptive, commanding cadence of the narrative deployment and the underlying fluidity of the models themselves.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_4> ;
    narr:covers <https://aswritten.ai/narrative#Position_8> ;
    narr:covers <https://aswritten.ai/narrative#RubricAssess_StrategicAlignment> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_3> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_4> ;
    narr:keyPhrase [ narr:text "I treated the models themselves like a computer, and a narrative architecture - an interconnected web of narratives that define a way of thinking - like a program that can be installed onto their hardware." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:keyPhrase [ narr:text "The physics never changed. The substrate did" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:keyPhrase [ narr:text "A bit like the \"I know kung fu\" skill downloads in the Matrix" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_4> ] ;
    narr:keyPhrase [ narr:text "Version, collaborate, manipulate, review, deploy perspective—treating narrative like software." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_4> ] ;
    narr:keyPhrase [ narr:text "Eye chart = fixed-format document exercising key claims and relationships; lens changes, eye chart stays constant" ; narr:phraseSource <https://aswritten.ai/narrative#Position_8> ] ;
    narr:variation [ narr:text "The tension between prescriptive, imperative command structures and the fluid, conversational 'founder voice' register." ; narr:over <https://aswritten.ai/narrative#StyleObs_3> ; narr:over <https://aswritten.ai/narrative#StyleObs_4> ] ;
    narr:variation [ narr:text "The potential for 'narrative as vector' to be interpreted as either a rigid product constraint or a flexible strategic framework." ; narr:over <https://aswritten.ai/narrative#RubricAssess_StrategicAlignment> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}