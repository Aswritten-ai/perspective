    narr:covers <https://aswritten.ai/narrative#Obs_LiveTranscriptionQuestion> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletTemporalityQuote> ;
    narr:covers <https://aswritten.ai/narrative#Observation_ConvergenceInsight> ;
    narr:covers <https://aswritten.ai/narrative#Observation_InflectionPoints_1> ;
    narr:covers <https://aswritten.ai/narrative#Observation_QuickWins> ;
    narr:keyPhrase [ narr:text "license expansion 2→7→16 in one week, MSA out to lawyer" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_BaseCampNotCamp4> ] ;
    narr:keyPhrase [ narr:text "You've got a two year window" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_TwoYearWindow> ] ;
    narr:keyPhrase [ narr:text "SaaS stocks (Salesforce, ServiceNow, Workday, SAP) sold off on AI agent disintermediation fears" ; narr:phraseSource <https://aswritten.ai/narrative#Observation_InflectionPoints_1> ] ;
    narr:keyPhrase [ narr:text "the optometrist model IS the review flow" ; narr:phraseSource <https://aswritten.ai/narrative#Observation_ConvergenceInsight> ] ;
