GRAPH <https://aswritten.ai/narrative#Digest_Anaphora> {
  <https://aswritten.ai/narrative#Digest_Anaphora> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Anaphora> ;
    narr:childCount "12"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """This hub gathers style observations of **anaphora** — repeated clause-initial structure used for emphasis, rhythm, and memorability across the corpus. The dominant reading is rhetorical refrain: [repeated 'no' and 'the consulting IS'](narr:StyleObs_Anaphora), [cumulative 'Here's...' six times](narr:StyleObs_Anaphora_HereIs) building a fundraising arc, [parallel 'No company...'](narr:StyleObs_NoCompanyAnaphora), [OLD/NEW parallel contrast](narr:StyleObs_Anaphora_OldNew), and [the implied 'all agree that...' over five numbered consensus claims](narr:StyleObs_UnanimousAgreement). A strong sub-strand is **anaphora-by-negation** — discipline enumerated through prohibition: [four rapid 'Do NOT' imperatives](narr:StyleObs_DoNotBullets) and [the dated 'The company does not bloat... does not build... does not grow...'](narr:StyleObs_CalibratedGrowth_Anaphora) (27 May 2026). Smaller cadence markers: [repeated 'Fills'](narr:StyleObs_Anaphora_Fills), [the four-beat em-dash ladder](narr:StyleObs_LadderAnaphora), [editorial 'snappy, snappy'](narr:StyleObs_SnappySnappy), and [recursive 'a collaborator a collaborator AI' doubling](narr:StyleObs_CedarCedarAI). One child sits only loosely here: [StyleObs_4](narr:StyleObs_4) catalogs mostly non-anaphoric devices and contributes only its tricolon. Only one observation carries a date; the rest are undated, so no temporal trajectory is asserted.""" ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_4> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Anaphora> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Anaphora_Fills> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Anaphora_HereIs> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Anaphora_OldNew> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_CalibratedGrowth_Anaphora> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_DoNotBullets> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_CedarCedarAI> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_LadderAnaphora> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NoCompanyAnaphora> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_SnappySnappy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_UnanimousAgreement> ;
    narr:keyPhrase [ narr:text "No company would develop software without GitHub. No company should deploy AI agents without versioned organizational context." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_NoCompanyAnaphora> ] ;
    narr:keyPhrase [ narr:text "The company does not bloat ahead of application. It does not build abstract product without delivery. It does not grow team before customer pipeline justifies it." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_CalibratedGrowth_Anaphora> ] ;
    narr:keyPhrase [ narr:text "snappy, snappy" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_SnappySnappy> ] ;
    narr:keyPhrase [ narr:text "dream bigger" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_4> ] ;
    narr:variation [ narr:text "Affirmative/cumulative anaphora (momentum-building: 'Here's' ×6, 'Fills', 'the consulting IS') versus negation-anaphora (prohibition: 'No company', 'does not', 'Do NOT', repeated 'no') — the same device serving opposite rhetorical work." ; narr:over <https://aswritten.ai/narrative#StyleObs_Anaphora_HereIs> ; narr:over <https://aswritten.ai/narrative#StyleObs_Anaphora_Fills> ; narr:over <https://aswritten.ai/narrative#StyleObs_DoNotBullets> ; narr:over <https://aswritten.ai/narrative#StyleObs_NoCompanyAnaphora> ; narr:over <https://aswritten.ai/narrative#StyleObs_CalibratedGrowth_Anaphora> ] ;
    narr:variation [ narr:text "Word-level reduplication ('a collaborator a collaborator AI', 'snappy, snappy') is doubling, not clause-initial anaphora — structurally distinct outliers filed under the same hub." ; narr:over <https://aswritten.ai/narrative#StyleObs_CedarCedarAI> ; narr:over <https://aswritten.ai/narrative#StyleObs_SnappySnappy> ] ;
    narr:variation [ narr:text "StyleObs_4 is a loose fit: it mainly catalogs non-anaphoric devices (Matrix/Kahneman analogies, declarative short sentences) and qualifies only via one tricolon." ; narr:over <https://aswritten.ai/narrative#StyleObs_4> ] ;
    narr:variation [ narr:text "Only StyleObs_CalibratedGrowth_Anaphora bears a date (20260527); all others are undated, so the hub supports no temporal sequence." ; narr:over <https://aswritten.ai/narrative#StyleObs_CalibratedGrowth_Anaphora> ] ;
    narr:writer "claude (subscription)" .
}