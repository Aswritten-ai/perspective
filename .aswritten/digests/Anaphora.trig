@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Anaphora> {
  <https://aswritten.ai/narrative#Digest_Anaphora> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Anaphora> ;
    narr:childCount "10"^^xsd:integer ;
    narr:generatedFrom "bcb14dc7ed47fac3d7c0f71a50350a5588d47322" ;
    narr:narration """This hub gathers style observations of **anaphora** — repeated clause-initial structure deployed for emphasis, rhythm, and memorability across the corpus. The dominant strand is **rhetorical refrain**: [repeated 'the consulting IS' and 'no' at clause start](narr:StyleObs_Anaphora), [parallel 'No company...' analogy](narr:StyleObs_NoCompanyAnaphora), and [OLD/NEW parallel contrast rhythm](narr:StyleObs_Anaphora_OldNew). A strong sub-strand is **anaphora-by-negation** — discipline enumerated through prohibition: [four rapid 'Do NOT' imperatives](narr:StyleObs_DoNotBullets) and [the dated 'does not bloat... does not build... does not grow...' commitment list](narr:StyleObs_CalibratedGrowth_Anaphora) (27 May 2026). A newer dated entry (2 Jul 2026) extends the pattern into **collective pivot**: [the 'We too are compiled' closing](narr:StyleObs_EVFlocking_Anaphora) shifts from first-person founder voice to shared mission, with a fragment-as-declaration for maximum finality. Smaller cadence markers include [repeated 'Fills' checkmarks](narr:StyleObs_Anaphora_Fills), [the five-fold 'No, no, no, no, no' categorical rejection](narr:StyleObs_NoNoNoAnaphora), [editorial 'snappy, snappy' doubling](narr:StyleObs_SnappySnappy), and [the tricolon 'what it believes, what it pushes back on, what it lets slide'](narr:StyleObs_4). Two children carry dates (May and Jul 2026); the rest are undated, so no full temporal trajectory is asserted.""" ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_4> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Anaphora> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Anaphora_Fills> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Anaphora_OldNew> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_CalibratedGrowth_Anaphora> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_DoNotBullets> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_EVFlocking_Anaphora> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NoCompanyAnaphora> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NoNoNoAnaphora> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_SnappySnappy> ;
    narr:keyPhrase [ narr:text "The company does not bloat ahead of application. It does not build abstract product without delivery. It does not grow team before customer pipeline justifies it." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_CalibratedGrowth_Anaphora> ] ;
    narr:keyPhrase [ narr:text "No company would develop software without GitHub. No company should deploy AI agents without versioned organizational context." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_NoCompanyAnaphora> ] ;
    narr:keyPhrase [ narr:text "We too are compiled, from stories inherited and newly written." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_EVFlocking_Anaphora> ] ;
    narr:keyPhrase [ narr:text "No, no, no, no, no." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_NoNoNoAnaphora> ] ;
    narr:keyPhrase [ narr:text "✅ **Fills gap_demo_beat_sequence**\n✅ **Fills gap_demo_persona_tailoring**" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Anaphora_Fills> ] ;
    narr:keyPhrase [ narr:text "snappy, snappy" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_SnappySnappy> ] ;
    narr:keyPhrase [ narr:text "Anaphoric 'Do NOT' repeated four times in rapid succession; imperative mood creates a checklist-as-manifesto effect" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DoNotBullets> ] ;
    narr:variation [ narr:text "Most anaphora here is prohibitive or declarative; one outlier uses anaphora as collective pivot — shifting grammatical person from 'I' to 'We' to close a piece, a structural function distinct from the refrain or negation patterns." ; narr:over <https://aswritten.ai/narrative#StyleObs_EVFlocking_Anaphora> ] ;
    narr:variation [ narr:text "StyleObs_4 sits loosely: it catalogs multiple non-anaphoric devices (em-dash cadence, emphatic capitalization, second-person imperative) and contributes only its tricolon as anaphora proper — an outlier in scope relative to the single-device observations." ; narr:over <https://aswritten.ai/narrative#StyleObs_4> ] ;
    narr:variation [ narr:text "Negation-anaphora splits into two registers: the five-fold 'No, no, no, no, no' is raw categorical rejection (philosophical boundary), while 'does not bloat / does not build / does not grow' is structured commitment rhetoric — same device, different rhetorical posture." ; narr:over <https://aswritten.ai/narrative#StyleObs_NoNoNoAnaphora> ; narr:over <https://aswritten.ai/narrative#StyleObs_CalibratedGrowth_Anaphora> ] ;
    narr:variation [ narr:text "The 'snappy, snappy' and 'Fills / Fills' entries are micro-repetitions functioning as cadence or editorial markers rather than argument-structuring anaphora — a lighter-weight use of the device." ; narr:over <https://aswritten.ai/narrative#StyleObs_SnappySnappy> ; narr:over <https://aswritten.ai/narrative#StyleObs_Anaphora_Fills> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}