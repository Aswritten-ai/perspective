    narr:covers <https://aswritten.ai/narrative#StyleObs_VerbatimReframe> ;
    narr:keyPhrase [ narr:text "Antithesis: 'knowledge growth driver, not just a verification tool' — the 'not just' construction explicitly inverts the expected framing to elevate the concept." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_2> ] ;
    narr:keyPhrase [ narr:text "Anaphoric numbered imperatives: 'Annotate first', 'Complete the user's actual request', 'Present annotation results' — each begins with a strong verb, creating a commanding cadence." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_4> ] ;
    narr:keyPhrase [ narr:text "'Asymptotic approach' applied to knowledge convergence — mathematical metaphor conveying progressive trust without discrete endpoint" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_5> ] ;
    narr:keyPhrase [ narr:text "'Escape valve' as mechanical metaphor for psychological pressure-release function of Type 7 ideation." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_5> ] ;
    narr:keyPhrase [ narr:text "'bootload a new worldview' — technical metaphor (OS bootloading) applied to epistemological context-setting; idiolect marker for Scarlet." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_6> ] ;
    narr:keyPhrase [ narr:text "the cutover decision was saved as a memory through the new production pipeline, its citation offsets landing slice-exact on the first try" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_SelfDocumentingRelease> ] ;
    narr:keyPhrase [ narr:text "testing it against every archetype in the perspective" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ArchetypeTesting> ] ;
    narr:keyPhrase [ narr:text "a readable test framework becomes the critical human review interface" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AnalogyReadableTest> ] ;
    narr:keyPhrase [ narr:text "Adverb 'counterintuitively' used as a rhetorical signal to pre-empt objection and reframe a weakness (the AI admitting ignorance) as a strength (epistemic integrity)." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_CounterIntuitivelyPowerful> ] ;
    narr:keyPhrase [ narr:text "Antithesis used to sharpen the [amount] outcome: 'running it, not evaluating it' — draws a hard line between deployment and consideration" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Antithesis> ] ;
    narr:variation [ narr:text "The arrows/archery metaphor carries an unresolved draft flag — the EV version should open to the voices question rather than close on productivity, leaving the metaphor's final rhetorical destination open." ; narr:over <https://aswritten.ai/narrative#Obs_FeatherArrowsClose> ] ;
    narr:variation [ narr:text "Technical-register metaphors (\"bootload a new worldview,\" \"memories are like PRs,\" \"opinion machine\") form a distinct idiolect layer that sits in tension with the clinical optometry register dominating the main explanatory framework." ; narr:over <https://aswritten.ai/narrative#StyleObs_6> ; narr:over <https://aswritten.ai/narrative#StyleObs_5> ] ;
    narr:variation [ narr:text "The self-documenting release enacts the product thesis structurally, not just rhetorically — a recursive move that could be read as demonstration or as self-congratulation, depending on the reader's prior." ; narr:over <https://aswritten.ai/narrative#StyleObs_SelfDocumentingRelease> ; narr:over <https://aswritten.ai/narrative#StyleObs_ProductTestingItself> ] ;
    narr:variation [ narr:text "Antithesis appears both as a clarifying device (binary decision points, process semantics) and as a persuasive reframe ('not just,' 'It's not X, it's Y') — the same surface form doing structurally different rhetorical work." ; narr:over <https://aswritten.ai/narrative#StyleObs_Antithesis> ; narr:over <https://aswritten.ai/narrative#StyleObs_VerbatimReframe> ; narr:over <https://aswritten.ai/narrative#StyleObs_2> ] ;
    narr:variation [ narr:text "Scare-quotes as vocabulary rejection signal ('infrastructure' vs. 'the product working or not working') is a distinct move from the capitalized-IS emphasis pattern, though both police term boundaries." ; narr:over <https://aswritten.ai/narrative#StyleObs_QuotedTermReframe> ; narr:over <https://aswritten.ai/narrative#StyleObs_CallIsMemory> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
