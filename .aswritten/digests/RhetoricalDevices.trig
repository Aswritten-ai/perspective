    narr:covers <https://aswritten.ai/narrative#StyleObs_Antithesis> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ArchetypeTesting> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_CallIsMemory> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_CounterIntuitivelyPowerful> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Metaphor_1> ;
