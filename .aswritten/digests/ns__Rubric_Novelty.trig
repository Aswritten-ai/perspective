    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Novelty_ADR002> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Novelty_GTM> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_novelty> ;
    narr:keyPhrase [ narr:text "worldview as executable strategy" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Novelty> ] ;
    narr:keyPhrase [ narr:text "IP crisis vs developer convenience" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assessment_Novelty_IPCrisis> ] ;
