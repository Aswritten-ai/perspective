    narr:variation [ narr:text "ADR documentation is explicitly noted for its reliance on conventional business language, contrasting with the high-novelty creative artifacts." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Novelty_ADR001> ] ;
    narr:variation [ narr:text "Some assessments identify a tension between 'fresh metaphors' and the inclusion of domain-standard phrases like 'pain-first' or 'four pillars'." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Novelty> ] ;
