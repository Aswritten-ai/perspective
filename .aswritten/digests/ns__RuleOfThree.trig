    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_cadence_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_rule_of_three> ;
    narr:keyPhrase [ narr:text "git native, i.e. versionable, branchable, reviewable" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_GitNativeTriad> ] ;
    narr:keyPhrase [ narr:text "Senior people have supercharged AIs. Junior people have dumb AIs. New hires have useless AIs." ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_RuleOfThree> ] ;
    narr:keyPhrase [ narr:text "new hires, clients, and investors" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_4> ] ;
    narr:keyPhrase [ narr:text "explicit, reviewable, and testable" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_10> ] ;
    narr:keyPhrase [ narr:text "positioning, offering, product, teams, and process" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_6> ] ;
    narr:variation [ narr:text "Outlier — not a triad: five parallel clauses, the rule-of-three 'extended for completeness' (positioning, offering, product, teams, and process)." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_6> ] ;
    narr:variation [ narr:text "Different device entirely: a before→after compression pattern (days → 15 minutes), not parallel triadic structure." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_TimeMetrics> ] ;
    narr:variation [ narr:text "Structurally distinct attachment — joined via skos:related, not broader; parallel noun phrases without verbs." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_cadence_1> ] ;
