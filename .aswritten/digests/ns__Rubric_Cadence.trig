    narr:generatedFrom "721e9f5c7dd127d8bf27311de37d64a4583fda0f" ;
    narr:narration """This hub gathers per-document **cadence** assessments under one rubric dimension — how rhythm, sentence-length variation, and structural devices shape readability. The dominant pattern across children is consistent praise for short-punchy-plus-longer-explanatory alternation: [varied sentence length for technical documentation](narr:Assess_Cadence_cm), [bullet points and sequence diagrams breaking dense prose](narr:Assess_Cadence_collective_memory), [em-dashes and parentheticals carrying speech rhythm](narr:Assessment_Cadence_CustomerArchitect), and [strategic short sentences for key claims](narr:Assessment_Cadence_IPCrisis). Structural devices recur as cadence carriers: [antithesis for impact ('weeks → days') with fast-scan density](narr:RubricAssess_Cadence_GTM), [triadic structures and anaphora for oral delivery](narr:RubricAssess_cadence), and [parallel heading construction across speakers](narr:RubricAssess_Cadence). The richest entry, [the multi-source rubric assessment](narr:RubricAssess_Cadence), holds several distinct verdicts simultaneously — from 'exemplary staccato' to mixed transcribed-speech patterns needing editing. [ADR-format assessments](narr:RubricAssess_Cadence_ADR001) note complex rationale clauses as a counterweight to punchy sections. No dates attach to most children; this reads as a standing rubric library rather than a dated trajectory.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Assess_Cadence_cm> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assess_Cadence_collective_memory> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assessment_Cadence_CustomerArchitect> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assessment_Cadence_IPCrisis> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Cadence> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Cadence_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Cadence_ADR001> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Cadence_ADR002> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Cadence_GTM> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_cadence> ;
    narr:keyPhrase [ narr:text "Varied sentence length; mix of short declarative statements and longer explanatory sentences; good rhythm for technical documentation" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assess_Cadence_cm> ] ;
    narr:keyPhrase [ narr:text "bullet points create scannable rhythm; sequence diagrams break up dense technical prose" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assess_Cadence_collective_memory> ] ;
    narr:keyPhrase [ narr:text "natural speech rhythm; effective use of em-dashes and parentheticals." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assessment_Cadence_CustomerArchitect> ] ;
    narr:keyPhrase [ narr:text "Exemplary short & punchy cadence. Staccato rhythm. Rule of three. Parallel structures. Em-dashes for emphasis. Varies sentence length for impact." ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Cadence> ] ;
    narr:keyPhrase [ narr:text "Mixed cadence: some punchy declaratives ('The answer is no.'), but also long explanatory clauses with hedges ('you know', 'right?'). Transcribed speech patterns visible; would benefit from editing for written form." ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Cadence> ] ;
    narr:keyPhrase [ narr:text "antithesis for impact ('weeks → days'); fast scan, high density." ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Cadence_GTM> ] ;
    narr:keyPhrase [ narr:text "Short, punchy sentences; triadic structures; anaphora for emphasis; varied rhythm" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_cadence> ] ;
    narr:keyPhrase [ narr:text "some complex clauses in rationale section" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Cadence_ADR001> ] ;
    narr:variation [ narr:text "Transcribed-speech degradation: two entries in the multi-source assessment flag run-ons, hedges ('you know', 'right?'), and a recommendation to edit for written form — a qualified verdict against the otherwise-praised conversational rhythm." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Cadence> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Cadence_1> ] ;
    narr:variation [ narr:text "Complex rationale clauses as counterweight: ADR-format documents earn praise for punchy hooks but are also noted for heavier compound sentences in explanatory sections — cadence is document-section-dependent, not uniform." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Cadence_ADR001> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Cadence_ADR002> ] ;
    narr:variation [ narr:text "Speaker-differentiated rhythm: the multi-source entry distinguishes Tony's short quotes from Scarlet's longer analytical sentences — cadence as a property of voice within a document, not just of the document as a whole." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Cadence> ] ;
