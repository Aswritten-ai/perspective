    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Cadence_ADR001> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Cadence_ADR002> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Cadence_GTM> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_cadence> ;
    narr:keyPhrase [ narr:text "Exemplary short & punchy cadence. Staccato rhythm. Rule of three." ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Cadence> ] ;
    narr:keyPhrase [ narr:text "Transcribed speech patterns visible; would benefit from editing for written form." ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Cadence> ] ;
    narr:keyPhrase [ narr:text "antithesis for impact ('weeks → days'); fast scan, high density." ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Cadence_GTM> ] ;
    narr:keyPhrase [ narr:text "before → after pattern provides drumbeat; occasional long voice memo quotes balanced by crisp metrics." ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Cadence_20260107> ] ;
    narr:keyPhrase [ narr:text "Rhythm varies by speaker but maintains clarity." ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Cadence> ] ;
    narr:variation [ narr:text "Not all assessments are praise: transcribed-speech sources are flagged as needing editing for written form, with visible hedges ('you know', 'right?') — a critical note against the otherwise-positive grain." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Cadence> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Cadence_1> ] ;
    narr:variation [ narr:text "Cadence is judged per-speaker, not per-document: Tony's punchy quotes vs Scarlet's longer analytical sentences are scored as distinct rhythms within one piece." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Cadence> ] ;
    narr:variation [ narr:text "Two different things called 'cadence' — prose-level rhythm (sentence length, anaphora) vs. visual/structural cadence (bullets, sequence diagrams, headers); some children lean on layout rather than sentence rhythm." ; narr:over <https://aswritten.ai/ns/narrative#Assess_Cadence_collective_memory> ; narr:over <https://aswritten.ai/ns/narrative#Assessment_Cadence_1> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Cadence_ADR002> ] ;
    narr:variation [ narr:text "Run-on sentences appear as a tolerated flaw in conversational/transcribed pieces, treated as natural rhythm rather than a defect." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Cadence> ] ;
