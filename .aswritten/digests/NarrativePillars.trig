    narr:covers <https://aswritten.ai/narrative#StyleObs_FailureProgression> ;
    narr:keyPhrase [ narr:text "Ghost blog/newsletter to re-engage warm leads without awkward follow-up. Scarlet commits to launch within a week." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ContentAsReengagement> ] ;
    narr:keyPhrase [ narr:text "signals executive summary register" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_BoldLabels> ] ;
    narr:keyPhrase [ narr:text "a structured cadence that mimics slide deck logic within prose" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_BulletCadence> ] ;
    narr:keyPhrase [ narr:text "Creates rhetorical momentum toward the breakthrough" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_FailureProgression> ] ;
    narr:keyPhrase [ narr:text "reinforcing the prohibition on side effects in pure functions" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Anaphora> ] ;
    narr:variation [ narr:text "Structural outlier: four children are craft/style observations, but the re-engagement child is a concrete business action with a launch deadline — a different kind of 'pillar' entirely." ; narr:over <https://aswritten.ai/narrative#Narrative_ContentAsReengagement> ] ;
