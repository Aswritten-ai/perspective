@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Signals> {
  <https://aswritten.ai/narrative#Digest_Signals> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Signals> ;
    narr:childCount "7"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """A mixed gather of market, product, and self-observation signals — no single arc, several distinct registers. The strongest are enterprise pilot signals: [the enterprise customer week-1 metrics](narr:Obs_EnterpriseCustomerWeek1Metrics) show fast engagement and license expansion (2→7→16), MSA out and Phase 2 targeting Q4 2026 (May 18), grounded in the earlier [transcript-surprise diagnosis](narr:Obs_EnterpriseCustomerTranscriptSurpriseQuote) (Apr 16) that named the pitch gap. A separate [pilot-expansion signal](narr:Narrative_PilotExpansionInRealTime) records demand outstripping the 10-seat sizing live on the call (May 7), with billing confirmed. Against these run macro and framing signals: [Tony's two-year-window](narr:Narrative_TwoYearWindow) warning of legal pressure on current LLMs, and the [AI-coworker framing shift](narr:Observation_Signals_1) from OpenAI. Two off-axis signals sit here too — a [pseudo-autism/IEP demand](narr:Observation_PseudoAutismSignal) trend, and a [self-critique](narr:Obs_ShipItButKeepWorking) on failing to act on a known-correct move.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PilotExpansionInRealTime> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_TwoYearWindow> ;
    narr:covers <https://aswritten.ai/narrative#Obs_EnterpriseCustomerTranscriptSurpriseQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_EnterpriseCustomerWeek1Metrics> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ShipItButKeepWorking> ;
    narr:covers <https://aswritten.ai/narrative#Observation_PseudoAutismSignal> ;
    narr:covers <https://aswritten.ai/narrative#Observation_Signals_1> ;
    narr:keyPhrase [ narr:text "8 of 16 added users immediately engaging, license expansion 2 → 7 → 16 in a single week" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_EnterpriseCustomerWeek1Metrics> ] ;
    narr:keyPhrase [ narr:text "the enterprise customer was like, 'Oh we have historical transcripts' and that sort of didn't seem obvious to them" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_EnterpriseCustomerTranscriptSurpriseQuote> ] ;
    narr:keyPhrase [ narr:text "billing structure ([amount]base + [amount]/seat, no cap) confirmed" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PilotExpansionInRealTime> ] ;
    narr:keyPhrase [ narr:text "Tony: 'You've got a two year window' before legal pressure breaks current LLMs; next wave will be built from approved sources." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_TwoYearWindow> ] ;
    narr:keyPhrase [ narr:text "**\"AI coworker\" framing**: OpenAI is pushing \"AI coworker\" as the dominant frame over \"AI agent\"" ; narr:phraseSource <https://aswritten.ai/narrative#Observation_Signals_1> ] ;
    narr:variation [ narr:text "Bullish pilot signals run against a countervailing macro clock: a two-year legal-pressure window on current LLMs." ; narr:over <https://aswritten.ai/narrative#Narrative_TwoYearWindow> ; narr:over <https://aswritten.ai/narrative#Obs_EnterpriseCustomerWeek1Metrics> ] ;
    narr:variation [ narr:text "An off-axis demand signal from a different domain entirely — pediatric screen-time, pseudo-autism, IEP demand — not enterprise sales." ; narr:over <https://aswritten.ai/narrative#Observation_PseudoAutismSignal> ] ;
    narr:variation [ narr:text "A framing/competitive signal (OpenAI's 'AI coworker' category language) rather than an own-pilot signal." ; narr:over <https://aswritten.ai/narrative#Observation_Signals_1> ] ;
    narr:variation [ narr:text "A self-critique signal: the correct action was articulated but not executed due to gravitational pull — tension between knowing and doing." ; narr:over <https://aswritten.ai/narrative#Obs_ShipItButKeepWorking> ] ;
    narr:writer "claude (subscription)" .
}