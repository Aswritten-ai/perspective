    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_Colloquial> ;
    narr:keyPhrase [ narr:text "train the trainers → here's the solution" ; narr:phraseSource <https://aswritten.ai/ns/narrative#DeckUpdate_GTMFraming> ] ;
    narr:keyPhrase [ narr:text "Well let's be honest. You want the money up front. That too." ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_Colloquial> ] ;
    narr:keyPhrase [ narr:text "1. Implement `story/group-txs` (transaction deduplication logic)" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Obs_NextSteps> ] ;
    narr:variation [ narr:text "The technical roadmap has narrowed from a broad infrastructure vision to a specific, three-item tactical queue." ; narr:over <https://aswritten.ai/ns/narrative#Obs_NextSteps> ] ;
    narr:variation [ narr:text "The colloquial tone introduces a tension between professional 'train the trainer' framing and raw, blunt commercial honesty." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_Colloquial> ; narr:over <https://aswritten.ai/ns/narrative#DeckUpdate_GTMFraming> ] ;
