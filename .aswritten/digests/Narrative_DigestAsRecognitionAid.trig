@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_DigestAsRecognitionAid> {
  <https://aswritten.ai/narrative#Digest_Narrative_DigestAsRecognitionAid> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_DigestAsRecognitionAid> ;
    narr:childCount "10"^^xsd:integer ;
    narr:generatedFrom "dacf4f8217e4ebf309944aba08e7c1ca6a721cef" ;
    narr:narration """The architecture of the digest has evolved from a conceptual [recognition surface](narr:https://aswritten.ai/narrative#Position_AbsenceIsNoRecognizedAssociation) into a concrete [product surface](narr:https://aswritten.ai/narrative#Narrative_DigestBrowserProductSurface) that treats the human as a consumer of the same collapse-expand navigation used by the system. The core principle remains that [expansion is steering](narr:https://aswritten.ai/narrative#Position_ExpansionIsSteering), supported by a [visibility invariant](narr:https://aswritten.ai/narrative#Narrative_VisibilityInvariantAreaIndex) where every hub is named in every response, ensuring the [index never gates the store](narr:https://aswritten.ai/narrative#Position_IndexNeverGatesStore). To maintain this, [richness and visibility are separated](narr:https://aswritten.ai/narrative#Narrative_RichnessVsVisibilitySeparation), allowing for tier weighting without demotion. The system now organizes [perspective responses by volatility](narr:https://aswritten.ai/narrative#Narrative_PerspectiveResponseOrderedByVolatility), keeping the skeleton stable while appending focus. Furthermore, [reconciliation is now defined as a set transaction](narr:https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction), surfacing the referent set to the user, while a pending [content-commentary split](narr:https://aswritten.ai/narrative#Narrative_ContentCommentarySplit) seeks to distinguish primary integration from authored commentary.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DigestBrowserProductSurface> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PerspectiveResponseOrderedByVolatility> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_RichnessVsVisibilitySeparation> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_VisibilityInvariantAreaIndex> ;
    narr:covers <https://aswritten.ai/narrative#Position_AbsenceIsNoRecognizedAssociation> ;
    narr:covers <https://aswritten.ai/narrative#Position_ExpansionIsSteering> ;
    narr:covers <https://aswritten.ai/narrative#Position_IndexNeverGatesStore> ;
    narr:covers <https://aswritten.ai/narrative#Position_MultiplicityInVariation> ;
    narr:keyPhrase [ narr:text "Absence is no recognized association, never nothing here." ; narr:phraseSource <https://aswritten.ai/narrative#Position_AbsenceIsNoRecognizedAssociation> ] ;
    narr:keyPhrase [ narr:text "Richness is a budget decision; visibility is an invariant" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_RichnessVsVisibilitySeparation> ] ;
    narr:keyPhrase [ narr:text "Reconciliation is a transaction about a set of transactions or nodes" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction> ] ;
    narr:keyPhrase [ narr:text "The map is never reordered per call. Focus selects what to append, never what to move." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PerspectiveResponseOrderedByVolatility> ] ;
    narr:keyPhrase [ narr:text "The correct model: per-message integration captures primary source material (content layer); reconciliation is authored commentary" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ] ;
    narr:variation [ narr:text "Tension exists between the current conflated memory model and the proposed content-commentary split." ; narr:over <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ] ;
    narr:variation [ narr:text "The risk of 'cheap legible-absence' potentially discouraging creative exploration versus the efficiency of targeted grounding." ; narr:over <https://aswritten.ai/narrative#Position_AbsenceIsNoRecognizedAssociation> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}