@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_DigestAsRecognitionAid> {
  <https://aswritten.ai/narrative#Digest_Narrative_DigestAsRecognitionAid> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_DigestAsRecognitionAid> ;
    narr:childCount "12"^^xsd:integer ;
    narr:generatedFrom "b6a9d4d918338cfce5a392033500736cbdfb157d" ;
    narr:narration """Established 20260616, this hub frames the digest as a **recognition surface** — not an account of meaning — whose job is to let an agent route or rule out without expanding to discover. [Absence as no recognized association](narr:https://aswritten.ai/narrative#Claim_AbsenceIsNoRecognizedAssociation) draws the sharpest line: a legible-absence is never \"nothing here,\" only \"no recognized association,\" and targeted grounding may trust it while creative exploration must deliberately distrust it. [Expansion as steering](narr:https://aswritten.ai/narrative#Claim_ExpansionIsSteering) completes the pair: the bad case is expanding to discover whether anything is there; the good case is expanding onto material already decided relevant. [The index never gating the store](narr:https://aswritten.ai/narrative#Claim_IndexNeverGatesStore) holds the anti-reductionist spine — a claim is available to be read as many things, so the digest need only get close enough via an old association. [Multiplicity lives in variation](narr:https://aswritten.ai/narrative#Claim_MultiplicityInVariation), not a theme label, and that block is the load-bearing anti-reductionist mechanism. [The eval must not reimport reductionism](narr:https://aswritten.ai/narrative#Claim_EvalMustNotReimportReductionism) by scoring anticipation of every reading. By 20260701 the arc extended into structural implementation: [visibility as invariant](narr:https://aswritten.ai/narrative#Narrative_VisibilityInvariantAreaIndex) (every hub named in every response), [richness vs. visibility separation](narr:https://aswritten.ai/narrative#Narrative_RichnessVsVisibilitySeparation) as the principled line making tier weighting compatible with compression-only, [perspective response ordered by volatility](narr:https://aswritten.ai/narrative#Narrative_PerspectiveResponseOrderedByVolatility) with stable skeleton leading and per-call focus appended last, [reconciliation as set transaction](narr:https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction) surfacing the referent set explicitly, and [guidance embedded in the surface rather than each caller's prompt](narr:https://aswritten.ai/narrative#Claim_GuidanceInSurfaceNotPrompt) — proven by cite and introspect navigating correctly with zero prompt changes.""" ;
    narr:covers <https://aswritten.ai/narrative#Claim_AbsenceIsNoRecognizedAssociation> ;
    narr:covers <https://aswritten.ai/narrative#Claim_EvalMustNotReimportReductionism> ;
    narr:covers <https://aswritten.ai/narrative#Claim_ExpansionIsSteering> ;
    narr:covers <https://aswritten.ai/narrative#Claim_GuidanceInSurfaceNotPrompt> ;
    narr:covers <https://aswritten.ai/narrative#Claim_IndexNeverGatesStore> ;
    narr:covers <https://aswritten.ai/narrative#Claim_MultiplicityInVariation> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DigestBrowserProductSurface> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PerspectiveResponseOrderedByVolatility> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_RichnessVsVisibilitySeparation> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_VisibilityInvariantAreaIndex> ;
    narr:keyPhrase [ narr:text "Absence is no recognized association, never nothing here." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_AbsenceIsNoRecognizedAssociation> ] ;
    narr:keyPhrase [ narr:text "A cheap legible-absence is dangerous precisely because the encounters it lets you skip are where novelty would have struck." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_AbsenceIsNoRecognizedAssociation> ] ;
    narr:keyPhrase [ narr:text "The bad case is expanding to discover whether anything is there; the good case is expanding onto material you have already decided is relevant." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_ExpansionIsSteering> ] ;
    narr:keyPhrase [ narr:text "The index must never gate the store." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_IndexNeverGatesStore> ] ;
    narr:keyPhrase [ narr:text "A claim is not about something; it is available to be read as many things." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_IndexNeverGatesStore> ] ;
    narr:keyPhrase [ narr:text "The thing we protect (the unforeseen reading) is by definition not in the answer key." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_EvalMustNotReimportReductionism> ] ;
    narr:keyPhrase [ narr:text "Richness is a budget decision; visibility is an invariant — the principled separation that makes tier weighting compatible with compression-only" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_RichnessVsVisibilitySeparation> ] ;
    narr:keyPhrase [ narr:text "Perspective response ordered by volatility: stable skeleton leads, per-call focus appended last" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PerspectiveResponseOrderedByVolatility> ] ;
    narr:variation [ narr:text "Legible-absence is a feature for targeted grounding but a hazard for creative exploration — the same mechanism is trustworthy in one mode and must be deliberately distrusted in the other." ; narr:over <https://aswritten.ai/narrative#Claim_AbsenceIsNoRecognizedAssociation> ; narr:over <https://aswritten.ai/narrative#Claim_ExpansionIsSteering> ] ;
    narr:variation [ narr:text "Eval scoring 'did it anticipate every reading' would reimport the reductionism the whole design refuses — the unforeseen reading is structurally absent from any answer key." ; narr:over <https://aswritten.ai/narrative#Claim_EvalMustNotReimportReductionism> ; narr:over <https://aswritten.ai/narrative#Claim_MultiplicityInVariation> ] ;
    narr:variation [ narr:text "Steering guidance belongs in the perspective's own returned surface, not in each caller's prompt — proven empirically, but this is a design commitment that could be revisited if surface real-estate becomes constrained." ; narr:over <https://aswritten.ai/narrative#Claim_GuidanceInSurfaceNotPrompt> ] ;
    narr:variation [ narr:text "The 20260701 structural arc (visibility invariant, volatility ordering, content/commentary split, reconciliation-as-transaction) extends the 20260616 recognition-aid principles into write and product primitives — a later layer that presupposes but does not simply restate the core claims." ; narr:over <https://aswritten.ai/narrative#Narrative_VisibilityInvariantAreaIndex> ; narr:over <https://aswritten.ai/narrative#Narrative_PerspectiveResponseOrderedByVolatility> ; narr:over <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ; narr:over <https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction> ] ;
    narr:variation [ narr:text "Richness weighting (tier budget) gives the map an opinion about steering value — in tension with compression-only; the resolution is that visibility is an invariant and richness is only a budget decision, but the line requires active maintenance." ; narr:over <https://aswritten.ai/narrative#Narrative_RichnessVsVisibilitySeparation> ; narr:over <https://aswritten.ai/narrative#Narrative_VisibilityInvariantAreaIndex> ] ;
    narr:variation [ narr:text "The digest browser product surface positions the human as consumer of the same collapse/expand read path agents use — a convergence that could be read as democratizing or as flattening the human/agent distinction." ; narr:over <https://aswritten.ai/narrative#Narrative_DigestBrowserProductSurface> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}