@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_DigestAsRecognitionAid> {
  <https://aswritten.ai/narrative#Digest_Narrative_DigestAsRecognitionAid> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_DigestAsRecognitionAid> ;
    narr:childCount "10"^^xsd:integer ;
    narr:generatedFrom "b4172ab9294ab4fadb4948c6ac0fc08cb3272b86" ;
    narr:narration """The architecture of the digest has transitioned from a conceptual [recognition surface](narr:https://aswritten.ai/narrative#Position_AbsenceIsNoRecognizedAssociation) to a concrete [product surface](narr:https://aswritten.ai/narrative#Narrative_DigestBrowserProductSurface), formalizing the human's role as a consumer of the same collapse-expand navigation used by the system. Central to this is the [visibility invariant](narr:https://aswritten.ai/narrative#Narrative_VisibilityInvariantAreaIndex), which ensures the [index never gates the store](narr:https://aswritten.ai/narrative#Position_IndexNeverGatesStore) by naming every hub in every response. To balance this with steering, [richness and visibility are separated](narr:https://aswritten.ai/narrative#Narrative_RichnessVsVisibilitySeparation), allowing for tier weighting without demotion. The system now organizes [perspective responses by volatility](narr:https://aswritten.ai/narrative#Narrative_PerspectiveResponseOrderedByVolatility), maintaining a stable skeleton while appending focus. Furthermore, [reconciliation is now defined as a set transaction](narr:https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction), surfacing the referent set to the user, while a pending [content-commentary split](narr:https://aswritten.ai/narrative#Narrative_ContentCommentarySplit) seeks to distinguish primary integration from authored commentary, ensuring [multiplicity in variation](narr:https://aswritten.ai/narrative#Position_MultiplicityInVariation) remains the primary anti-reductionist mechanism.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DigestBrowserProductSurface> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PerspectiveResponseOrderedByVolatility> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_RichnessVsVisibilitySeparation> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_VisibilityInvariantAreaIndex> ;
    narr:covers <https://aswritten.ai/narrative#Position_AbsenceIsNoRecognizedAssociation> ;
    narr:covers <https://aswritten.ai/narrative#Position_ExpansionIsSteering> ;
    narr:covers <https://aswritten.ai/narrative#Position_IndexNeverGatesStore> ;
    narr:covers <https://aswritten.ai/narrative#Position_MultiplicityInVariation> ;
    narr:keyPhrase [ narr:text "The product surface is the digest browser — the human as consumer of the same collapse/expand navigation that extraction and citation already use" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_DigestBrowserProductSurface> ] ;
    narr:keyPhrase [ narr:text "Richness is a budget decision; visibility is an invariant — the principled separation that makes tier weighting compatible with compression-only" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_RichnessVsVisibilitySeparation> ] ;
    narr:keyPhrase [ narr:text "Perspective response ordered by volatility: stable skeleton leads, per-call focus appended last" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PerspectiveResponseOrderedByVolatility> ] ;
    narr:keyPhrase [ narr:text "Reconciliation is a transaction about a set of transactions or nodes — the design of correction and commentary about the past" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction> ] ;
    narr:keyPhrase [ narr:text "Content/commentary split: per-message integration is the content layer; reconciliation is the authored commentary layer" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ] ;
    narr:variation [ narr:text "Creative exploration distrusts legible-absence, prioritizing manual expansion over system-provided recognition." ; narr:over <https://aswritten.ai/narrative#Position_AbsenceIsNoRecognizedAssociation> ] ;
    narr:variation [ narr:text "Expansion is intended as a steering mechanism for relevant material, not as a discovery tool for whether content exists." ; narr:over <https://aswritten.ai/narrative#Position_ExpansionIsSteering> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}