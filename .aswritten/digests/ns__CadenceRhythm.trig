GRAPH <https://aswritten.ai/narrative#Digest_ns__CadenceRhythm> {
  <https://aswritten.ai/narrative#Digest_ns__CadenceRhythm> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#CadenceRhythm> ;
    narr:childCount "9"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """This hub gathers the document's cadence and rhythm devices. The dominant engine is the rule of three: a [git-native triad](narr:Observation_GitNativeTriad) of parallel -able suffixes, a [triadic list at the cursor](narr:StyleObs_10), and [triadic audiences](narr:StyleObs_4) widening scope to new hires, clients, and investors. Against that accumulating rhythm runs [sharp antithesis](narr:StyleObs_Antithesis) — They/We, lock-in/freedom, the parenthetical \"not X\" — and [anaphoric repetition](narr:StyleObs_Anaphora) hammering \"every single.\" Pacing swings between extremes: a [run-on value prop](narr:StyleObs_6) packing five parallel clauses into one <30-second sentence, versus [short punchy clauses](narr:StyleObs_ShortPunchy) and a [seven-word closer](narr:StyleObs_ShortCadence). [Rhetorical questions](narr:StyleObs_RhetoricalQ) appear both self-answered and as framed enterprise objections. The [sailing-metaphor self-correction](narr:StyleObs_4) — \"telltales… that's the right word\" — shows a spoken, self-aware register beneath the polished structure. Together these are handles for how the document sounds: triadic memorability, antithetical contrast, anaphoric scale, and deliberate tempo shifts between dense and clipped.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Observation_GitNativeTriad> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_10> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_4> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_6> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_Anaphora> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_Antithesis> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_RhetoricalQ> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_ShortCadence> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_ShortPunchy> ;
    narr:keyPhrase [ narr:text "git native, i.e. versionable, branchable, reviewable" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_GitNativeTriad> ] ;
    narr:keyPhrase [ narr:text "They solve memory for individuals. We solve memory for organizations. They create lock-in. We create freedom." ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_Antithesis> ] ;
    narr:keyPhrase [ narr:text "every single home, but every single venture, every single backend, every surface" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_Anaphora> ] ;
    narr:keyPhrase [ narr:text "Power is in the connections, not the pillars" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_ShortCadence> ] ;
    narr:keyPhrase [ narr:text "They serve as telltales. That's the right word. They serve as telltales" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_4> ] ;
    narr:keyPhrase [ narr:text "positioning, offering, product, teams, and process" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_6> ] ;
    narr:keyPhrase [ narr:text "So what is the importance of narrative? I mean, it's everything" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_RhetoricalQ> ] ;
    narr:variation [ narr:text "The rule of three dominates, but StyleObs_6 deliberately breaks it — five parallel clauses and five-item lists extended 'for completeness' over triadic neatness." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_6> ; narr:over <https://aswritten.ai/ns/narrative#Observation_GitNativeTriad> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_10> ] ;
    narr:variation [ narr:text "Tempo splits hard: a single <30-second run-on value prop versus clipped seven-word and conversational 'right?' cadences." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_6> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_ShortCadence> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_ShortPunchy> ] ;
    narr:variation [ narr:text "Accumulation devices (triad, anaphora) sit beside their opposite — antithesis built on contrast and negation rather than additive rhythm." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_Antithesis> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_Anaphora> ] ;
    narr:variation [ narr:text "Rhetorical questions pull two ways: emphatic self-answer ('it's everything') versus a second-person enterprise objection about the shared repository." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_RhetoricalQ> ] ;
    narr:variation [ narr:text "The telltales self-correction exposes an unpolished spoken register that cuts against the otherwise engineered cadence." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_4> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_ShortPunchy> ] ;
    narr:writer "claude (subscription)" .
}