    narr:keyPhrase [ narr:text "bulk ingestion via AI summarization is a deliberate, successful method she advised the customer's chief architect to use for the enterprise customer's ARB transcripts" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_BulkIngestionValidMethod> ] ;
    narr:keyPhrase [ narr:text "The deck is a derived artifact; the real value is the perspective shift." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_DeckIsArtifact> ] ;
    narr:keyPhrase [ narr:text "no answers to questions two and three means friendly or pass, not buyer" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_FiveQuestionDiscoveryFramework> ] ;
    narr:keyPhrase [ narr:text "aswritten would keep what Bob thinks and what Anna thinks and what Charlie thinks in the provenance. They're different perspectives. I think there is value in marketing this as a discovery tool." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_DiscoveryConsultantBobAnnaCharlieQuote> ] ;
    narr:keyPhrase [ narr:text "it's steering the entire ecosystem and process around technical development, which is functionally the same thing as ARB" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_UseCase2AgenticScalesQuote> ] ;
    narr:keyPhrase [ narr:text "Process governance and process steering for aligning the commonalities and shared process between different engagements, different clients, different processes" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_UseCase3Quote> ] ;
    narr:keyPhrase [ narr:text "The proposal artifact is the lock-in framing for the consumer healthcare use case. It is structurally accurate (engagement letters, fee proposals) and sidesteps regulatory edges by describing methodology rather than case-specific clinical decisions." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ProposalArtifactPractitioner> ] ;
    narr:keyPhrase [ narr:text "One thing you might do instead of directly ingesting all of the historical transcripts is after you do a code base review" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletTopicAnalysisQuote> ] ;
    narr:variation [ narr:text "The three-part seeding pattern explicitly rejects direct historical ingestion as a trap, but the May 21 bulk-ingestion correction walks that back — the anti-pattern framing was a graph error, and bulk ingestion via AI summarization is valid; these two children are in tension." ; narr:over <https://aswritten.ai/narrative#Narrative_ThreePartSeedingPattern> ; narr:over <https://aswritten.ai/narrative#Narrative_BulkIngestionValidMethod> ] ;
    narr:variation [ narr:text "The Jul 2 Discovery/Onboarding/Governance taxonomy demotes 'organizational memory' to a sub-use-case, diverging from earlier framings where it was a primary pitch concept." ; narr:over <https://aswritten.ai/narrative#Narrative_ThreeUseCaseTaxonomy> ; narr:over <https://aswritten.ai/narrative#Narrative_UseCase1GoverningHumanTeam> ] ;
    narr:variation [ narr:text "The collaboration-shape taxonomy (Individual→Self/Team/Many, Team→Many) is explicitly flagged as missing from the strategy doc's three-archetype model — a structural gap, not a resolved position." ; narr:over <https://aswritten.ai/narrative#Narrative_CollaborationTaxonomy> ; narr:over <https://aswritten.ai/narrative#Obs_CollaborationTaxonomyList> ] ;
    narr:variation [ narr:text "Agentic steering (Use Case 2) is flagged as currently underrepresented in aswritten's materials — a known gap in the pitch, not a settled archetype." ; narr:over <https://aswritten.ai/narrative#Narrative_UseCase2AgenticSteering> ] ;
    narr:variation [ narr:text "The self-serve demo on aswritten's own perspective argues the honesty beats (product flagging its own uncommitted areas) are the least-fakeable material and should lead — a counter to leading with positive answers in demos." ; narr:over <https://aswritten.ai/narrative#Narrative_SelfServeDemoOnOwnPerspective> ] ;
    narr:variation [ narr:text "Refract and Registry were removed as product features and migrated to local org skills — a scope contraction that may affect which archetypes are still live." ; narr:over <https://aswritten.ai/narrative#Position_RemoveRefractProduct> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
