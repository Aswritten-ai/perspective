    narr:covers <https://aswritten.ai/narrative#Narrative_UseCase2AgenticSteering> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_UseCase3SharedProcessSteering> ;
    narr:covers <https://aswritten.ai/narrative#Obs_CollaborationTaxonomyList> ;
    narr:covers <https://aswritten.ai/narrative#Obs_CustomerEngManagerUseCasesQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_DeckIsArtifact> ;
    narr:covers <https://aswritten.ai/narrative#Obs_DiscoveryConsultantBobAnnaCharlieQuote> ;
