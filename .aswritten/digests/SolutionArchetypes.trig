    narr:covers <https://aswritten.ai/narrative#Obs_CustomerEngManagerUseCasesQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletProposalQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletTopicAnalysisQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_SolutionArchetype> ;
    narr:covers <https://aswritten.ai/narrative#Obs_UseCase1Quote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_UseCase2AgenticScalesQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_UseCase3Quote> ;
    narr:covers <https://aswritten.ai/narrative#SolutionArchetype_CEOKnowledgeTransfer> ;
    narr:covers <https://aswritten.ai/narrative#SolutionArchetype_CodeQualityThroughContext> ;
