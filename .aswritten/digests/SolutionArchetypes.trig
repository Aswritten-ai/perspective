    narr:keyPhrase [ narr:text "The deck is a derived artifact; the real value is the perspective shift." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_DeckIsArtifact> ] ;
    narr:keyPhrase [ narr:text "have an AI replace me at ARB." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_EnterpriseCustomerARBPilotUseCase> ] ;
    narr:keyPhrase [ narr:text "the killer sales demo" ; narr:phraseSource <https://aswritten.ai/narrative#SolutionArchetype_QAOnboarding> ] ;
    narr:keyPhrase [ narr:text "you need to make it as easy as possible for your sponsor to do what you need them to do." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_SponsorVsChampionPlaybook> ] ;
    narr:keyPhrase [ narr:text "it's steering the entire ecosystem and process around technical development, which is functionally the same thing as ARB" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_UseCase2AgenticScalesQuote> ] ;
    narr:keyPhrase [ narr:text "19 of 24 claims grounded with full provenance (79% coverage)" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_EnterpriseCustomerEngagementProposal> ] ;
    narr:variation [ narr:text "Direct flip on onboarding method: the Three-Part Seeding pattern 'explicitly rejects direct historical ingestion as a trap' (20260501), but a later correction declares bulk transcript ingestion via AI summarization a valid, advised method — the anti-pattern framing was 'overplayed' (20260521)." ; narr:over <https://aswritten.ai/narrative#Narrative_ThreePartSeedingPattern> ; narr:over <https://aswritten.ai/narrative#Narrative_BulkIngestionValidMethod> ] ;
    narr:variation [ narr:text "Use Case 2 (agentic steering) is self-flagged as 'currently underrepresented' in aswritten's materials — a gap the taxonomy is meant to correct, not a settled archetype." ; narr:over <https://aswritten.ai/narrative#Narrative_UseCase2AgenticSteering> ] ;
    narr:variation [ narr:text "'Domain' framing is explicitly corrected to 'organizational worldview' — domain implies siloing, worldview implies integration; a deliberate reframe of how extraction scope is described." ; narr:over <https://aswritten.ai/narrative#Narrative_ExtractionScopeOrgWorldview> ; narr:over <https://aswritten.ai/narrative#Claim_ExtractionScopeOrgWorldview> ] ;
    narr:variation [ narr:text "Product-surface retraction outlier: Refract and Registry removed as product features and migrated to local org skills (20260326) — a structurally distinct claim about what is NOT a product." ; narr:over <https://aswritten.ai/narrative#Claim_RemoveRefractProduct> ] ;
    narr:variation [ narr:text "The original Solo/Parallel/Hub/Salon/Teams archetype set is superseded — the Salon is reclassified as the collaborative-review behavior, not a standalone archetype; someone may still reach for the old taxonomy." ; narr:over <https://aswritten.ai/narrative#Narrative_CollaborationTaxonomy> ; narr:over <https://aswritten.ai/narrative#Obs_CollaborationTaxonomyList> ] ;
    narr:writer "claude (subscription)" .
