    narr:covers <https://aswritten.ai/narrative#Obs_UseCase2AgenticScalesQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_UseCase3Quote> ;
    narr:covers <https://aswritten.ai/narrative#Position_ConsultingDeliveryAsModule> ;
    narr:covers <https://aswritten.ai/narrative#Position_ExtractionScopeOrgWorldview> ;
    narr:covers <https://aswritten.ai/narrative#Position_QAOnboardingKillerDemo> ;
    narr:covers <https://aswritten.ai/narrative#Position_RemoveRefractProduct> ;
    narr:covers <https://aswritten.ai/narrative#SolutionArchetype_CEOKnowledgeTransfer> ;
