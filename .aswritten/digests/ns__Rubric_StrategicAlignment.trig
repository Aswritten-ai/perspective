    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_StrategicAlignment_ADR002> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_StrategicAlignment_GTM> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Strategy_ADR001> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_strategic_alignment> ;
    narr:keyPhrase [ narr:text "Exemplary strategic coherence." ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_StrategicAlignment> ] ;
    narr:keyPhrase [ narr:text "document IS the strategy." ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_StrategicAlignment> ] ;
