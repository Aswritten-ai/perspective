    narr:keyPhrase [ narr:text "shifts from 'tool' to 'infrastructure'" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assessment_Strategy_1> ] ;
    narr:keyPhrase [ narr:text "worldview-as-product aligns with platform positioning; IP protection moat" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assessment_StrategicAlignment_IPCrisis> ] ;
    narr:keyPhrase [ narr:text "Exceptional alignment: document IS the strategy" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_StrategicAlignment> ] ;
    narr:keyPhrase [ narr:text "Clear narrative anchor (Git-native AI memory)" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_StrategicAlignment_1> ] ;
    narr:keyPhrase [ narr:text "network effects = moat" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Strategy_20260107> ] ;
    narr:keyPhrase [ narr:text "accessibility (non-technical users), provenance (Git as source of truth), collaboration (two-interface model), auditability (append-only transactions)" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assess_Strategy_collective_memory> ] ;
    narr:variation [ narr:text "Not all praise — one assessment surfaces gaps (DevOps, security) that the strategy doesn't yet cover." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_StrategicAlignment> ] ;
    narr:variation [ narr:text "An explicit positioning/rebrand shift with migration plan, distinct from the documents that merely restate the existing thesis." ; narr:over <https://aswritten.ai/ns/narrative#Assess_Strategy_rebrand> ; narr:over <https://aswritten.ai/ns/narrative#Assessment_StrategicAlignment_IPCrisis> ] ;
    narr:variation [ narr:text "Some children align on the Architecture/implementation axis (phases, sequencing, team responsibilities) rather than positioning/GTM." ; narr:over <https://aswritten.ai/ns/narrative#Assess_Strategy_cm> ; narr:over <https://aswritten.ai/ns/narrative#Assess_Strategy_collective_memory> ] ;
    narr:variation [ narr:text "the customer's chief architect's assessment centers actor incentives and product-market fit, a lens absent from the mission/moat-focused mainline." ; narr:over <https://aswritten.ai/ns/narrative#Assessment_StrategicAlignment_CustomerArchitect> ] ;
    narr:variation [ narr:text "Uniformly high scores across all children risk being a flatness of the rubric itself — no dissent or failing grade appears anywhere." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_strategic_alignment> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Strategy_ADR001> ] ;
