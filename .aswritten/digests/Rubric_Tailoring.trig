    narr:variation [ narr:text "Audience targets diverge widely: YC investors vs. enterprise Chief Architect (compliance/cost) vs. founder/operator vs. general blog/LinkedIn reader — not a single audience." ; narr:over <https://aswritten.ai/narrative#Rubric_Assess_Tailoring> ; narr:over <https://aswritten.ai/narrative#Rubric_Tailoring_CustomerArchitect> ; narr:over <https://aswritten.ai/narrative#Assess_Tailoring_RevModel> ; narr:over <https://aswritten.ai/narrative#RubricAssess_Tailoring> ] ;
