    narr:variation [ narr:text "Many entries flag under-tailoring: blog piece 'could be tailored further for specific buyer personas (technical vs. economic)', TXReview wants persona-specific examples, WeeklyCall wants explicit persona JTBD framing." ; narr:over <https://aswritten.ai/narrative#RubricAssess_Tailoring> ; narr:over <https://aswritten.ai/narrative#RubricAssess_Tailoring_TXReview> ; narr:over <https://aswritten.ai/narrative#RubricAssess_Tailoring_WeeklyCall> ] ;
