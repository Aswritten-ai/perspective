    narr:covers <https://aswritten.ai/narrative#Rubric_Tailoring_PilotPlan> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Tailoring_ScarletDame> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Tailoring_YCDemoBeats> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Tailoring_YC_Call> ;
    narr:keyPhrase [ narr:text "50-char tagline, 3-min demo video, 60-sec founder video." ; narr:phraseSource <https://aswritten.ai/narrative#Assessment_Tailoring_YC> ] ;
    narr:keyPhrase [ narr:text "Addresses compliance concerns (GDPR, ISO), cost sensitivity (3x token differential), integration patterns (MCP, JIRA)" ; narr:phraseSource <https://aswritten.ai/narrative#Rubric_Tailoring_CustomerArchitect> ] ;
    narr:keyPhrase [ narr:text "Three distinct expansion tracks (Core/Enterprise/Executive) tailored to buyer personas" ; narr:phraseSource <https://aswritten.ai/narrative#Rubric_Tailoring_PilotPlan> ] ;
    narr:keyPhrase [ narr:text "Dual-persona approach (Tony/Scarlet) addresses gap_demo_persona_tailoring" ; narr:phraseSource <https://aswritten.ai/narrative#Rubric_Tailoring_YCDemoBeats> ] ;
    narr:keyPhrase [ narr:text "balances technical depth (LLMs, embedding space, NLP) with narrative accessibility" ; narr:phraseSource <https://aswritten.ai/narrative#RubricAssess_Tailoring> ] ;
    narr:variation [ narr:text "Internal-facing content assumes high domain familiarity, requiring significant adaptation for external audiences." ; narr:over <https://aswritten.ai/narrative#RubricAssess_Tailoring> ; narr:over <https://aswritten.ai/narrative#RubricAssess_Tailoring_GTM> ] ;
