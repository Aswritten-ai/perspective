@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_RhetoricalQuestion> {
  <https://aswritten.ai/narrative#Digest_RhetoricalQuestion> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#RhetoricalQuestion> ;
    narr:childCount "17"^^xsd:integer ;
    narr:generatedFrom "0d6d01a1169a11e6c11248b8e2509fa7d2d1f4c5" ;
    narr:narration """This hub tracks the rhetorical question as a primary structural and persuasive device. The [opening hook](narr:StyleObs_RhetoricalQuestion) remains a standard, universalizing fear or pain to anchor the reader before a pivot. Increasingly, however, the device has shifted toward [epistemic reframing](narr:StyleObs_NotFacts), where questions replace factual assertions to guide the reader's perspective ([Better through A or B?](narr:StyleObs_BetterThroughAOrB)). A significant trajectory involves using questions to [stage binary choices](narr:StyleObs_DesignCollaboratorCall_RhetoricalQuestion) or [build ownership dilemmas](narr:StyleObs_SII_RhetoricalQuestionOwnership), escalating stakes from the practical to the existential. Structurally, the device has matured into [entire deck architectures](narr:StyleObs_QuestionFirstRhetoric) where questions dictate the flow of discovery, and [bounded scope markers](narr:StyleObs_OpenQuestions) that define the limits of a project. Whether through [British-inflected asides](narr:StyleObs_HowMadRhetQ) or [falsifiable hypotheses](narr:StyleObs_11), the rhetorical question functions less as a query and more as a simulation of the reader's own internal inquiry.""" ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_11> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_7> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_BetterThroughAOrB> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_BrokenSyncQuote> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_DesignCollaboratorCall_RhetoricalQuestion> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_HowMadRhetQ> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_KeyInsightCallout> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NotFacts> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_OpenQuestions> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_QuestionFirstRhetoric> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RhetoricalHook> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RhetoricalQ_1> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RhetoricalQuestion> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RhetoricalQuestionAsFramingDevice> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_SII_RhetoricalQuestionOwnership> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_WhatIfYouShow> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_WhyYC> ;
    narr:keyPhrase [ narr:text "You don't ask \"is this triple true?\" — you ask \"does viewing through this lens produce the right output?\"" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_NotFacts> ] ;
    narr:keyPhrase [ narr:text "it's how many voices in super intelligence are there going to be?" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_RhetoricalQuestionAsFramingDevice> ] ;
    narr:keyPhrase [ narr:text "Next call, I'll show you this conversation — turned into the beginning of your perspective." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_QuestionFirstRhetoric> ] ;
    narr:keyPhrase [ narr:text "What is invasive in the world of AI? What is necessary, both for oour own health, freedom, and happiness" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_SII_RhetoricalQuestionOwnership> ] ;
    narr:keyPhrase [ narr:text "This is my life's work." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_7> ] ;
    narr:variation [ narr:text "Questions as structural boundary markers vs. questions as emotional hooks." ; narr:over <https://aswritten.ai/narrative#StyleObs_OpenQuestions> ; narr:over <https://aswritten.ai/narrative#StyleObs_RhetoricalHook> ] ;
    narr:variation [ narr:text "The use of rhetorical questions to simulate reader doubt vs. the use of them to dictate the author's conviction." ; narr:over <https://aswritten.ai/narrative#StyleObs_7> ; narr:over <https://aswritten.ai/narrative#StyleObs_11> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}