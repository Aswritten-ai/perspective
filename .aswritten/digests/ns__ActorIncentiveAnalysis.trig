@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__ActorIncentiveAnalysis> {
  <https://aswritten.ai/narrative#Digest_ns__ActorIncentiveAnalysis> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#ActorIncentiveAnalysis> ;
    narr:childCount "6"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """This hub maps the actors around the product and what each one wants. The buyer question is answered concretely in the [VC-channel go-to-market map](narr:Narrative_VCChannel) — Primary = CEO/founder, Champion = Strategy/CTO, Channel = VCs/advisors — with VCs incentivized by portfolio visibility, faster board prep, and cross-portfolio learning. Incentive framings range from operational upside to threat-level: the [existential IP-crisis narrative](narr:Narrative_IPCrisis) reframes adoption from developer convenience to a board-level business risk, while [non-technical accessibility](narr:Narrative_NonTechnicalAccessibility) and [Day-1 new-hire productivity](narr:ValueProp_1) carry the convenience/onboarding upside. Two children push against dominant framings rather than extend them: the [premise-mismatch insight](narr:Insight_PremiseMismatch) argues the 'AI memory lock-in' thesis doesn't land for enterprises, and the [no-network-problem observation](narr:Observation_NoNetworkProblem) denies any network-effect gating. No dates are attached, so no trajectory or landing is asserted.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Insight_PremiseMismatch> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_IPCrisis> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_NonTechnicalAccessibility> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_VCChannel> ;
    narr:covers <https://aswritten.ai/ns/narrative#Observation_NoNetworkProblem> ;
    narr:covers <https://aswritten.ai/ns/narrative#ValueProp_1> ;
    narr:keyPhrase [ narr:text "Primary = CEO/founder, Champion = Strategy/CTO, Channel = VCs/advisors" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_VCChannel> ] ;
    narr:keyPhrase [ narr:text "VCs get better portfolio visibility (queryable, not just reported), faster board prep, cross-portfolio learning" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_VCChannel> ] ;
    narr:keyPhrase [ narr:text "Every employee tells state secrets to AI; models lift IP into training data; existential business risk" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_IPCrisis> ] ;
    narr:keyPhrase [ narr:text "Knowledge is locked in people's heads, not AI conversations." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Insight_PremiseMismatch> ] ;
    narr:keyPhrase [ narr:text "There is actually no network problem here. This is just as useful for one person, but it is even more useful for two people" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_NoNetworkProblem> ] ;
    narr:keyPhrase [ narr:text "Day 1 productivity for new hires" ; narr:phraseSource <https://aswritten.ai/ns/narrative#ValueProp_1> ] ;
    narr:variation [ narr:text "Premise dissent: the 'AI memory lock-in' framing is said NOT to resonate for enterprises, because knowledge is locked in people's heads, not in AI conversations." ; narr:over <https://aswritten.ai/ns/narrative#Insight_PremiseMismatch> ] ;
    narr:variation [ narr:text "Denies network effects as a driver — value is asserted for a single user, only incrementally more for two, so adoption incentives can't lean on a network-problem story." ; narr:over <https://aswritten.ai/ns/narrative#Observation_NoNetworkProblem> ] ;
    narr:variation [ narr:text "Incentive register splits hard: existential IP-threat to leadership vs. low-friction convenience (zero-code access, new-hire onboarding) — different actors pulled by opposite framings." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_IPCrisis> ; narr:over <https://aswritten.ai/ns/narrative#Narrative_NonTechnicalAccessibility> ; narr:over <https://aswritten.ai/ns/narrative#ValueProp_1> ] ;
    narr:variation [ narr:text "Buyer vs. channel tension: the economic buyer is CEO/founder, but VCs/advisors are positioned as the introducing channel with their own distinct incentives." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_VCChannel> ] ;
    narr:writer "claude (subscription)" .
}