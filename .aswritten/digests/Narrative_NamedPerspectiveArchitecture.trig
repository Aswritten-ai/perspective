@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_NamedPerspectiveArchitecture> {
  <https://aswritten.ai/narrative#Digest_Narrative_NamedPerspectiveArchitecture> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_NamedPerspectiveArchitecture> ;
    narr:childCount "6"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """The architecture's founding move (Jul 2025): a named perspective is not a flat memory dump but a [curated sub-perspective representing one advisor's take](narr:Claim_NamedPerspectiveAsSubAgent), distinct from the root org perspective and operable as a sub-agent in automations and code. Scarlet frames this as a [staffing model that substitutes for hiring](narr:Claim_AdvisoryStaffingReplacesHiring) — advisor cadence meetings keep the agent representation current and audited. A later clarification (Apr 2026) insists the [advisor role is additive, not exclusive](narr:Claim_AdvisorDualRole_BothNotEither): Tony's enterprise-pipeline role coexists with his advisory-as-perspective role — both, not either/or. Two open threads pull against the mainline: the [Microsoft multi-role gatekeeper pattern](narr:Claim_MultiRoleCoordinationGatekeeper) (May 2025) flags a centralized ground-truth holder the current architecture lacks, [reopened May 2026 as a product-config question](narr:Claim_GatekeeperOrSalonQuestion); and [agentic steering as Use Case 2](narr:Narrative_UseCase2AgenticSteering) (May 2026) — steering one model vs. the whole agentic ecosystem, grounded in the factoryfactory.ai briefing — is named as underrepresented and needing foregrounding.""" ;
    narr:covers <https://aswritten.ai/narrative#Claim_AdvisorDualRole_BothNotEither> ;
    narr:covers <https://aswritten.ai/narrative#Claim_AdvisoryStaffingReplacesHiring> ;
    narr:covers <https://aswritten.ai/narrative#Claim_GatekeeperOrSalonQuestion> ;
    narr:covers <https://aswritten.ai/narrative#Claim_MultiRoleCoordinationGatekeeper> ;
    narr:covers <https://aswritten.ai/narrative#Claim_NamedPerspectiveAsSubAgent> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_UseCase2AgenticSteering> ;
    narr:keyPhrase [ narr:text "it is a curated sub-perspective that represents the advisor's particular take, distinct from the root organizational perspective. Sub-perspectives operate as sub-agents in automations and coding." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_NamedPerspectiveAsSubAgent> ] ;
    narr:keyPhrase [ narr:text "Instead of hiring, can I set up regular cadence meetings with all of the people that represent roles and perspectives that I need and then I create, you know, internal AI agents that represent those roles in all of the automations and coding that I'm doing?" ; narr:phraseSource <https://aswritten.ai/narrative#Claim_AdvisoryStaffingReplacesHiring> ] ;
    narr:keyPhrase [ narr:text "The model is both, not either/or." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_AdvisorDualRole_BothNotEither> ] ;
    narr:keyPhrase [ narr:text "The Microsoft gatekeeper pattern suggests a centralized ground-truth holding mechanism missing from current named-perspective architecture." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_MultiRoleCoordinationGatekeeper> ] ;
    narr:keyPhrase [ narr:text "factoryfactory builds the Agent Expert Systems orchestration loop; aswritten is the memory the loop runs on." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_UseCase2AgenticSteering> ] ;
    narr:variation [ narr:text "Explicit challenge: the Microsoft multi-role gatekeeper pattern says the architecture has no story for centralized ground-truth holding in multi-perspective deployments — open since May 2025, reframed May 2026 as a possible org-tier product config vs. already-covered-by-review." ; narr:over <https://aswritten.ai/narrative#Claim_MultiRoleCoordinationGatekeeper> ; narr:over <https://aswritten.ai/narrative#Claim_GatekeeperOrSalonQuestion> ] ;
    narr:variation [ narr:text "Road not yet foregrounded: agentic steering (one model vs. the whole agentic ecosystem) is flagged as currently underrepresented in aswritten's materials despite being where the product dogfoods itself." ; narr:over <https://aswritten.ai/narrative#Narrative_UseCase2AgenticSteering> ] ;
    narr:variation [ narr:text "Corrective against a mutually-exclusive reading: advisor-as-perspective and advisor-as-lead-generator are meant to coexist (both/and), not compete." ; narr:over <https://aswritten.ai/narrative#Claim_AdvisorDualRole_BothNotEither> ] ;
    narr:writer "claude (subscription)" .
}