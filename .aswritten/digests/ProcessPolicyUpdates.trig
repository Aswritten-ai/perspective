@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ProcessPolicyUpdates> {
  <https://aswritten.ai/narrative#Digest_ProcessPolicyUpdates> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#ProcessPolicyUpdates> ;
    narr:childCount "9"^^xsd:integer ;
    narr:generatedFrom "195e02dff0429a48302c125aa6764e685cb8d15e" ;
    narr:narration """This hub tracks the evolution of process and policy, centering on the [perspective-vs-implementation boundary](narr:https://aswritten.ai/narrative#Narrative_PerspectiveVsImplementationLine) established in April 2026. This principle dictates that while perspective captures intent, reasoning, and directional logic, the repository remains the domain for literal configuration and specific identifiers, a distinction reinforced by [Position_PerspectiveHoldsIntent](narr:https://aswritten.ai/narrative#Position_PerspectiveHoldsIntent). Parallel to this, the [research branch as temporal isolation](narr:https://aswritten.ai/narrative#Narrative_ResearchBranchTemporalIsolation) strategy emerged as a pragmatic alternative to complex ontology, favoring [branch-at-root](narr:https://aswritten.ai/narrative#Obs_ScarletBranchAtRootQuote) as a \"boring-and-works\" mechanism. This approach, supported by [Position_ResearchBranchMethodologyDecision](narr:https://aswritten.ai/narrative#Position_ResearchBranchMethodologyDecision), defers structural experiments in favor of stability. Earlier foundational shifts include the [product-wide pattern of prompting in return values](narr:https://aswritten.ai/narrative#Narrative_ReviewReturnValuePattern), which integrates reinforcement directly into tool feedback loops rather than relying solely on upfront descriptions. These policies collectively prioritize operational stability and clear separation of concerns over experimental architectural complexity.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PerspectiveVsImplementationLine> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ResearchBranchTemporalIsolation> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ReviewReturnValuePattern> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletBranchAtRootQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletBranchPolicyQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletNotRightTimeQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletReturnValueShiftQuote> ;
    narr:covers <https://aswritten.ai/narrative#Position_PerspectiveHoldsIntent> ;
    narr:covers <https://aswritten.ai/narrative#Position_ResearchBranchMethodologyDecision> ;
    narr:keyPhrase [ narr:text "Perspective holds decisions and reasoning; implementation holds literal detail; both are knowledge but belong in different places" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PerspectiveVsImplementationLine> ] ;
    narr:keyPhrase [ narr:text "this isn't the right time for ontology and repo structure experiments." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletNotRightTimeQuote> ] ;
    narr:keyPhrase [ narr:text "Boring-and-works beats clever-and-risky at launch." ; narr:phraseSource <https://aswritten.ai/narrative#Position_ResearchBranchMethodologyDecision> ] ;
    narr:keyPhrase [ narr:text "doing more prompting in the return values from tools instead of always just up front in the tool descriptions." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletReturnValueShiftQuote> ] ;
    narr:keyPhrase [ narr:text "I think branch should be optional, and it should default to main." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletBranchPolicyQuote> ] ;
    narr:variation [ narr:text "Tension exists between the desire for branch-optionality and the current reliance on long-lived research branches." ; narr:over <https://aswritten.ai/narrative#Narrative_ResearchBranchTemporalIsolation> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletBranchPolicyQuote> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}