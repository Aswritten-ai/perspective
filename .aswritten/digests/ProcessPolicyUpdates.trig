    narr:covers <https://aswritten.ai/narrative#Narrative_TieredCICoverage> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_TryDirectFallbackOnRejection> ;
    narr:covers <https://aswritten.ai/narrative#Obs_PruningQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletBranchAtRootQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletBranchPolicyQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletBranchingDoctrineQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletCostDirectiveQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletNotRightTimeQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletPostCutoverProtocolQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletReturnValueShiftQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_SlashStartSeparationPrinciple> ;
    narr:covers <https://aswritten.ai/narrative#Obs_WriteFlowTryDirectMechanism> ;
    narr:covers <https://aswritten.ai/narrative#Observation_30489_Fix> ;
    narr:keyPhrase [ narr:text "The direct-to-main hotfix path now runs the test suite before anything deploys, closing the one route by which untested code could reach production." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_HotfixPathGated> ] ;
    narr:keyPhrase [ narr:text "Main is a promotion target, not a development surface — continuously testing it re-verifies what promotion already proved." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_MainIsPromotionTargetNotDevSurface> ] ;
    narr:keyPhrase [ narr:text "Read-path tests cost cents and run on every PR. Write-path tests cost real LLM dollars and run only deliberately (opt-in label, manual dispatch, or daily scheduled baseline). This is now live in CI." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_ReadPathFreeWritePathDeliberate> ] ;
    narr:keyPhrase [ narr:text "Boring-and-works beats clever-and-risky at launch." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_ResearchBranchMethodologyDecision> ] ;
    narr:keyPhrase [ narr:text "pruning before each extraction is a great idea, one we should add to the current pipeline regardless of model hosting" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_PruningQuote> ] ;
    narr:keyPhrase [ narr:text "Nothing should have been moved into /start. /start should only be for project level stuff (backlog, etc, not aswritten)." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_SlashStartSeparationPrinciple> ] ;
    narr:keyPhrase [ narr:text "This is part of a shift I want to start making in the product as a whole: doing more prompting in the return values from tools instead of always just up front in the tool descriptions." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletReturnValueShiftQuote> ] ;
    narr:keyPhrase [ narr:text "But actually I think we should just do a branch at root, this isn't the right time for ontology and repo structure experiments." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletBranchAtRootQuote> ] ;
    narr:variation [ narr:text "Pruning rationale shifts by hosting model: with API it is cost optimization; with self-hosting it becomes quality optimization (tokens free, context window is the hard wall) — same action, different forcing function." ; narr:over <https://aswritten.ai/narrative#Narrative_SnapshotPruningPrePass> ] ;
    narr:variation [ narr:text "Try-direct write flow explicitly rejected probe-first as an alternative: probing protection status requires admin permissions the app may not hold and introduces a race condition — the fallback-on-rejection design was chosen over the seemingly safer upfront check." ; narr:over <https://aswritten.ai/narrative#Narrative_TryDirectFallbackOnRejection> ; narr:over <https://aswritten.ai/narrative#Obs_WriteFlowTryDirectMechanism> ] ;
    narr:variation [ narr:text "Research branch methodology is currently decision-level (used twice), not yet principle-level — its promotion is explicitly deferred to a future decision point, leaving its canonical status open." ; narr:over <https://aswritten.ai/narrative#Claim_ResearchBranchMethodologyDecision> ; narr:over <https://aswritten.ai/narrative#Narrative_ResearchBranchTemporalIsolation> ] ;
    narr:variation [ narr:text "Post-cutover fix protocol (Jul 2026) breaks from the implicit full-heartbeat-wait assumption: the heartbeat is a detection instrument, not a gate for every fix — three fix-verify-merge cycles ran in ~30 min each rather than waiting 90 min per cycle." ; narr:over <https://aswritten.ai/narrative#Narrative_PostCutoverFixProtocol> ] ;
    narr:variation [ narr:text "Branch defaulting to main (Jul 2025 Scarlet quote: optional, default main, context-dependent) sits in tension with direct-to-branch as a first-class mode (Jul 2026) — the later framing elevates direct-to-branch from a legacy behavior to an explicit product commitment." ; narr:over <https://aswritten.ai/narrative#Obs_ScarletBranchPolicyQuote> ; narr:over <https://aswritten.ai/narrative#Narrative_DirectToBranchFirstClass> ] ;
    narr:variation [ narr:text "The perspective-vs-implementation line is drawn inside 'how': directional/relational how belongs in the perspective; specific values, identifiers, and config belong in the implementation — a boundary that is principled but requires judgment at the margin." ; narr:over <https://aswritten.ai/narrative#Claim_PerspectiveHoldsIntent> ; narr:over <https://aswritten.ai/narrative#Narrative_PerspectiveVsImplementationLine> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}