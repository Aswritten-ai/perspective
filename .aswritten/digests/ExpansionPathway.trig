@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ExpansionPathway> {
  <https://aswritten.ai/narrative#Digest_ExpansionPathway> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#ExpansionPathway> ;
    narr:childCount "15"^^xsd:integer ;
    narr:generatedFrom "3a307e4600c5cebc6046d751e5a02407b420b873" ;
    narr:narration """The growth of aswritten centers on a [supplier-side distribution](narr:Narrative_SupplierSideDistribution) model, where experts push installable modules to their networks rather than relying on buyer-side marketplace browsing. This [interview-as-flywheel](narr:Narrative_ContentFlywheel) motion simultaneously solves supply-side acquisition, marketing, and product demonstration. The [three network bootstrap strategies](narr:Narrative_NetworkBootstrapStrategies) (curation, partnership, and task-specific modules) provide the initial momentum, while [forward-shareable gifting](narr:Narrative_ForwardShareableGifting) enables viral expansion. As the system matures, [self-hosting](narr:Narrative_SelfHostingEnablesNewProducts) shifts the cost structure from variable API tokens to fixed server costs, unlocking previously prohibitive product surfaces like SMS interfaces and always-on agents. The [expansion path](narr:Narrative_ExpansionPath) moves from direct pilots to VC-portfolio rollouts and enterprise platform deals, supported by [two distinct upgrade drivers](narr:Narrative_TwoUpgradeDrivers): value-driven growth and requirements-driven compliance. A [new media angle](narr:Narrative_NewMediaIndividualAngle) now extends this to creatives and influencers, who produce work using their own individual-as-a-service.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_CompoundingValue> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ContentDistributionAIAge> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ContentFlywheel> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ExpansionPath> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ExpansionTracks> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ForwardShareableGifting> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_InfluenceSales> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_NetworkBootstrapStrategies> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_NewMediaIndividualAngle> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_SelfHostingEnablesNewProducts> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_SupplierSideDistribution> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_TwoUpgradeDrivers> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ContentCreatorPublishingQuestion> ;
    narr:covers <https://aswritten.ai/narrative#Position_NetworkProblemStrategies> ;
    narr:covers <https://aswritten.ai/narrative#Position_ReferralOnlyGrowthRisk> ;
    narr:keyPhrase [ narr:text "how do people using AI access this?" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ContentCreatorPublishingQuestion> ] ;
    narr:keyPhrase [ narr:text "The marketplace concept shifts from buyer-side browsing to supplier-side distribution." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ContentDistributionAIAge> ] ;
    narr:keyPhrase [ narr:text "The interview model creates a flywheel: each expert interview produces an installable perspective (supply side), a published content piece (marketing), and a live proof of the product working (sales)." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ContentFlywheel> ] ;
    narr:keyPhrase [ narr:text "Fixed server costs vs. per-token API spend is not just a cost reduction — it unlocks an entirely different product surface area" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_SelfHostingEnablesNewProducts> ] ;
    narr:keyPhrase [ narr:text "I don't want to paint myself in a corner where like the only expansion pathway over the next however many years is like progressive referral based" ; narr:phraseSource <https://aswritten.ai/narrative#Position_ReferralOnlyGrowthRisk> ] ;
    narr:variation [ narr:text "High-touch referral growth is identified as a significant risk if it remains the sole expansion pathway." ; narr:over <https://aswritten.ai/narrative#Position_ReferralOnlyGrowthRisk> ] ;
    narr:variation [ narr:text "The B2C creative/influencer track introduces a new media category distinct from the B2B expert marketplace." ; narr:over <https://aswritten.ai/narrative#Narrative_NewMediaIndividualAngle> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}