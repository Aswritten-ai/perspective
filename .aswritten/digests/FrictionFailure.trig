    narr:keyPhrase [ narr:text "I will spend a couple days and end up with eight honking PRs of world changing features that would have taken us three weeks previously" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletBackPressureQuote> ] ;
    narr:keyPhrase [ narr:text "I'm a key candidate for this because I forget as much as I remember." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerEngManagerForgetQuote1> ] ;
    narr:keyPhrase [ narr:text "We gave you pros and cons and you were to go away and figure out which one suits and come back with a proposal. We didn't give you a full solution, we just gave you options." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_OptionsVsDecisionsQuote> ] ;
    narr:keyPhrase [ narr:text "The reason why a collaborator doesn't work is I'm not all in on a collaborator." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_TonyPipitAdoptionBarrier> ] ;
    narr:keyPhrase [ narr:text "the conversations I have with other people and the conversations I have with myself (i.e. these voice memos) are really my two primary inputs" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletPrimaryInputsQuote> ] ;
    narr:variation [ narr:text "Value proof via 'showing' vs. 'trying' (the felt-vs-shown crux): is own-data essential for proof or just a conversion deepener?" ; narr:over <https://aswritten.ai/narrative#Narrative_ShowVsDemoProof> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletFeltVsShownQuote> ] ;
    narr:variation [ narr:text "Adoption friction as contamination fear (technical users) vs. organizational change management (non-technical users)." ; narr:over <https://aswritten.ai/narrative#Narrative_TechnicalAdoptionFriction> ; narr:over <https://aswritten.ai/narrative#Narrative_StaffingAIAdoptionWall> ] ;
    narr:variation [ narr:text "The 'forgetting bottleneck' as a structural role requirement vs. a personal failing." ; narr:over <https://aswritten.ai/narrative#Narrative_ForgettingBottleneckIsRole> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
