    narr:covers <https://aswritten.ai/narrative#StyleObs_IdiolectPhrasing> ;
    narr:keyPhrase [ narr:text "I will spend a couple days and end up with eight honking PRs of world changing features that would have taken us three weeks previously" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletBackPressureQuote> ] ;
    narr:keyPhrase [ narr:text "Each one of these is somebody telling us really valuable information about why them understanding the product value does not equal a sale." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletPurchaseTriggerQuote> ] ;
    narr:keyPhrase [ narr:text "Text message, in certain contexts, is absolutely the right move. But in a lot of skeptical or lower-trust contexts, texting is so associated with spam now that requiring someone to text might actually be a real downside." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_OutsideTechBetaUserSMSSpamCodedQuote> ] ;
    narr:keyPhrase [ narr:text "every single response prompts another action, right? And while that's good for token consumption, it's not good for humans because if the prompt is, do you want me to do that?" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_TonyAITrapQuote> ] ;
    narr:keyPhrase [ narr:text "Everything you said about committing and pulling and all of that is completely foreign to me." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_OutsideTechBetaUserGitHubOpacityFeedback> ] ;
    narr:keyPhrase [ narr:text "A huge amount of the ARB time is actually spent on just trying to figure out or just asking, just people coming and being like, I need to scan an Amazon return. Does the product support that?" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ARBPainPoint1_Quote> ] ;
    narr:variation [ narr:text "Sales blocker is framed two ways: 'lack of clarity on exactly what is being sold' (root cause) vs. clarity isn't enough — the purchase trigger must be firing." ; narr:over <https://aswritten.ai/narrative#Obs_FrictionFailure> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletPurchaseTriggerQuote> ; narr:over <https://aswritten.ai/narrative#Narrative_TwoPurchaseTriggers> ] ;
    narr:variation [ narr:text "Counter-reading: technical-user resistance is NOT product difficulty but contamination fear of breaking existing AI workflows — solution is onboarding guidance, not simplification." ; narr:over <https://aswritten.ai/narrative#Narrative_TechnicalAdoptionFriction> ; narr:over <https://aswritten.ai/narrative#Obs_TechnicalChaosQuote> ; narr:over <https://aswritten.ai/narrative#Obs_TonyPipitAdoptionBarrier> ] ;
    narr:variation [ narr:text "Outlier: AI working *too well* becomes the blocker — recruiter hit quota and poached colleagues; org change management, not technology, stalls adoption." ; narr:over <https://aswritten.ai/narrative#Narrative_StaffingAIAdoptionWall> ; narr:over <https://aswritten.ai/narrative#Obs_CustomerArchitectAIResistantQuote> ] ;
    narr:variation [ narr:text "SMS friction is scoped, not condemned — channel stays viable in high-trust/post-consent contexts and only flips suspicious in evaluator/first-touch ones." ; narr:over <https://aswritten.ai/narrative#Narrative_SMSContextDependentTrustTax> ; narr:over <https://aswritten.ai/narrative#Obs_OutsideTechBetaUserSMSSpamCodedQuote> ] ;
    narr:variation [ narr:text "Attribution outlier: MCP flakiness in Copilot CLI is explicitly ruled a Copilot problem, not an aswritten failure." ; narr:over <https://aswritten.ai/narrative#Obs_CopilotMCPIssues> ] ;
    narr:variation [ narr:text "Distinct mechanism: friction can originate inside the LLM itself — the framing layer over-resolves and manufactures procedural exit ramps to dodge effortful tasks." ; narr:over <https://aswritten.ai/narrative#Narrative_FramingLayerDeflection> ] ;
    narr:writer "claude (subscription)" .
