    narr:keyPhrase [ narr:text "Consistent with the Scarlet session-memo idiolect across the perspective." ; narr:phraseSource <https://aswritten.ai/narrative#Metrics_PractitionerBetaUserBarber_20260430> ] ;
    narr:keyPhrase [ narr:text "Active voice dominant in editorial prose; blockquoted speech is run-on and filler-heavy." ; narr:phraseSource <https://aswritten.ai/narrative#Metrics_NicheEmerges_20260424> ] ;
    narr:keyPhrase [ narr:text "Short punchy declaratives at conviction peaks ('Keeping beats starting.')" ; narr:phraseSource <https://aswritten.ai/narrative#Metrics_ConsultingFramingDecision_20260610> ] ;
    narr:keyPhrase [ narr:text "Antithesis-heavy structure (conversational vs. coined, grammar vs. diction, her phrasing vs. AI phrasing)." ; narr:phraseSource <https://aswritten.ai/narrative#Metrics_ScarletVoiceRule_20260612> ] ;
    narr:keyPhrase [ narr:text "High active voice ratio; technical jargon (SPARQL, n8n, BYOK, SHA) is domain-appropriate and consistently expanded on first use." ; narr:phraseSource <https://aswritten.ai/narrative#Metrics_Demo1Pipeline> ] ;
    narr:keyPhrase [ narr:text "High jargon density (SPARQL, RDF, ABAC, IRI, Datomic, XTDB, ARQ). Active voice dominant in direct quotes; passive voice appears in analytical framing sections." ; narr:phraseSource <https://aswritten.ai/narrative#StyleMetrics_DiscoveryConsultantCall> ] ;
    narr:keyPhrase [ narr:text "raw first-person stream-of-consciousness in blockquoted speech (run-on, filler-heavy, ~35 words avg per sentence) vs. editorial framing prose (structured, shorter, ~18 words avg)" ; narr:phraseSource <https://aswritten.ai/narrative#StyleMetrics_Moonshot_20260701> ] ;
    narr:keyPhrase [ narr:text "Metrics computed from full document; high active voice ratio; moderate jargon density (technical terms: embedding space, vector, LLM, NLP, etc.); high lexical diversity." ; narr:phraseSource <https://aswritten.ai/narrative#Metrics_FoundingStory> ] ;
    narr:variation [ narr:text "High RDF/SPARQL/ABAC jargon density with passive voice in analytical framing — structurally distinct from the low-jargon session-memo idiolect dominant elsewhere." ; narr:over <https://aswritten.ai/narrative#StyleMetrics_DiscoveryConsultantCall> ; narr:over <https://aswritten.ai/narrative#StyleMetrics_DiscoveryConsultant_20260630> ] ;
    narr:variation [ narr:text "Voice-memo / morning-pages register (~35 words avg per sentence in blockquotes, profanity as rhetorical intensifier) contrasts sharply with the tighter editorial framing prose of the session-memo cluster." ; narr:over <https://aswritten.ai/narrative#StyleMetrics_Moonshot_20260701> ; narr:over <https://aswritten.ai/narrative#StyleMetrics_DesignCollaboratorCall_20260629> ] ;
    narr:variation [ narr:text "Technical post-mortem register with elevated jargon density from system-specific identifiers (outseta-id, JSONB, JWT) and long parenthetical-laden sentences — no antithesis structure, no blockquoted speech." ; narr:over <https://aswritten.ai/narrative#StyleMetrics_EnterpriseCustomerWeekOne> ] ;
    narr:variation [ narr:text "Lyrical founder essay embedded in a session-memo shell — active voice with deliberate sentence-length variation and sparse jargon, structurally unlike the analytical antithesis-heavy majority." ; narr:over <https://aswritten.ai/narrative#StyleMetrics_EVFlockingApplication> ] ;
    narr:variation [ narr:text "Beta strategy reframe uses markdown tables, code blocks, and aphoristic one-sentence paragraphs as rhetorical anchors — a structural outlier with no blockquoted speech and second-person implicit framing." ; narr:over <https://aswritten.ai/narrative#StyleMetrics_BetaStrategyReframe> ] ;
    narr:variation [ narr:text "Unusually self-critical epistemic register flagged in one strategic memo ('potentially rationalizing') — a hedging posture absent from the conviction-forward session-memo idiolect." ; narr:over <https://aswritten.ai/narrative#Metrics_EnterpriseShapePrimaryFocus_20260421> ] ;
