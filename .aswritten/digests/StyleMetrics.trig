    narr:keyPhrase [ narr:text "Antithesis-heavy structure (conversational vs. coined, grammar vs. diction, her phrasing vs. AI phrasing)." ; narr:phraseSource <https://aswritten.ai/narrative#Metrics_ScarletVoiceRule_20260612> ] ;
    narr:keyPhrase [ narr:text "Active voice dominant in editorial prose; blockquoted speech is run-on and filler-heavy." ; narr:phraseSource <https://aswritten.ai/narrative#Metrics_PractitionerBetaUserBarber_20260430> ] ;
    narr:keyPhrase [ narr:text "No hedging in evaluative claims." ; narr:phraseSource <https://aswritten.ai/narrative#Metrics_ModelComparison_20260331> ] ;
    narr:keyPhrase [ narr:text "Provisional flag in frontmatter signals research-branch status." ; narr:phraseSource <https://aswritten.ai/narrative#StyleMetrics_AgentSimulationResearch> ] ;
    narr:keyPhrase [ narr:text "Unusually self-critical epistemic register — 'potentially rationalizing' signals intellectual honesty." ; narr:phraseSource <https://aswritten.ai/narrative#Metrics_EnterpriseShapePrimaryFocus_20260421> ] ;
    narr:keyPhrase [ narr:text "Short punchy declaratives at conviction peaks ('Keeping beats starting.')." ; narr:phraseSource <https://aswritten.ai/narrative#Metrics_ConsultingFramingDecision_20260610> ] ;
    narr:keyPhrase [ narr:text "Profanity used by Scarlet as rhetorical intensifier at conviction peaks." ; narr:phraseSource <https://aswritten.ai/narrative#Metrics_TonyScarletCall_20260331> ] ;
    narr:keyPhrase [ narr:text "high active voice ratio; moderate jargon density (technical terms: embedding space, vector, LLM, NLP, etc.); high lexical diversity." ; narr:phraseSource <https://aswritten.ai/narrative#Metrics_FoundingStory> ] ;
    narr:variation [ narr:text "Engineering post-mortem register diverges sharply from the session-memo idiolect: no hedging, verdicts in 3-5 words, dense RDF/SPARQL jargon — a distinct voice cluster from the antithesis-heavy strategic memos." ; narr:over <https://aswritten.ai/narrative#Metrics_ModelComparison_20260331> ; narr:over <https://aswritten.ai/narrative#Metrics_ModelComparison_20260331_Updated> ; narr:over <https://aswritten.ai/narrative#StyleMetrics_N8nSQLiteToPostgres> ] ;
    narr:variation [ narr:text "Voice-memo / morning-pages register (raw stream-of-consciousness, ~35 words avg per sentence in blockquotes, profanity as intensifier) sits at the opposite pole from the tighter editorial framing prose that wraps it." ; narr:over <https://aswritten.ai/narrative#StyleMetrics_Moonshot_20260701> ; narr:over <https://aswritten.ai/narrative#StyleMetrics_DesignCollaboratorCall_20260629> ] ;
    narr:variation [ narr:text "The voice-rule memo is the one node that explicitly codifies the idiolect as a rule rather than describing it as an observed pattern — a meta-level outlier among descriptive metrics records." ; narr:over <https://aswritten.ai/narrative#Metrics_ScarletVoiceRule_20260612> ] ;
    narr:variation [ narr:text "Several nodes carry empty content (no metrics extracted), leaving gaps in the corpus coverage — notably demo-prep, MCP tool surface, and pitch-artifacts nodes." ; narr:over <https://aswritten.ai/narrative#Metrics_EnterpriseCustomerDemoPrep> ; narr:over <https://aswritten.ai/narrative#Metrics_MCPToolSurface> ; narr:over <https://aswritten.ai/narrative#StyleMetrics_PitchArtifacts_20260430> ] ;
    narr:variation [ narr:text "The founding story and YC transcript nodes report high lexical diversity and domain-appropriate jargon without the antithesis structure — suggesting the idiolect is a session-memo convention, not a universal voice signature." ; narr:over <https://aswritten.ai/narrative#Metrics_FoundingStory> ; narr:over <https://aswritten.ai/narrative#Metrics_YC> ] ;
    narr:variation [ narr:text "The ScarletRules node inverts the usual direction: rather than measuring style, it prescribes it — 'short declarative sentences, active voice throughout, minimal jargon' — functioning as a normative anchor rather than a descriptive metric." ; narr:over <https://aswritten.ai/narrative#StyleMetrics_ScarletRules> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
