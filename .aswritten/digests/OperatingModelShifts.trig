    narr:keyPhrase [ narr:text "Monthly fee range: [amount]–[amount]/month." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_AdvisoryStaffingEconomics> ] ;
    narr:keyPhrase [ narr:text "roughly 1.5 concurrent engagements means attention tiering" ; narr:phraseSource <https://aswritten.ai/narrative#Claim_CapacityTieringAttention> ] ;
    narr:keyPhrase [ narr:text "group freelance with a license to aswritten" ; narr:phraseSource <https://aswritten.ai/narrative#Claim_InternalCompensationCalibrated> ] ;
    narr:keyPhrase [ narr:text "Stop trying to get it to see the way that you see and start getting it to use you to give the perspective on what you see." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_PerspectiveInversionQuote> ] ;
    narr:keyPhrase [ narr:text "If we can stop the work being about my actual execution in a terminal and start it being about my curation of a perspective that is then used by somebody else." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletExecutionStrategyQuote> ] ;
    narr:keyPhrase [ narr:text "There's a clear pathway for a demo-call prospect to go after both individuals and small businesses who can package a single book or asset and also to convert them and larger orgs to the org plan." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletDemoProspectPathwayQuote> ] ;
    narr:keyPhrase [ narr:text "when you're pulling these people in, get them to adopt AI the way you use it" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerArchitectCTODirectiveQuote> ] ;
    narr:keyPhrase [ narr:text "What's the biggest asset of a lot of the people you're talking about? Right. Us included. It's the experience and the strategy that we can bring." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_TonyExperienceAsAsset> ] ;
    narr:variation [ narr:text "Advisory staffing logic (replace hiring with expert networks) sits in tension with the team bottleneck reframe, which names specific unfillable gaps requiring actual hires — the two staffing logics pull in opposite directions." ; narr:over <https://aswritten.ai/narrative#Narrative_AdvisoryStaffingAlternativeToHiring> ; narr:over <https://aswritten.ai/narrative#Narrative_TeamBottleneckReframe> ] ;
    narr:variation [ narr:text "Template vs. emergence: an advisor pushed twice for structured templates; the customer's CTO and the customer's chief architect pushed back for process-discovered structure — a product gap (system should generate templates from decisions) was identified but not resolved." ; narr:over <https://aswritten.ai/narrative#Narrative_EmergenceVsTemplate> ] ;
    narr:variation [ narr:text "Protocol command register vs. enrollment: the commanding grammar of prior protocols earns model resistance over time; the enrollment-over-command principle is a direct correction of the existing protocol's tone." ; narr:over <https://aswritten.ai/narrative#Narrative_ProtocolEnrollmentOverCommand> ; narr:over <https://aswritten.ai/narrative#Narrative_SeparationPrincipleProtocolVsOps> ] ;
    narr:variation [ narr:text "Fable scarcity vs. Opus abundance reframes the cost model: the budget-relevant resource is Fable alone (weekly-credit-rationed, availability-limited by outage), while Opus is effectively free at the margin — the architect/implementer split is partly a cost-management response, not only a quality pattern." ; narr:over <https://aswritten.ai/narrative#Narrative_FableScarcityOpusAbundance> ; narr:over <https://aswritten.ai/narrative#Narrative_ArchitectImplementerSplit> ] ;
    narr:variation [ narr:text "Altitude-switching cognitive cost (building vs. vision-pitch is harder than project-switching) surfaces a personal operating constraint that the advisory and sales model shifts do not yet structurally address." ; narr:over <https://aswritten.ai/narrative#Narrative_AltitudeSwitchingCognitiveCost> ] ;
    narr:variation [ narr:text "a collaborator's B2C→B2B outcome-based pivot and an early prospect's managed-care framing represent a parallel operating model shift in a client context — related logic but a distinct domain with no direct bridge to the aswritten staffing or sales architecture." ; narr:over <https://aswritten.ai/narrative#Narrative_BusinessModelPivot> ; narr:over <https://aswritten.ai/narrative#Claim_OutcomeBasedModel> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}