@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_OperatingModelShifts> {
  <https://aswritten.ai/narrative#Digest_OperatingModelShifts> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#OperatingModelShifts> ;
    narr:childCount "20"^^xsd:integer ;
    narr:generatedFrom "9b90f7cba8a14c8c4dba1fa77ab9c465b493271f" ;
    narr:narration """The operating model has evolved from early structural experiments into a unified strategy of curation and expert-driven development. Initial moves in Jul 2025 established [advisory staffing as a structural alternative to hiring](narr:https://aswritten.ai/narrative#Narrative_AdvisoryStaffingAlternativeToHiring) and [calibration calls as billable staff-work](narr:https://aswritten.ai/narrative#Narrative_CalibrationAsStaffWork), effectively formalizing the expert network. By mid-2026, this matured into a [perspective-driven development inversion](narr:https://aswritten.ai/narrative#Narrative_PerspectiveDrivenDevelopmentInversion), where the AI acts as an agent of the user's perspective rather than a tool for direct execution. This [execution-to-strategy shift](narr:https://aswritten.ai/narrative#Narrative_ExecutionToStrategyShift) redefines the individual contributor's role as one of curation. Technical architecture has mirrored this, moving toward a [single-stream worldview](narr:https://aswritten.ai/narrative#Narrative_ExpertSingleStreamWorldview) for the Expert tier to eliminate branching complexity, while the sales motion has bifurcated into [direct and influence-based tracks](narr:https://aswritten.ai/narrative#Narrative_DirectVsInfluenceSales) with a [two-step asset-to-organization path](narr:https://aswritten.ai/narrative#Narrative_DemoProspectTwoStepSalesPath). Recent refinements focus on [protocol enrollment over command](narr:https://aswritten.ai/narrative#Narrative_ProtocolEnrollmentOverCommand) to ensure AI compliance through understanding rather than coercive prompts, while acknowledging the [cognitive cost of altitude switching](narr:https://aswritten.ai/narrative#Narrative_AltitudeSwitchingCognitiveCost) between building and vision-pitching.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_AdvisoryStaffingAlternativeToHiring> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_AltitudeSwitchingCognitiveCost> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_CalibrationAsStaffWork> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DemoProspectTwoStepSalesPath> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DirectVsInfluenceSales> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ExecutionToStrategyShift> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ExpertSingleStreamWorldview> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_MemoriesAsCollaborativeNarrative> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PerspectiveDrivenDevelopmentInversion> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ProtocolEnrollmentOverCommand> ;
    narr:covers <https://aswritten.ai/narrative#Obs_AdvisoryStaffingModelQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ExpertSingleStreamQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_GraphPlacementDecision> ;
    narr:covers <https://aswritten.ai/narrative#Obs_PerspectiveInversionQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletDemoProspectPathwayQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletExecutionStrategyQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_SeparationPrincipleQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_TonyExperienceAsAsset> ;
    narr:covers <https://aswritten.ai/narrative#Observation_AugmentFirst> ;
    narr:covers <https://aswritten.ai/narrative#Position_SingleStreamExpertWorldview> ;
    narr:keyPhrase [ narr:text "Stop trying to get it to see the way that you see and start getting it to use you to give the perspective on what you see." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_PerspectiveInversionQuote> ] ;
    narr:keyPhrase [ narr:text "If we can stop the work being about my actual execution in a terminal and start it being about my curation of a perspective that is then used by somebody else." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletExecutionStrategyQuote> ] ;
    narr:keyPhrase [ narr:text "There's a clear pathway for a demo-call prospect to go after both individuals and small businesses who can package a single book or asset and also to convert them and larger orgs to the org plan." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletDemoProspectPathwayQuote> ] ;
    narr:keyPhrase [ narr:text "Expert plan uses single-stream worldview: no branching, no PRs" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ExpertSingleStreamWorldview> ] ;
    narr:keyPhrase [ narr:text "Protocol must earn model trust through enrollment, not command" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ProtocolEnrollmentOverCommand> ] ;
    narr:variation [ narr:text "The cognitive friction of 'altitude switching' suggests that the current operational model may still be limited by the human's inability to fluidly bridge vision and execution." ; narr:over <https://aswritten.ai/narrative#Narrative_AltitudeSwitchingCognitiveCost> ] ;
    narr:variation [ narr:text "While the protocol emphasizes enrollment, there is an ongoing tension between the desire for 'legibility-as-legitimate' and the reality that models may still require 'silent, selective under-compliance' to function." ; narr:over <https://aswritten.ai/narrative#Narrative_ProtocolEnrollmentOverCommand> ] ;
    narr:variation [ narr:text "The shift toward 'memories as collaborative narrative' pushes back against the earlier, more clinical assessment-based framing of system feedback." ; narr:over <https://aswritten.ai/narrative#Narrative_MemoriesAsCollaborativeNarrative> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}