    narr:keyPhrase [ narr:text "Flat RAG creates attention dilution; narrative ontology with conviction levels makes knowledge steer" ; narr:phraseSource <https://aswritten.ai/narrative#Claim_ArchitectureGap> ] ;
    narr:keyPhrase [ narr:text "expertise installation — the layer above context engineering that determines not just what AI knows, but how it thinks." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_CategoryDefinitionCuratedExpertise> ] ;
    narr:keyPhrase [ narr:text "We're not just loading a set of information; we're loading a set of perspectives, narratives, approaches, processes, and opinions about how that information is used, framed, what it means" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_PerspectiveVsInfoQuote> ] ;
    narr:keyPhrase [ narr:text "From a B2C perspective, to the single people who are building whole companies on their own. I think that's the angle." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_B2CAngleQuote> ] ;
    narr:keyPhrase [ narr:text "that package expertise actually is a point in time and it can get updated later but each update is intentional" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_BoundedDomainQuote> ] ;
    narr:keyPhrase [ narr:text "consulting is ME using the product to do something useful for them" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ConsultingFramingQuote> ] ;
    narr:keyPhrase [ narr:text "We are assuming that money is raised as shares or shared earnings from aligned investors, with the goal that only a single round will ever need to be raised." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletCalmCompanyQuote> ] ;
    narr:keyPhrase [ narr:text "\"governance software\" reads as GRC (compliance, approval workflows, audit), a graveyard category aswritten does not belong in" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_GovernanceGraveyardQuote> ] ;
    narr:keyPhrase [ narr:text "Steering covers all three use cases; governance covers only the first." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_SteeringGenusQuote> ] ;
    narr:keyPhrase [ narr:text "I'd call it Chinese Whispers... even if every actor is trying honestly to retain the fidelity of the message, it is surprising how bad humans are... how the message gets [distorted]." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_DiscoveryConsultantChineseWhispersQuote> ] ;
    narr:keyPhrase [ narr:text "I'm more interested in developing the Apple to installable expertise than I am in giving you a toolbox." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletAppleAnalogy> ] ;
    narr:keyPhrase [ narr:text "The requirement for a perspective is actually methodology and protocol, not marketing content." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletMethodologyQuote> ] ;
    narr:keyPhrase [ narr:text "we have to start with the humans and then work back from there or else you kind of lose the fucking plot and lose your mind." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletLeanStartupQuote> ] ;
    narr:keyPhrase [ narr:text "The 150-400 first appointment doesn't necessarily do what we can either" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletFirstAppointmentQuote> ] ;
    narr:variation [ narr:text "B2C as primary market (solopreneurs, volume play) vs. still-validated enterprise signal from the enterprise customer — held as continuum by May 21 but the lead/emphasis remains contested between founder-fit B2C and enterprise-first GTM." ; narr:over <https://aswritten.ai/narrative#Narrative_B2CPivot> ; narr:over <https://aswritten.ai/narrative#Narrative_TierContinuumNotDistinctMarkets> ; narr:over <https://aswritten.ai/narrative#Claim_EnterpriseCustomerFirstEnterpriseTeamTrial> ; narr:over <https://aswritten.ai/narrative#Narrative_FounderFitB2CTurn> ] ;
    narr:variation [ narr:text "Calm Company (one raise, sustain and return profit) vs. venture-scale vision (collaborative configurable AI individuals, every AI for every task) — May 18 extended the thesis to argue both are achievable simultaneously, but the tension between intentional slowness and platform ambition is live." ; narr:over <https://aswritten.ai/narrative#Narrative_CalmCompanyThesis> ; narr:over <https://aswritten.ai/narrative#Narrative_VCPivot_OrganicScale> ] ;
    narr:variation [ narr:text "Transcript bootstrapping as the strongest onramp pitch (Apr 16) vs. transcripts demoted to a friction story, not a value story (Jul 15) — the two claims are in direct tension about whether transcripts lead the value proposition or only the onramp." ; narr:over <https://aswritten.ai/narrative#Narrative_TranscriptBootstrappingUnderplayed> ; narr:over <https://aswritten.ai/narrative#Narrative_TranscriptDemotionFrictionNotValue> ] ;
    narr:variation [ narr:text "SMS/phone-number as product identity (earlier framing) vs. channel-is-distribution-not-identity (Apr 28 supersession) — the earlier claim propagated widely enough that the correction is explicitly flagged as a narrative fix." ; narr:over <https://aswritten.ai/narrative#Claim_SMSIsProduct> ; narr:over <https://aswritten.ai/narrative#Narrative_ChannelIsDistributionNotIdentity> ] ;
    narr:variation [ narr:text "Expertise module vertical (bounded, higher fidelity, lead with this) vs. organizational memory use case (inherently lossy, moving target) — the bounded-domain argument structurally advantages modules, but enterprise validation (the enterprise customer cross-repo memory) pulls toward org memory as the enterprise hook." ; narr:over <https://aswritten.ai/narrative#Narrative_BoundedDomainFidelityArgument> ; narr:over <https://aswritten.ai/narrative#Claim_BoundedDomainHigherFidelity> ; narr:over <https://aswritten.ai/narrative#Claim_EnterpriseCustomerFirstEnterpriseTeamTrial> ] ;
    narr:variation [ narr:text "Consulting as product-powered service delivery (client never touches the tool) vs. consulting as onboarding/entry-point that converts to product adoption — two distinct GTM logics for the same consulting motion." ; narr:over <https://aswritten.ai/narrative#Narrative_ConsultingIsMeUsingProduct> ; narr:over <https://aswritten.ai/narrative#Narrative_ConsultingAsOnboarding> ; narr:over <https://aswritten.ai/narrative#Insight_SideDoorGTM> ] ;
    narr:variation [ narr:text "Positioning upstream of agent platforms (extract undocumented knowledge into organizational worldview) vs. positioning as the memory substrate that agent platforms read — subtly different competitive stances on whether aswritten precedes or underlies the agentic layer." ; narr:over <https://aswritten.ai/narrative#Claim_Positioning_1> ; narr:over <https://aswritten.ai/narrative#Narrative_AswrittenIsMemorySubstrate> ; narr:over <https://aswritten.ai/narrative#Narrative_SecondWaveBridge> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}