    narr:keyPhrase [ narr:text "Expertise installation is the layer above context engineering — it determines not just what AI knows but how it thinks; 'curated' was dropped as redundant" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_CategoryCuratedExpertiseInstallation> ] ;
    narr:keyPhrase [ narr:text "Steering covers all three use cases; governance covers only the first." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_SteeringGenusQuote> ] ;
    narr:keyPhrase [ narr:text "consulting is ME using the product to do something useful for them" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ConsultingFramingQuote> ] ;
    narr:keyPhrase [ narr:text "We're not just loading a set of information; we're loading a set of perspectives, narratives, approaches, processes, and opinions about how that information is used, framed, what it means" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_PerspectiveVsInfoQuote> ] ;
    narr:keyPhrase [ narr:text "AI has made every individual their own team; the volume play is B2C — solopreneurs and small business owners who need structure for context and memory" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_B2CPivot> ] ;
    narr:keyPhrase [ narr:text "Expertise modules are higher fidelity than org memory because they are bounded, intentionally curated, and do not drift without the expert's knowledge" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_BoundedDomainFidelityArgument> ] ;
    narr:keyPhrase [ narr:text "\"governance software\" reads as GRC (compliance, approval workflows, audit), a graveyard category aswritten does not belong in" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_GovernanceGraveyardQuote> ] ;
    narr:keyPhrase [ narr:text "The requirement for a perspective is actually methodology and protocol, not marketing content." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletMethodologyQuote> ] ;
    narr:keyPhrase [ narr:text "I really see this as the future of trusted information in the AI age. Search is your AI trying to decide what's important and finding it for you." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_TrustedInformationQuote> ] ;
    narr:keyPhrase [ narr:text "we have to start with the humans and then work back from there or else you kind of lose the fucking plot and lose your mind." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletLeanStartupQuote> ] ;
    narr:variation [ narr:text "Transcript bootstrapping was pitched as the onramp (April 2026), then demoted: transcripts are a friction story not a value story, priced at ~$0/seat by the market — the two claims coexist in tension rather than resolving cleanly." ; narr:over <https://aswritten.ai/narrative#Narrative_TranscriptBootstrappingUnderplayed> ; narr:over <https://aswritten.ai/narrative#Narrative_TranscriptDemotionFrictionNotValue> ] ;
    narr:variation [ narr:text "B2C-primary is the market thesis, but the founder-fit B2C turn (July 2026) holds it in tension with still-validated enterprise signal — the framing is explicitly a continuum, not a binary, and the emphasis question remains open." ; narr:over <https://aswritten.ai/narrative#Narrative_FounderFitB2CTurn> ; narr:over <https://aswritten.ai/narrative#Narrative_B2CPivot> ; narr:over <https://aswritten.ai/narrative#Narrative_TierContinuumNotDistinctMarkets> ] ;
    narr:variation [ narr:text "The channel-is-not-identity demotion (April 2026) explicitly supersedes an over-embedded 'the product is a phone number' claim — a prior framing that may still be in circulation." ; narr:over <https://aswritten.ai/narrative#Narrative_ChannelIsDistributionNotIdentity> ] ;
    narr:variation [ narr:text "Calm Company thesis (single raise, bootstrapped ambition) was extended May 2026 to accommodate venture-scale vision achievable on calm-company economics — the two framings coexist rather than one superseding the other." ; narr:over <https://aswritten.ai/narrative#Narrative_CalmCompanyThesis> ; narr:over <https://aswritten.ai/narrative#Narrative_VCPivot_OrganicScale> ] ;
    narr:variation [ narr:text "Ingestion-as-protocol (June 2026) retired the OAuth connector-building framing from the same month's handoff — the prior workstream definition may persist in external documents." ; narr:over <https://aswritten.ai/narrative#Narrative_IngestionIsProtocol> ] ;
    narr:variation [ narr:text "The 'understanding never sells — outputs do' demotion pushes against the quantified-organization and introspective-analytics framing, which is now scoped to the enterprise-customer shape specifically rather than universal." ; narr:over <https://aswritten.ai/narrative#Narrative_TranscriptDemotionFrictionNotValue> ; narr:over <https://aswritten.ai/narrative#Narrative_QuantifiedOrganization> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
