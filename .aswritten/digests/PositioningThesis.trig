    narr:keyPhrase [ narr:text "aswritten is the memory the steering runs on — read at the start of the work, written at the end — never the tool that does the governing or orchestrating" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_AswrittenIsMemorySubstrate> ] ;
    narr:keyPhrase [ narr:text "The product eliminates the CEO's invisible unpaid second job as the company's context server" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_CEOContextServerReframe> ] ;
    narr:keyPhrase [ narr:text "aswritten is an amplifier of human diversity — AI should encode as much flavor and variety as there are people, not collapse it into a monoculture" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_AntiMonocultureAmplifier> ] ;
    narr:keyPhrase [ narr:text "The conversion mechanic is own-by-default, pay-to-continue: the graph belongs to the user by default; payment is required to continue building it past the free threshold." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_IndividuationCurveConversionMechanic> ] ;
    narr:keyPhrase [ narr:text "Consulting is the founder using the product as infrastructure to deliver value — the client never touches the tool, never adopts it, never believes in it" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ConsultingIsMeUsingProduct> ] ;
    narr:variation [ narr:text "Enterprise remains a validated top-tier segment despite the B2C primary pivot." ; narr:over <https://aswritten.ai/narrative#Narrative_B2CPivot> ; narr:over <https://aswritten.ai/narrative#Narrative_TierContinuumNotDistinctMarkets> ] ;
    narr:variation [ narr:text "Transcripts are a friction-heavy onramp rather than a core value proposition." ; narr:over <https://aswritten.ai/narrative#Narrative_TranscriptDemotionFrictionNotValue> ] ;
    narr:variation [ narr:text "The 'Calm Company' bootstrapped model is held in tension with the venture-scale vision." ; narr:over <https://aswritten.ai/narrative#Narrative_CalmCompanyThesis> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
