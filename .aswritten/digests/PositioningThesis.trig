    narr:keyPhrase [ narr:text "aswritten is always the substrate — read at the start of work, written at the end — never the loop that does the governing or orchestrating" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_AswrittenIsMemorySubstrate> ] ;
    narr:keyPhrase [ narr:text "The product eliminates the CEO's invisible unpaid second job as the company's context server" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_CEOContextServerReframe> ] ;
    narr:keyPhrase [ narr:text "aswritten is an amplifier of human diversity — AI should encode as much flavor and variety as there are people, not collapse it into a monoculture" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_AntiMonocultureAmplifier> ] ;
    narr:keyPhrase [ narr:text "Consulting is the founder using the product as infrastructure to deliver value — the client never touches the tool, never adopts it, never believes in it" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ConsultingIsMeUsingProduct> ] ;
    narr:keyPhrase [ narr:text "Expertise modules are higher fidelity than org memory because they are bounded, intentionally curated, and do not drift without the expert's knowledge" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_BoundedDomainFidelityArgument> ] ;
    narr:variation [ narr:text "The B2C pivot is held in tension with validated enterprise demand, framed as a continuum rather than a binary choice." ; narr:over <https://aswritten.ai/narrative#Narrative_TierContinuumNotDistinctMarkets> ; narr:over <https://aswritten.ai/narrative#Narrative_FounderFitB2CTurn> ] ;
    narr:variation [ narr:text "The 'transcript-as-gold-mine' framing has been demoted to a friction-reduction story rather than a primary value proposition." ; narr:over <https://aswritten.ai/narrative#Narrative_TranscriptDemotionFrictionNotValue> ] ;
    narr:variation [ narr:text "The 'Calm Company' bootstrapping thesis is challenged by the venture-scale vision of collaborative AI individuals." ; narr:over <https://aswritten.ai/narrative#Narrative_CalmCompanyThesis> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
