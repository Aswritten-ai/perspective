    narr:keyPhrase [ narr:text "expertise installation — the layer above context engineering that determines not just what AI knows, but how it thinks" ; narr:phraseSource <https://aswritten.ai/narrative#Position_CategoryDefinitionCuratedExpertise> ] ;
    narr:keyPhrase [ narr:text "aswritten is always the substrate — read at the start of work, written at the end — never the loop that does the governing or orchestrating" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_AswrittenIsMemorySubstrate> ] ;
    narr:keyPhrase [ narr:text "The product eliminates the CEO's invisible unpaid second job as the company's context server" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_CEOContextServerReframe> ] ;
    narr:keyPhrase [ narr:text "aswritten fights Chinese Whispers — the inevitable distortion of meaning as it passes through human intermediaries — by preserving full provenance" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ChineseWhispersProvenance> ] ;
    narr:keyPhrase [ narr:text "Consulting is the founder using the product as infrastructure to deliver value — the client never touches the tool" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ConsultingIsMeUsingProduct> ] ;
    narr:variation [ narr:text "The 'transcript gold mine' is now framed as a friction story rather than a value proposition." ; narr:over <https://aswritten.ai/narrative#Narrative_TranscriptDemotionFrictionNotValue> ] ;
    narr:variation [ narr:text "The B2C pivot is held in tension with the validated enterprise signal, treated as a continuum of founder-fit rather than a binary choice." ; narr:over <https://aswritten.ai/narrative#Narrative_FounderFitB2CTurn> ] ;
    narr:variation [ narr:text "Expertise modules are argued to be higher fidelity than organizational memory due to their bounded, curated nature." ; narr:over <https://aswritten.ai/narrative#Narrative_BoundedDomainFidelityArgument> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
