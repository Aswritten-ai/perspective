    narr:keyPhrase [ narr:text "institutional knowledge at the cursor" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_StockPhrase_InstitutionalKnowledge> ] ;
    narr:keyPhrase [ narr:text "senior expert bottleneck" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_StockPhrase_SeniorExpertBottleneck> ] ;
    narr:keyPhrase [ narr:text "The builder trap isn't \"building instead of selling\" — it's \"not knowing what you're selling\"" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_BuilderTrap> ] ;
    narr:keyPhrase [ narr:text "fire-and-forget" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_FeatureNotBug> ] ;
    narr:keyPhrase [ narr:text "Vibe Coding" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_VibeCoding> ] ;
    narr:keyPhrase [ narr:text "The physics never changed. The substrate did" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:keyPhrase [ narr:text "FOUNDATION" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_7> ] ;
    narr:variation [ narr:text "Dismissive framing of process patterns as 'quality gate theater' pushes against standard corporate terminology." ; narr:over <https://aswritten.ai/narrative#StyleObs_7> ] ;
    narr:variation [ narr:text "Conversational skepticism in 'no one's selling that' contrasts with the formal, canonical tone of other stock phrases." ; narr:over <https://aswritten.ai/narrative#StyleObs_NoOnesSellingThat> ] ;
