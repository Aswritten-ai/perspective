    narr:keyPhrase [ narr:text "Launching = moving from being privately terrified about the quality of my product to being publicly terrified" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_LaunchingDefinition> ] ;
    narr:keyPhrase [ narr:text "Your book is a snapshot. We'll turn it into a living AI module. Your expertise becomes installable, citable, and generates revenue through the marketplace." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_PitchVerbatim> ] ;
    narr:keyPhrase [ narr:text "sit the fuck down at the finish line kind of pit" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Tranche1_ProfanityIntensifier> ] ;
    narr:keyPhrase [ narr:text "Humans know secrets. Maybe AIs can be fed secrets, but they don't in general know secrets." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_VerbatimQuote> ] ;
    narr:keyPhrase [ narr:text "The physics never changed. The substrate did" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_6> ] ;
    narr:keyPhrase [ narr:text "table sticks" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObservation_TonyDiction> ] ;
    narr:keyPhrase [ narr:text "Think about the numbers though, right? The numbers really work." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TonyIdiolect_Numbers> ] ;
    narr:variation [ narr:text "Not all idiolect here is Scarlet's — distinct non-founder speakers are captured: a founder beta user (filler/hedging), the customer's chief architect (numbers-first), Tony (volume logic, 'table sticks' malapropism), a beta user from outside tech ('on spec')." ; narr:over <https://aswritten.ai/narrative#StyleObs_LikeFiller> ; narr:over <https://aswritten.ai/narrative#StyleObs_BizarreIndustryIdiom> ; narr:over <https://aswritten.ai/narrative#StyleObs_CustomerArchitectNumbersFirst> ; narr:over <https://aswritten.ai/narrative#StyleObs_TonyIdiolect_Numbers> ; narr:over <https://aswritten.ai/narrative#StyleObservation_TonyDiction> ; narr:over <https://aswritten.ai/narrative#StyleObs_OnSpecJargon> ] ;
    narr:variation [ narr:text "A handful attach via skos:related rather than the dominant skos:broader — looser membership for jargon/idioms not core to a speaker's signature." ; narr:over <https://aswritten.ai/narrative#StyleObs_FeatureNotBug> ; narr:over <https://aswritten.ai/narrative#StyleObs_OnSpecJargon> ; narr:over <https://aswritten.ai/narrative#StyleObs_RahRahIdiolect> ; narr:over <https://aswritten.ai/narrative#StyleObs_RunningAway> ; narr:over <https://aswritten.ai/narrative#StyleObs_OutsideTechBetaUserChannel_LoadBearing> ] ;
    narr:variation [ narr:text "Register splits sharply: raw colloquial/profane emphasis vs. formal conviction-taxonomy vocabulary — same author, opposite tonal poles." ; narr:over <https://aswritten.ai/narrative#StyleObs_ScarletProfanityAsEmphasis> ; narr:over <https://aswritten.ai/narrative#StyleObs_SuperSuper> ; narr:over <https://aswritten.ai/narrative#StyleObs_SettledDecisionMarker> ; narr:over <https://aswritten.ai/narrative#StyleObs_7> ] ;
    narr:variation [ narr:text "Two metaphor families coexist: technical/computational framing (Clojure, zombie var, bootload, navigates-vs-queries) vs. organic/biological framing (natural evolution, feeder)." ; narr:over <https://aswritten.ai/narrative#StyleObs_ClojureIdiolect> ; narr:over <https://aswritten.ai/narrative#StyleObs_ZombieIdiolect> ; narr:over <https://aswritten.ai/narrative#StyleObs_WorldviewFraming> ; narr:over <https://aswritten.ai/narrative#StyleObs_NaturalEvolutionPhrasing> ] ;
    narr:variation [ narr:text "Some entries are meta-rules that enact themselves (methodology phrasing) rather than captured speech, e.g. 'Name patterns without prescribing.'" ; narr:over <https://aswritten.ai/narrative#StyleObs_NamePatternsWithoutPrescribing> ; narr:over <https://aswritten.ai/narrative#StyleObs_OptimizationNotPrereq> ] ;
