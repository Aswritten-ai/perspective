    narr:keyPhrase [ narr:text "it speaks to, references, and works from what was already said" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ConversationalDistinction> ] ;
    narr:keyPhrase [ narr:text "The Twilio rejection context is load-bearing here, not incidental." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_OutsideTechBetaUserChannel_LoadBearing> ] ;
