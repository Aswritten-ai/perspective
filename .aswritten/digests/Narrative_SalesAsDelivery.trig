@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_SalesAsDelivery> {
  <https://aswritten.ai/narrative#Digest_Narrative_SalesAsDelivery> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_SalesAsDelivery> ;
    narr:childCount "10"^^xsd:integer ;
    narr:generatedFrom "22605eca6b922da83f6e388c2d779db8f2c196da" ;
    narr:narration """The core thesis that [sales motion and product delivery are identical](narr:Position_SalesIsDelivery) has evolved from a tactical principle into a codified structural template. This trajectory is anchored by the [Vouch four-step sales motion](narr:Position_VouchEmailMotionTemplate), which formalizes the transition from person-first outreach to the creation of a [durable container](narr:Position_VouchEmailMotionTemplate) for the client relationship. Recent reflections on the [Deli Story](narr:Narrative_DeliStoryReframe) further refine this by shifting the pitch from credentials to recognition, framing the founder’s availability as a byproduct of transparency. Operationalizing this, the [consulting-as-product](narr:Position_ConsultingAdoptionBurdenRemoved) model removes the adoption burden by embedding infrastructure within the delivery itself, supported by [deck operating rules](narr:Position_DeckOperatingRules) that mandate the sales call serve as the demo and onboarding. Earlier milestones, such as [selling the process itself](narr:Position_ProcessSaleNoMaterialNeeded) and [prioritizing revenue over projections](narr:Position_RevenueBeforeRaise), remain foundational to this shift toward 'generosity as demonstration.'""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DeliStoryReframe> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_VouchEmailSalesMotionTemplate> ;
    narr:covers <https://aswritten.ai/narrative#Position_ConsultingAdoptionBurdenRemoved> ;
    narr:covers <https://aswritten.ai/narrative#Position_DeckOperatingRules> ;
    narr:covers <https://aswritten.ai/narrative#Position_DiscoveryToolBatteringRam> ;
    narr:covers <https://aswritten.ai/narrative#Position_ProcessSaleNoMaterialNeeded> ;
    narr:covers <https://aswritten.ai/narrative#Position_RevenueBeforeRaise> ;
    narr:covers <https://aswritten.ai/narrative#Position_SalesIsDelivery> ;
    narr:covers <https://aswritten.ai/narrative#Position_TeamTierSalesCallIsOnboarding> ;
    narr:covers <https://aswritten.ai/narrative#Position_VouchEmailMotionTemplate> ;
    narr:keyPhrase [ narr:text "The sales motion and product delivery are the same thing." ; narr:phraseSource <https://aswritten.ai/narrative#Position_SalesIsDelivery> ] ;
    narr:keyPhrase [ narr:text "The process itself — channel setup, voice mirroring, value verification, MSA rollout — is the sellable unit" ; narr:phraseSource <https://aswritten.ai/narrative#Position_ProcessSaleNoMaterialNeeded> ] ;
    narr:keyPhrase [ narr:text "generosity as demonstration" ; narr:phraseSource <https://aswritten.ai/narrative#Position_VouchEmailMotionTemplate> ] ;
    narr:keyPhrase [ narr:text "The framing 'consulting is me using the product' removes the adoption burden entirely." ; narr:phraseSource <https://aswritten.ai/narrative#Position_ConsultingAdoptionBurdenRemoved> ] ;
    narr:keyPhrase [ narr:text "No case-study slides — the close is the case study, performed on the prospect" ; narr:phraseSource <https://aswritten.ai/narrative#Position_DeckOperatingRules> ] ;
    narr:variation [ narr:text "Discovery as a loss-leader 'battering ram' for relationship value vs. direct revenue." ; narr:over <https://aswritten.ai/narrative#Position_DiscoveryToolBatteringRam> ] ;
    narr:variation [ narr:text "Tension between selling the process as a product vs. the Deli story's focus on personal recognition." ; narr:over <https://aswritten.ai/narrative#Position_ProcessSaleNoMaterialNeeded> ; narr:over <https://aswritten.ai/narrative#Narrative_DeliStoryReframe> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}