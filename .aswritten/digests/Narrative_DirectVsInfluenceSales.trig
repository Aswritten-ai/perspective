@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_DirectVsInfluenceSales> {
  <https://aswritten.ai/narrative#Digest_Narrative_DirectVsInfluenceSales> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_DirectVsInfluenceSales> ;
    narr:childCount "6"^^xsd:integer ;
    narr:generatedFrom "1f35cd786119273b1788d9da03ba92493bd6d9a2" ;
    narr:narration """The sales strategy for demo-call prospects remains anchored in a two-step ladder, moving from a [Publisher tier](narr:Position_DemoProspectStep1PublisherTier) focused on individual experts to an [Organization tier](narr:Position_DemoProspectStep2OrgTier) that introduces compliance and on-premise requirements. Enablement efforts have coalesced around providing the prospect with a repeatable process rather than just a deal structure. This includes the development of a [play-by-play playbook](narr:Position_SalesPlaybookForDemoProspect) featuring visual demonstrations of the knowledge extraction workflow, alongside a [pre-read deck](narr:Position_PreReadDeckRequest) designed to streamline initial meetings. To improve the user experience, there is a push for [tighter onboarding](narr:Position_TighterOnboarding) that clarifies the distinction between static documentation and AI-driven features. Additionally, the prospect has requested a [written sales guide](narr:Position_SalesGuideRequest) to support their own internal sales conversations, ensuring they can effectively communicate the value of the module repository.""" ;
    narr:covers <https://aswritten.ai/narrative#Position_DemoProspectStep1PublisherTier> ;
    narr:covers <https://aswritten.ai/narrative#Position_DemoProspectStep2OrgTier> ;
    narr:covers <https://aswritten.ai/narrative#Position_PreReadDeckRequest> ;
    narr:covers <https://aswritten.ai/narrative#Position_SalesGuideRequest> ;
    narr:covers <https://aswritten.ai/narrative#Position_SalesPlaybookForDemoProspect> ;
    narr:covers <https://aswritten.ai/narrative#Position_TighterOnboarding> ;
    narr:keyPhrase [ narr:text "Your expertise becomes installable, citable, and generates revenue through the marketplace." ; narr:phraseSource <https://aswritten.ai/narrative#Position_DemoProspectStep1PublisherTier> ] ;
    narr:keyPhrase [ narr:text "The compliance, on-prem, and data sovereignty hooks all apply at this tier." ; narr:phraseSource <https://aswritten.ai/narrative#Position_DemoProspectStep2OrgTier> ] ;
    narr:keyPhrase [ narr:text "A sales playbook for a demo-call prospect is the critical sales enablement piece this week." ; narr:phraseSource <https://aswritten.ai/narrative#Position_SalesPlaybookForDemoProspect> ] ;
    narr:keyPhrase [ narr:text "New users should not have to figure out which parts are documentation and which are AI-driven." ; narr:phraseSource <https://aswritten.ai/narrative#Position_TighterOnboarding> ] ;
    narr:variation [ narr:text "Tension exists between the desire for a simple, approachable 'Publisher' entry point and the complex, compliance-heavy requirements of the 'Organization' tier." ; narr:over <https://aswritten.ai/narrative#Position_DemoProspectStep1PublisherTier> ; narr:over <https://aswritten.ai/narrative#Position_DemoProspectStep2OrgTier> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}