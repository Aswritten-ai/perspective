    narr:keyPhrase [ narr:text "Snappy, snappy" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Cadence_1> ] ;
    narr:keyPhrase [ narr:text "The physics never changed. The substrate did" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:keyPhrase [ narr:text "Calibration is staff-work, not friendship" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_EngagementShape_ShortPunchy> ] ;
    narr:keyPhrase [ narr:text "A repo IS a module — no new abstraction needed." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_MVPRedef_ShortPunchy> ] ;
    narr:keyPhrase [ narr:text "It's about people now." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ItsPeopleNow> ] ;
    narr:keyPhrase [ narr:text "Summarization compresses the reading; it must never compress the receipts." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TranscriptOnramp_ShortPunchy> ] ;
    narr:variation [ narr:text "While most entries treat brevity as a design choice, some use it as a defensive mechanism to avoid hedging or to enforce procedural rules." ; narr:over <https://aswritten.ai/narrative#StyleObs_ShortPunchyDeclaratives> ; narr:over <https://aswritten.ai/narrative#StyleObs_ShortPunchy_DesignSession> ] ;
    narr:variation [ narr:text "The cadence is occasionally used to create a 'dialogue-within-document' effect, contrasting analytical prose with embedded first-person speech." ; narr:over <https://aswritten.ai/narrative#StyleObs_1> ; narr:over <https://aswritten.ai/narrative#StyleObs_4> ] ;
    narr:variation [ narr:text "Some instances prioritize visual rhythm via arrow notation rather than sentence structure alone." ; narr:over <https://aswritten.ai/narrative#StyleObs_ArrowCadence> ; narr:over <https://aswritten.ai/narrative#StyleObs_ArrowChainFlow> ] ;
