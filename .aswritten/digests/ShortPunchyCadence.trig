    narr:covers <https://aswritten.ai/narrative#StyleObs_UntilSomeoneBuys> ;
    narr:covers <https://aswritten.ai/narrative#StyleObservation_Cadence_1> ;
    narr:covers <https://aswritten.ai/narrative#StyleObservation_OneLinerRhetoric> ;
    narr:keyPhrase [ narr:text "Snappy, snappy" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Cadence_1> ] ;
    narr:keyPhrase [ narr:text "Keeping beats starting." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ConsultingFramingShortPunchy> ] ;
    narr:keyPhrase [ narr:text "It's falsifiable. The agent can either open the car or it can't. It's very Boolean." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DiscoveryConsultantBooleanCadence> ] ;
    narr:keyPhrase [ narr:text "Yeah, yeah, 100, 100% without actually having to show them anything." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_SellTheProcessCadence> ] ;
    narr:keyPhrase [ narr:text "Exportable data is not the same as ownership. The right to be forgotten is not the same thing as freedom." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_SII_EmDashBlade> ] ;
    narr:keyPhrase [ narr:text "You've published one module. Now imagine every role in your organization has one." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TwoStepCadence> ] ;
    narr:keyPhrase [ narr:text "Transform is for **permanent forks**. Actor/role/focus lenses are for **ephemeral views on the living graph**." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ShortPunchyDeclaratives> ] ;
    narr:keyPhrase [ narr:text "Show, don't send: call two is scheduled in the room." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ShowDontSendCadence> ] ;
    narr:keyPhrase [ narr:text "It looks real is the trick." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ShortPunchyCadence> ] ;
    narr:keyPhrase [ narr:text "Summarization compresses the reading; it must never compress the receipts." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TranscriptOnramp_ShortPunchy> ] ;
    narr:keyPhrase [ narr:text "A repo IS a module — no new abstraction needed." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_MVPRedef_ShortPunchy> ] ;
    narr:keyPhrase [ narr:text "It's about people now." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ItsPeopleNow> ] ;
    narr:variation [ narr:text "Tony's filler-affirmation bursts ('Right. Right.', 'Yeah, yeah, 100, 100%') are staccato punctuation from spoken register, structurally distinct from Scarlet's crafted aphoristic closers — same surface brevity, different generative mechanism" ; narr:over <https://aswritten.ai/narrative#StyleObs_SellTheProcessCadence> ; narr:over <https://aswritten.ai/narrative#StyleObs_ConsultingFramingShortPunchy> ] ;
    narr:variation [ narr:text "The consultant's Boolean cadence ends on a single technical verdict word ('Boolean'), contrasting with Scarlet's emotional-truth closers ('It's about people now.') — brevity serving precision vs. brevity serving feeling" ; narr:over <https://aswritten.ai/narrative#StyleObs_DiscoveryConsultantBooleanCadence> ; narr:over <https://aswritten.ai/narrative#StyleObs_ItsPeopleNow> ] ;
    narr:variation [ narr:text "Some children document the short-punchy as a design rule enforcer ('No shifts yet.' 'Not three at once.') — procedural/imperative register rather than conviction-peak rhetoric" ; narr:over <https://aswritten.ai/narrative#StyleObs_ShortPunchyDeclaratives> ] ;
    narr:variation [ narr:text "Arrow-chain and numbered-flow children compress process sequences rather than landing emotional verdicts — the same brevity impulse applied to procedural rather than rhetorical ends" ; narr:over <https://aswritten.ai/narrative#StyleObs_ArrowChainFlow> ; narr:over <https://aswritten.ai/narrative#StyleObs_ArrowCadence> ; narr:over <https://aswritten.ai/narrative#StyleObs_NumberedFlow> ] ;
    narr:variation [ narr:text "The two-beat tagline ('Expertise from humans you trust. Cited by AI, aswritten.') encodes product value sequence in its rhythm — cadence as product argument, not just style" ; narr:over <https://aswritten.ai/narrative#StyleObs_TwoBeatTaglineStructure> ] ;
    narr:variation [ narr:text "Several children are nearly content-free (single-line labels, no quotes, no dates) — the pattern is asserted but not witnessed, creating uneven evidential weight across the hub" ; narr:over <https://aswritten.ai/narrative#StyleObs_KeyReframeTagline> ; narr:over <https://aswritten.ai/narrative#StyleObs_ProductIsPhoneNumber> ; narr:over <https://aswritten.ai/narrative#StyleObs_ShortPunchyClose> ; narr:over <https://aswritten.ai/narrative#StyleObs_DistortionIsInstrument> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
