    narr:keyPhrase [ narr:text "Snappy, snappy" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Cadence_1> ] ;
    narr:keyPhrase [ narr:text "Em-dash used to deliver a short punchy verdict after a longer setup clause — a consistent cadence device throughout." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_4> ] ;
    narr:keyPhrase [ narr:text "Keeping beats starting." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ConsultingFramingShortPunchy> ] ;
    narr:keyPhrase [ narr:text "The split belongs at the session boundary, not the turn." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DevModelRouting_Antithesis> ] ;
    narr:keyPhrase [ narr:text "It's falsifiable. The agent can either open the car or it can't. It's very Boolean." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DiscoveryConsultantBooleanCadence> ] ;
    narr:keyPhrase [ narr:text "Calibration is staff-work, not friendship" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_EngagementShape_ShortPunchy> ] ;
    narr:keyPhrase [ narr:text "Short. Not a wall of text." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ShortPunchy_DesignSession> ] ;
    narr:keyPhrase [ narr:text "the sales call IS real work — it produces the first memory, seeds the worldview, and demonstrates value" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_SalesCallIsOnboardingCadence> ] ;
    narr:variation [ narr:text "Several children document extended, non-punchy devices — sustained optometrist metaphor, block-quoted founder voice, ten-item numbered checklists — that frame or contrast the short-punchy pattern rather than instantiate it, sitting uneasily under a hub named for compression." ; narr:over <https://aswritten.ai/narrative#StyleObs_1> ; narr:over <https://aswritten.ai/narrative#StyleObs_NumberedChecklistCadence> ; narr:over <https://aswritten.ai/narrative#StyleObs_4> ] ;
    narr:variation [ narr:text "a consultant who ran enterprise discovery engagements for fifteen years's Boolean verdict cadence is documented as a distinct engineering-precision idiolect, not Scarlet's — raising the question of whether the hub describes one author's style or a cross-speaker pattern." ; narr:over <https://aswritten.ai/narrative#StyleObs_DiscoveryConsultantBooleanCadence> ; narr:over <https://aswritten.ai/narrative#StyleObs_SellTheProcessCadence> ] ;
    narr:variation [ narr:text "Short-punchy appears both as an editing directive ('snappy, snappy', 'super snappy') and as an observed emergent pattern — two different functional claims about whether the cadence is prescribed or descriptive." ; narr:over <https://aswritten.ai/narrative#StyleObs_SnappySnappy> ; narr:over <https://aswritten.ai/narrative#StyleObs_ShortPunchy_1> ; narr:over <https://aswritten.ai/narrative#StyleObs_ShortPunchyCadence> ] ;
    narr:variation [ narr:text "The em-dash blade device (long setup → short aphoristic close) is documented as its own cadence sub-pattern with a 'scanner/manifesto register' label, potentially a distinct style mode from the pure staccato fragment." ; narr:over <https://aswritten.ai/narrative#StyleObs_SII_EmDashBlade> ; narr:over <https://aswritten.ai/narrative#StyleObs_EmDashCadence> ] ;
