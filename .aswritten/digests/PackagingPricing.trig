    narr:keyPhrase [ narr:text "[amount]a month isn't like real money" ; narr:phraseSource <https://aswritten.ai/narrative#Claim_400PerMonthNotRealMoney> ] ;
    narr:keyPhrase [ narr:text "that all tracks for me." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_PricingTierValidatedByTony> ] ;
    narr:keyPhrase [ narr:text "Org base locked at [amount]/mo (the enterprise customer floor preserved)." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_OrgBaseLocked4K> ] ;
    narr:keyPhrase [ narr:text "Think about when it switches from team to enterprise. I think that happens reasonably quickly." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_CustomerCTOScalingPricing> ] ;
    narr:keyPhrase [ narr:text "2-10x cheaper than comparable Tier B assembly" ; narr:phraseSource <https://aswritten.ai/narrative#Claim_AswrittenCheaperThanTierB> ] ;
    narr:keyPhrase [ narr:text "Instead of taking a cut of practitioner fee, it could be outcome based. I.e., every perspective carries a goal which is a forward to a link. Essentially a click like ads." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CPCPricingQuote> ] ;
    narr:variation [ narr:text "A whole alternative pricing philosophy: CPC-on-goal-URL (outcome-based, ad-like clicks) for external funnels vs. subscription for internal — not just different numbers but a different revenue logic." ; narr:over <https://aswritten.ai/narrative#Narrative_CPCOnGoalURL> ; narr:over <https://aswritten.ai/narrative#Obs_CPCPricingQuote> ] ;
    narr:variation [ narr:text "the customer's chief architect's chatbot calibration ([amount]-[amount] for 20-30 users) implies a tier that would fill the very 10x Team→Enterprise gap the model insists is an intentional 'clean break.'" ; narr:over <https://aswritten.ai/narrative#Narrative_ChatbotTierPricingSignal> ; narr:over <https://aswritten.ai/narrative#Obs_CustomerArchitectChatbotPricingQuote> ; narr:over <https://aswritten.ai/narrative#Claim_TeamVsEnterpriseTierCleanBreak> ] ;
    narr:variation [ narr:text "Tier naming never settled: Individual/Publisher → Expert/Team renames decided March 23 but still not propagated in code, with conflicting labels across strategy docs." ; narr:over <https://aswritten.ai/narrative#Claim_TierRenameDecided> ; narr:over <https://aswritten.ai/narrative#Claim_TierStructureNamed> ; narr:over <https://aswritten.ai/narrative#Narrative_TierRenameExpertTeam> ] ;
    narr:variation [ narr:text "Conversion-service revenue is unresolved: 'we do it' (upfront fee + marketplace %) vs 'they do it' (marketplace % only) — both called viable, neither chosen." ; narr:over <https://aswritten.ai/narrative#Claim_WeDoItConversionModel> ; narr:over <https://aswritten.ai/narrative#Claim_TheyDoItConversionModel> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletRevenueModelQuote> ] ;
    narr:variation [ narr:text "a beta user from outside tech sits on Individual tier by relationship (fiancé/beta tester), not sales logic — an outlier that neither validates nor invalidates the pricing it appears to instantiate." ; narr:over <https://aswritten.ai/narrative#Claim_OutsideTechBetaUserCommercialStatusRelational> ] ;
    narr:variation [ narr:text "Setup/pilot pricing has its own churn: [amount] SOW vs earlier [amount]/[amount] pilot splits vs [amount] EDO single-tenant setup (bumped from [amount])." ; narr:over <https://aswritten.ai/narrative#Narrative_PricingModel> ; narr:over <https://aswritten.ai/narrative#Claim_EDO_SingleTenantManaged> ] ;
    narr:variation [ narr:text "MSA timing tension: clean-break tiering attaches MSA at the Enterprise boundary, while Tony's unlock runs MSA/procurement in parallel with the POC, not after." ; narr:over <https://aswritten.ai/narrative#Claim_TeamVsEnterpriseTierCleanBreak> ; narr:over <https://aswritten.ai/narrative#Claim_POCMSAParallelNotSequential> ] ;
    narr:writer "claude (subscription)" .
