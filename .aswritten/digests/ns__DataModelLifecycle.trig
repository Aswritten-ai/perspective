@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__DataModelLifecycle> {
  <https://aswritten.ai/narrative#Digest_ns__DataModelLifecycle> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#DataModelLifecycle> ;
    narr:childCount "5"^^xsd:integer ;
    narr:generatedFrom "dd48bdf1de48c78368f05335ee493b479b7deba1" ;
    narr:narration """This hub tracks the architectural evolution of a Git-based data-model lifecycle, where the repository serves as the primary source of truth for all content prior to extraction. The system relies on an [append-only transaction log](narr:https://aswritten.ai/ns/narrative#Narrative_SIC_DataModelLifecycle_1) stored in `.aswritten` directories, enabling hierarchical compilation across ancestor nodes. This engineering framework is deeply coupled with a [Git-centric architecture](narr:https://aswritten.ai/ns/narrative#Narrative_RepoAsSourceOfTruth) that leverages GitHub Actions for asynchronous processing. Social organization is explicitly mapped onto this structure, with [Discourse categories and threads mirrored as filesystem folders](narr:https://aswritten.ai/ns/narrative#Obs_CategoryMapping). Beyond the mechanical implementation, the design is guided by a generative philosophy: [worldview acts as the source of truth](narr:https://aswritten.ai/ns/narrative#Narrative_CompilationTargets), rendering all other outputs—code, apps, and content—as functional transformations. This is complemented by a conceptual framing of [AI identity as a resonant body](narr:https://aswritten.ai/ns/narrative#Concept_AIIdentity), suggesting that these data structures are not merely storage, but embodiments of collective meaning.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Concept_AIIdentity> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_CompilationTargets> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_RepoAsSourceOfTruth> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_SIC_DataModelLifecycle_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#Obs_CategoryMapping> ;
    narr:keyPhrase [ narr:text "Append-only transaction log in .aswritten directories." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_SIC_DataModelLifecycle_1> ] ;
    narr:keyPhrase [ narr:text "Each Discourse category = folder in repo" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Obs_CategoryMapping> ] ;
    narr:keyPhrase [ narr:text "Everything becomes a compiled target; worldview is source of truth" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_CompilationTargets> ] ;
    narr:variation [ narr:text "The tension between rigid filesystem-based social mapping and the abstract, philosophical goal of AI as a resonant body." ; narr:over <https://aswritten.ai/ns/narrative#Obs_CategoryMapping> ; narr:over <https://aswritten.ai/ns/narrative#Concept_AIIdentity> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}