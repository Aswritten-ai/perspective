@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__Parallelism> {
  <https://aswritten.ai/narrative#Digest_ns__Parallelism> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#Parallelism> ;
    narr:childCount "5"^^xsd:integer ;
    narr:generatedFrom "341fca0fdc2855d1dfd25acec4a0b5d5fa9fc26f" ;
    narr:narration """This hub tracks the deployment of [parallelism as a rhetorical and structural device](narr:StyleObs_8) within AI-native strategic documentation. The strategy relies on [rhythmic triadic structures](narr:Observation_GitNativeTriad) to define core product attributes, often utilizing consistent suffixes to anchor technical concepts. [Anaphoric repetition](narr:Observation_CompiledTarget) is employed to emphasize the shift from static content to dynamic, machine-queryable targets. The documentation further utilizes [antithetical clause pairs](narr:StyleObs_8) and [explicit past-vs-future framing](narr:StyleObs_9) to contrast legacy paradigms with the proposed AI-native worldview. Beyond stylistic rhythm, parallelism serves as a functional scaffold for [decision-making logs](narr:StyleObs_Parallelism_Alternatives), where a rigid, repeated syntax is used to categorize rejected strategic alternatives. The span encompasses both the aesthetic cadence of the prose and the systematic, templated structure of the document's logic.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Observation_CompiledTarget> ;
    narr:covers <https://aswritten.ai/ns/narrative#Observation_GitNativeTriad> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_8> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_9> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_Parallelism_Alternatives> ;
    narr:keyPhrase [ narr:text "git native, i.e. versionable, branchable, reviewable" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_GitNativeTriad> ] ;
    narr:keyPhrase [ narr:text "content is a compiled target. The application is a compiled target" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_CompiledTarget> ] ;
    narr:keyPhrase [ narr:text "Documentation describes; worldview generates. Documentation goes stale; worldview evolves" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_8> ] ;
    narr:keyPhrase [ narr:text "The past 20-25 years optimized for human-readable documentation; AI-native paradigm optimizes for machine-queryable worldview" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_9> ] ;
    narr:keyPhrase [ narr:text "Alternatives Considered:\n\nSingle use case focus (e.g., just coding agents) - Rejected\nEnterprise-first (sell to Capitol-like companies) - Rejected\nHorizontal \"AI memory platform\" (any use case) - Rejected" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_Parallelism_Alternatives> ] ;
    narr:variation [ narr:text "Parallelism as a tool for negation and boundary-setting rather than positive assertion." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_Parallelism_Alternatives> ] ;
    narr:variation [ narr:text "Tension between rhythmic, aesthetic parallelism and purely functional, list-based structural parallelism." ; narr:over <https://aswritten.ai/ns/narrative#Observation_GitNativeTriad> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_Parallelism_Alternatives> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}