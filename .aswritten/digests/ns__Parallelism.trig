@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__Parallelism> {
  <https://aswritten.ai/narrative#Digest_ns__Parallelism> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#Parallelism> ;
    narr:childCount "8"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """This hub gathers observations of [parallelism as a recurring stylistic device](narr:StyleObs_8) across an AI-native strategy/pitch document. Several distinct forms appear. **Triadic rhythm** drives the [git-native triad](narr:Observation_GitNativeTriad) (\"versionable, branchable, reviewable\", parallel -able suffix). **Anaphora** repeats a [compiled-target frame](narr:Observation_CompiledTarget). **Antithesis** pairs old vs. new paradigms in [contrastive clause pairs](narr:StyleObs_8) and an explicit [past-vs-future framing](narr:StyleObs_9). **Accumulation** extends the triad into longer enumerations — a [five-clause value prop and five-item pillar list](narr:StyleObs_6). **Templated parallelism** structures comparison: a [four-part role framework repeated across 7 roles](narr:StyleObs_FrameworkStructure) and [before/after pairs repeated 3x](narr:StyleObs_parallel_1). One child applies parallel syntax to [reject alternatives](narr:StyleObs_Parallelism_Alternatives) (\"[Option] - Rejected: [Reason]\"). Register notes recur: lowercase product name, second-person address, imperative mood. The span covers rhetorical function (contrast, rhythm, enumeration) and structural scaffolding (frameworks, list parallelism).""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Observation_CompiledTarget> ;
    narr:covers <https://aswritten.ai/ns/narrative#Observation_GitNativeTriad> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_6> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_8> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_9> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_FrameworkStructure> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_Parallelism_Alternatives> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_parallel_1> ;
    narr:keyPhrase [ narr:text "git native, i.e. versionable, branchable, reviewable" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_GitNativeTriad> ] ;
    narr:keyPhrase [ narr:text "content is a compiled target. The application is a compiled target" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_CompiledTarget> ] ;
    narr:keyPhrase [ narr:text "Documentation describes; worldview generates. Documentation goes stale; worldview evolves" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_8> ] ;
    narr:keyPhrase [ narr:text "The past 20-25 years optimized for human-readable documentation; AI-native paradigm optimizes for machine-queryable worldview" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_9> ] ;
    narr:keyPhrase [ narr:text "positioning, offering, product, teams, and process" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_6> ] ;
    narr:variation [ narr:text "Tight triadic 'rule of three' (parallel -able suffix) vs. accumulation that extends to five items 'for completeness' — rhythm vs. exhaustiveness." ; narr:over <https://aswritten.ai/ns/narrative#Observation_GitNativeTriad> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_6> ] ;
    narr:variation [ narr:text "Parallelism for contrast/antithesis (old vs. new paradigm) vs. parallelism for flat enumeration/listing — opposing rhetorical purposes sharing one form." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_8> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_9> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_FrameworkStructure> ] ;
    narr:variation [ narr:text "Anaphora (verbatim repetition of a phrase) is a structurally distinct device from the suffix/clause parallelism dominating the other children." ; narr:over <https://aswritten.ai/ns/narrative#Observation_CompiledTarget> ] ;
    narr:variation [ narr:text "Outlier use: parallel syntax deployed to reject options ('[Option] - Rejected') rather than to assert or enumerate value." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_Parallelism_Alternatives> ] ;
    narr:variation [ narr:text "Templated/scaffolding parallelism repeated across many units (4-part x 7 roles; before/after x3) vs. one-off in-sentence parallelism." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_FrameworkStructure> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_parallel_1> ] ;
    narr:writer "claude (subscription)" .
}