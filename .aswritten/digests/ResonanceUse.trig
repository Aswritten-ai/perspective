@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ResonanceUse> {
  <https://aswritten.ai/narrative#Digest_ResonanceUse> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#ResonanceUse> ;
    narr:childCount "8"^^xsd:integer ;
    narr:generatedFrom "737314f6fd80008449dd6f6a60df5649df23660f" ;
    narr:narration """This hub tracks the mechanics of resonant framing, focusing on how dense, complex information is structured to land with specific audiences. The core structural thesis remains [density inversion at scale](narr:Narrative_DensityInversionAtScale), which treats communication density as a strategic asset rather than a liability. Surrounding this are various metaphors used to ground abstract system behaviors in familiar, high-stakes, or human-centric domains. These include diagnostic analogies like the [eye-chart micro-telltales](narr:StyleObs_BetterAorB) and the [phoropter eye exam](narr:StyleObs_Optometrist), which frame validation as an iterative, granular process. Other metaphors serve to elevate the system's status or explain its opacity, such as the [gods of Olympus](narr:StyleObs_GodsMetaphor) for organizational power dynamics, [gold mines for AI](narr:StyleObs_GoldMineMetaphor) for value extraction, [religion-as-living-system](narr:StyleObs_ReligionAnalogy) for system adoption, and [brain personification](narr:StyleObs_BrainPersonification) for cognitive partnership. Finally, the [consultant interview](narr:StyleObs_ConsultantInterviewAnalogy) analogy grounds the expert-system interaction in a validated, service-oriented model.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DensityInversionAtScale> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_BetterAorB> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_BrainPersonification> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ConsultantInterviewAnalogy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_GodsMetaphor> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_GoldMineMetaphor> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Optometrist> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ReligionAnalogy> ;
    narr:keyPhrase [ narr:text "micro-telltales at decreasing granularity" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_BetterAorB> ] ;
    narr:keyPhrase [ narr:text "Review is iterative and convergent, like an eye exam with a phoropter." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Optometrist> ] ;
    narr:keyPhrase [ narr:text "It's almost like the gods of Olympus. If Zeus decides to strike you with lightning, one, there's nothing you can do about it." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_GodsMetaphor> ] ;
    narr:variation [ narr:text "The diagnostic metaphors (eye-chart, phoropter) emphasize precision and iterative refinement, contrasting with the more abstract, power-oriented metaphors (gods, gold mines)." ; narr:over <https://aswritten.ai/narrative#StyleObs_BetterAorB> ; narr:over <https://aswritten.ai/narrative#StyleObs_Optometrist> ; narr:over <https://aswritten.ai/narrative#StyleObs_GodsMetaphor> ; narr:over <https://aswritten.ai/narrative#StyleObs_GoldMineMetaphor> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}