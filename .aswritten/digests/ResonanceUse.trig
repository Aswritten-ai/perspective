    narr:covers <https://aswritten.ai/narrative#StyleObs_GodsMetaphor> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_GoldMineMetaphor> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Optometrist> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ReligionAnalogy> ;
