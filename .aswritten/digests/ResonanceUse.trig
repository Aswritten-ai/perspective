    narr:keyPhrase [ narr:text "The system needs an equivalent to the eye chart with progressively smaller lines — micro-telltales at decreasing granularity" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_BetterAorB> ] ;
    narr:keyPhrase [ narr:text "It's almost like the gods of Olympus. If Zeus decides to strike you with lightning, one, there's nothing you can do about it." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_GodsMetaphor> ] ;
    narr:keyPhrase [ narr:text "Review is iterative and convergent, like an eye exam with a phoropter." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Optometrist> ] ;
    narr:keyPhrase [ narr:text "I would like to improve the mess." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_VerbatimQuoteIntegration> ] ;
    narr:keyPhrase [ narr:text "updates and abstracting information from the current memory across the existing snapshot is really important and hard" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_VerbatimQuoteIntegration> ] ;
    narr:variation [ narr:text "Structural outlier: an emotional-vulnerability observation (mutual crying) sits among otherwise rhetorical-device children — not a framing technique at all." ; narr:over <https://aswritten.ai/narrative#Obs_ArmorComingOff> ] ;
    narr:variation [ narr:text "Opposing metaphor valences: positive reframing (gift, gold mine) vs. destruction/opacity/urgency (burning away, Zeus's lightning) — resonance cuts both directions." ; narr:over <https://aswritten.ai/narrative#StyleObs_GiftMetaphor> ; narr:over <https://aswritten.ai/narrative#StyleObs_GoldMineMetaphor> ; narr:over <https://aswritten.ai/narrative#StyleObs_BurningAwayMetaphor> ; narr:over <https://aswritten.ai/narrative#StyleObs_GodsMetaphor> ] ;
    narr:variation [ narr:text "Two attachment registers: broader = load-bearing structural theses (density inversion, quote integration); related = ornamental/illustrative metaphors — different epistemic weight under one hub." ; narr:over <https://aswritten.ai/narrative#Narrative_DensityInversionAtScale> ; narr:over <https://aswritten.ai/narrative#StyleObs_VerbatimQuoteIntegration> ; narr:over <https://aswritten.ai/narrative#StyleObs_ReligionAnalogy> ] ;
    narr:variation [ narr:text "Only the quote-integration child carries dates (Mar→Jun 2026); the metaphor observations are undated, so any trajectory claim rests on a single child." ; narr:over <https://aswritten.ai/narrative#StyleObs_VerbatimQuoteIntegration> ] ;
