@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_TechnicalExplainers> {
  <https://aswritten.ai/narrative#Digest_TechnicalExplainers> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#TechnicalExplainers> ;
    narr:childCount "13"^^xsd:integer ;
    narr:generatedFrom "ecbd7fe738df40b78c102413671b62960cca0696" ;
    narr:narration """Technical explainers here trace the evolution of aswritten's architecture, moving from foundational representation choices to the mechanics of agent-graph interaction. Early constraints regarding [TriG-over-JSON efficiency](narr:Position_TriGOverJSON) and [schema-as-prompt](narr:Position_MCP_SchemaAsPrompt) have matured into a focus on navigation and state management. The [update problem](narr:Narrative_UpdateProblem_Evolution) remains the central challenge, with recent work shifting toward [stateless deduplicating cursors](narr:Narrative_StatelessDedupCursor) to mitigate [attention dilution](narr:Obs_ScarletNavigationScalingQuote) at scale. This design, which relies on [carrying the manifest forward](narr:Obs_StatelessDedupDesign) rather than session state, aligns with a broader [HATEOAS-style navigation](narr:Obs_DiscoveryConsultantHATEOASQuote) philosophy. Parallel research into [agent memory architectures](narr:Narrative_AgentMemoryArchitectureParallel) provides a framework for these developments, though the team explicitly notes [what does not transfer](narr:Narrative_AgentSimResearchWhatDoesntTransfer) from academic simulations. Ongoing tension exists in reconciling [decay and depreciation](narr:Narrative_DecayVsDepreciationDistinction) as distinct yet overlapping operations, while the [absence of vector search](narr:Position_VectorSearchNotUsedInPapers) in surveyed literature continues to signal a preference for procedural over retrieval-based mechanisms.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_AgentMemoryArchitectureParallel> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_AgentSimResearchWhatDoesntTransfer> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DecayVsDepreciationDistinction> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_StatelessDedupCursor> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_UpdateProblem_Evolution> ;
    narr:covers <https://aswritten.ai/narrative#Obs_DiscoveryConsultantHATEOASQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletNavigationScalingQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_StatelessDedupDesign> ;
    narr:covers <https://aswritten.ai/narrative#Position_MCP_SchemaAsPrompt> ;
    narr:covers <https://aswritten.ai/narrative#Position_ReflectionLoopAsAbstractionMechanism> ;
    narr:covers <https://aswritten.ai/narrative#Position_TriGOverJSON> ;
    narr:covers <https://aswritten.ai/narrative#Position_VectorSearchNotUsedInPapers> ;
    narr:covers <https://aswritten.ai/narrative#SolutionArchetype_CodeQualityThroughContext> ;
    narr:keyPhrase [ narr:text "expand(want, have) returns want \\ have, and every response hands back a served manifest the agent forwards verbatim on the next call" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_StatelessDedupDesign> ] ;
    narr:keyPhrase [ narr:text "as graphs get into the 400,000–500,000 token range... you start to get attention dilution where LLMs just stop looking." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletNavigationScalingQuote> ] ;
    narr:keyPhrase [ narr:text "the primary way of navigating any information base... is through discovery and navigation, going link by link... It's like surfing the web in the 90s." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_DiscoveryConsultantHATEOASQuote> ] ;
    narr:keyPhrase [ narr:text "None of the five agent-simulation papers surveyed used vector search in its classic form" ; narr:phraseSource <https://aswritten.ai/narrative#Position_VectorSearchNotUsedInPapers> ] ;
    narr:keyPhrase [ narr:text "JSON was 1.94x the token cost with no information gain." ; narr:phraseSource <https://aswritten.ai/narrative#Position_TriGOverJSON> ] ;
    narr:variation [ narr:text "Procedural reflection vs. structural ontology: tension between academic memory models and aswritten's roadmap." ; narr:over <https://aswritten.ai/narrative#Narrative_AgentMemoryArchitectureParallel> ; narr:over <https://aswritten.ai/narrative#Position_ReflectionLoopAsAbstractionMechanism> ] ;
    narr:variation [ narr:text "Decay (temporal) vs. Depreciation (semantic): unresolved whether these require one workflow or two." ; narr:over <https://aswritten.ai/narrative#Narrative_DecayVsDepreciationDistinction> ] ;
    narr:variation [ narr:text "Stateless purity vs. stateful session tracking: the design choice to prioritize ZDR-pure read paths." ; narr:over <https://aswritten.ai/narrative#Narrative_StatelessDedupCursor> ; narr:over <https://aswritten.ai/narrative#Obs_StatelessDedupDesign> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}