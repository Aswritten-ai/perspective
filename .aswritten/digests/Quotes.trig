    narr:keyPhrase [ narr:text "this is definitely base camp, not camp 4 for whatever it is" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_BaseCampQuote> ] ;
    narr:keyPhrase [ narr:text "Information is a commodity. Code is free. But the power of perspective and collaboration — that's always where the value was." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerCTOInformationCommodity> ] ;
    narr:keyPhrase [ narr:text "we should treat that like code. We should treat that like a pull request with unit tests." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerCTOPRMetaphorQuote> ] ;
    narr:keyPhrase [ narr:text "What you can't automate is what the customer's chief architect's talking about, which is reviewing the memory that comes out for one factual consistency." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletCantAutomateQuote> ] ;
    narr:keyPhrase [ narr:text "This is incredible. I literally could not have written this better myself — and that's the product working!" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletIncredibleQuote> ] ;
    narr:keyPhrase [ narr:text "Ultimately, we want to get from pilot to Enterprise, but I want to have kind of this proof point." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DirectQuoteStyle> ] ;
    narr:variation [ narr:text "Tension between SMS as a trust-signal vs. an operational fraud/spam liability." ; narr:over <https://aswritten.ai/narrative#Obs_OutsideTechBetaUserSpamPushback> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletSMSFraudCost> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletPhoneNumberFeels> ] ;
    narr:variation [ narr:text "Disagreement on whether the architecture is a 1:1 map or a non-linear web." ; narr:over <https://aswritten.ai/narrative#Obs_ScarletWebNotMappingQuote> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletMetaLayerQuote> ] ;
    narr:variation [ narr:text "Divergence in how to handle deduplication and reductionism in citations." ; narr:over <https://aswritten.ai/narrative#Obs_ScarletQuote_Reductionist> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletQuote_SameClaim> ] ;
