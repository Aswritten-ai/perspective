    narr:keyPhrase [ narr:text "this is definitely base camp, not camp 4 for whatever it is" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_BaseCampQuote> ] ;
    narr:keyPhrase [ narr:text "Information is a commodity. Code is free. But the power of perspective and collaboration — that's always where the value was." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerCTOInformationCommodity> ] ;
    narr:keyPhrase [ narr:text "People who don't have a well grounded perspective on their own... the tools are just going to create AI slop. I'm just making it easier for someone to do a shitty job." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerCTOAISlopQuote> ] ;
    narr:keyPhrase [ narr:text "we should treat that like code. We should treat that like a pull request with unit tests. It actually creates this because it's, it's, it's better for us to be a little slow" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerCTOPRMetaphorQuote> ] ;
    narr:keyPhrase [ narr:text "I'm just not super comfortable saying we should just dump every transcript unreviewed straight into the perspective." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerArchitectNotComfortableQuote> ] ;
    narr:keyPhrase [ narr:text "What you can't automate is what the customer's chief architect's talking about, which is reviewing the memory that comes out for one factual consistency. And for me, more importantly, for narrative and perceptual alignment. And that's a human process." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletCantAutomateQuote> ] ;
    narr:keyPhrase [ narr:text "This is incredible. I literally could not have written this better myself — and that's the product working!" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletIncredibleQuote> ] ;
    narr:keyPhrase [ narr:text "I'm getting the same feeling I get when I make music with modular synthesizers" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletModularSynthesizerQuote> ] ;
    narr:keyPhrase [ narr:text "Ultimately, we want to get from pilot to Enterprise, but I want to have kind of this proof point." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DirectQuoteStyle> ] ;
    narr:variation [ narr:text "The SMS/channel question is unresolved: outside-tech beta users pushed back on spam association while Scarlet held SMS as a trust signal and enterprise-only lean — no decision recorded as of April 2026." ; narr:over <https://aswritten.ai/narrative#Obs_OutsideTechBetaUserSpamPushback> ; narr:over <https://aswritten.ai/narrative#Obs_OutsideTechBetaUserChatWidget> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletSMSEnterpriseLeaning> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletSMSFraudCost> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletSMSBonus> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletTierUncertain> ] ;
    narr:variation [ narr:text "The customer's engineering manager's 24-hour transcript lag complaint sits in tension with the curated-not-dumped consensus — operational urgency pulling against deliberate slowness." ; narr:over <https://aswritten.ai/narrative#Obs_CustomerEngManagerLag24h> ; narr:over <https://aswritten.ai/narrative#Obs_CustomerCTOPRMetaphorQuote> ; narr:over <https://aswritten.ai/narrative#Obs_CustomerArchitectNotComfortableQuote> ] ;
    narr:variation [ narr:text "Scarlet's base-camp framing (May 2026) positions the moment as early-stage, qualifying the March 2026 \"incredible\" validation — enthusiasm and sobriety in the same corpus." ; narr:over <https://aswritten.ai/narrative#Obs_BaseCampQuote> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletIncredibleQuote> ] ;
    narr:variation [ narr:text "The citation-architecture thread (constellation, reductionist diagnosis, primary-uniqueness) is a product-design debate internal to the system, distinct from the buyer-validation thread — different register, different stakes." ; narr:over <https://aswritten.ai/narrative#Obs_ScarletQuote_Constellation> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletQuote_Reductionist> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletQuote_PrimaryUnique> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletQuote_SameClaim> ] ;
    narr:variation [ narr:text "The demo-vs-product distinction (July 2026) introduces a corrective note: the share demo is not the product goal, qualifying how earlier demo reactions should be read." ; narr:over <https://aswritten.ai/narrative#Obs_ScarletDemoVsProductQuote> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletIncredibleQuote> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletModularSynthesizerQuote> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
