    narr:covers <https://aswritten.ai/narrative#StyleObs_WriteFlow_VerbatimBlockquote> ;
    narr:keyPhrase [ narr:text "this is definitely base camp, not camp 4 for whatever it is" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_BaseCampQuote> ] ;
    narr:keyPhrase [ narr:text "Information is a commodity. Code is free. But the power of perspective and collaboration — that's always where the value was." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerCTOInformationCommodity> ] ;
    narr:keyPhrase [ narr:text "People who don't have a well grounded perspective on their own... the tools are just going to create AI slop. I'm just making it easier for someone to do a shitty job." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerCTOAISlopQuote> ] ;
    narr:keyPhrase [ narr:text "we should treat that like code. We should treat that like a pull request with unit tests. It actually creates this because it's, it's, it's better for us to be a little slow" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerCTOPRMetaphorQuote> ] ;
    narr:keyPhrase [ narr:text "What you can't automate is what the customer's chief architect's talking about, which is reviewing the memory that comes out for one factual consistency. And for me, more importantly, for narrative and perceptual alignment. And that's a human process." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletCantAutomateQuote> ] ;
    narr:keyPhrase [ narr:text "I'm just not super comfortable saying we should just dump every transcript unreviewed straight into the perspective." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerArchitectNotComfortableQuote> ] ;
    narr:keyPhrase [ narr:text "This is incredible. I literally could not have written this better myself — and that's the product working!" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletIncredibleQuote> ] ;
    narr:keyPhrase [ narr:text "[amount] now to bridge to the 3 to 4 million dollar round." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_CorrectionVerbatimQuote> ] ;
    narr:variation [ narr:text "the customer's chief architect's skepticism sets the acceptance bar — mere playback of what he said is \"not really very much\" — while his unprompted goal-directed riff suggests the bar can be cleared; these two sit in tension as the pilot's open question." ; narr:over <https://aswritten.ai/narrative#Obs_CustomerArchitectSkepticismQuote> ; narr:over <https://aswritten.ai/narrative#Obs_CustomerArchitectGoalRiffQuote> ] ;
    narr:variation [ narr:text "the customer's CTO pushes back on templates in favor of emergence, while an advisor pushes for structured templates — an unresolved design tension within the same pilot cohort." ; narr:over <https://aswritten.ai/narrative#Obs_CustomerCTOEmergence> ; narr:over <https://aswritten.ai/narrative#Obs_AdvisorMStructure> ] ;
    narr:variation [ narr:text "a beta user from outside tech's preference for chat widget and a beta user from outside tech's spam-association pushback on SMS sit against Scarlet's corrected positive position on SMS as channel and her enterprise-only leaning — the channel question is open, not settled." ; narr:over <https://aswritten.ai/narrative#Obs_OutsideTechBetaUserChatWidget> ; narr:over <https://aswritten.ai/narrative#Obs_OutsideTechBetaUserSpamPushback> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletSMSNotPhoneNumber> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletSMSEnterpriseLeaning> ] ;
    narr:variation [ narr:text "Scarlet frames SMS trust-signal as bonus/upsell rather than core product identity, but also acknowledges genuine trust-signal value in the phone number format — the product-identity question around SMS remains deliberately undecided." ; narr:over <https://aswritten.ai/narrative#Obs_ScarletSMSBonus> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletPhoneNumberFeels> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletTierUncertain> ] ;
    narr:variation [ narr:text "Scarlet's \"Sunday scaries\" self-assessment and base-camp framing register genuine uncertainty at the May 2026 inflection, while the team-bottleneck quote and the customer's chief architect's six-people-joining signal simultaneously accelerating demand — confidence and anxiety coexist in the same moment." ; narr:over <https://aswritten.ai/narrative#Obs_ScarletSundayScaries> ; narr:over <https://aswritten.ai/narrative#Obs_BaseCampQuote> ; narr:over <https://aswritten.ai/narrative#Obs_TeamBottleneckQuote> ; narr:over <https://aswritten.ai/narrative#Obs_CustomerArchitectSixPeopleJoining> ] ;
    narr:variation [ narr:text "The cite-prompt cluster (constellation frame, primary-uniqueness refinement, reductionist diagnosis, deduplication problem) records an internal design debate about citation architecture that is distinct from the buyer-validation quotes and may not be resolved by them." ; narr:over <https://aswritten.ai/narrative#Obs_ScarletQuote_Constellation> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletQuote_PrimaryUnique> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletQuote_Reductionist> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletQuote_SameClaim> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
