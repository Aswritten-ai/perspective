@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ActorIncentiveAnalysis> {
  <https://aswritten.ai/narrative#Digest_ActorIncentiveAnalysis> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#ActorIncentiveAnalysis> ;
    narr:childCount "10"^^xsd:integer ;
    narr:generatedFrom "87b088f4031c722706555fc011fe7d712d2f40ea" ;
    narr:narration """This hub tracks the evolving taxonomy of actor incentives, moving from rigid market-lever constraints toward a more relational, human-centric model. While early framing focused on [enterprise token-cost sensitivity](narr:Narrative_TokenCostSensitivity) and [ratio-based value reframing](narr:Narrative_MetricReframe) to bypass procurement friction, recent discourse introduces a [warm incentive taxonomy](narr:Narrative_AgentWarmIncentiveTaxonomy) that prioritizes drives like credibility, sensitivity, and accountability over simple budget policy. The sales motion remains anchored in [NYC-based serendipity](narr:Narrative_InPersonSalesAdvantage) and the specific hook of [undocumented knowledge extraction](narr:Narrative_UndocumentedKnowledgeExtraction), which serves as a primary animator for users. Structural incentives are further defined by [per-group billing models](narr:Arch_ParticipantsFree) and a [Tyler Cowen-inspired screening principle](narr:Obs_TylerCowenScreeningQuote) that frames 'boring' applications as existential risks. The hub continues to emphasize [temporality over conviction](narr:Obs_ActorTransformTemporalityQuote) when mapping how actors transform, suggesting that the 'what' of an incentive is less critical than the 'when' of its manifestation.""" ;
    narr:covers <https://aswritten.ai/narrative#Arch_ParticipantsFree> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_AgentWarmIncentiveTaxonomy> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_InPersonSalesAdvantage> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_MetricReframe> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_TokenCostSensitivity> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_UndocumentedKnowledgeExtraction> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ActorTransformTemporalityQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_TylerCowenScreeningQuote> ;
    narr:covers <https://aswritten.ai/narrative#Observation_NotificationPersuasion> ;
    narr:covers <https://aswritten.ai/narrative#SolutionArchetype_CEOKnowledgeTransfer> ;
    narr:keyPhrase [ narr:text "Agent relational incentive taxonomy: warm drives beyond functional" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_AgentWarmIncentiveTaxonomy> ] ;
    narr:keyPhrase [ narr:text "Token cost sensitivity in enterprise" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_TokenCostSensitivity> ] ;
    narr:keyPhrase [ narr:text "Physical presence enables organic live demos that convert to warm referrals in ways remote calls cannot replicate" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_InPersonSalesAdvantage> ] ;
    narr:keyPhrase [ narr:text "If I'm looking at an actor transformation, I want to see more about what Tony thinks might need to happen in the different temporalities than the things that I want to have seen happening." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ActorTransformTemporalityQuote> ] ;
    narr:keyPhrase [ narr:text "boring applications fail across hiring, funding, and buying" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_TylerCowenScreeningQuote> ] ;
    narr:variation [ narr:text "The 'warm' relational taxonomy pushes against the established 'market-lever' vocabulary of risk and budget." ; narr:over <https://aswritten.ai/narrative#Narrative_AgentWarmIncentiveTaxonomy> ] ;
    narr:variation [ narr:text "Enterprise price sensitivity remains a hard functional constraint despite the shift toward softer, relational incentives." ; narr:over <https://aswritten.ai/narrative#Narrative_TokenCostSensitivity> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}