@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ProductLadder> {
  <https://aswritten.ai/narrative#Digest_ProductLadder> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#ProductLadder> ;
    narr:childCount "6"^^xsd:integer ;
    narr:generatedFrom "7089c5af3b14249bd84e87732406b9626ea35fc3" ;
    narr:narration """This hub defines the product-and-go-to-market ladder, centering on a [goal-directed agent primitive](narr:Narrative_GoalDirectedPrimitive) that unifies delegation and coding-agent back-pressure. This framework, extended in April 2026 to include a scarce-expert filter, positions the product as a boundary-setting tool for expert time. The commercial entry point remains a [consulting-led pilot](narr:Narrative_PilotOffer) designed to transition into [post-pilot self-sufficiency](narr:Narrative_PostPilotSelfSufficiency), where teams gain full autonomy over graph queries and memory management. The underlying product architecture is defined by a [distinct tool hierarchy](narr:Observation_ToolHierarchy) separating foundational primitives from composers, a shift reinforced by the [removal of the Stories system](narr:Position_RemoveStoriesSystem) in favor of on-demand skills. Complementing these structural changes, the [shared agent memory](narr:Narrative_SharedAgentMemory) model provides the mechanism for automated knowledge convergence across collaborators, mapping directly to existing product capabilities.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_GoalDirectedPrimitive> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PilotOffer> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PostPilotSelfSufficiency> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_SharedAgentMemory> ;
    narr:covers <https://aswritten.ai/narrative#Observation_ToolHierarchy> ;
    narr:covers <https://aswritten.ai/narrative#Position_RemoveStoriesSystem> ;
    narr:keyPhrase [ narr:text "perspective + goal + termination criteria + escalation criteria = a bounded autonomous agent" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_GoalDirectedPrimitive> ] ;
    narr:keyPhrase [ narr:text "Consulting pilot as entry point for collective memory adoption" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PilotOffer> ] ;
    narr:keyPhrase [ narr:text "full self-service capability with free tier" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PostPilotSelfSufficiency> ] ;
    narr:keyPhrase [ narr:text "Entire Stories system removed; functions migrated to on-demand skills or direct TX returns." ; narr:phraseSource <https://aswritten.ai/narrative#Position_RemoveStoriesSystem> ] ;
    narr:variation [ narr:text "The shift from 'Stories' to 'on-demand skills' represents a move away from structured narrative flows toward direct, functional execution." ; narr:over <https://aswritten.ai/narrative#Position_RemoveStoriesSystem> ; narr:over <https://aswritten.ai/narrative#Observation_ToolHierarchy> ] ;
    narr:variation [ narr:text "The 'scarce-expert filter' reframes the agent not just as a productivity tool, but as a defensive gatekeeper for human attention." ; narr:over <https://aswritten.ai/narrative#Narrative_GoalDirectedPrimitive> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}