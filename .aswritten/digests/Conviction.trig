@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Conviction> {
  <https://aswritten.ai/narrative#Digest_Conviction> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Conviction> ;
    narr:childCount "10"^^xsd:integer ;
    narr:generatedFrom "c6acb314b8ae3905d7d92d821c9dada54b9598c2" ;
    narr:narration """This hub defines the [conviction construct](narr:Narrative_ConvictionFramework) as a measure of epistemic settledness, structured across a spectrum from ephemeral notions to foundational graves. The primary trajectory, formalized in April 2026, centers on the [orthogonality of conviction and temporality](narr:Narrative_ConvictionVsTemporality), a distinction necessitated by [pipeline conflation](narr:Position_ConvictionAndTemporalityAreDistinctAxes) that previously caused speculative future-state claims to be misread as current reality. [Scarlet’s canonical framing](narr:Obs_ConvictionTemporalityQuote) anchors this, asserting that high-conviction claims can exist for speculative or future-oriented states. This separation has received [technical validation](narr:Obs_DavidConvictionQuote) from early adopters, reinforcing the need to treat conviction independently of [review evidence](narr:Position_5), which tracks the validation thoroughness of the extraction process. Emerging alongside this is a [spaced-repetition model](narr:Narrative_ConvictionDecay) for conviction decay, proposing that unreinforced claims should lose weight over time, a [feature request](narr:Position_ConvictionDecayFeatureRequest) currently under consideration. Stylistically, the system employs [all-caps markers](narr:StyleObs_ConvictionLabel) like BOULDER to signal validated confidence within the graph.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ConvictionDecay> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ConvictionFramework> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ConvictionVsTemporality> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ConvictionDecayQuestion> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ConvictionTemporalityQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_DavidConvictionQuote> ;
    narr:covers <https://aswritten.ai/narrative#Position_5> ;
    narr:covers <https://aswritten.ai/narrative#Position_ConvictionAndTemporalityAreDistinctAxes> ;
    narr:covers <https://aswritten.ai/narrative#Position_ConvictionDecayFeatureRequest> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ConvictionLabel> ;
    narr:keyPhrase [ narr:text "Conviction levels: notion → stake → boulder → grave" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ConvictionFramework> ] ;
    narr:keyPhrase [ narr:text "Conviction is something that is supposed to be built over time, i.e., do people act? Do multiple people actually agree on it? I can be very sure about something that might need to happen in the future." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ConvictionTemporalityQuote> ] ;
    narr:keyPhrase [ narr:text "Conviction (how settled) and temporality (when it applies) are orthogonal axes that the extraction pipeline currently conflates" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ConvictionVsTemporality> ] ;
    narr:keyPhrase [ narr:text "Conviction = epistemological settledness of knowledge itself; review evidence = thoroughness of extraction validation." ; narr:phraseSource <https://aswritten.ai/narrative#Position_5> ] ;
    narr:keyPhrase [ narr:text "BOULDER used as an inline conviction label in all-caps" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ConvictionLabel> ] ;
    narr:variation [ narr:text "The proposal for conviction decay introduces a temporal dependency that challenges the static nature of the current conviction framework." ; narr:over <https://aswritten.ai/narrative#Narrative_ConvictionDecay> ; narr:over <https://aswritten.ai/narrative#Position_ConvictionDecayFeatureRequest> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}