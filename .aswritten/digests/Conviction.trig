@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Conviction> {
  <https://aswritten.ai/narrative#Digest_Conviction> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Conviction> ;
    narr:childCount "10"^^xsd:integer ;
    narr:generatedFrom "edb9f6070d05850ea732b36518ceed0603f28d08" ;
    narr:narration """This hub defines the [conviction construct](narr:Narrative_ConvictionFramework) as the epistemic settledness of organizational knowledge, mapped across a spectrum from notion to grave. The core trajectory centers on the [orthogonality of conviction and temporality](narr:Narrative_ConvictionVsTemporality), a distinction formalized in April 2026 to address [pipeline conflation](narr:Position_ConvictionAndTemporalityAreDistinctAxes) that previously caused demo-pollution. [Scarlet’s canonical framing](narr:Obs_ConvictionTemporalityQuote) anchors this, emphasizing that high-conviction claims can exist for future-oriented or speculative states. This distinction has gained [technical validation](narr:Obs_DavidConvictionQuote) from early adopters, reinforcing the need to treat conviction as distinct from [review evidence](narr:Position_5), which measures the thoroughness of extraction validation. Emerging alongside this is a [spaced-repetition model](narr:Narrative_ConvictionDecay) for conviction decay, proposing that unreinforced claims should lose weight over time. Stylistically, the system utilizes [all-caps markers](narr:StyleObs_ConvictionLabel) like BOULDER to signal validated confidence within the graph.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ConvictionDecay> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ConvictionFramework> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ConvictionVsTemporality> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ConvictionDecayQuestion> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ConvictionTemporalityQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_DavidConvictionQuote> ;
    narr:covers <https://aswritten.ai/narrative#Position_5> ;
    narr:covers <https://aswritten.ai/narrative#Position_ConvictionAndTemporalityAreDistinctAxes> ;
    narr:covers <https://aswritten.ai/narrative#Position_ConvictionDecayFeatureRequest> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ConvictionLabel> ;
    narr:keyPhrase [ narr:text "Conviction is something that is supposed to be built over time, i.e., do people act? Do multiple people actually agree on it? I can be very sure about something that might need to happen in the future." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ConvictionTemporalityQuote> ] ;
    narr:keyPhrase [ narr:text "Conviction (how settled) and temporality (when it applies) are orthogonal axes that the extraction pipeline currently conflates" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ConvictionVsTemporality> ] ;
    narr:keyPhrase [ narr:text "Conviction = epistemological settledness of knowledge itself; review evidence = thoroughness of extraction validation." ; narr:phraseSource <https://aswritten.ai/narrative#Position_5> ] ;
    narr:keyPhrase [ narr:text "Conviction should decay over time when claims are not reinforced" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ConvictionDecay> ] ;
    narr:keyPhrase [ narr:text "BOULDER used as an inline conviction label in all-caps" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ConvictionLabel> ] ;
    narr:variation [ narr:text "The decay model introduces a temporal volatility that contrasts with the static, provenance-based accumulation of the core framework." ; narr:over <https://aswritten.ai/narrative#Narrative_ConvictionDecay> ; narr:over <https://aswritten.ai/narrative#Narrative_ConvictionFramework> ] ;
    narr:variation [ narr:text "Review evidence is treated as an independent variable from conviction, potentially decoupling 'how settled' a claim is from 'how well validated' the extraction process was." ; narr:over <https://aswritten.ai/narrative#Position_5> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}