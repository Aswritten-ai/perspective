@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Conviction> {
  <https://aswritten.ai/narrative#Digest_Conviction> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Conviction> ;
    narr:childCount "10"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """This hub gathers the **conviction** construct: the epistemic settledness of organizational knowledge, formalized as a [Notion→Stake→Boulder→Grave framework](narr:Narrative_ConvictionFramework) where memories raise or lower conviction with provenance for every shift. Conviction is repeatedly defined as *built over time through agreement and action* — Scarlet's [canonical distinction](narr:Obs_ConvictionTemporalityQuote) anchors this. Two design tensions run through the children. First, the pipeline [conflates conviction with temporality](narr:Claim_ConvictionAndTemporalityAreDistinctAxes) — *when* a claim applies (now/soon/future/speculative) is orthogonal to *how settled* it is, a [distinct-axes argument](narr:Narrative_ConvictionVsTemporality) validated by the customer's chief architect's demo-pollution failure (Apr–May 2026). Second, conviction is treated as separate from [review evidence](narr:Claim_5) — extraction-validation thoroughness — which informs compile behavior independently. A live feature request proposes [conviction decay](narr:Claim_ConvictionDecayFeatureRequest): a founder beta user's [spaced-repetition framing](narr:Narrative_ConvictionDecay) where unreinforced claims lose weight. Claim_5 also extends the dynamic to human organizations. A stylistic trace records [BOULDER as an all-caps inline label](narr:StyleObs_ConvictionLabel).""" ;
    narr:covers <https://aswritten.ai/narrative#Claim_5> ;
    narr:covers <https://aswritten.ai/narrative#Claim_ConvictionAndTemporalityAreDistinctAxes> ;
    narr:covers <https://aswritten.ai/narrative#Claim_ConvictionDecayFeatureRequest> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ConvictionDecay> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ConvictionFramework> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ConvictionVsReview> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ConvictionVsTemporality> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ConvictionDecayQuestion> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ConvictionTemporalityQuote> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ConvictionLabel> ;
    narr:keyPhrase [ narr:text "Notion: can be changed easily. Stake: planted but needs validation. Boulder: hard to move without others involved. Grave: done, settled." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ConvictionFramework> ] ;
    narr:keyPhrase [ narr:text "Conviction is something that is supposed to be built over time, i.e., do people act? Do multiple people actually agree on it? I can be very sure about something that might need to happen in the future." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ConvictionTemporalityQuote> ] ;
    narr:keyPhrase [ narr:text "A claim can be high-conviction and speculative simultaneously — e.g., 'we should build X' stated with certainty during a brainstorm." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_ConvictionAndTemporalityAreDistinctAxes> ] ;
    narr:keyPhrase [ narr:text "Conviction = epistemological settledness of knowledge itself; review evidence = thoroughness of extraction validation. Both inform compile behavior independently." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_5> ] ;
    narr:keyPhrase [ narr:text "Claims not reinforced over time should lose conviction weight in the graph." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_ConvictionDecayFeatureRequest> ] ;
    narr:variation [ narr:text "Conviction and temporality are treated as conflated by the current pipeline but argued to be orthogonal — high conviction can attach to speculative/future content, so the framework alone mis-encodes speculation as current worldview." ; narr:over <https://aswritten.ai/narrative#Claim_ConvictionAndTemporalityAreDistinctAxes> ; narr:over <https://aswritten.ai/narrative#Narrative_ConvictionVsTemporality> ; narr:over <https://aswritten.ai/narrative#Obs_ConvictionTemporalityQuote> ] ;
    narr:variation [ narr:text "Conviction-decay proposes conviction is NOT static once set: unreinforced claims should lose weight over time — pushing against the framework's provenance-only model of conviction change." ; narr:over <https://aswritten.ai/narrative#Claim_ConvictionDecayFeatureRequest> ; narr:over <https://aswritten.ai/narrative#Narrative_ConvictionDecay> ; narr:over <https://aswritten.ai/narrative#Obs_ConvictionDecayQuestion> ] ;
    narr:variation [ narr:text "Conviction is held distinct from review/extraction-validation evidence — a separate axis informing compile behavior, not part of the Notion→Grave ladder." ; narr:over <https://aswritten.ai/narrative#Claim_5> ; narr:over <https://aswritten.ai/narrative#Narrative_ConvictionVsReview> ] ;
    narr:variation [ narr:text "The dynamic is claimed to generalize beyond the tool to human organizations (governance, change management, decision rights) — a scope claim broader than the extraction-pipeline framing." ; narr:over <https://aswritten.ai/narrative#Claim_5> ; narr:over <https://aswritten.ai/narrative#Narrative_ConvictionFramework> ] ;
    narr:writer "claude (subscription)" .
}