GRAPH <https://aswritten.ai/narrative#Digest_CitationConventions> {
  <https://aswritten.ai/narrative#Digest_CitationConventions> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#CitationConventions> ;
    narr:childCount "13"^^xsd:integer ;
    narr:generatedFrom "acd63666a2004ed05daca54d6d2dda67ca510c10" ;
    narr:narration """This hub documents the evolving citation conventions used to ground claims in source material. The primary evidentiary register relies on [timestamp-anchored speaker attribution](narr:StyleObs_TimestampedSpeakerAttribution), which provides temporal provenance for spoken evidence. While [MM:SS](narr:StyleObs_ConversationalTimestamps) remains the standard, variations including [HH:MM:SS](narr:StyleObs_DavidNolen_TimestampCitations) and [inline grounding](narr:StyleObs_TimestampGrounding) are employed to maintain traceability. Parallel to these temporal markers, the perspective utilizes a [two-register document structure](narr:StyleObs_NicheBlockquoteVerbatim) that separates [verbatim blockquote](narr:StyleObs_ThreeUseCases_VerbatimBlock) evidence from editorial synthesis. This structure is driven by the requirement that [precision matters](narr:StyleObs_VerbatimPrecision) when capturing technical or taxonomic claims. A distinct, non-temporal convention involves [backtick-wrapped IRIs](narr:StyleObs_NotNegotiationFloor), which function as an idiolect for cross-referencing internal graph entities. Together, these methods ensure that claims are either anchored to a specific moment in a recording or explicitly demarcated as authoritative verbatim content.""" ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ConversationalTimestamps> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_DavidNolen_TimestampCitations> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_EnterpriseShape_TimestampCitation> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NicheBlockquoteVerbatim> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NotNegotiationFloor> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ThreeUseCases_VerbatimBlock> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TimestampGrounding> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TimestampedQuotes> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TimestampedSpeakerAttribution> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TonyTimestampCitation_CustomerArchitectSponsor> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_VerbatimAttribution> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_VerbatimPrecision> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_VerbatimQuoteHeavy> ;
    narr:keyPhrase [ narr:text "Scarlet [33:02]:" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TimestampedSpeakerAttribution> ] ;
    narr:keyPhrase [ narr:text "preserved verbatim because the precision matters" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_VerbatimPrecision> ] ;
    narr:keyPhrase [ narr:text "`Claim_10xGapIntentional`" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_NotNegotiationFloor> ] ;
    narr:keyPhrase [ narr:text "Tony [12:10]: \"You've got something that most people don't get and that's a sponsor." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TonyTimestampCitation_CustomerArchitectSponsor> ] ;
    narr:keyPhrase [ narr:text "> I was thinking about those as different use cases:" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ThreeUseCases_VerbatimBlock> ] ;
    narr:variation [ narr:text "Temporal precision varies between [MM:SS] and [HH:MM:SS] formats." ; narr:over <https://aswritten.ai/narrative#StyleObs_ConversationalTimestamps> ; narr:over <https://aswritten.ai/narrative#StyleObs_DavidNolen_TimestampCitations> ] ;
    narr:variation [ narr:text "Backtick-wrapped IRIs serve as a structural idiolect distinct from evidentiary citation." ; narr:over <https://aswritten.ai/narrative#StyleObs_NotNegotiationFloor> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}