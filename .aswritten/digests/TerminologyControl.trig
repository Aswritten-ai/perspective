    narr:keyPhrase [ narr:text "The confusion is with stake and boulder without prior explanation." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ConvictionLabelPlainEnglish> ] ;
    narr:keyPhrase [ narr:text "I've let go of the memory word sort of entirely and I'm now calling it installable expertise." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_InstallableExpertiseTerm> ] ;
    narr:keyPhrase [ narr:text "New vocabulary, preserved verbatim because paraphrasing will blunt it" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_VerbatimVocabulary> ] ;
    narr:keyPhrase [ narr:text "System generates micro-telltales — small content artifacts that exercise the triples in a given lens." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_LensMicroTelltale> ] ;
    narr:keyPhrase [ narr:text "collective memory" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_CollectiveMemory> ] ;
