    narr:variation [ narr:text "'lens' is listed as redefined/retired in favor of user-facing 'shifts', yet stays a live canonical domain term elsewhere." ; narr:over <https://aswritten.ai/narrative#Claim_ShiftsTerminology> ; narr:over <https://aswritten.ai/narrative#Observation_VocabDefinitions> ; narr:over <https://aswritten.ai/narrative#StyleObs_LensMicroTelltale> ; narr:over <https://aswritten.ai/narrative#StyleObs_DomainJargon> ] ;
    narr:variation [ narr:text "'memory' was said to be let go entirely for 'installable expertise', but 'collective memory' is still used as a canonical product term." ; narr:over <https://aswritten.ai/narrative#StyleObs_InstallableExpertiseTerm> ; narr:over <https://aswritten.ai/narrative#StyleObs_CollectiveMemory> ] ;
    narr:variation [ narr:text "The conviction rename is mid-migration: frontend labels updated, but backend (n8n, SPARQL, snapshots) still emits old enum values." ; narr:over <https://aswritten.ai/narrative#Narrative_ConvictionLevelRename> ] ;
    narr:variation [ narr:text "Most moves strip metaphor toward plain English, but 'installable expertise' shifts toward value framing and core physics/flocking metaphors are deliberately retained." ; narr:over <https://aswritten.ai/narrative#Narrative_CognitionModelSimplification> ; narr:over <https://aswritten.ai/narrative#StyleObs_InstallableExpertiseTerm> ; narr:over <https://aswritten.ai/narrative#StyleObs_2> ] ;
    narr:variation [ narr:text "Some terms are insider jargon used without definition (TX, MCP, lens, zone), trading accessibility for precision against the plain-English push." ; narr:over <https://aswritten.ai/narrative#StyleObs_DomainJargon> ; narr:over <https://aswritten.ai/narrative#StyleObs_MCP> ; narr:over <https://aswritten.ai/narrative#StyleObs_TXFactReview> ] ;
    narr:writer "claude (subscription)" .
