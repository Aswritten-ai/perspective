    narr:variation [ narr:text "Roads dropped/superseded: voice interviews explicitly cut (20260408), and the landing-page redo superseded by the deep-link move — items removed, not just deprioritized." ; narr:over <https://aswritten.ai/narrative#Claim_VoiceDroppedFromRoadmap> ; narr:over <https://aswritten.ai/narrative#Claim_AboveTheLine_April1> ] ;
    narr:variation [ narr:text "GitHub abstraction flipped from open high-priority blocker (20260312) to a resolved tier-design feature (20260319) — a question that closed rather than persisting." ; narr:over <https://aswritten.ai/narrative#Claim_GitHubAbstractionHighPriority> ] ;
    narr:variation [ narr:text "Counter-intuitive adoption: even dev-focused users are steered chat-first, populating worldview before any coding — pushes against a code-tool framing." ; narr:over <https://aswritten.ai/narrative#Narrative_ChatFirstCodeLater> ] ;
    narr:variation [ narr:text "Expansion is framed three incompatible ways — linear funding ladder, advisor/VC-channel expansion path, and three parallel buyer tracks — not yet reconciled into one motion." ; narr:over <https://aswritten.ai/narrative#Narrative_FundingLadder> ; narr:over <https://aswritten.ai/narrative#Narrative_ExpansionPath> ; narr:over <https://aswritten.ai/narrative#Narrative_ExpansionTracks> ] ;
    narr:variation [ narr:text "Manual-now vs automate-later tension: Phase 1 is Scarlet doing it by hand; pipeline automation and LoRA self-hosted extraction are explicitly post-raise long-term bets." ; narr:over <https://aswritten.ai/narrative#Claim_Phase1Manual> ; narr:over <https://aswritten.ai/narrative#Narrative_FineTuningExtractionPath> ] ;
    narr:variation [ narr:text "Priority sequencing is dated and shifting — the 2026-02-10 post-YC stack (pipeline→outreach→incubators) coexists with later a demo-call prospect-driven material priorities; no single canonical order." ; narr:over <https://aswritten.ai/narrative#PriorityStack_2026_02_10> ; narr:over <https://aswritten.ai/narrative#Obs_DemoProspectMaterialPriorities> ] ;
