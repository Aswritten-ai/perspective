    narr:covers <https://aswritten.ai/narrative#Observation_FutureLensTool> ;
    narr:covers <https://aswritten.ai/narrative#Observation_LensDraftingProcess> ;
    narr:covers <https://aswritten.ai/narrative#Position_AboveTheLine_April1> ;
    narr:covers <https://aswritten.ai/narrative#Position_GitHubAbstractionHighPriority> ;
    narr:covers <https://aswritten.ai/narrative#Position_MissingCompileTimeLayerParameter> ;
