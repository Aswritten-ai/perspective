    narr:covers <https://aswritten.ai/narrative#Position_ScopeBuildFirst> ;
    narr:covers <https://aswritten.ai/narrative#Position_StrategyDocAsInternalSourceOfTruth> ;
    narr:covers <https://aswritten.ai/narrative#Position_TopicAnalysisPlatformFeature> ;
