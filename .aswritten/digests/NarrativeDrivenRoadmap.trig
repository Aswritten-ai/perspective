    narr:keyPhrase [ narr:text "The strategy document is the single internal source of truth; all audience-specific documents are derived from it, not the other way around" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_DocumentEcosystem> ] ;
    narr:keyPhrase [ narr:text "Perspective as agent steering: install behavior, values, and self-understanding through accumulated human-agent conversation rather than RAG" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PerspectiveAsAgentSteering> ] ;
    narr:keyPhrase [ narr:text "Product doc | Internal | Users, tools, flows, actor stories" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_DocumentEcosystemTable> ] ;
    narr:keyPhrase [ narr:text "Onboarding mode is the highest-leverage product gap for beta." ; narr:phraseSource <https://aswritten.ai/narrative#Position_OnboardingModeHighestLeverage> ] ;
    narr:keyPhrase [ narr:text "Voice interviews are explicitly dropped from the roadmap." ; narr:phraseSource <https://aswritten.ai/narrative#Position_VoiceDroppedFromRoadmap> ] ;
    narr:variation [ narr:text "Tension between RAG-based document management and conversational perspective-based steering." ; narr:over <https://aswritten.ai/narrative#Narrative_PerspectiveAsAgentSteering> ; narr:over <https://aswritten.ai/narrative#Obs_ScarletRAGCritiqueQuote> ] ;
    narr:variation [ narr:text "B2C staging: text-first individual vs. the long-term goal of immersive voice." ; narr:over <https://aswritten.ai/narrative#Narrative_TextFirstIndividualStaging> ; narr:over <https://aswritten.ai/narrative#Position_VoiceDroppedFromRoadmap> ] ;
