    narr:keyPhrase [ narr:text "The strategy document is the internal source of truth." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_StrategyDocAsInternalSourceOfTruth> ] ;
    narr:keyPhrase [ narr:text "The demo IS the delivery — every sales call produces the deliverable." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_DemoEqualsDelivery> ] ;
    narr:keyPhrase [ narr:text "Onboarding mode is the highest-leverage product gap for beta." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_OnboardingModeHighestLeverage> ] ;
    narr:keyPhrase [ narr:text "Technical infrastructure works; cognitive bootstrapping does not." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_OnboardingModeHighestLeverage> ] ;
    narr:keyPhrase [ narr:text "Voice interviews are explicitly dropped from the roadmap." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_VoiceDroppedFromRoadmap> ] ;
