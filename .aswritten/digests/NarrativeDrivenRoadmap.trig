@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_NarrativeDrivenRoadmap> {
  <https://aswritten.ai/narrative#Digest_NarrativeDrivenRoadmap> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#NarrativeDrivenRoadmap> ;
    narr:childCount "26"^^xsd:integer ;
    narr:generatedFrom "99d6dafe09412ac24617bf594deb2c86d6e9ca86" ;
    narr:narration """This hub tracks the evolution of the aswritten roadmap, document strategy, and core product philosophy. The [strategy document](narr:Narrative_DocumentEcosystem) serves as the internal source of truth, from which a [nine-part document ecosystem](narr:Obs_DocumentEcosystemTable) is derived. Product development has shifted from RAG-based architectures toward [perspective-based agent steering](narr:Narrative_PerspectiveAsAgentSteering), where behavioral norms are installed through accumulated conversation. The roadmap is currently structured around [three-beat YC demo](narr:Decision_YCDemoBeats) sequences and a [text-first B2C staging](narr:Narrative_TextFirstIndividualStaging) that prioritizes cost-effective individual adoption over immersive voice. Technical priorities include [onboarding cognitive bootstrapping](narr:Position_OnboardingModeHighestLeverage), a [compile-time layer parameter](narr:Position_MissingCompileTimeLayerParameter), and [platform-level topic analysis](narr:Position_TopicAnalysisPlatformFeature). GTM strategy remains multifaceted, balancing [influence-first sales](narr:Narrative_InfluenceSales) with [buyer-specific expansion tracks](narr:Narrative_ExpansionTracks) and a [funding ladder](narr:Narrative_ExpansionPath). The [GitHub abstraction](narr:Position_GitHubAbstractionHighPriority) for SMB users has been resolved as a tier-based feature, while [voice-based interview integration](narr:Position_VoiceDroppedFromRoadmap) has been removed from the roadmap in favor of native phone-based text entry.""" ;
    narr:covers <https://aswritten.ai/narrative#Decision_YCDemoBeats> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ChatFirstCodeLater> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_CoreProductLoop> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DocumentEcosystem> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ExpansionPath> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ExpansionTracks> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_InfluenceSales> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PerspectiveAsAgentSteering> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PromptAsCompilationFromArchitecture> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_TextFirstIndividualStaging> ;
    narr:covers <https://aswritten.ai/narrative#Obs_DemoProspectMaterialPriorities> ;
    narr:covers <https://aswritten.ai/narrative#Obs_DocumentEcosystemTable> ;
    narr:covers <https://aswritten.ai/narrative#Obs_SMBProductImplications> ;
