GRAPH <https://aswritten.ai/narrative#Digest_Narrative_2> {
  <https://aswritten.ai/narrative#Digest_Narrative_2> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_2> ;
    narr:childCount "7"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """This hub holds the thesis that collective memory is an opinion machine: [whoever writes the memories controls the worldview](narr:Claim_4), so the writing layer is a steering surface, not neutral infrastructure. The supporting children extend the claim along three lines. First, the dynamic scales: [identity-as-architecture in human organizations](narr:Claim_5) treats conviction (epistemological settledness) and review evidence (extraction thoroughness) as independent inputs to compile behavior. Second, the compile mechanism is graded, not categorical — [continuous-valued weighting by review count, recency, reviewer diversity, lens coverage](narr:Claim_9). Third, a related narrative qualifies the optimism: [transparency is necessary but insufficient](narr:Narrative_3) as mitigation for narrative steering, reframing review around an optometrist/refraction metaphor. A strategic-alignment rubric ([narrative-as-vector positioning](narr:RubricAssess_StrategicAlignment)) ties the thesis to product moat and origin story. Note Claim_4 records a superseded 2026-02-10 design, now reframing review as accumulation of named graphs (who, when, lens, feedback). Two `aboutNode` children — [cross-cutting rules](narr:Claim_CrossCuttingRules) and [tool-description coverage](narr:Claim_ToolDescriptionCoverage) — attach without content here.""" ;
    narr:covers <https://aswritten.ai/narrative#Claim_4> ;
    narr:covers <https://aswritten.ai/narrative#Claim_5> ;
    narr:covers <https://aswritten.ai/narrative#Claim_9> ;
    narr:covers <https://aswritten.ai/narrative#Claim_CrossCuttingRules> ;
    narr:covers <https://aswritten.ai/narrative#Claim_ToolDescriptionCoverage> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_3> ;
    narr:covers <https://aswritten.ai/narrative#RubricAssess_StrategicAlignment> ;
    narr:keyPhrase [ narr:text "Whoever writes the memories controls the worldview" ; narr:phraseSource <https://aswritten.ai/narrative#Claim_4> ] ;
    narr:keyPhrase [ narr:text "The same identity-as-architecture dynamic operates in human organizations" ; narr:phraseSource <https://aswritten.ai/narrative#Claim_5> ] ;
    narr:keyPhrase [ narr:text "Compile weights by: review count, recency, reviewer diversity, lens coverage — continuous-valued, not binary" ; narr:phraseSource <https://aswritten.ai/narrative#Claim_9> ] ;
    narr:keyPhrase [ narr:text "Transparency is necessary but insufficient mitigation for narrative steering" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_3> ] ;
    narr:keyPhrase [ narr:text "Interconnected web of narratives that define a way of thinking—a program installed onto model hardware." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_3> ] ;
    narr:variation [ narr:text "Transparency is framed as necessary-but-insufficient — a brake on the mainline assumption that disclosure neutralizes steering." ; narr:over <https://aswritten.ai/narrative#Narrative_3> ] ;
    narr:variation [ narr:text "Compile weighting is explicitly continuous-valued, pushing against any binary accept/reject review model." ; narr:over <https://aswritten.ai/narrative#Claim_9> ] ;
    narr:variation [ narr:text "Claim_4 carries a superseded 2026-02-10 design — review reframed as accumulation of named graphs; the older framing may still be reached for." ; narr:over <https://aswritten.ai/narrative#Claim_4> ] ;
    narr:variation [ narr:text "Conviction (settledness of knowledge) and review evidence (extraction thoroughness) are asserted as independent inputs, not one collapsed score." ; narr:over <https://aswritten.ai/narrative#Claim_5> ] ;
    narr:variation [ narr:text "Two aboutNode children attach with no content surfaced here — structural outliers whose substance lives elsewhere." ; narr:over <https://aswritten.ai/narrative#Claim_CrossCuttingRules> ; narr:over <https://aswritten.ai/narrative#Claim_ToolDescriptionCoverage> ] ;
    narr:writer "claude (subscription)" .
}