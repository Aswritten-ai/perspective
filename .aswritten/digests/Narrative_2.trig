@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_2> {
  <https://aswritten.ai/narrative#Digest_Narrative_2> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_2> ;
    narr:childCount "5"^^xsd:integer ;
    narr:generatedFrom "142d39b84fbc553e165ebc9d9126d7715b1eb76a" ;
    narr:narration """This hub examines the thesis that collective memory functions as an opinion machine, where the writing layer acts as a steering surface rather than neutral infrastructure. The core framework, [Narrative Architecture](narr:Narrative_3), replaces previous vocabulary with an optometrist metaphor, unifying review processes under a refraction pattern. This architecture is supported by a [redefined review model](narr:Position_4) that treats review as the accumulation of named graphs (who, when, lens, feedback, and scope). The system's behavior is governed by [epistemological conviction and validation thoroughness](narr:Position_5), which act as independent inputs, and [continuous-valued compile weights](narr:Position_9) derived from reviewer diversity and lens coverage. The [strategic-alignment rubric](narr:RubricAssess_StrategicAlignment) bridges this technical ontology with product-level concerns, mapping the 'narrative as vector' thesis directly to origin stories, moat construction, and vision scaling.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_3> ;
    narr:covers <https://aswritten.ai/narrative#Position_4> ;
    narr:covers <https://aswritten.ai/narrative#Position_5> ;
    narr:covers <https://aswritten.ai/narrative#Position_9> ;
    narr:covers <https://aswritten.ai/narrative#RubricAssess_StrategicAlignment> ;
    narr:keyPhrase [ narr:text "review is accumulation of named graphs (who, when, lens, feedback, triples in scope)" ; narr:phraseSource <https://aswritten.ai/narrative#Position_4> ] ;
    narr:keyPhrase [ narr:text "Conviction = epistemological settledness of knowledge itself; review evidence = thoroughness of extraction validation." ; narr:phraseSource <https://aswritten.ai/narrative#Position_5> ] ;
    narr:keyPhrase [ narr:text "Compile weights by: review count, recency, reviewer diversity, lens coverage — continuous-valued, not binary" ; narr:phraseSource <https://aswritten.ai/narrative#Position_9> ] ;
    narr:keyPhrase [ narr:text "'narrative as vector' is both the story and the product thesis" ; narr:phraseSource <https://aswritten.ai/narrative#RubricAssess_StrategicAlignment> ] ;
    narr:variation [ narr:text "The optometrist metaphor shifts focus from 'infrastructure' to 'refraction,' potentially downplaying the raw data extraction in favor of lens-based filtering." ; narr:over <https://aswritten.ai/narrative#Narrative_3> ] ;
    narr:variation [ narr:text "Strategic alignment rubric prioritizes narrative-as-product, which may conflict with purely technical or epistemological interpretations of the steering model." ; narr:over <https://aswritten.ai/narrative#RubricAssess_StrategicAlignment> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}