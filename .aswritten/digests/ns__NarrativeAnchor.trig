    narr:generatedFrom "64a3d69ee28d5891bc5436326b8d8b102f225f44" ;
    narr:narration """This hub defines the core of aswritten.ai, centering on [narrative as the fundamental control mechanism](narr:Narrative_AI_Steering) for AI alignment. This conceptual anchor is paired with a technical framing of [AI memory as a versionable, Git-native system](narr:Narrative_SIC_WhatIsIt_1) that encodes organizational style and conviction. These elements coalesce under the term [narrative architecture](narr:StyleObs_KeyPhrase_NarrArch), which serves as the primary product concept. The mission is further supported by a [Day 1 productivity value proposition](narr:NarrativeAnchor_DayOneProductivity) focused on eliminating onboarding friction and preventing knowledge loss. The rhetoric surrounding these claims employs a distinct [biological metaphor](narr:StyleObs_1) of organizations as organisms, expressed through a [rhythmic, declarative sentence structure](narr:StyleObs_5) that emphasizes direct, conversational engagement. The span of this hub covers the intersection of technical memory architecture, AI steering, and the specific linguistic phenotype used to articulate the founder's worldview.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#NarrativeAnchor_DayOneProductivity> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_AI_Steering> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_SIC_WhatIsIt_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_5> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_KeyPhrase_NarrArch> ;
    narr:keyPhrase [ narr:text "narrative as the fundamental control mechanism for AI behavior and alignment." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_AI_Steering> ] ;
    narr:keyPhrase [ narr:text "AI memory that is versionable, collaborative, branchable, so Git native, and narrative driven." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_SIC_WhatIsIt_1> ] ;
    narr:keyPhrase [ narr:text "narrative architecture" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_KeyPhrase_NarrArch> ] ;
    narr:keyPhrase [ narr:text "the treatment of an organization as an AI organism, right? Whose DNA, if you will, is expressed" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_1> ] ;
    narr:keyPhrase [ narr:text "Day 1 Productivity + Zero Knowledge Loss + Tool Freedom" ; narr:phraseSource <https://aswritten.ai/ns/narrative#NarrativeAnchor_DayOneProductivity> ] ;
    narr:variation [ narr:text "Tension exists between the abstract 'organism' metaphor and the concrete 'Git-native' technical implementation." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_1> ; narr:over <https://aswritten.ai/ns/narrative#Narrative_SIC_WhatIsIt_1> ] ;
