GRAPH <https://aswritten.ai/narrative#Digest_ns__StyleMetrics> {
  <https://aswritten.ai/narrative#Digest_ns__StyleMetrics> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#StyleMetrics> ;
    narr:childCount "14"^^xsd:integer ;
    narr:generatedFrom "9c228a29f8ff5100e78514cbec14023c6ea429d7" ;
    narr:narration """This hub gathers per-document style and readability metrics across the org's corpus, computed on shared axes: active-voice ratio, jargon density, lexical diversity (TTR), sentence-length variance, and — where given — Flesch-Kincaid grade. The dominant profile is consistent: high active voice, domain-appropriate jargon, varied sentence length, strong lexical diversity. Register splits clearly by document type: technical architecture pieces — [collective-memory addendum](narr:Metrics_cm_addendum), [collective-memory arch](narr:Metrics_collective_memory_arch), and [SIC transcript](narr:StyleMetrics_SIC_1) — run high jargon density; pitch, GTM, CVP, and rebrand material lean concise and accessible. The [GTM doc](narr:StyleMetrics_GTM) and [CVP](narr:StyleMetrics_collective_memory_cvp) exemplify the punchy, short-sentence end of the spectrum; the [ADR001](narr:Metrics_ADR001) and [IP-crisis strategy](narr:Metrics_IPCrisis) anchor the denser, more complex end. The [founder reflection](narr:StyleMetrics_founder_reflection) is the sole child with a full numeric profile — 80 sentences averaging 42.8 words each, 78% active voice, TTR 0.62 — making it the most precisely witnessed node. Most other entries are qualitative-only. The [deck-editing notes](narr:StyleMetrics_DeckEditing) and [customer architect transcript](narr:Metrics_CustomerArchitect) both exhibit mixed cadence: short punchy sentences alongside longer analytical or explanatory clauses.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Metrics_ADR001> ;
    narr:covers <https://aswritten.ai/ns/narrative#Metrics_ADR002> ;
    narr:covers <https://aswritten.ai/ns/narrative#Metrics_CustomerArchitect> ;
    narr:covers <https://aswritten.ai/ns/narrative#Metrics_IPCrisis> ;
    narr:covers <https://aswritten.ai/ns/narrative#Metrics_cm_addendum> ;
    narr:covers <https://aswritten.ai/ns/narrative#Metrics_collective_memory_arch> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleMetrics_AIOrg> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleMetrics_DeckEditing> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleMetrics_GTM> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleMetrics_InfraAdvisor> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleMetrics_SIC_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleMetrics_Sample> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleMetrics_collective_memory_cvp> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleMetrics_founder_reflection> ;
    narr:keyPhrase [ narr:text "80 sentences, avg 42.8 words/sentence; 78% active voice; high lexical diversity (TTR 0.62); moderate rhythm variance; low jargon density (8% domain-specific terms)" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleMetrics_founder_reflection> ] ;
    narr:keyPhrase [ narr:text "High jargon density appropriate for technical architecture document; active voice dominant; varied vocabulary" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Metrics_cm_addendum> ] ;
    narr:keyPhrase [ narr:text "Mix of short punchy sentences (Tony's quotes) and longer analytical sentences (Scarlet's insights, decision rationale). High active voice ratio. Technical terms defined in context. Bulleted lists aid scannability." ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleMetrics_DeckEditing> ] ;
    narr:keyPhrase [ narr:text "High active voice ratio; short sentences; concise phrasing; punchy cadence" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleMetrics_collective_memory_cvp> ] ;
    narr:keyPhrase [ narr:text "High jargon density reflects technical domain. Moderate conciseness due to conversational fillers." ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleMetrics_SIC_1> ] ;
    narr:keyPhrase [ narr:text "Conversational register with technical precision; mix of short punchy sentences and longer explanatory clauses." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Metrics_CustomerArchitect> ] ;
    narr:keyPhrase [ narr:text "High active-voice ratio, moderate jargon density (technical terms defined in context), short-to-medium sentence length for clarity." ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleMetrics_GTM> ] ;
    narr:variation [ narr:text "The founder reflection's avg 42.8 words/sentence is a significant outlier — far longer cadence than the punchy CVP or GTM docs — suggesting the long-form reflective register is not the org's default pitch voice." ; narr:over <https://aswritten.ai/ns/narrative#StyleMetrics_founder_reflection> ; narr:over <https://aswritten.ai/ns/narrative#StyleMetrics_collective_memory_cvp> ; narr:over <https://aswritten.ai/ns/narrative#StyleMetrics_GTM> ] ;
    narr:variation [ narr:text "SIC transcript carries 'moderate conciseness due to conversational fillers' — a drag on conciseness absent from written documents, marking transcript-derived metrics as structurally different from authored ones." ; narr:over <https://aswritten.ai/ns/narrative#StyleMetrics_SIC_1> ; narr:over <https://aswritten.ai/ns/narrative#StyleMetrics_InfraAdvisor> ] ;
    narr:variation [ narr:text "Most children are qualitative-only; only the founder reflection carries a full numeric profile, so cross-document FK comparison is not possible from this hub alone." ; narr:over <https://aswritten.ai/ns/narrative#StyleMetrics_founder_reflection> ; narr:over <https://aswritten.ai/ns/narrative#Metrics_ADR001> ; narr:over <https://aswritten.ai/ns/narrative#Metrics_ADR002> ] ;
    narr:variation [ narr:text "ADR002 is described as 'high active voice, moderate complexity' while ADR001 is 'professional register with technical domain terms' — the two ADRs are not metrically identical, leaving open whether ADR complexity tracks document age or subject matter." ; narr:over <https://aswritten.ai/ns/narrative#Metrics_ADR001> ; narr:over <https://aswritten.ai/ns/narrative#Metrics_ADR002> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
