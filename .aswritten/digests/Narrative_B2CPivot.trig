@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_B2CPivot> {
  <https://aswritten.ai/narrative#Digest_Narrative_B2CPivot> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_B2CPivot> ;
    narr:childCount "9"^^xsd:integer ;
    narr:generatedFrom "a2fd073d60e04942bcc868e2b10e574c782d2885" ;
    narr:narration """The strategic trajectory of aswritten has moved from a binary B2B/B2C choice toward a unified model where the individual is the primary unit of value. This [B2C primary-market convergence](narr:Position_B2CPrimaryMarket) posits that [AI has made every individual their own team](narr:Position_EveryIndividualIsTheirOwnTeam), a shift that [restored individual contributor status](narr:Position_AIRestoredICStatus) by prioritizing strategy and curation. While early discussions identified a [need to reconcile](narr:Position_SMBPivotReconciliationNeeded) this volume-based B2C pivot with enterprise-style engagement, the current framework asserts that [Expert, Team, and Org are a continuum of one use case](narr:Narrative_TierContinuumNotDistinctMarkets). This view holds that [enterprise shapes do not supersede](narr:Position_EnterpriseDoesNotSupersedB2C) the B2C framing, but rather represent different scales of the same core activity. Recent reflections emphasize [founder-fit](narr:Position_FounderFitNarrativeEdge), diagnosing previous B2B defaults as [career artifacts](narr:Position_B2BDefaultCareerArtifact) rather than strategic requirements. Operational focus has now shifted to the [individuation curve](narr:Narrative_IndividuationCurveConversionMechanic), a conversion mechanic mapping user progression from generic engagement to ownership.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_IndividuationCurveConversionMechanic> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_TierContinuumNotDistinctMarkets> ;
    narr:covers <https://aswritten.ai/narrative#Position_AIRestoredICStatus> ;
    narr:covers <https://aswritten.ai/narrative#Position_B2BDefaultCareerArtifact> ;
    narr:covers <https://aswritten.ai/narrative#Position_B2CPrimaryMarket> ;
    narr:covers <https://aswritten.ai/narrative#Position_EnterpriseDoesNotSupersedB2C> ;
    narr:covers <https://aswritten.ai/narrative#Position_EveryIndividualIsTheirOwnTeam> ;
    narr:covers <https://aswritten.ai/narrative#Position_FounderFitNarrativeEdge> ;
    narr:covers <https://aswritten.ai/narrative#Position_SMBPivotReconciliationNeeded> ;
    narr:keyPhrase [ narr:text "AI has made every individual their own team" ; narr:phraseSource <https://aswritten.ai/narrative#Position_EveryIndividualIsTheirOwnTeam> ] ;
    narr:keyPhrase [ narr:text "Expert, Team, and Org tiers are a continuum of one use case differentiated only by the number of people writing to and consuming the perspective" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_TierContinuumNotDistinctMarkets> ] ;
    narr:keyPhrase [ narr:text "her B2B default is an artifact of her career history" ; narr:phraseSource <https://aswritten.ai/narrative#Position_B2BDefaultCareerArtifact> ] ;
    narr:keyPhrase [ narr:text "The conversion mechanic is own-by-default, pay-to-continue" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_IndividuationCurveConversionMechanic> ] ;
    narr:variation [ narr:text "The 'enterprise-shape' engagement pattern may be orthogonal to organizational size, potentially complicating the volume-B2C pivot." ; narr:over <https://aswritten.ai/narrative#Position_SMBPivotReconciliationNeeded> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}