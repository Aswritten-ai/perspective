    narr:covers <https://aswritten.ai/narrative#StyleObs_ScaffoldingMetaphor> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_SelfServe_TechnicalMetaphor> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_SideDoorMetaphor> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Spec_2> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_SteeringVector> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_SystemSketchMetaphor> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TelltaleMetaphor> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Tranche1_MountainMetaphor> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_WaveMetaphor> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_WizardOfOz> ;
    narr:covers <https://aswritten.ai/narrative#StyleObservation_MetaphoricalLabeling> ;
    narr:keyPhrase [ narr:text "narrative operates like a velocity or acceleration vector in these particle systems" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_2> ] ;
    narr:keyPhrase [ narr:text "I treated the models themselves like a computer, and a narrative architecture - an interconnected web of narratives that define a way of thinking - like a program that can be installed onto their hardware." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:keyPhrase [ narr:text "you don't want to clip the wings of the raven — it won't fly if you do that" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DiscoveryWedge_MetaphorRaven> ] ;
    narr:keyPhrase [ narr:text "The system needs an equivalent to the eye chart with progressively smaller lines — micro-telltales at decreasing granularity" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_BetterAorB> ] ;
    narr:keyPhrase [ narr:text "all the white space collapses to here." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_MetaphorWhiteSpace> ] ;
    narr:variation [ narr:text "The 'raven' metaphor warns against over-focusing, contrasting with the drive for precise, opinionated workflow control." ; narr:over <https://aswritten.ai/narrative#StyleObs_DiscoveryConsultantCallMetaphor> ; narr:over <https://aswritten.ai/narrative#StyleObs_DiscoveryWedge_MetaphorRaven> ] ;
    narr:variation [ narr:text "The 'gods of Olympus' metaphor introduces a sense of organizational opacity and fatalism, pushing against the 'infrastructure' framing." ; narr:over <https://aswritten.ai/narrative#StyleObs_GodsMetaphor> ] ;
    narr:variation [ narr:text "Physical-exertion metaphors (mountain climbing) emphasize the struggle of progress, whereas 'installable program' metaphors imply a seamless technical deployment." ; narr:over <https://aswritten.ai/narrative#StyleObs_Tranche1_MountainMetaphor> ; narr:over <https://aswritten.ai/narrative#StyleObs_Metaphor_InstallableProgram> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
