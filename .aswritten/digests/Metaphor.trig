    narr:keyPhrase [ narr:text "narrative operates like a velocity or acceleration vector in these particle systems" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_2> ] ;
    narr:keyPhrase [ narr:text "Narrative as steering vector for generative systems" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_SteeringVector> ] ;
    narr:keyPhrase [ narr:text "No company would develop software without GitHub. No company should deploy AI agents without versioned organizational context." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_GitHubMetaphor> ] ;
    narr:keyPhrase [ narr:text "like Git for software, aswritten.ai is for AI collaboration" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_GitMetaphor> ] ;
    narr:keyPhrase [ narr:text "The consulting is the manufacturing process." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_BusinessShape_2> ] ;
    narr:keyPhrase [ narr:text "With an enterprise prospect, you don't go for the hotel." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TonyMetaphorHotel> ] ;
    narr:keyPhrase [ narr:text "It's almost like the gods of Olympus. If Zeus decides to strike you with lightning, one, there's nothing you can do about it." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_GodsMetaphor> ] ;
    narr:variation [ narr:text "Several children aren't metaphors at all but brand-stylization and syntax notes (lowercase 'i', staccato fragments, 'aswritten' casing) — outliers in kind under a Metaphor hub." ; narr:over <https://aswritten.ai/narrative#StyleObs_1> ; narr:over <https://aswritten.ai/narrative#StyleObs_12> ] ;
    narr:variation [ narr:text "Metaphor authorship is not Scarlet-only: Tony (hotel), the customer's chief architect (financial scale), the customer's CTO (engineering), a design collaborator (infrastructure) each deploy their own idiomatic frames." ; narr:over <https://aswritten.ai/narrative#StyleObs_TonyMetaphorHotel> ; narr:over <https://aswritten.ai/narrative#StyleObs_CustomerArchitectMetaphorUse> ; narr:over <https://aswritten.ai/narrative#StyleObs_EngineeringMetaphor> ; narr:over <https://aswritten.ai/narrative#StyleObs_DesignCollaborator_Metaphor> ] ;
    narr:variation [ narr:text "Tonal split: most metaphors aggrandize (gods of Olympus, Holy Grail, religion), but some are self-deprecating/ironic (developer as cron job, slots at the gas station)." ; narr:over <https://aswritten.ai/narrative#StyleObs_GodsMetaphor> ; narr:over <https://aswritten.ai/narrative#StyleObs_HolyGrail> ; narr:over <https://aswritten.ai/narrative#StyleObs_CronJobMetaphor> ; narr:over <https://aswritten.ai/narrative#StyleObs_SlotsAtGasStation> ] ;
    narr:variation [ narr:text "Register span pulls opposite ways: clean technical/infra analogies vs visceral body/affect metaphors (foot cut off, addiction withdrawal, burning away)." ; narr:over <https://aswritten.ai/narrative#StyleObs_FootCutOff> ; narr:over <https://aswritten.ai/narrative#StyleObs_MissingDrugMetaphor> ; narr:over <https://aswritten.ai/narrative#StyleObs_BurningAwayMetaphor> ] ;
    narr:variation [ narr:text "Some metaphors deliberately minimize alarm (scaffolding 'waiting for real data', system sketch) where others heighten stakes — rhetorical intent diverges." ; narr:over <https://aswritten.ai/narrative#StyleObs_ScaffoldingMetaphor> ; narr:over <https://aswritten.ai/narrative#StyleObs_SystemSketchMetaphor> ] ;
