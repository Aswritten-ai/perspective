    narr:keyPhrase [ narr:text "intellectual property as code" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_IPAsCode> ] ;
    narr:keyPhrase [ narr:text "context squishing" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_ContextSquishing> ] ;
    narr:keyPhrase [ narr:text "git native, i.e. versionable, branchable, reviewable" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_GitNativeTriad> ] ;
    narr:keyPhrase [ narr:text "**Memory**: Ephemeral user content (chat message, Discourse post, uploaded doc)" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Obs_MemoryDefinition> ] ;
    narr:keyPhrase [ narr:text "**Transaction**: Graph changes (insert/delete operations)" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Obs_TransactionDefinition> ] ;
    narr:variation [ narr:text "Tension exists between automated summarization and the project's insistence on 'intentional' manual curation." ; narr:over <https://aswritten.ai/ns/narrative#Observation_ContextSquishing> ; narr:over <https://aswritten.ai/ns/narrative#Observation_IntentionalMemory> ] ;
    narr:variation [ narr:text "The use of 'SSoT' (Single Source of Truth) sits in potential friction with the 'git-native' paradigm of branching and multiple versions." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_7> ; narr:over <https://aswritten.ai/ns/narrative#Observation_GitNativeTriad> ] ;
