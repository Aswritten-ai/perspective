@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_PerspectiveOnSpec> {
  <https://aswritten.ai/narrative#Digest_Narrative_PerspectiveOnSpec> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_PerspectiveOnSpec> ;
    narr:childCount "7"^^xsd:integer ;
    narr:generatedFrom "737314f6fd80008449dd6f6a60df5649df23660f" ;
    narr:narration """This hub gathers the thesis that a perspective built *on spec* — before any prospect interview — is itself the pitch. The throughline: [the demo is the sale](narr:Position_DemoIsTheSale), since a perspective-grounded agent that navigates a prospect's own funnel proves understanding without their time. Because [interviews don't scale but public content does](narr:Position_ExistingContentScales), podcasts, blogs and YouTube become the [bootstrap substrate for outbound](narr:Position_PublicContentBootstrapOnramp). A reframe argues [the medium, not fidelity, is the message](narr:Position_MediumIsTheMessage) — the transparent back-and-forth agent compels regardless of the perspective's absolute accuracy. On 20260421 the cold-outreach tactic firmed: Scarlet floated aggressive clone-as-you outreach; [Tony softened it](narr:Position_OutboundVariantSoftening) toward a bounded, less-scary script. In July 2026 a new pattern entered: [the 48-hour bespoke artifact as generosity-as-demonstration](narr:Narrative_GenerosityAsDemonstration), with [its systematic operationalization](narr:Position_48HourGiftSystematic) — the prospect's own first call extracted into a demo perspective branch. The region spans go-to-market mechanics (demo, outbound, content seeding) and the product-philosophy question of what actually compels.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_GenerosityAsDemonstration> ;
    narr:covers <https://aswritten.ai/narrative#Position_48HourGiftSystematic> ;
    narr:covers <https://aswritten.ai/narrative#Position_DemoIsTheSale> ;
    narr:covers <https://aswritten.ai/narrative#Position_ExistingContentScales> ;
    narr:covers <https://aswritten.ai/narrative#Position_MediumIsTheMessage> ;
    narr:covers <https://aswritten.ai/narrative#Position_OutboundVariantSoftening> ;
    narr:covers <https://aswritten.ai/narrative#Position_PublicContentBootstrapOnramp> ;
    narr:keyPhrase [ narr:text "The demo IS the sale: the prospect receives a perspective-grounded agent that proves it understands their business by navigating their own funnel and hitting their contact channel." ; narr:phraseSource <https://aswritten.ai/narrative#Position_DemoIsTheSale> ] ;
    narr:keyPhrase [ narr:text "Interviews don't scale, but existing public content (podcasts, blogs, YouTube) does." ; narr:phraseSource <https://aswritten.ai/narrative#Position_ExistingContentScales> ] ;
    narr:keyPhrase [ narr:text "The compelling part of the product is the MEDIUM (the transparent agent that can go back and forth), not necessarily the perspective's absolute fidelity." ; narr:phraseSource <https://aswritten.ai/narrative#Position_MediumIsTheMessage> ] ;
    narr:keyPhrase [ narr:text "a perspective trained on a singular artifact is lower fidelity than one built with self-directing interactive feedback — so don't overpromise" ; narr:phraseSource <https://aswritten.ai/narrative#Position_OutboundVariantSoftening> ] ;
    narr:keyPhrase [ narr:text "The bounded claim ('I've cloned your voice for PR questions, try me') is the correct cold outreach script." ; narr:phraseSource <https://aswritten.ai/narrative#Position_OutboundVariantSoftening> ] ;
    narr:keyPhrase [ narr:text "The most effective sales move is an unsolicited bespoke artifact delivered within 48 hours of a values-resonance call — generosity as demonstration, not pitch" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_GenerosityAsDemonstration> ] ;
    narr:keyPhrase [ narr:text "With permission, the prospect's own first call is extracted into a demo perspective branch — the deli story manufactured from the conversation itself. This is the aswritten operationalization of generosity-as-demonstration." ; narr:phraseSource <https://aswritten.ai/narrative#Position_48HourGiftSystematic> ] ;
    narr:variation [ narr:text "Medium-over-fidelity vs. fidelity-matters: the medium thesis says absolute accuracy is secondary, but the outbound-softening guardrail insists a single-artifact perspective is lower fidelity and must not be overpromised — a live tension about how much fidelity actually matters for conversion." ; narr:over <https://aswritten.ai/narrative#Position_MediumIsTheMessage> ; narr:over <https://aswritten.ai/narrative#Position_OutboundVariantSoftening> ] ;
    narr:variation [ narr:text "Aggressive clone-as-you outreach (Scarlet's original framing) vs. the bounded, less-scary script Tony advocated — the hub holds both without resolving which converts better." ; narr:over <https://aswritten.ai/narrative#Position_OutboundVariantSoftening> ] ;
    narr:variation [ narr:text "Public-content bootstrap (no prospect time) vs. the July 2026 generosity pattern (requires a values-resonance call first) — two different on-ramps with different prospect-relationship assumptions." ; narr:over <https://aswritten.ai/narrative#Position_PublicContentBootstrapOnramp> ; narr:over <https://aswritten.ai/narrative#Narrative_GenerosityAsDemonstration> ; narr:over <https://aswritten.ai/narrative#Position_48HourGiftSystematic> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}