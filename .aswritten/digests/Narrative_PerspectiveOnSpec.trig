@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_PerspectiveOnSpec> {
  <https://aswritten.ai/narrative#Digest_Narrative_PerspectiveOnSpec> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_PerspectiveOnSpec> ;
    narr:childCount "7"^^xsd:integer ;
    narr:generatedFrom "d8cc59ed0be02489cca218a90013bea807c23de0" ;
    narr:narration """This hub explores the thesis that a perspective built *on spec* functions as the primary sales instrument. The core through-line holds that [the demo is the sale](narr:Position_DemoIsTheSale), where an agent proves its utility by navigating a prospect's funnel autonomously. Because [interviews don't scale but public content does](narr:Position_ExistingContentScales), existing media serves as the [bootstrap substrate for outbound](narr:Position_PublicContentBootstrapOnramp). A persistent tension exists regarding the product's value proposition: while some argue [the medium, not fidelity, is the message](narr:Position_MediumIsTheMessage), others emphasize the necessity of managing prospect comfort. By April 2026, this manifested in [outbound script softening](narr:Position_OutboundVariantSoftening), moving from aggressive cloning to bounded, permission-based invitations. By July 2026, the strategy evolved into [generosity-as-demonstration](narr:Narrative_GenerosityAsDemonstration), where the [48-hour bespoke artifact](narr:Position_48HourGiftSystematic) operationalizes the extraction of a prospect's own first-call content into a demo branch, shifting the focus from cold speculation to immediate, value-added proof.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_GenerosityAsDemonstration> ;
    narr:covers <https://aswritten.ai/narrative#Position_48HourGiftSystematic> ;
    narr:covers <https://aswritten.ai/narrative#Position_DemoIsTheSale> ;
    narr:covers <https://aswritten.ai/narrative#Position_ExistingContentScales> ;
    narr:covers <https://aswritten.ai/narrative#Position_MediumIsTheMessage> ;
    narr:covers <https://aswritten.ai/narrative#Position_OutboundVariantSoftening> ;
    narr:covers <https://aswritten.ai/narrative#Position_PublicContentBootstrapOnramp> ;
    narr:keyPhrase [ narr:text "The demo IS the sale" ; narr:phraseSource <https://aswritten.ai/narrative#Position_DemoIsTheSale> ] ;
    narr:keyPhrase [ narr:text "The most effective sales move is an unsolicited bespoke artifact delivered within 48 hours" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_GenerosityAsDemonstration> ] ;
    narr:keyPhrase [ narr:text "You don't want it to be so scary that they're freaked out by it" ; narr:phraseSource <https://aswritten.ai/narrative#Position_OutboundVariantSoftening> ] ;
    narr:keyPhrase [ narr:text "the prospect's own first call is extracted into a demo perspective branch" ; narr:phraseSource <https://aswritten.ai/narrative#Position_48HourGiftSystematic> ] ;
    narr:variation [ narr:text "High-fidelity cloning vs. bounded, low-risk utility scripts" ; narr:over <https://aswritten.ai/narrative#Position_OutboundVariantSoftening> ] ;
    narr:variation [ narr:text "Medium-centric engagement (the agent's interactivity) vs. content-centric engagement (the perspective's accuracy)" ; narr:over <https://aswritten.ai/narrative#Position_MediumIsTheMessage> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}