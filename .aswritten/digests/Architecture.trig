@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Architecture> {
  <https://aswritten.ai/narrative#Digest_Architecture> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Architecture> ;
    narr:childCount "21"^^xsd:integer ;
    narr:generatedFrom "efc98fe0b6fedaa11f685ef830f45296dfc96569" ;
    narr:narration """This hub tracks the architectural evolution of aswritten, centering on the transition from brute-force graph compilation to [structural index + LLM selection](narr:Narrative_ContextArch_3). The core thesis posits [RDF propositions as the semantic layer](narr:Narrative_ContextArch_2) that bridges logic and natural language, favoring [associative LLM retrieval over formal SPARQL](narr:Position_ContextArch_1) to capture context-heavy organizational memory. This shift necessitates a tool redesign: [scope as a windowed-graph tool](narr:Position_ScopeIsNewSeparateTool) effectively [deprecates worldview domain layers](narr:Position_WorldviewDomainLayersDeprecated), while [compile remains a focus-free bootstrap](narr:Position_CompileNoFocusParam) to ensure grounding in the full organizational context. The lens architecture has matured into a [generator-based model](narr:Position_LensToolIsGenerator) where [lenses are compound](narr:Position_LensIsCompoundNotStacked) rather than stacked, and [text refraction and eye charts are treated as identical operations](narr:Position_TextAndEyeChartSameOperation). Finally, the system distinguishes between [deterministic and LLM-driven operations](narr:Arch_PaywallBoundary), reinforcing the principle that [transactions and memory are the durable source of truth](narr:Narrative_MemoryAsSourceOfTruth), while generated documents remain transient.""" ;
    narr:covers <https://aswritten.ai/narrative#Arch_PaywallBoundary> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_2> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ContextArch_2> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ContextArch_3> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_LossyCompressionProblem> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_MemoryAsSourceOfTruth> ;
    narr:covers <https://aswritten.ai/narrative#Obs_TransactionSourceOfTruth> ;
    narr:covers <https://aswritten.ai/narrative#Position_AbsenceIsIntrospect> ;
    narr:covers <https://aswritten.ai/narrative#Position_CompileNoFocusParam> ;
    narr:covers <https://aswritten.ai/narrative#Position_ContextArch_1> ;
    narr:covers <https://aswritten.ai/narrative#Position_ContextArch_2> ;
    narr:covers <https://aswritten.ai/narrative#Position_ContextArch_3> ;
    narr:covers <https://aswritten.ai/narrative#Position_ContextArch_6> ;
    narr:covers <https://aswritten.ai/narrative#Position_EyeChartIsDocumentBeingEvaluated> ;
    narr:covers <https://aswritten.ai/narrative#Position_IntrospectNoSubgraphReturn> ;
    narr:covers <https://aswritten.ai/narrative#Position_LensIsCompoundNotStacked> ;
    narr:covers <https://aswritten.ai/narrative#Position_LensToolIsGenerator> ;
    narr:covers <https://aswritten.ai/narrative#Position_ScopeIsNewSeparateTool> ;
    narr:covers <https://aswritten.ai/narrative#Position_TextAndEyeChartSameOperation> ;
    narr:covers <https://aswritten.ai/narrative#Position_WorldviewDomainLayersDeprecated> ;
    narr:covers <https://aswritten.ai/narrative#Position_WorldviewSummaryIsAlreadyLens> ;
    narr:keyPhrase [ narr:text "RDF triples mirror natural language grammar" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ContextArch_2> ] ;
    narr:keyPhrase [ narr:text "structural index + LLM selection is the replacement" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ContextArch_3> ] ;
    narr:keyPhrase [ narr:text "compile(layer=worldview) is ~4-8K editorially compressed tokens" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_LossyCompressionProblem> ] ;
    narr:keyPhrase [ narr:text "the transaction/memory graph is the durable source of truth" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_TransactionSourceOfTruth> ] ;
    narr:keyPhrase [ narr:text "A real RDF query engine is not needed yet" ; narr:phraseSource <https://aswritten.ai/narrative#Position_ContextArch_6> ] ;
    narr:variation [ narr:text "The reliance on LLM-driven extraction and generation accepts compounding imprecision as an acceptable baseline." ; narr:over <https://aswritten.ai/narrative#Position_ContextArch_6> ] ;
    narr:variation [ narr:text "Introspect is defined as the mechanism for handling absence, though some views suggest this overlaps with lens shift dimensions." ; narr:over <https://aswritten.ai/narrative#Position_AbsenceIsIntrospect> ] ;
    narr:variation [ narr:text "Returning subgraph content alongside introspect analysis is explicitly rejected to prevent attention dilution." ; narr:over <https://aswritten.ai/narrative#Position_IntrospectNoSubgraphReturn> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}