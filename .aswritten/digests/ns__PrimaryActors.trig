@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__PrimaryActors> {
  <https://aswritten.ai/narrative#Digest_ns__PrimaryActors> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#PrimaryActors> ;
    narr:childCount "5"^^xsd:integer ;
    narr:generatedFrom "75095ac1d69196914bb4f5d010de7d57a4acd0ce" ;
    narr:narration """This hub maintains the evolving definition of the product's primary actors, mapping the tension between individual technical users and organizational decision-makers. The current thematic span balances [git-fluent practitioners](narr:Narrative_SIC_PrimaryActors_1)—those with direct AI-coding fluency—against the [seed-stage buying trio](narr:Observation_PrimaryActors_CEOStratCTO) of CEOs, Heads of Strategy, and CTOs who prioritize alignment and technical validation. These actors are unified by specific friction points: the [brittleness of current coding agents](narr:ActorPain_CodingAgents) that fail to maintain context, the [generic nature of automated content](narr:ActorPain_ContentGeneration) that lacks organizational depth, and the [lack of strategic memory](narr:ActorPain_ExecutiveAssistants) in current executive assistant tooling. The hub remains an open set of personas and pain-points rather than a singular profile, reflecting a transition from individual utility to organizational strategic alignment.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#ActorPain_CodingAgents> ;
    narr:covers <https://aswritten.ai/ns/narrative#ActorPain_ContentGeneration> ;
    narr:covers <https://aswritten.ai/ns/narrative#ActorPain_ExecutiveAssistants> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_SIC_PrimaryActors_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#Observation_PrimaryActors_CEOStratCTO> ;
    narr:keyPhrase [ narr:text "Coding agents (Claude Code, Cursor) rely on brittle personas (\"You are a senior developer\") and scattered docs" ; narr:phraseSource <https://aswritten.ai/ns/narrative#ActorPain_CodingAgents> ] ;
    narr:keyPhrase [ narr:text "Content generation produces generic output disconnected from actual organizational perspective" ; narr:phraseSource <https://aswritten.ai/ns/narrative#ActorPain_ContentGeneration> ] ;
    narr:keyPhrase [ narr:text "Executive assistants lack persistent memory of strategic decisions, priorities, worldview" ; narr:phraseSource <https://aswritten.ai/ns/narrative#ActorPain_ExecutiveAssistants> ] ;
    narr:variation [ narr:text "Tension exists between targeting the individual 'git-fluent' power user versus the organizational 'buying trio' focused on consensus." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_SIC_PrimaryActors_1> ; narr:over <https://aswritten.ai/ns/narrative#Observation_PrimaryActors_CEOStratCTO> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}