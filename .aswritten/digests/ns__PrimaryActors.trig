@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__PrimaryActors> {
  <https://aswritten.ai/narrative#Digest_ns__PrimaryActors> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#PrimaryActors> ;
    narr:childCount "9"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """This hub gathers the cast of who the product is *for* and *with* — and the children do not agree on a single primary actor. The audience is drawn three ways: [git-fluent practitioners](narr:Narrative_SIC_PrimaryActors_1) (entrepreneurs, designers, developers, consultants), [the seed-stage buying trio](narr:Observation_PrimaryActors_CEOStratCTO) of CEOs/Heads of Strategy/CTOs, and [small creative & consulting agencies](narr:Narrative_TargetMarket) of 5-50 people. The pains motivating them span [coding-agent brittleness](narr:ActorPain_CodingAgents), [generic content output](narr:ActorPain_ContentGeneration), and [assistants without strategic memory](narr:ActorPain_ExecutiveAssistants). Alongside the abstract personas sit three named, concrete people: [Tony Maley](narr:Actor_TonyMaley), prospective co-founder still tied to a collaborator; [the customer's chief architect](narr:Actor_CustomerArchitect), the knowledge-bottleneck exemplar at the enterprise customer; and [AJ at a collaborator](narr:Actor_Lark), an ecosystem connector valued for introductions, not revenue. Together they cover buyer, user, champion, and exemplar-of-the-problem — a span, not a settled profile.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#ActorPain_CodingAgents> ;
    narr:covers <https://aswritten.ai/ns/narrative#ActorPain_ContentGeneration> ;
    narr:covers <https://aswritten.ai/ns/narrative#ActorPain_ExecutiveAssistants> ;
    narr:covers <https://aswritten.ai/ns/narrative#Actor_Lark> ;
    narr:covers <https://aswritten.ai/ns/narrative#Actor_CustomerArchitect> ;
    narr:covers <https://aswritten.ai/ns/narrative#Actor_TonyMaley> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_SIC_PrimaryActors_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_TargetMarket> ;
    narr:covers <https://aswritten.ai/ns/narrative#Observation_PrimaryActors_CEOStratCTO> ;
    narr:keyPhrase [ narr:text "Seed/Series A CEOs (decision authority, feel pain acutely), Heads of Strategy (consensus chase, alignment), CTOs (technical validation, git-native understanding)." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_PrimaryActors_CEOStratCTO> ] ;
    narr:keyPhrase [ narr:text "Programming literate entrepreneurs, designers, developers, consultants with Git and basic AI coding fluency." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_SIC_PrimaryActors_1> ] ;
    narr:keyPhrase [ narr:text "Primary: Creative agencies, consulting firms, digital agencies (5-50 people). Not tech startups (will build themselves), not enterprise (too slow)." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_TargetMarket> ] ;
    narr:keyPhrase [ narr:text "Executive assistants lack persistent memory of strategic decisions, priorities, worldview" ; narr:phraseSource <https://aswritten.ai/ns/narrative#ActorPain_ExecutiveAssistants> ] ;
    narr:keyPhrase [ narr:text "if only we could get AI to duplicate the customer's chief architect's brain." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Actor_CustomerArchitect> ] ;
    narr:keyPhrase [ narr:text "Role if formalized: Co-founder, angel network, GTM strategy" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Actor_TonyMaley> ] ;
    narr:variation [ narr:text "Who the primary actor *is* differs across children: individual git-fluent practitioners vs. the seed-stage CEO/Strategy/CTO trio vs. agencies as organizational buyers — three different unit-of-sale framings." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_SIC_PrimaryActors_1> ; narr:over <https://aswritten.ai/ns/narrative#Observation_PrimaryActors_CEOStratCTO> ; narr:over <https://aswritten.ai/ns/narrative#Narrative_TargetMarket> ] ;
    narr:variation [ narr:text "TargetMarket explicitly excludes the tech-startup/enterprise segments that the CEO/CTO trio framing leans toward ('Not tech startups... not enterprise'), a direct push against the seed-stage reading." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_TargetMarket> ; narr:over <https://aswritten.ai/ns/narrative#Observation_PrimaryActors_CEOStratCTO> ] ;
    narr:variation [ narr:text "Named individuals occupy distinct, non-overlapping roles — co-founder (Tony), problem-exemplar (the customer's chief architect), non-paying connector (AJ) — and AJ is flagged 'not necessarily in position to pay,' an actor who is influence rather than revenue." ; narr:over <https://aswritten.ai/ns/narrative#Actor_TonyMaley> ; narr:over <https://aswritten.ai/ns/narrative#Actor_CustomerArchitect> ; narr:over <https://aswritten.ai/ns/narrative#Actor_Lark> ] ;
    narr:variation [ narr:text "TargetMarket attaches via skos:related while the persona/pain children attach via skos:broader — it is a channel/segment lens, structurally distinct from the actor definitions." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_TargetMarket> ] ;
    narr:writer "claude (subscription)" .
}