    narr:childCount "12"^^xsd:integer ;
    narr:generatedFrom "c7a063b08d28d1d04a5e5e660431761ed9488987" ;
    narr:narration """This hub gathers per-document flow assessments, each judging logical progression, transitions, and structural coherence across the corpus. The dominant verdict is positive. Revenue docs trace [pricing→levers→projections](narr:Assess_Flow_RevenueModelTAM) and [problem→pricing→licensing→process](narr:RubricAssess_Flow_GTM) with implicit but clear transitions and guiding section headers. Narrative docs — the [YC application](narr:Assessment_Flow_YC) and [YC call](narr:Rubric_Flow_YC_Call) — run founding story→vision→demo storyboard with coherent logical flow. The [origin/founder narrative](narr:RubricAssess_Flow) uses chronological arc (2012→2019→Vouch→aswritten) with explicit connectives and a synthesizing Through-Line section, though one assessment flags some transitions as abrupt and notes the text as a raw draft. Call notes — [customer architect](narr:Rubric_Flow_CustomerArchitect), [founder beta user](narr:Rubric_Flow_FounderBetaUser), [weekly call](narr:RubricAssess_Flow_WeeklyCall) — move context→validation→next steps, with transitions ranging from explicit connectives to implicit topic headers. Planning docs ([pilot plan](narr:Rubric_Flow_PilotPlan), [demo beats](narr:Rubric_Flow_YCDemoBeats)) favor parallel structure. The [Scarlet Dame profile](narr:Rubric_Flow_ScarletDame) uses chronological career arc with a section that signals incompleteness transparently. The recurring axis of judgment: whether transitions read as natural connective tissue or formulaic scaffolding.""" ;
    narr:covers <https://aswritten.ai/narrative#Assess_Flow_RevenueModelTAM> ;
    narr:covers <https://aswritten.ai/narrative#Assessment_Flow_YC> ;
    narr:covers <https://aswritten.ai/narrative#RubricAssess_Flow> ;
    narr:covers <https://aswritten.ai/narrative#RubricAssess_Flow_GTM> ;
    narr:covers <https://aswritten.ai/narrative#RubricAssess_Flow_WeeklyCall> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Assess_Flow> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Flow_CustomerArchitect> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Flow_FounderBetaUser> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Flow_PilotPlan> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Flow_ScarletDame> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Flow_YCDemoBeats> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Flow_YC_Call> ;
    narr:keyPhrase [ narr:text "Logical progression: revenue model → metric reframe → TAM expansion → contract tiers → expansion path. Section headers guide; transitions implicit but clear." ; narr:phraseSource <https://aswritten.ai/narrative#Assess_Flow_RevenueModelTAM> ] ;
    narr:keyPhrase [ narr:text "Natural progression: founding story → application decisions → tagline → demo storyboard → conviction framework → differentiation → vision → why YC. Coherent, logical flow." ; narr:phraseSource <https://aswritten.ai/narrative#Assessment_Flow_YC> ] ;
    narr:keyPhrase [ narr:text "Chronological progression (2012 → 2019 → Vouch → aswritten) provides natural flow. Some transitions abrupt; could benefit from smoother connective tissue. Noted as 'raw draft' by author." ; narr:phraseSource <https://aswritten.ai/narrative#RubricAssess_Flow> ] ;
    narr:keyPhrase [ narr:text "Transitions are implicit (topic headers) rather than explicit connectives." ; narr:phraseSource <https://aswritten.ai/narrative#RubricAssess_Flow_WeeklyCall> ] ;
    narr:keyPhrase [ narr:text "some formulaic headings but content is organic." ; narr:phraseSource <https://aswritten.ai/narrative#Rubric_Assess_Flow> ] ;
    narr:keyPhrase [ narr:text "Minor formulaic structure in case study sections, but overall coherent." ; narr:phraseSource <https://aswritten.ai/narrative#Rubric_Flow_CustomerArchitect> ] ;
    narr:keyPhrase [ narr:text "'Pending Questions' section signals incompleteness transparently. Minimal formulaicness." ; narr:phraseSource <https://aswritten.ai/narrative#Rubric_Flow_ScarletDame> ] ;
    narr:keyPhrase [ narr:text "Clear three-act structure; natural progression from problem→solution→propagation; transitions between beats are logical; Why This Works section provides coherent summary" ; narr:phraseSource <https://aswritten.ai/narrative#Rubric_Flow_YCDemoBeats> ] ;
    narr:variation [ narr:text "The origin/founder narrative receives split verdicts: one assessment calls transitions clear with minimal formulaic scaffolding; another flags some transitions as abrupt and marks the text a 'raw draft' needing smoother connective tissue." ; narr:over <https://aswritten.ai/narrative#RubricAssess_Flow> ] ;
    narr:variation [ narr:text "Weekly call transitions are implicit (topic headers only), not explicit connectives — a structural mode distinct from the explicit 'This is significant:' / 'Scarlet connected' connectives praised in the customer architect notes." ; narr:over <https://aswritten.ai/narrative#RubricAssess_Flow_WeeklyCall> ; narr:over <https://aswritten.ai/narrative#Rubric_Flow_CustomerArchitect> ] ;
    narr:variation [ narr:text "Formulaic scaffolding is flagged as a minor concern in the customer architect call and the general rubric assessment, even where overall flow is judged coherent — a recurring qualification against the dominant positive verdict." ; narr:over <https://aswritten.ai/narrative#Rubric_Flow_CustomerArchitect> ; narr:over <https://aswritten.ai/narrative#Rubric_Assess_Flow> ] ;
    narr:variation [ narr:text "The founder beta user assessment notes some sections could be tightened — a tightness/completeness concern absent from most other assessments." ; narr:over <https://aswritten.ai/narrative#Rubric_Flow_FounderBetaUser> ] ;
