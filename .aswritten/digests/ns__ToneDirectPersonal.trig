@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__ToneDirectPersonal> {
  <https://aswritten.ai/narrative#Digest_ns__ToneDirectPersonal> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#ToneDirectPersonal> ;
    narr:childCount "6"^^xsd:integer ;
    narr:generatedFrom "f4eb501cba9eb1c2564fcad7a4e422ece7d57552" ;
    narr:narration """This hub tracks the evolution of a [direct, second-person, personal voice](narr:StyleObs_7) used to frame product value and technical utility. The register is consistently [imperative and action-oriented](narr:StyleObs_DirectTone), relying on [confident, declarative clauses](narr:StyleObs_5) to establish authority. This voice [assumes reader agency](narr:StyleObs_7) by positioning the product as an extension of the user's workflow, often through [conversational, outcome-first descriptions](narr:StyleObs_CustomerArchitectPitch_DirectSpeech). A distinct rhetorical technique involves [visceral impossibility framing](narr:StyleObs_YouCantFraming), which shifts the focus from the difficulty of a task to its fundamental unfeasibility without the tool. While the tone remains [consistently instructional](narr:StyleObs_Tone_DirectImperative), the underlying strategy moves between inviting the user to 'pilot' and asserting the necessity of the tool to overcome structural knowledge gaps.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_5> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_7> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_CustomerArchitectPitch_DirectSpeech> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_DirectTone> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_Tone_DirectImperative> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_YouCantFraming> ;
    narr:keyPhrase [ narr:text "Add collective memory to your repo, never write README again" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_DirectTone> ] ;
    narr:keyPhrase [ narr:text "you can connect that to anything that you could automate with Zapier" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_7> ] ;
    narr:keyPhrase [ narr:text "(You can't)" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_YouCantFraming> ] ;
    narr:keyPhrase [ narr:text "an AI tool that extracts undocumented knowledge from senior members of staff in a conversational way" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_CustomerArchitectPitch_DirectSpeech> ] ;
    narr:variation [ narr:text "The shift from 'instructional' (how to use) to 'impossibility' (why you must) creates a tension between helpfulness and alarmism." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_7> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_YouCantFraming> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}