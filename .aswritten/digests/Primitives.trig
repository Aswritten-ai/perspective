@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Primitives> {
  <https://aswritten.ai/narrative#Digest_Primitives> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Primitives> ;
    narr:childCount "10"^^xsd:integer ;
    narr:generatedFrom "7898c09e272e8fa67049947e5466f3c2f2623b4f" ;
    narr:narration """This hub defines the core structural primitives of the aswritten knowledge graph, centered on the [content/commentary split](narr:https://aswritten.ai/narrative#Narrative_ContentCommentarySplit) established in July 2026. This design mandates that primary source material and authored commentary occupy distinct layers, ensuring that while the read model is already reconciled, the write practice remains in transition. Complementing this is the definition of [reconciliation as a set transaction](narr:https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction), which treats commentary as a formal transaction over a specific, user-verified referent set of graph nodes. This approach prioritizes legibility, forcing the system to surface exactly what it is reasoning from. Broader architectural explorations include [shared agent memory](narr:https://aswritten.ai/narrative#Narrative_SharedAgentMemory) for collaborative knowledge distribution and [conversational AI interview extraction](narr:https://aswritten.ai/narrative#Observation_ApproachPattern_1) as the primary ingestion method. Several nodes, including definitions for [refract](narr:https://aswritten.ai/narrative#Position_RefractDefinition), [scope](narr:https://aswritten.ai/narrative#Position_ScopeDefinition), and [transaction-as-prompt](narr:https://aswritten.ai/narrative#Position_TXIsPrompt), are registered as placeholders for future semantic grounding.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_SharedAgentMemory> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ContentCommentaryKeystoneQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ReconciliationSetTransactionQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletGoalDefinition> ;
    narr:covers <https://aswritten.ai/narrative#Observation_ApproachPattern_1> ;
    narr:covers <https://aswritten.ai/narrative#Position_RefractDefinition> ;
    narr:covers <https://aswritten.ai/narrative#Position_ScopeDefinition> ;
    narr:covers <https://aswritten.ai/narrative#Position_TXIsPrompt> ;
    narr:keyPhrase [ narr:text "Content/commentary split: per-message integration is the content layer; reconciliation is the authored commentary layer" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ] ;
    narr:keyPhrase [ narr:text "Reconciliation is a transaction about a set of transactions or nodes — the design of correction and commentary about the past" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction> ] ;
    narr:keyPhrase [ narr:text "aswritten uses conversational AI interviews to extract expert knowledge, storing it in git-native collective memory accessible to agents." ; narr:phraseSource <https://aswritten.ai/narrative#Observation_ApproachPattern_1> ] ;
    narr:variation [ narr:text "The rich transcription format and resolve tool mentioned in previous iterations are absent from the current child set." ; narr:over <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}