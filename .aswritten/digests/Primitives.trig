@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Primitives> {
  <https://aswritten.ai/narrative#Digest_Primitives> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Primitives> ;
    narr:childCount "12"^^xsd:integer ;
    narr:generatedFrom "b6a9d4d918338cfce5a392033500736cbdfb157d" ;
    narr:narration """This hub gathers the write primitives and structural definitions underlying the aswritten knowledge graph. The keystone design, articulated on 20260701, is the [content/commentary split](narr:https://aswritten.ai/narrative#Narrative_ContentCommentarySplit): per-message integration is the content layer; reconciliation is the authored commentary layer. That split is already reflected in the read model but had not yet been implemented in the write practice at the time of recording. Alongside it, [reconciliation as a set transaction](narr:https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction) defines reconciliation structurally as a transaction about a set of prior transactions or nodes — the legibility differentiator that surfaces the referent set explicitly to the user. The [resolve tool](narr:https://aswritten.ai/narrative#Narrative_ResolveToolInverseOfCite) is the inverse of cite: it finds the nodes commentary is about, runs once per pipeline run, and binds each reconciliation to its own subset. Source is append-only; all merge and supersession live in the reconciliation layer. A structurally distinct child, dated 20260704, introduces the [rich transcription format](narr:https://aswritten.ai/narrative#Narrative_RichTranscriptionFormat) with a per-span acoustic signal sidecar. [Shared agent memory](narr:https://aswritten.ai/narrative#Narrative_SharedAgentMemory) and [conversational AI interview extraction](narr:https://aswritten.ai/narrative#Observation_ApproachPattern_1) appear as related but thinner entries. Three claim children — covering refract, scope, and TX-as-prompt definitions — are named but carry no content yet.""" ;
    narr:covers <https://aswritten.ai/narrative#Claim_RefractDefinition> ;
    narr:covers <https://aswritten.ai/narrative#Claim_ScopeDefinition> ;
    narr:covers <https://aswritten.ai/narrative#Claim_TXIsPrompt> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ResolveToolInverseOfCite> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_RichTranscriptionFormat> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_SharedAgentMemory> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ContentCommentaryKeystoneQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ReconciliationSetTransactionQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletGoalDefinition> ;
    narr:covers <https://aswritten.ai/narrative#Observation_ApproachPattern_1> ;
    narr:keyPhrase [ narr:text "per-message integration captures primary source material (content layer); reconciliation is authored commentary about a referent set of previously extracted nodes (commentary layer)" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ] ;
    narr:keyPhrase [ narr:text "This is a write primitive that is read-implemented but not yet written." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ] ;
    narr:keyPhrase [ narr:text "Disambiguate, never permission — the prompt rule." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ReconciliationAsSetTransaction> ] ;
    narr:keyPhrase [ narr:text "Source is append-only and never deduplicated; all dedup/merge/supersession lives in the reconciliation layer." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ResolveToolInverseOfCite> ] ;
    narr:keyPhrase [ narr:text "Resolve once per pipeline run; bind each reconciliation statement to its own subset of the resolved set" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ResolveToolInverseOfCite> ] ;
    narr:keyPhrase [ narr:text "The signal sidecar carries per-span acoustic features (f0_hz, db, rate_wps, pitch_z, energy_z, conf, pause_s)." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_RichTranscriptionFormat> ] ;
    narr:variation [ narr:text "The content/commentary split is read-implemented but not yet written as of 20260701 — a live asymmetry between the read model and write practice, not a resolved design." ; narr:over <https://aswritten.ai/narrative#Narrative_ContentCommentarySplit> ] ;
    narr:variation [ narr:text "Whole-set citation 'bleeds at read time' — binding a reconciliation to the full resolved set rather than its own subset is an explicit anti-pattern, creating a tension between resolve-once efficiency and per-statement precision." ; narr:over <https://aswritten.ai/narrative#Narrative_ResolveToolInverseOfCite> ] ;
    narr:variation [ narr:text "The rich transcription format (acoustic sidecar, delivery annotations) is structurally distinct from the write-primitive cluster — it concerns capture fidelity, not graph write semantics, and may belong to a different thematic region." ; narr:over <https://aswritten.ai/narrative#Narrative_RichTranscriptionFormat> ] ;
    narr:variation [ narr:text "Three named claim children (RefractDefinition, ScopeDefinition, TXIsPrompt) carry no content — their definitions are structurally present but unwitnessed, leaving core vocabulary terms opaque in this hub." ; narr:over <https://aswritten.ai/narrative#Claim_RefractDefinition> ; narr:over <https://aswritten.ai/narrative#Claim_ScopeDefinition> ; narr:over <https://aswritten.ai/narrative#Claim_TXIsPrompt> ] ;
    narr:variation [ narr:text "Shared agent memory is proposed (Tony/Scarlet exchange) but undated and thin — it may represent an aspirational direction rather than an implemented primitive, unlike the 20260701 write-primitive cluster." ; narr:over <https://aswritten.ai/narrative#Narrative_SharedAgentMemory> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}