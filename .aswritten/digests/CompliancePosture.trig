@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_CompliancePosture> {
  <https://aswritten.ai/narrative#Digest_CompliancePosture> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#CompliancePosture> ;
    narr:childCount "5"^^xsd:integer ;
    narr:generatedFrom "ff795e335a68f7de99d4fd45d165b85c1c14b1d8" ;
    narr:narration """The compliance posture at aswritten continues to evolve as a tension between productized tiers and bespoke requirements-driven deployment. The core narrative maintains that [on-premise deployment is a compliance-triggered add-on](narr:Narrative_OnPremAsRequirementsDriven) rather than a defining feature of the Professional tier, with [consultant-led knowledge extraction](narr:Position_OnPremNotDefiningFeature) serving as the primary value differentiator. This framing, recently reinforced by [canonical examples of Team-to-Professional upgrades](narr:Obs_OnPremHIPAAQuote) driven by HIPAA needs, positions compliance as a functional gateway rather than a static product attribute. Simultaneously, the underlying trust architecture remains anchored in [client data ownership and the absence of vendor lock-in](narr:Narrative_DataOwnership), ensuring that the repo resides within the client's own infrastructure from the outset. While the enterprise-level view continues to treat [GDPR and ISO compliance as significant adoption blockers](narr:Narrative_EnterpriseComplianceGate), the operational reality is increasingly defined by the ability to architecturally containerize components on demand during SOW engagements.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DataOwnership> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_EnterpriseComplianceGate> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_OnPremAsRequirementsDriven> ;
    narr:covers <https://aswritten.ai/narrative#Obs_OnPremHIPAAQuote> ;
    narr:covers <https://aswritten.ai/narrative#Position_OnPremNotDefiningFeature> ;
    narr:keyPhrase [ narr:text "On-prem is a compliance-triggered add-on at the Professional tier, not the defining feature of that tier" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_OnPremAsRequirementsDriven> ] ;
    narr:keyPhrase [ narr:text "Repo lives under client GitHub org from day one. No vendor lock-in." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_DataOwnership> ] ;
    narr:keyPhrase [ narr:text "GDPR, data sovereignty, and ISO compliance are real blockers." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_EnterpriseComplianceGate> ] ;
    narr:variation [ narr:text "Compliance as a procedural hurdle versus a structural blocker" ; narr:over <https://aswritten.ai/narrative#Narrative_EnterpriseComplianceGate> ] ;
    narr:variation [ narr:text "On-prem as a productized tier feature versus a bespoke SOW-driven engagement" ; narr:over <https://aswritten.ai/narrative#Narrative_OnPremAsRequirementsDriven> ; narr:over <https://aswritten.ai/narrative#Position_OnPremNotDefiningFeature> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}