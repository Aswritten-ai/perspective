    narr:keyPhrase [ narr:text "I need all software development to be directly about people and the thing that they need. Or else there is no end to the limb that you can walk yourself out on." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletHumanDrivenQuote> ] ;
    narr:keyPhrase [ narr:text "All of this means that this week is about testing, consolidation, and documentation, not active development. We're documenting this week and getting ready for sales." ; narr:phraseSource <https://aswritten.ai/narrative#Observation_ScarletWeekDeclaration> ] ;
    narr:keyPhrase [ narr:text "This is like a week and a half's work. Really the brunt of it is next week." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_WeekAndHalfQuote> ] ;
    narr:keyPhrase [ narr:text "Only task-027 (scaffold), task-112 (notifications), and task-086 (Demo 1) block V1 shipment." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_ThreeBlockersOnly> ] ;
    narr:keyPhrase [ narr:text "task-113 (proxy-orchestrated pipeline) is an optimization, not a V1 prerequisite." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_ProxyPipelineDeferred> ] ;
    narr:keyPhrase [ narr:text "friendlies before paid, paid before scaled" ; narr:phraseSource <https://aswritten.ai/narrative#Claim_FriendliesBeforePaidSequence> ] ;
    narr:keyPhrase [ narr:text "Enterprise consulting ([amount] pilot, knowledge extraction engagements) remains a valid revenue path but is no longer the framing for fundraising or product positioning." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_EnterpriseRemainsRevenue> ] ;
    narr:keyPhrase [ narr:text "if the only evidence is one pilot with a lukewarm champion (the customer's chief architect is sponsor, not champion), this may be rationalization." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_EnterpriseShapeTentativePriority> ] ;
    narr:keyPhrase [ narr:text "Scarlet's sequencing reflection: raise on the long-term emotional story and back it with feasibility strategy" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_EmotionalStoryFeasibilityQuote> ] ;
    narr:keyPhrase [ narr:text "Phase 0 gift → F&F raise → sell first engagement → angel/seed from traction. Clear stage-gate logic." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_FocusSequencing> ] ;
    narr:variation [ narr:text "Enterprise-shape as primary sales focus is explicitly tentative — one pilot, a sponsor not a champion, and the honest framing is that it may be rationalization pending 2-3 more validations." ; narr:over <https://aswritten.ai/narrative#Claim_EnterpriseShapeTentativePriority> ; narr:over <https://aswritten.ai/narrative#Narrative_EnterpriseShapePrimaryFocus> ] ;
    narr:variation [ narr:text "Enterprise consulting ([amount] pilot) remains a valid revenue path but is explicitly demoted from fundraising and positioning framing — SMB thesis leads instead." ; narr:over <https://aswritten.ai/narrative#Claim_EnterpriseRemainsRevenue> ] ;
    narr:variation [ narr:text "Scarlet believes she may have inverted the right order — building the feasible business first rather than raising on the emotional/vision story and backing it with feasibility." ; narr:over <https://aswritten.ai/narrative#Narrative_FundingOnEmotionalStory> ; narr:over <https://aswritten.ai/narrative#Obs_EmotionalStoryFeasibilityQuote> ] ;
    narr:variation [ narr:text "Product vs. sales tension is a named structural problem: Scarlet struggles to stop building; Tony frames the product as non-existent until someone buys it." ; narr:over <https://aswritten.ai/narrative#Narrative_ProductSalesTension> ] ;
    narr:variation [ narr:text "The consulting discovery GTM wedge (a consultant who ran enterprise discovery engagements for fifteen years / JUXT framing) offers a loss-leader entry model that competes with or precedes the product-led sequence." ; narr:over <https://aswritten.ai/narrative#Narrative_DiscoveryToolGTMWedge> ; narr:over <https://aswritten.ai/narrative#Insight_SideDoorGTM> ] ;
    narr:variation [ narr:text "June consolidation holds a tension: the deep desire to do product work is acknowledged, but consolidation before the fundraising push is the stated sequencing — both are valid, order is the question." ; narr:over <https://aswritten.ai/narrative#Narrative_JuneConsolidationPlan> ; narr:over <https://aswritten.ai/narrative#Claim_JuneConsolidationScope> ] ;
    narr:variation [ narr:text "Marketplace was originally a buyer-side browsing concept, reframed to supplier-side distribution, then deferred entirely below the April 1 line — three successive demotions of the same feature." ; narr:over <https://aswritten.ai/narrative#Claim_MarketplaceNotNeededAtLaunch> ; narr:over <https://aswritten.ai/narrative#Claim_BelowTheLine_April1> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
