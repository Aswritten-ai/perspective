    narr:generatedFrom "66728e0eafd09535285088f85926b09ce41aa9c6" ;
    narr:narration """This hub defines the organizational methodology for client engagement, centering on an [extraction-based interview process](narr:Position_ExtractionMethodology) designed to surface latent intent beneath surface-level text. This is paired with a [collaborative worldview-building practice](narr:Position_WorldviewBuilding), established in a February 2026 competitive analysis, which aims to synthesize a comprehensive organizational picture. Both positions frame the engagement as a foundational, upstream activity rather than mere surface-level editing. However, the trajectory is complicated by the [direction-not-context](narr:Position_DirectionNotContext) stance, which introduces a distinct tension: it posits that the primary value of the engagement is to provide active steering and strategic direction, rather than simply offering the client more context or understanding. The collection thus remains balanced between a passive, analytical role and an active, directive one, leaving the ultimate nature of the deliverable open to interpretation.""" ;
    narr:covers <https://aswritten.ai/narrative#Position_DirectionNotContext> ;
    narr:covers <https://aswritten.ai/narrative#Position_ExtractionMethodology> ;
    narr:covers <https://aswritten.ai/narrative#Position_WorldviewBuilding> ;
    narr:keyPhrase [ narr:text "Interviews you to understand what's underneath the text." ; narr:phraseSource <https://aswritten.ai/narrative#Position_ExtractionMethodology> ] ;
    narr:keyPhrase [ narr:text "comprehensive worldview" ; narr:phraseSource <https://aswritten.ai/narrative#Position_WorldviewBuilding> ] ;
    narr:keyPhrase [ narr:text "Foundation-level from competitive analysis session (Feb 5, 2026)." ; narr:phraseSource <https://aswritten.ai/narrative#Position_WorldviewBuilding> ] ;
    narr:variation [ narr:text "The 'direction-not-context' stance challenges the purely analytical, extractive framing of the other two positions." ; narr:over <https://aswritten.ai/narrative#Position_DirectionNotContext> ; narr:over <https://aswritten.ai/narrative#Position_ExtractionMethodology> ; narr:over <https://aswritten.ai/narrative#Position_WorldviewBuilding> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}