@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Proof> {
  <https://aswritten.ai/narrative#Digest_Proof> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Proof> ;
    narr:childCount "10"^^xsd:integer ;
    narr:generatedFrom "8c4969aaec41b46413b64d8901f5f1c237181cac" ;
    narr:narration """The proof hub tracks the evolution of aswritten's demonstration strategy, moving from external validation to recursive self-documentation. The [value demonstration gap](narr:https://aswritten.ai/narrative#Narrative_ValueDemonstrationGap) remains the central tension, framed as a [prerequisite for raising capital](narr:https://aswritten.ai/narrative#Position_ValueDemoPrerequisite) and enterprise adoption. Early validation relied on [annotation metrics](narr:https://aswritten.ai/narrative#Position_AnnotationResults80Claims), quantifying claim support against collective memory. The strategy has since shifted toward [product-as-proof](narr:https://aswritten.ai/narrative#Narrative_ProductAsProof), culminating in the [pipeline self-documentation release](narr:https://aswritten.ai/narrative#Narrative_PipelineSelfDocumentation_20260704), where the system successfully processed its own cutover. Rhetorical construction supports this trajectory through [antithetical framing](narr:https://aswritten.ai/narrative#StyleObs_Antithesis), which defines process semantics by contrasting binary states, and [timestamped citation conventions](narr:https://aswritten.ai/narrative#StyleObs_TimestampedQuotes) that mirror the product's own provenance-first architecture. While internal metrics emphasize [provenance over precision](narr:https://aswritten.ai/narrative#Position_ContextArch_5), external observers focus on [product stickiness](narr:https://aswritten.ai/narrative#Obs_StickyProductQuote) and the potential for word-of-mouth scaling.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PipelineSelfDocumentation_20260704> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ProductAsProof> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ValueDemonstrationGap> ;
    narr:covers <https://aswritten.ai/narrative#Obs_StickyProductQuote> ;
    narr:covers <https://aswritten.ai/narrative#Observation_ElephantCollective> ;
    narr:covers <https://aswritten.ai/narrative#Position_AnnotationResults80Claims> ;
    narr:covers <https://aswritten.ai/narrative#Position_ContextArch_5> ;
    narr:covers <https://aswritten.ai/narrative#Position_ValueDemoPrerequisite> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Antithesis> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TimestampedQuotes> ;
    narr:keyPhrase [ narr:text "The real risk is misattribution, not hallucination; mitigation is provenance in output, not query precision" ; narr:phraseSource <https://aswritten.ai/narrative#Position_ContextArch_5> ] ;
    narr:keyPhrase [ narr:text "I think you've got a sticky product. If you can get it into the hands of 20, 50 people... The word of mouth of that will just... that's really catapult." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_StickyProductQuote> ] ;
    narr:keyPhrase [ narr:text "The product documents itself: cutover decision saved through new production pipeline, citation offsets slice-exact on first try" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PipelineSelfDocumentation_20260704> ] ;
    narr:keyPhrase [ narr:text "80 claims analyzed, 64 supported. 80% aggregate coverage across 14 source memories" ; narr:phraseSource <https://aswritten.ai/narrative#Position_AnnotationResults80Claims> ] ;
    narr:variation [ narr:text "The tension between 'evaluating' (annotation metrics) and 'running' (self-documenting production) as the primary proof mechanism." ; narr:over <https://aswritten.ai/narrative#Position_AnnotationResults80Claims> ; narr:over <https://aswritten.ai/narrative#Narrative_PipelineSelfDocumentation_20260704> ] ;
    narr:variation [ narr:text "External market validation (word-of-mouth/stickiness) vs. internal technical validation (provenance/citation accuracy)." ; narr:over <https://aswritten.ai/narrative#Obs_StickyProductQuote> ; narr:over <https://aswritten.ai/narrative#Position_ContextArch_5> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}