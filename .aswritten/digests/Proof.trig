@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Proof> {
  <https://aswritten.ai/narrative#Digest_Proof> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Proof> ;
    narr:childCount "20"^^xsd:integer ;
    narr:generatedFrom "0a92f1347943270df0bd7f8026c934d7b28f1544" ;
    narr:narration """The proof hub tracks how aswritten demonstrates that it changes AI behavior — across sales pitch, technical verification, and live product behavior. The [value demonstration gap](narr:https://aswritten.ai/narrative#Narrative_ValueDemonstrationGap) was named in Mar 2026 (a demo-call prospect: \"show, don't tell\") and framed as a [prerequisite for raising bigger money](narr:https://aswritten.ai/narrative#Claim_ValueDemoPrerequisite). The primary pitch mechanism is the [before/after annotation frame](narr:https://aswritten.ai/narrative#Claim_AnnotateAsProof) — one visual that collapses the argument. An [annotation run against collective memory](narr:https://aswritten.ai/narrative#Claim_AnnotationResults80Claims) produced 80 claims, 64 supported across 14 source memories (Jan 2025–Mar 2026). On the infrastructure side, [OAuth end-to-end](narr:https://aswritten.ai/narrative#Claim_OAuthEndToEnd) was verified in production, and [the enterprise customer's [amount]/mo payment on 2026-04-30](narr:https://aswritten.ai/narrative#Narrative_FirstRevenueEvent_EnterpriseCustomer) became the first external revenue event. By Jul 2026, the [pipeline self-documentation release](narr:https://aswritten.ai/narrative#Narrative_PipelineSelfDocumentation_20260704) processed its own cutover through the product — citation offsets slice-exact on first try — and [David Nolen's unprompted repo access request](narr:https://aswritten.ai/narrative#Obs_DavidNolenAccessRequestQuote) followed. The [enrollment A/B experiment](narr:https://aswritten.ai/narrative#Narrative_EnrollmentABExperiment) (Jul 2026) added a structural finding: guarantees survived removal of commands, attribution volume rose. Style observations — [antithesis](narr:https://aswritten.ai/narrative#StyleObs_Antithesis), [numbers as authority](narr:https://aswritten.ai/narrative#StyleObs_NumbersAsAuthority) — cover the rhetorical layer of proof construction.""" ;
    narr:covers <https://aswritten.ai/narrative#CaseStudy_EnterpriseCustomerBulkMail> ;
    narr:covers <https://aswritten.ai/narrative#Claim_AnnotateAsProof> ;
    narr:covers <https://aswritten.ai/narrative#Claim_AnnotationResults80Claims> ;
    narr:covers <https://aswritten.ai/narrative#Claim_ContextArch_5> ;
    narr:covers <https://aswritten.ai/narrative#Claim_OAuthEndToEnd> ;
    narr:covers <https://aswritten.ai/narrative#Claim_ValueDemoPrerequisite> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DeliveryGate> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_EnrollmentABExperiment> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_FirstRevenueEvent_EnterpriseCustomer> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_OAuthShipped> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PipelineSelfDocumentation_20260704> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ProductAsProof> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ValueDemonstrationGap> ;
    narr:covers <https://aswritten.ai/narrative#Obs_DavidNolenAccessRequestQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_StickyProductQuote> ;
    narr:covers <https://aswritten.ai/narrative#Observation_ElephantCollective> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Antithesis> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_BeforeAfterFrame> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NumbersAsAuthority> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TimestampedQuotes> ;
    narr:keyPhrase [ narr:text "Your AI was guessing. Now it knows." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_AnnotateAsProof> ] ;
    narr:keyPhrase [ narr:text "80 claims analyzed, 64 supported. 80% aggregate coverage across 14 source memories spanning Jan 2025–Mar 2026." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_AnnotationResults80Claims> ] ;
    narr:keyPhrase [ narr:text "Clear, visible proof that aswritten changes how AI works is a prerequisite for raising bigger money." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_ValueDemoPrerequisite> ] ;
    narr:keyPhrase [ narr:text "OAuth discovery, PKCE flow, JWT issuance/validation, and dual auth (JWT + API key) all verified in production." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_OAuthEndToEnd> ] ;
    narr:keyPhrase [ narr:text "the enterprise customer's payment of [amount]/mo on 2026-04-30 is the first paid transaction by an external customer in aswritten.ai's history." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_FirstRevenueEvent_EnterpriseCustomer> ] ;
    narr:keyPhrase [ narr:text "This is the strongest form of product proof — the product's own release is the case study, processed by the product itself." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PipelineSelfDocumentation_20260704> ] ;
    narr:keyPhrase [ narr:text "I think you've got a sticky product. If you can get it into the hands of 20, 50 people... The word of mouth of that will just... that's really catapult." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_StickyProductQuote> ] ;
    narr:keyPhrase [ narr:text "The real risk is misattribution, not hallucination; mitigation is provenance in output, not query precision" ; narr:phraseSource <https://aswritten.ai/narrative#Claim_ContextArch_5> ] ;
    narr:variation [ narr:text "Proof-as-pitch vs. proof-as-infrastructure: the before/after annotation frame targets sales conviction, while OAuth verification and the A/B enrollment experiment address technical and behavioral proof — these are distinct audiences and distinct standards of evidence." ; narr:over <https://aswritten.ai/narrative#Claim_AnnotateAsProof> ; narr:over <https://aswritten.ai/narrative#Claim_OAuthEndToEnd> ; narr:over <https://aswritten.ai/narrative#Narrative_EnrollmentABExperiment> ] ;
    narr:variation [ narr:text "The enrollment A/B finding cuts against the assumption that imperatives hold the system together: guarantees survived removal of commands, and the conclusion is explicit — 'do not regrow imperatives as new capabilities land.'" ; narr:over <https://aswritten.ai/narrative#Narrative_EnrollmentABExperiment> ] ;
    narr:variation [ narr:text "Misattribution reframes what proof must address: the risk is not hallucination but wrong provenance in output — shifting the proof burden from accuracy to citation traceability." ; narr:over <https://aswritten.ai/narrative#Claim_ContextArch_5> ] ;
    narr:variation [ narr:text "The delivery gate structure (live demo or no [amount]; [amount] deposit non-refundable) operationalizes proof as a contractual threshold — a different register than either pitch or technical verification." ; narr:over <https://aswritten.ai/narrative#Narrative_DeliveryGate> ] ;
    narr:variation [ narr:text "Style observations (antithesis, timestamped quotes, numbers as authority) treat proof as a rhetorical construction — distinct from empirical or behavioral proof, and not addressed by the value demonstration gap framing." ; narr:over <https://aswritten.ai/narrative#StyleObs_Antithesis> ; narr:over <https://aswritten.ai/narrative#StyleObs_NumbersAsAuthority> ; narr:over <https://aswritten.ai/narrative#StyleObs_TimestampedQuotes> ] ;
    narr:variation [ narr:text "The Elephant Collective bootstrapping case ([amount]to [amount]/event in 6 months via mass SMS) sits as an analogy or precedent for proof-by-traction, but its connection to the aswritten proof argument is not made explicit in the children." ; narr:over <https://aswritten.ai/narrative#Observation_ElephantCollective> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}