    narr:covers <https://aswritten.ai/narrative#Observation_VouchSSoT> ;
    narr:covers <https://aswritten.ai/narrative#Observation_WhatDoesItDo_1> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_7> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_AmbientQuote> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Analogy_Citations> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ArrowChainFlow> ;
