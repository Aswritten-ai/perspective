    narr:keyPhrase [ narr:text "As Written: git-native organizational memory tool that compiles a worldview graph and exposes MCP tools for content introspection and generation." ; narr:phraseSource <https://aswritten.ai/narrative#Observation_AsWrittenProduct> ] ;
    narr:keyPhrase [ narr:text "aswritten extracts undocumented knowledge locked in senior experts' heads through conversational AI interviews, creating version-controlled organizational worldview." ; narr:phraseSource <https://aswritten.ai/narrative#Observation_WhatDoesItDo_1> ] ;
    narr:keyPhrase [ narr:text "Scarlet's articulated V1 UX: MCP endpoint + notifications; GitHub is infrastructure, not interface." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_V1UXVision> ] ;
    narr:keyPhrase [ narr:text "Ask the AI to do real work that would normally require an hour of briefing." ; narr:phraseSource <https://aswritten.ai/narrative#Observation_Beat1_ColdDelegation> ] ;
    narr:keyPhrase [ narr:text "the application has the problem (clear), the benefit (clear), and the tech architecture (clear) — but is missing how the actual workflow within an organization works." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_HowItWorksGap> ] ;
    narr:keyPhrase [ narr:text "You don't have to open a new tool. You're just using Claude Code... And in the middle of your current work, it's like, you should save that" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AmbientQuote> ] ;
    narr:variation [ narr:text "Explicit self-documented gap: problem, benefit, and architecture are clear, but the human-language organizational workflow is missing — the one thing the hub does not yet answer." ; narr:over <https://aswritten.ai/narrative#Obs_HowItWorksGap> ] ;
    narr:variation [ narr:text "Two competing answers to 'what does it do': upstream knowledge extraction vs. downstream cold-delegation work product — the same tool framed from opposite ends." ; narr:over <https://aswritten.ai/narrative#Observation_WhatDoesItDo_1> ; narr:over <https://aswritten.ai/narrative#Observation_Beat1_ColdDelegation> ] ;
    narr:variation [ narr:text "Present vs. future: 'Remember' is introduced as a concept, not a live feature — bridging to a later call rather than something it does today." ; narr:over <https://aswritten.ai/narrative#Observation_RememberAsConcept> ] ;
    narr:variation [ narr:text "A large cluster of children are not product claims at all but style/craft analysis of how the pitch is written — a different axis from 'what it does'." ; narr:over <https://aswritten.ai/narrative#StyleObs_BoldBeats> ; narr:over <https://aswritten.ai/narrative#StyleObs_ImperativeFlow> ; narr:over <https://aswritten.ai/narrative#StyleObs_VerbChoice_Extract> ] ;
    narr:variation [ narr:text "Interface positioning is a deliberate, potentially contestable stance: GitHub demoted to infrastructure, MCP + notifications as the real surface." ; narr:over <https://aswritten.ai/narrative#Obs_V1UXVision> ] ;
    narr:variation [ narr:text "Prior manual precedent at Vouch — a hand-built 'narrative source of truth' as steering vectors — is what the product now automates." ; narr:over <https://aswritten.ai/narrative#Observation_VouchSSoT> ] ;
    narr:writer "claude (subscription)" .
