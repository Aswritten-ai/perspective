    narr:covers <https://aswritten.ai/narrative#Observation_Beat2_CitationLayer> ;
    narr:covers <https://aswritten.ai/narrative#Observation_Beat3_GapHonesty> ;
    narr:covers <https://aswritten.ai/narrative#Observation_ExtractionExplainer> ;
