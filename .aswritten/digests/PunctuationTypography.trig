    narr:keyPhrase [ narr:text "SMB **replaces** enterprise as the primary market focus" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_SMB_BoldEmphasis> ] ;
    narr:keyPhrase [ narr:text "✅ **Fills gap_demo_beat_sequence**: Three distinct beats" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Checkmark_Validation> ] ;
    narr:keyPhrase [ narr:text "group interview → consensus → merge" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ArrowNotation> ] ;
    narr:keyPhrase [ narr:text "The physics never changed. The substrate did" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:keyPhrase [ narr:text "All-caps emphasis 'IS' used for rhetorical stress in a declarative positioning statement." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_2> ] ;
    narr:variation [ narr:text "Two registers coexist: an essayistic prose voice (em-dash, antithesis, italics, metaphor) versus an analytical-markdown voice (checkmark emoji, fenced code blocks, bold nav labels, arrow notation) — the typography splits by document type, not one uniform style." ; narr:over <https://aswritten.ai/narrative#StyleObs_5> ; narr:over <https://aswritten.ai/narrative#StyleObs_EmDashRhetoric> ; narr:over <https://aswritten.ai/narrative#StyleObs_Checkmark_Validation> ; narr:over <https://aswritten.ai/narrative#StyleObs_CodeBlockArchDiagram> ; narr:over <https://aswritten.ai/narrative#StyleObs_BoldEmphasis> ] ;
    narr:variation [ narr:text "The em-dash carries divergent jobs under one mark: amplifier/payoff clause, inline definition append, and assertion→reframe pivot — not a single consistent function." ; narr:over <https://aswritten.ai/narrative#StyleObs_DashAsAmplifier> ; narr:over <https://aswritten.ai/narrative#StyleObs_EmDashDefinition> ; narr:over <https://aswritten.ai/narrative#StyleObs_EmDashRhetoric> ] ;
    narr:variation [ narr:text "Bold likewise carries two unrelated weights: conviction/semantic stress (substitutive 'replaces') versus purely structural heading/navigation aid — same device, different intent." ; narr:over <https://aswritten.ai/narrative#StyleObs_SMB_BoldEmphasis> ; narr:over <https://aswritten.ai/narrative#StyleObs_BoldEmphasis> ; narr:over <https://aswritten.ai/narrative#StyleObs_BoldKeyPrinciple> ] ;
    narr:variation [ narr:text "An orthographic brand rule sits among the rhetorical devices: 'aswritten' kept lowercase even at sentence start — a hard stylization rule, not a cadence choice." ; narr:over <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:writer "claude (subscription)" .
