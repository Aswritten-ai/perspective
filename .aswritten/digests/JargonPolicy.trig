    narr:covers <https://aswritten.ai/narrative#StyleObs_MCP> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ModelComparison_2> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ModelComparison_NumberedListStructure> ;
