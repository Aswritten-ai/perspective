GRAPH <https://aswritten.ai/narrative#Digest_JargonPolicy> {
  <https://aswritten.ai/narrative#Digest_JargonPolicy> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#JargonPolicy> ;
    narr:childCount "23"^^xsd:integer ;
    narr:generatedFrom "fffddbaac7a15b84cb4ed77fb2c40cae638e650a" ;
    narr:narration """This hub tracks the evolution of jargon policy, oscillating between [internal-audience density](narr:StyleObs_DomainJargon) and [explicit terminology control](narr:StyleObs_JargonPolicy). The corpus exhibits a persistent tension: while many artifacts assume [insider fluency](narr:StyleObs_EngagementShape_JargonPolicy) through un-defined technical acronyms like [MCP](narr:StyleObs_MCP) or [SOW](narr:StyleObs_EnterpriseCustomerPattern_Jargon), there is a parallel, rigorous effort to [codify canonical vocabulary](narr:StyleObs_8). This control manifests as [hard verb constraints](narr:StyleObs_TranscriptBootstrap_VerbConstraint), [intentional jargon splits](narr:StyleObs_JargonSplit) between user-facing and engineering registers, and [plain-language exclusion policies](narr:StyleObs_PlainLanguagePolicy). A recurring idiolect, notably in [Scarlet's contributions](narr:StyleObs_ScarletConversationalWhy), uses jargon to name mechanisms while appending plain-language clauses to explain their strategic 'why.' Recent entries highlight the emergence of [idiomatic AI-era terms](narr:StyleObs_VibeCoding) and [strategic reframing jargon](narr:StyleObs_RelationshipCadenceArtifact) that signal in-group status while simultaneously attempting to standardize the lexicon for broader organizational use.""" ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_8> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Cargoculting> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_DomainJargon> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_EngagementShape_JargonPolicy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_EnterpriseCustomerPattern_Jargon> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_GitHubTier_JargonPolicy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_JargonDensityHealthcare> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_JargonPolicy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_JargonSplit> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Jargon_EnterpriseCustomer> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Jargon_MCP> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_MCP> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_PlainLanguagePolicy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RecursiveDogfooding> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RegisterTechnical> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RelationshipCadenceArtifact> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ScarletConversationalWhy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TechnicalJargonNarrPrefix> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TechnicalJargon_DesignSession> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TierNamingJargonPolicy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TranscriptBootstrap_VerbConstraint> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_VerbatimPreservation> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_VibeCoding> ;
    narr:keyPhrase [ narr:text "Do NOT say \"train\" — say \"create a perspective\"" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TranscriptBootstrap_VerbConstraint> ] ;
    narr:keyPhrase [ narr:text "so when the agent is making a new decision in that space, it can reason from the intent rather than cargo-culting the last value" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Cargoculting> ] ;
    narr:keyPhrase [ narr:text "Preserve verbatim quotes as verbatim claims, not as paraphrasable evidence." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_VerbatimPreservation> ] ;
    narr:keyPhrase [ narr:text "Especially for the free and expert tier, you shouldn't need to know anything about GitHub or that the product even runs on GitHub." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_GitHubTier_JargonPolicy> ] ;
    narr:keyPhrase [ narr:text "tx_summary — plain-language summary of what shifted in the worldview" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TechnicalJargon_DesignSession> ] ;
    narr:variation [ narr:text "Explicit prohibition of infrastructure jargon in favor of pure process description." ; narr:over <https://aswritten.ai/narrative#StyleObs_PlainLanguagePolicy> ] ;
    narr:variation [ narr:text "Use of RDF namespace notation (narr:*) as a primary, code-like prose register." ; narr:over <https://aswritten.ai/narrative#StyleObs_TechnicalJargonNarrPrefix> ] ;
    narr:variation [ narr:text "Strategic selection of tier names (e.g., 'Professional') to avoid organizational-size bias." ; narr:over <https://aswritten.ai/narrative#StyleObs_TierNamingJargonPolicy> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}