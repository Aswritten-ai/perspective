    narr:covers <https://aswritten.ai/narrative#StyleObservation_Jargon_TFV> ;
    narr:keyPhrase [ narr:text "add glossary as appendix; define terms at first use, science-paper style" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_JargonAccessibilityDecisions> ] ;
    narr:keyPhrase [ narr:text "so when the agent is making a new decision in that space, it can reason from the intent rather than cargo-culting the last value" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_Cargoculting> ] ;
    narr:keyPhrase [ narr:text "battery-v2 evaluation returned GO. The merge gate was a green full-tier heartbeat plus explicit founder approval at checkpoint 3" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_CutoverTechnicalPrecision> ] ;
    narr:keyPhrase [ narr:text "Especially for the free and expert tier, you shouldn't need to know anything about GitHub or that the product even runs on GitHub." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_GitHubTier_JargonPolicy> ] ;
    narr:keyPhrase [ narr:text "'Enterprise' implies large company; 'Professional' implies a level of service." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TierNamingJargonPolicy> ] ;
    narr:keyPhrase [ narr:text "Do NOT say \"train\" — say \"create a perspective\"" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TranscriptBootstrap_VerbConstraint> ] ;
    narr:keyPhrase [ narr:text "which is really just RAG, and you're missing the conversational why behind it." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ScarletConversationalWhy> ] ;
    narr:keyPhrase [ narr:text "Preserve verbatim quotes as verbatim claims, not as paraphrasable evidence." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_VerbatimPreservation> ] ;
    narr:keyPhrase [ narr:text "relationship-cadence artifact" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_RelationshipCadenceArtifact> ] ;
    narr:keyPhrase [ narr:text "SAFE — covers [amount]/month bare-bones salary plus ~[amount]/month operating costs through the worst-case timeline to close the seed raise." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_FinancialJargonDensity> ] ;
    narr:variation [ narr:text "Dense jargon without definition is the default across most documents (internal audience assumed), but an explicit plain-language exclusion policy exists that bans infrastructure terms entirely for certain audiences — these are not reconciled into a single house style." ; narr:over <https://aswritten.ai/narrative#StyleObs_TechnicalJargonDensity> ; narr:over <https://aswritten.ai/narrative#StyleObs_PlainLanguagePolicy> ; narr:over <https://aswritten.ai/narrative#StyleObs_GitHubTier_JargonPolicy> ] ;
    narr:variation [ narr:text "a collaborator's accessibility review (Mar 2026) treats ~15 undefined terms as a problem requiring a glossary and first-use definitions — in tension with the many documents that treat undefined jargon as a feature signaling insider audience." ; narr:over <https://aswritten.ai/narrative#Narrative_JargonAccessibilityDecisions> ; narr:over <https://aswritten.ai/narrative#StyleObs_DomainJargon> ; narr:over <https://aswritten.ai/narrative#StyleObs_FableWindowJargonDensity> ] ;
    narr:variation [ narr:text "Code-switching documents (internal ↔ customer-facing within one artifact) represent a third mode distinct from both pure-internal jargon density and pure plain-language policy." ; narr:over <https://aswritten.ai/narrative#StyleObs_EnterpriseCustomerDemo_JargonPolicy> ; narr:over <https://aswritten.ai/narrative#StyleObs_JargonSplit> ] ;
    narr:variation [ narr:text "Terminology control ranges from soft convention (bold on first definition, first-use gloss) to hard prohibition ('Do NOT say X — say Y'), with no single document establishing which mode governs when." ; narr:over <https://aswritten.ai/narrative#StyleObs_JargonPolicy> ; narr:over <https://aswritten.ai/narrative#StyleObs_TranscriptBootstrap_VerbConstraint> ; narr:over <https://aswritten.ai/narrative#StyleObs_TierNamingJargonPolicy> ] ;
    narr:variation [ narr:text "Profanity and informality appear as register markers (authenticity, candor) under a 'related' predicate — a structurally distinct outlier that sits adjacent to jargon policy without being a jargon observation." ; narr:over <https://aswritten.ai/narrative#StyleObs_Profanity> ; narr:over <https://aswritten.ai/narrative#StyleObs_RegisterTechnical> ] ;
    narr:variation [ narr:text "Scarlet's named idiolect — jargon names mechanism, plain clause explains consequence — is a hybrid pattern not captured by either the 'define at first use' or 'assume fluency' poles." ; narr:over <https://aswritten.ai/narrative#StyleObs_ScarletConversationalWhy> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}