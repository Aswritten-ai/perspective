    narr:keyPhrase [ narr:text "aswritten is a citation engine, not a synthesis engine" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_CitationEngineNotSynthesis> ] ;
    narr:keyPhrase [ narr:text "Nobody seems to be solving this problem in a way that I like. Copilot has a feature called Copilot Memories, but it's scoped to a repo" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerArchitectCrossRepoQuote> ] ;
    narr:keyPhrase [ narr:text "The money answer is a real concrete question whose answer comes back grounded in dated cited conversational provenance" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_MoneyAnswerDecisionArchaeology> ] ;
    narr:keyPhrase [ narr:text "aswritten tells you what you don't know yet — introspect is an active surface that points at its own thin spots" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ProductSurfacesOwnRoadmap> ] ;
    narr:keyPhrase [ narr:text "Store the decision process, not the half-baked artifact" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_StoreDecisionProcessNotArtifact> ] ;
    narr:variation [ narr:text "SMS-based interfaces are framed as trust-building channel properties rather than core product identity." ; narr:over <https://aswritten.ai/narrative#Position_SMSTrustSignalChannelProperty> ] ;
    narr:variation [ narr:text "Shared agent memory is a proposed stake that currently lacks direct user validation compared to core differentiators." ; narr:over <https://aswritten.ai/narrative#Narrative_SharedAgentMemory> ; narr:over <https://aswritten.ai/narrative#Position_SharedAgentMemoryProductFit> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
