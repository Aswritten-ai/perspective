    narr:keyPhrase [ narr:text "aswritten is a citation engine, not a synthesis engine" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_CitationEngineNotSynthesis> ] ;
    narr:keyPhrase [ narr:text "Cross-project, cross-platform, org-owned memory is the pain nobody else is solving" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_CrossRepoMemoryEnterpriseHook> ] ;
    narr:keyPhrase [ narr:text "Design-token extraction process is structurally identical to perspective extraction" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_DesignTokenPerspectiveParallel> ] ;
    narr:keyPhrase [ narr:text "aswritten tells you what you don't know yet" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ProductSurfacesOwnRoadmap> ] ;
    narr:keyPhrase [ narr:text "Store the decision process, not the half-baked artifact" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_StoreDecisionProcessNotArtifact> ] ;
    narr:variation [ narr:text "SMS-based interaction is viewed as a trust-signal channel property rather than a core product identity." ; narr:over <https://aswritten.ai/narrative#Position_SMSTrustSignalChannelProperty> ] ;
    narr:variation [ narr:text "Knowledge packaging is framed as a distinct 'second moment of value' tied to delegation triggers." ; narr:over <https://aswritten.ai/narrative#Narrative_KnowledgePackagingMoment> ] ;
