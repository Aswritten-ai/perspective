    narr:keyPhrase [ narr:text "Nobody seems to be solving this problem in a way that I like. Copilot has a feature called Copilot Memories, but it's scoped to a repo" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerArchitectCrossRepoQuote> ] ;
    narr:keyPhrase [ narr:text "Aswritten does not tell you a practitioner takes a trauma informed approach" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletCitationEngineQuote> ] ;
    narr:keyPhrase [ narr:text "You can compile multiple repos in a single chat and since it's all the same ontology, it all fits together." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_MultiRepoCompilationQuote> ] ;
    narr:keyPhrase [ narr:text "they, by nature, are auto. They can be updated, right? The publishing process allows someone to publish a module but also to add to it over time and it'll automatically update for the person consuming it." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_AutoUpdateQuote> ] ;
    narr:keyPhrase [ narr:text "If we want expertise, not just information, we need to distill perspective into a format that AI can understand." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_UndocumentedKnowledgeQuote> ] ;
    narr:keyPhrase [ narr:text "AIs do have an opinion but they have a singular opinion in the middle of their training set and a number of narratives that we don't understand." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_AIOpinionQuote> ] ;
    narr:keyPhrase [ narr:text "All the criticisms that people have about AI responding... that's the kind of stuff that we're able to encode in worldview." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_WorldviewEncodingCriticismsQuote> ] ;
    narr:keyPhrase [ narr:text "The ontology encodes style, voice, diction, key phrases, and context around those phrases." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_StyleVoiceEncoding> ] ;
    narr:keyPhrase [ narr:text "Agents should cite which memories shaped their recommendations." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_AgentsCiteMemories> ] ;
    narr:keyPhrase [ narr:text "Store the decision process, not the half-baked artifact" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_StoreDecisionProcessNotArtifact> ] ;
    narr:variation [ narr:text "Decision-archaeology and process-storage (Jul-2026) reframe the core differentiator away from citation/provenance toward temporal decision trails — these are not the same claim and may compete for positioning priority." ; narr:over <https://aswritten.ai/narrative#Narrative_ArchaeologyQueryUseCase> ; narr:over <https://aswritten.ai/narrative#Narrative_StoreDecisionProcessNotArtifact> ; narr:over <https://aswritten.ai/narrative#Narrative_MoneyAnswerDecisionArchaeology> ] ;
    narr:variation [ narr:text "Knowledge packaging trigger has not yet fired in practice for the engineering manager prospect (Mar-2026: not currently hiring), qualifying the 'second moment of value' claim as latent rather than activated." ; narr:over <https://aswritten.ai/narrative#Narrative_KnowledgePackagingMoment> ] ;
    narr:variation [ narr:text "SMS trust-signal is framed as a channel property and 'bonus upsell,' not a core differentiator — present in the hub but explicitly scoped down." ; narr:over <https://aswritten.ai/narrative#Position_SMSTrustSignalChannelProperty> ] ;
    narr:variation [ narr:text "Shared agent memory and undocumented knowledge extraction are flagged as high-resonance differentiators by Tony but carry no dates and lack user validation — their weight relative to the dated claims is unresolved." ; narr:over <https://aswritten.ai/narrative#Narrative_SharedAgentMemory> ; narr:over <https://aswritten.ai/narrative#Narrative_UndocumentedKnowledgeExtraction> ] ;
    narr:variation [ narr:text "The design-token parallel (Jul-2026) suggests the perspective-extraction architecture is independently discoverable — which could mean it is less proprietary than the moat framing implies." ; narr:over <https://aswritten.ai/narrative#Narrative_DesignTokenPerspectiveParallel> ] ;
    narr:variation [ narr:text "Introspect-as-anti-hallucination is validated by David independently (Jul-2026), but the 62-gaps-in-nine-days figure (May-2026) frames it as roadmap surfacing — two distinct value framings of the same feature." ; narr:over <https://aswritten.ai/narrative#Position_IntrospectFixesHallucination> ; narr:over <https://aswritten.ai/narrative#Narrative_ProductSurfacesOwnRoadmap> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
