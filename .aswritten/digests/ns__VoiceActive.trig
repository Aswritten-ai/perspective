@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__VoiceActive> {
  <https://aswritten.ai/narrative#Digest_ns__VoiceActive> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#VoiceActive> ;
    narr:childCount "5"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """This hub gathers style observations of an **active, agentive voice** across the company's writing. The dominant pattern is [first-person-plural active construction](narr:StyleObs_ActiveVoice) — \"We eliminate,\" \"We make,\" \"We give\" — agent-centered and unhedged, echoed by the [product-as-decision framing](narr:StyleObs_ActiveDecision) declaring what \"we are building.\" Reinforcing it, one observation catalogs [strong action verbs](narr:StyleObs_ActiveVerbs) — unlocks, triggers, propagates, collapses, multiplies — with subject-verb-object clarity. But the register is not uniform: another child reads the voice as [second-person and imperative](narr:StyleObs_8) (\"your AI,\" \"you draft,\" \"Create single source of truth\") built on parallel old/new contrasts, while a fifth notes a [gerund-subject problem statement](narr:StyleObs_ActiveVoice_1) that is active yet impersonal. Note also that the action-verb observation attaches via *related*, not *broader* — structurally adjacent rather than core. Dates are absent throughout, so no trajectory is claimed; these are coexisting facets of one voice.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_8> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_ActiveDecision> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_ActiveVerbs> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_ActiveVoice> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_ActiveVoice_1> ;
    narr:keyPhrase [ narr:text "We eliminate the 3-6 month AI onboarding tax. We make knowledge loss on departure impossible." ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_ActiveVoice> ] ;
    narr:keyPhrase [ narr:text "This eliminates strategy-execution disconnect" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_ActiveVoice> ] ;
    narr:keyPhrase [ narr:text "We are building collective memory as a complete product - a collaborative worldview layer" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_ActiveDecision> ] ;
    narr:keyPhrase [ narr:text "Strong action verbs throughout: unlocks, triggers, propagates, collapses, multiplies; subject-verb-object clarity." ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_ActiveVerbs> ] ;
    narr:keyPhrase [ narr:text "Documentation describes; worldview generates. Documentation goes stale; worldview evolves" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_8> ] ;
    narr:keyPhrase [ narr:text "creating high quality output with AI requires extensive context" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_ActiveVoice_1> ] ;
    narr:variation [ narr:text "Subject person diverges: mostly first-person-plural 'we', but one child reads the voice as second-person/imperative ('your AI', 'you draft'), and another quotes first-person-singular 'I'm able to steer models successfully'." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_8> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_ActiveVoice> ] ;
    narr:variation [ narr:text "Active yet impersonal outlier: a gerund-subject problem statement ('creating...requires') is agentless, unlike the agent-centered mainline." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_ActiveVoice_1> ] ;
    narr:variation [ narr:text "Structural outlier: the action-verb catalog attaches via skos:related, not broader — adjacent evidence rather than a core instance of the active-voice pattern." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_ActiveVerbs> ] ;
    narr:writer "claude (subscription)" .
}