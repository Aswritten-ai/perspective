    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """This hub gathers the candidate taglines and brand-voice observations for [aswritten.ai](narr:Narrative_SIC_Tagline_1), whose name puns Latin *sic* (as written) onto the .ai domain. Several distinct positioning bets sit side by side rather than resolving to one line. The longest is a [7-word second-person hook](narr:Narrative_collective_memory_tagline) — \"AI that thinks like your company thinks\" — echoed in [tagline-hook style notes](narr:StyleObs_tagline_hook). Competing short handles include [category-first \"Collective memory for AI\"](narr:Tagline_1) (noted as used 3x in a two-sentence pitch), the [\"Worldview layer for AI agents\"](narr:Tagline_ADR002) 5-word handle from ADR002, and an [outcome/lifecycle framing](narr:Tagline_2) spanning day-one to exit. Brand voice recurs across observations: the [organization-as-organism metaphor](narr:StyleObs_1) (DNA/phenotype), [git-parallel verbs and emphatic repetition](narr:StyleObs_5), [consistent lowercase .ai stylization](narr:StyleObs_BrandName), and [Tony's pain-first register](narr:StyleObs_TonyPainFirst) reframing cost as a measure, not the problem. No human reconciliation selects a winning tagline; the candidates remain open.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_SIC_Tagline_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_collective_memory_tagline> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_5> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_BrandName> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_TonyPainFirst> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_brandname_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_tagline_hook> ;
    narr:covers <https://aswritten.ai/ns/narrative#Tagline_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#Tagline_2> ;
    narr:covers <https://aswritten.ai/ns/narrative#Tagline_ADR002> ;
    narr:keyPhrase [ narr:text "Your entire organization talks to AI that thinks like your company thinks." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_collective_memory_tagline> ] ;
    narr:keyPhrase [ narr:text "Collective memory for AI" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Tagline_1> ] ;
    narr:keyPhrase [ narr:text "Worldview layer for AI agents" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Tagline_ADR002> ] ;
    narr:keyPhrase [ narr:text "Day one-through-exit institutional knowledge" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Tagline_2> ] ;
    narr:keyPhrase [ narr:text "aswritten.ai — AI that tells you a story as written" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_SIC_Tagline_1> ] ;
    narr:keyPhrase [ narr:text "Cost isn't the problem, actually. It's a way to measure the problem." ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_TonyPainFirst> ] ;
    narr:variation [ narr:text "Four competing tagline framings coexist with no chosen winner: category-first 'Collective memory for AI' vs. technical 'Worldview layer for AI agents' vs. lifecycle 'Day one-through-exit' vs. the long 7-word conversational hook." ; narr:over <https://aswritten.ai/ns/narrative#Tagline_1> ; narr:over <https://aswritten.ai/ns/narrative#Tagline_ADR002> ; narr:over <https://aswritten.ai/ns/narrative#Tagline_2> ; narr:over <https://aswritten.ai/ns/narrative#Narrative_collective_memory_tagline> ] ;
    narr:variation [ narr:text "Two naming logics pull apart: the punning brand-etymology line ('sic / as written, tells you a story') vs. the functional product-promise taglines." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_SIC_Tagline_1> ; narr:over <https://aswritten.ai/ns/narrative#Tagline_1> ] ;
    narr:variation [ narr:text "Tony's pain-first register dissents from cost-led pitching — cost is a way to measure the problem, not the problem — cutting against outcome/ROI framings." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_TonyPainFirst> ] ;
    narr:variation [ narr:text "Brand voice itself spans registers: extended biological metaphor (org-as-organism, DNA/phenotype) vs. concrete git-parallel verbs (notices/draft/commit/review/update)." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_1> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_5> ] ;
