@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ToneVoice> {
  <https://aswritten.ai/narrative#Digest_ToneVoice> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#ToneVoice> ;
    narr:childCount "9"^^xsd:integer ;
    narr:generatedFrom "a676c91d02e6ea6729badf57a148effa45a1537a" ;
    narr:narration """This hub tracks the evolution of Scarlet’s writing voice, characterized by a [declarative, action-oriented register](narr:StyleObs_12) that avoids passive constructions in favor of [anaphoric, imperative-driven cadences](narr:StyleObs_4). The voice relies on [technical idiolect metaphors](narr:StyleObs_6)—such as 'bootloading' worldviews or 'collective memory'—to frame the knowledge graph as a living substrate. Authority is constructed through [first-person blockquotes](narr:StyleObs_DirectQuote_ScarletBlockquote) and [antithetical rhetorical questions](narr:StyleObs_NotFacts) that shift the reader’s epistemic focus from truth-claims to utility. While the baseline is [unhedged and authoritative](narr:StyleObs_RhetoricalQuestion_Implicit), the voice modulates under pressure, surfacing a [defensive register](narr:StyleObs_DefensiveRegister) (Apr 2026) or a [structured fragility concession](narr:StyleObs_FragilityHedge) where risks are acknowledged only to be immediately bounded. The texture is further defined by [emphatic self-correction](narr:StyleObs_SuperpowerIdiom) and a deliberate [code-switch between formal analysis and lowercase conversational asides](narr:StyleObs_12).""" ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_12> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_4> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_6> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_DefensiveRegister> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_DirectQuote_ScarletBlockquote> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_FragilityHedge> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NotFacts> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RhetoricalQuestion_Implicit> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_SuperpowerIdiom> ;
    narr:keyPhrase [ narr:text "A bit like the \"I know kung fu\" skill downloads in the Matrix" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_4> ] ;
    narr:keyPhrase [ narr:text "We are the future, as written." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_6> ] ;
    narr:keyPhrase [ narr:text "The physics never changed. The substrate did" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_6> ] ;
    narr:keyPhrase [ narr:text "lowered the defensive register and made the work feel like building rather than confessing" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DefensiveRegister> ] ;
    narr:keyPhrase [ narr:text "You don't ask \"is this triple true?\" — you ask \"does viewing through this lens produce the right output?\"" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_NotFacts> ] ;
    narr:variation [ narr:text "The voice shifts from assertive building to defensive confession depending on the framing." ; narr:over <https://aswritten.ai/narrative#StyleObs_DefensiveRegister> ] ;
    narr:variation [ narr:text "Fragility is not ignored but is instead bounded by immediate, pragmatic re-framing." ; narr:over <https://aswritten.ai/narrative#StyleObs_FragilityHedge> ] ;
    narr:variation [ narr:text "The use of lowercase, unpunctuated conversational asides creates a deliberate tension with the formal analytical prose." ; narr:over <https://aswritten.ai/narrative#StyleObs_12> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}