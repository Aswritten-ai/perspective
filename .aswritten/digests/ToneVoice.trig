@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ToneVoice> {
  <https://aswritten.ai/narrative#Digest_ToneVoice> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#ToneVoice> ;
    narr:childCount "10"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """This hub collects observations of Scarlet's writing voice. The dominant texture is a confident, action-oriented declarative register: [active voice with imperative next-steps](narr:StyleObs_12), [punchy parallel sentences serving as section anchors](narr:StyleObs_6), and [assertions stated as settled facts even for strategic claims](narr:StyleObs_RhetoricalQuestion_Implicit). Voice is built through borrowed scaffolds — [Matrix and Kahneman System 1/2 analogies plus tricolon address to the AI coworker](narr:StyleObs_4), [the Rumsfeld Framework and Enneagram quoted inner-voices](narr:StyleObs_6) — and idiolect metaphors like 'bootload a new worldview' and knowledge-graph-as-'collective memory'. A recurring move is the [epistemic reframe via antithetical rhetorical question](narr:StyleObs_NotFacts) and [emphatic self-correction cadence](narr:StyleObs_SuperpowerIdiom). Register is not uniform: it [code-switches between formal analytical and lowercase conversational](narr:StyleObs_12), anchors claims with [first-person Scarlet blockquotes](narr:StyleObs_DirectQuote_ScarletBlockquote), and stages [multi-voice persona authority](narr:StyleObs_PersonaVoiceContrast). The two broader-attached observations — a [defensive register that shifts with framing](narr:StyleObs_DefensiveRegister) (Apr 2026) and a [fragility concession pattern](narr:StyleObs_FragilityHedge) — describe how the voice modulates under pressure.""" ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_12> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_4> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_6> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_DefensiveRegister> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_DirectQuote_ScarletBlockquote> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_FragilityHedge> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NotFacts> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_PersonaVoiceContrast> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RhetoricalQuestion_Implicit> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_SuperpowerIdiom> ;
    narr:keyPhrase [ narr:text "dream bigger" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_4> ] ;
    narr:keyPhrase [ narr:text "A bit like the \"I know kung fu\" skill downloads in the Matrix" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_4> ] ;
    narr:keyPhrase [ narr:text "The physics never changed. The substrate did" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_6> ] ;
    narr:keyPhrase [ narr:text "We are the future, as written." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_6> ] ;
    narr:keyPhrase [ narr:text "You don't ask \"is this triple true?\" — you ask \"does viewing through this lens produce the right output?\"" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_NotFacts> ] ;
    narr:keyPhrase [ narr:text "lowered the defensive register and made the work feel like building rather than confessing" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DefensiveRegister> ] ;
    narr:keyPhrase [ narr:text "Not a plug-in superpower, a real life superpower" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_SuperpowerIdiom> ] ;
    narr:variation [ narr:text "Confidence vs. concession: one observation reads the voice as 'no hedging; assertions stated as settled facts,' while two others document explicit hedging — risk acknowledged then bounded, and a defensive register that drops when reframed." ; narr:over <https://aswritten.ai/narrative#StyleObs_RhetoricalQuestion_Implicit> ; narr:over <https://aswritten.ai/narrative#StyleObs_FragilityHedge> ; narr:over <https://aswritten.ai/narrative#StyleObs_DefensiveRegister> ] ;
    narr:variation [ narr:text "Single authoritative voice vs. staged multi-voice: the dominant declarative register coexists with deliberate multi-voice structures — persona-labeled reviewers and Enneagram quoted inner-voices." ; narr:over <https://aswritten.ai/narrative#StyleObs_RhetoricalQuestion_Implicit> ; narr:over <https://aswritten.ai/narrative#StyleObs_PersonaVoiceContrast> ; narr:over <https://aswritten.ai/narrative#StyleObs_6> ] ;
    narr:variation [ narr:text "Register code-switching: formal analytical prose deliberately contrasted against lowercase, unpunctuated conversational Scarlet quotes — not one tone but a managed oscillation." ; narr:over <https://aswritten.ai/narrative#StyleObs_12> ; narr:over <https://aswritten.ai/narrative#StyleObs_DirectQuote_ScarletBlockquote> ] ;
    narr:variation [ narr:text "Structural outliers: only DefensiveRegister and FragilityHedge attach via skos:broader (and DefensiveRegister is the sole dated child, Apr 2026); the rest are skos:related — suggesting these two are treated as more central/categorical observations." ; narr:over <https://aswritten.ai/narrative#StyleObs_DefensiveRegister> ; narr:over <https://aswritten.ai/narrative#StyleObs_FragilityHedge> ] ;
    narr:writer "claude (subscription)" .
}