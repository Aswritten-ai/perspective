    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """This hub collects rubric assessments of **resonance** — how well each document, claim, or rebrand lands emotionally and memorably — across the corpus. The dominant pattern: resonance is carried by metaphor and analogy plus concrete grounding. Recurring devices include [git/code analogies](narr:RubricAssess_resonance), [biological and sailing metaphors (DNA/phenotype, telltales)](narr:RubricAssess_Resonance), [antithesis framings like weeks→15 min](narr:Assessment_Resonance_1), and vivid problem stakes ([existential crisis, state secrets](narr:Assessment_Resonance_IPCrisis)). Concrete examples ground the abstractions: [the DC37 training and email-migration stories](narr:Assess_Resonance_collective_memory), [the College Board bitcoin-miner and .com DNS incidents](narr:RubricAssess_Resonance), the [[amount]-mistake startup framing](narr:RubricAssess_Resonance_ADR002), and the [organizational in-joke about duplicating the customer's chief architect's brain](narr:Assessment_Resonance_CustomerArchitect). The [Jan 7 assessment](narr:RubricAssess_Resonance_20260107) prizes authentic voice-memo quotes as mini case studies. Across assessments the verdict skews strongly positive, but a consistent shortfall recurs — several otherwise-strong pieces are flagged as missing a customer story or case study for top marks.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Assess_Resonance_cm> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assess_Resonance_collective_memory> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assess_Resonance_rebrand> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assessment_Resonance_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assessment_Resonance_IPCrisis> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assessment_Resonance_CustomerArchitect> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Resonance> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Resonance_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Resonance_20260107> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Resonance_ADR001> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Resonance_ADR002> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Resonance_GTM> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_resonance> ;
    narr:keyPhrase [ narr:text "Antithesis (weeks → 15 min) and metaphor (cursor) resonate. Could add case study or customer quote for deeper proof." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assessment_Resonance_1> ] ;
    narr:keyPhrase [ narr:text "Strong use of organizational in-joke ('duplicate the customer's chief architect's brain'), concrete analogies (pricing engine as test case), and relatable pain points (senior expert bottleneck)." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assessment_Resonance_CustomerArchitect> ] ;
    narr:keyPhrase [ narr:text "Highly resonant: College Board bitcoin miner story, Google Search team analogy, .com DNS incident context; stories ground abstract concepts in memorable examples" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Resonance> ] ;
    narr:keyPhrase [ narr:text "Platform vs. infrastructure antithesis resonates; moat metaphor familiar to business audience; lacks narrative story/case study but appropriate for ADR format" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Resonance_ADR001> ] ;
    narr:keyPhrase [ narr:text "[amount] mistake metaphor resonates with startup audience. 'Three Pillars' architectural metaphor aids recall. Concrete examples (README, ADRs) ground abstract concepts." ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Resonance_ADR002> ] ;
    narr:keyPhrase [ narr:text "Strong resonance: voice memo quotes preserve authentic speaker voice; 'Oh shiny' moment; 'random vector' metaphor; network effect analogy; before/after contrasts create visceral understanding; cross-role stories = mini case studies." ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Resonance_20260107> ] ;
    narr:variation [ narr:text "Recurring shortfall: even strong assessments dock for a missing customer story or case study needed for top marks." ; narr:over <https://aswritten.ai/ns/narrative#Assessment_Resonance_1> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Resonance_1> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Resonance_GTM> ] ;
    narr:variation [ narr:text "Outlier on the gap: ADR001 treats the absence of a narrative story as acceptable given the ADR format, rather than as a deficiency." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Resonance_ADR001> ] ;
    narr:variation [ narr:text "Weakest case: the cm assessment relies on implicit analogies and concedes it 'could add more narrative framing.'" ; narr:over <https://aswritten.ai/ns/narrative#Assess_Resonance_cm> ] ;
