    narr:keyPhrase [ narr:text "I'm a trans woman — there's an opportunity here to do something specifically about queer representation" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_QueerFirstPersonVoice> ] ;
    narr:keyPhrase [ narr:text "I just need to pick a fucking date and call it launch, whatever the fuck that means." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ProfanityDecisiveness> ] ;
