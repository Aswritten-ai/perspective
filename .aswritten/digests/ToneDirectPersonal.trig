    narr:keyPhrase [ narr:text "I wish we could clone me." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DirectQuoteEvidence> ] ;
    narr:keyPhrase [ narr:text "I just need to pick a fucking date and call it launch, whatever the fuck that means." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ProfanityDecisiveness> ] ;
    narr:keyPhrase [ narr:text "I'm a trans woman — there's an opportunity here to do something specifically about queer representation" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_QueerFirstPersonVoice> ] ;
    narr:keyPhrase [ narr:text "Show, don't tell." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ShowDontTell> ] ;
    narr:keyPhrase [ narr:text "I built aswritten to feather our arrows, that our first attempt may always take us further in the direction we're headed." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_5> ] ;
    narr:keyPhrase [ narr:text "whether she can say it out loud on a call comfortably" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ScarletCallTestCriterion> ] ;
    narr:variation [ narr:text "The 'vulnerable' register is identified as structurally distinct from the standard strategic/analytical outreach." ; narr:over <https://aswritten.ai/narrative#StyleObs_VulnerableRegister> ] ;
