    narr:keyPhrase [ narr:text "I sold a dream" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_5> ] ;
    narr:keyPhrase [ narr:text "I just need to pick a fucking date and call it launch, whatever the fuck that means." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ProfanityDecisiveness> ] ;
    narr:keyPhrase [ narr:text "jesus that could have been setup months ago — why did this get setup with sqlite?" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_FrustratedVoiceQuote> ] ;
    narr:keyPhrase [ narr:text "I don't like the word distillation. Let's just call it perspective creation?" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DirectPersonalRegister_Distillation> ] ;
    narr:keyPhrase [ narr:text "**This is incorrect.** Scarlet has tried to correct this before." ; narr:phraseSource <https://aswritten.ai/narrative#Style_DirectCorrection> ] ;
    narr:keyPhrase [ narr:text "I really see this as the future of trusted information in the AI age." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DirectPersonalTone> ] ;
    narr:keyPhrase [ narr:text "I'm not buying it because it's git native." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DirectPersonal_1> ] ;
    narr:variation [ narr:text "Hedged/conversational register cuts against the 'unhedged' mainline — approximation, filler, and lowercase stream-of-consciousness coexist with the declarative voice." ; narr:over <https://aswritten.ai/narrative#StyleObs_HedgedDirectness> ; narr:over <https://aswritten.ai/narrative#StyleObs_HedgedRegister> ; narr:over <https://aswritten.ai/narrative#StyleObs_HedgedSelfDeprecation> ; narr:over <https://aswritten.ai/narrative#StyleObs_ToneConversational> ; narr:over <https://aswritten.ai/narrative#StyleObs_LowercaseIdiolect> ; narr:over <https://aswritten.ai/narrative#StyleObs_InformalRegisterInQuote> ] ;
    narr:variation [ narr:text "A reflective, vulnerable strain ('feeling a little unsure') sits against the conviction-forward, decisive default." ; narr:over <https://aswritten.ai/narrative#StyleObservation_ScarletTone> ; narr:over <https://aswritten.ai/narrative#StyleObs_FirstPersonDeclarative> ] ;
    narr:variation [ narr:text "Profanity-as-authenticity is not only Scarlet's — it's also marked as a beta user from outside tech's idiolect, so the 'founder voice' label spans multiple speakers." ; narr:over <https://aswritten.ai/narrative#StyleObs_RawRegisterPD> ; narr:over <https://aswritten.ai/narrative#StyleObs_ShitDealIdiolect> ; narr:over <https://aswritten.ai/narrative#StyleObs_Profanity> ] ;
    narr:variation [ narr:text "Second-person address is a structurally distinct register from the first-person mainline — prospect-frame pitching vs founder testimony." ; narr:over <https://aswritten.ai/narrative#StyleObs_SecondPerson> ; narr:over <https://aswritten.ai/narrative#StyleObs_DirectSecondPerson> ; narr:over <https://aswritten.ai/narrative#StyleObs_AmbientQuote> ] ;
    narr:variation [ narr:text "Even brand stylization is internally inconsistent — lowercase 'aswritten' vs capital 'Aswritten' observed in the same child." ; narr:over <https://aswritten.ai/narrative#StyleObs_1> ] ;
