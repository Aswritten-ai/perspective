@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_FeedbackLoops> {
  <https://aswritten.ai/narrative#Digest_FeedbackLoops> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#FeedbackLoops> ;
    narr:childCount "11"^^xsd:integer ;
    narr:generatedFrom "9972ee47005b486cff1f21cae860f0692b9b7b93" ;
    narr:narration """This hub gathers the mechanics of how feedback enters and reshapes the product and its knowledge. Two structural loops anchor the space: the [save-memory/PR round semantics](narr:Position_ReviewMemorySemantics) — save-memory ends a round, merge closes the PR, a corrected review always takes at least two rounds — and the [five-step annotate→document→save→re-annotate cycle](narr:Observation_FeedbackLoop) where annotation surfaces unsupported claims and re-annotation confirms the shift. [Convergence is framed as asymptotic](narr:Obs_ConvergenceAsymptotic) accumulation of review evidence, not a binary threshold. On process, the [real-time per-section loop](narr:Narrative_RealTimeFeedbackLoop) (Mar 19) is held superior to batch review — errors caught before they compound, insights surfaced in the moment. A dense run of Scarlet corrections (Mar 19) sharpens product framing: [expertise on-demand not ambient](narr:Obs_AmbientBehaviorCorrection), [perspective vs local RAG](narr:Obs_CustomGPTCorrection), [expanding experts not replacing](narr:Obs_ExpertReachCorrection), and [Tinkerer's existing solution as barrier](narr:Obs_TinkererBarrierCorrection). Later signals: [text-for-topic precedent](narr:Obs_ScarletTextForTopicQuote) (Apr 8) as rationale for the research branch methodology, and [feedback/help tool as churn prevention](narr:Obs_FeedbackHelpQuote) (Mar 26). [Open rhetorical questions](narr:StyleObs_OpenQuestions) surface unresolved design decisions as bounded scopes.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_RealTimeFeedbackLoop> ;
    narr:covers <https://aswritten.ai/narrative#Obs_AmbientBehaviorCorrection> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ConvergenceAsymptotic> ;
    narr:covers <https://aswritten.ai/narrative#Obs_CustomGPTCorrection> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ExpertReachCorrection> ;
    narr:covers <https://aswritten.ai/narrative#Obs_FeedbackHelpQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletTextForTopicQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_TinkererBarrierCorrection> ;
    narr:covers <https://aswritten.ai/narrative#Observation_FeedbackLoop> ;
    narr:covers <https://aswritten.ai/narrative#Position_ReviewMemorySemantics> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_OpenQuestions> ;
    narr:keyPhrase [ narr:text "The product behavior is expertise at the moment of need, not ambient" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_AmbientBehaviorCorrection> ] ;
    narr:keyPhrase [ narr:text "Custom GPTs don't provide perspective — they're just local RAG" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomGPTCorrection> ] ;
    narr:keyPhrase [ narr:text "We're not replacing experts — we're expanding their reach" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ExpertReachCorrection> ] ;
    narr:keyPhrase [ narr:text "The Tinkerer doesn't activate fastest — their existing solution is a barrier" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_TinkererBarrierCorrection> ] ;
    narr:keyPhrase [ narr:text "This feels like a similar moment to the text for topic moment" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletTextForTopicQuote> ] ;
    narr:keyPhrase [ narr:text "Five-step feedback loop: annotate surfaces unsupported claims → agent offers to document → user provides knowledge → memory saved, extraction runs → re-annotate confirms shift." ; narr:phraseSource <https://aswritten.ai/narrative#Observation_FeedbackLoop> ] ;
    narr:keyPhrase [ narr:text "Correction 7: Save memory = corrections exist, ends round, PR updates. Merge = no corrections needed, closes PR. A review with corrections always takes at least two rounds." ; narr:phraseSource <https://aswritten.ai/narrative#Position_ReviewMemorySemantics> ] ;
    narr:variation [ narr:text "Real-time per-section feedback is held superior to batch review, but the asymptotic convergence framing implies no session fully closes — these two sit in tension about what 'done' means." ; narr:over <https://aswritten.ai/narrative#Narrative_RealTimeFeedbackLoop> ; narr:over <https://aswritten.ai/narrative#Obs_ConvergenceAsymptotic> ] ;
    narr:variation [ narr:text "Tinkerer archetype corrected from 'fastest activator' to 'barrier case' — a prior hypothesis about adoption sequence was reversed by Scarlet's feedback, not refined." ; narr:over <https://aswritten.ai/narrative#Obs_TinkererBarrierCorrection> ] ;
    narr:variation [ narr:text "Feedback/help tool framed as churn prevention (operational/retention lens) sits apart from the epistemic feedback loops that dominate the hub — a different register of 'feedback.'" ; narr:over <https://aswritten.ai/narrative#Obs_FeedbackHelpQuote> ] ;
    narr:variation [ narr:text "Open Questions as bounded rhetorical scopes is a structural/stylistic observation about how unresolved decisions surface — distinct from the process loops and product corrections elsewhere in the hub." ; narr:over <https://aswritten.ai/narrative#StyleObs_OpenQuestions> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}