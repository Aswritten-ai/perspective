@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_CategoryCuratedExpertiseInstallation> {
  <https://aswritten.ai/narrative#Digest_Narrative_CategoryCuratedExpertiseInstallation> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_CategoryCuratedExpertiseInstallation> ;
    narr:childCount "6"^^xsd:integer ;
    narr:generatedFrom "aeadc8d470e3c72b5f3ad1fe6a1c937bd7a8a82a" ;
    narr:narration """The category of [Expertise Installation](narr:Position_CategoryDefinitionCuratedExpertise) has undergone a series of refinements since March 2026, moving from a focus on mechanism to a broader product-oriented framework. Initially defined as 'curated expertise installation,' the [removal of the 'curated' modifier](narr:Position_CuratedDroppedFromCategory) in late March signaled a shift toward viewing the installation process itself as inherently selective. By April, the narrative trajectory pivoted toward [goal-directed delegation with citable escalation](narr:Position_CategoryExtensionDelegation), a framing subsequently expanded to include [matching-search as a core deployment value](narr:Position_CategoryExtensionMatchingSearch). This evolution culminated in the identification of a [cross-vertical pattern](narr:Position_CrossVerticalPattern) across high-context professional services, where the high cost of vetting expertise creates a bottleneck that the model aims to resolve. Most recently, the focus has shifted from vetting as a standalone utility to [vetting as a beachhead](narr:Position_VettingAsBeachhead), positioning it as the wedge used to establish a 'perspective primitive' for configurable AI individuals.""" ;
    narr:covers <https://aswritten.ai/narrative#Position_CategoryDefinitionCuratedExpertise> ;
    narr:covers <https://aswritten.ai/narrative#Position_CategoryExtensionDelegation> ;
    narr:covers <https://aswritten.ai/narrative#Position_CategoryExtensionMatchingSearch> ;
    narr:covers <https://aswritten.ai/narrative#Position_CrossVerticalPattern> ;
    narr:covers <https://aswritten.ai/narrative#Position_CuratedDroppedFromCategory> ;
    narr:covers <https://aswritten.ai/narrative#Position_VettingAsBeachhead> ;
    narr:keyPhrase [ narr:text "expertise installation — the layer above context engineering that determines not just what AI knows, but how it thinks." ; narr:phraseSource <https://aswritten.ai/narrative#Position_CategoryDefinitionCuratedExpertise> ] ;
    narr:keyPhrase [ narr:text "goal-directed delegation with citable escalation" ; narr:phraseSource <https://aswritten.ai/narrative#Position_CategoryExtensionDelegation> ] ;
    narr:keyPhrase [ narr:text "high-context expertise, low-cost-to-produce-perspective, high-cost-to-vet-via-conversation, asymmetric information." ; narr:phraseSource <https://aswritten.ai/narrative#Position_CrossVerticalPattern> ] ;
    narr:keyPhrase [ narr:text "Vetting is not the destination; it is the wedge that creates the perspective primitive." ; narr:phraseSource <https://aswritten.ai/narrative#Position_VettingAsBeachhead> ] ;
    narr:variation [ narr:text "The definition of the category as a mechanism (installation) persists alongside its newer definition as a product (delegation)." ; narr:over <https://aswritten.ai/narrative#Position_CategoryDefinitionCuratedExpertise> ; narr:over <https://aswritten.ai/narrative#Position_CategoryExtensionDelegation> ] ;
    narr:variation [ narr:text "Vetting is framed as the primary utility in some contexts, while being relegated to a mere 'beachhead' or 'wedge' in others." ; narr:over <https://aswritten.ai/narrative#Position_CategoryExtensionMatchingSearch> ; narr:over <https://aswritten.ai/narrative#Position_VettingAsBeachhead> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}