    narr:variation [ narr:text "Not all assessments are unqualified praise — several flag resonance as strong but under-supplied with concrete stories: 'could add case study', 'Could add more customer stories', 'Could use more analogies'." ; narr:over <https://aswritten.ai/narrative#Assess_Resonance_RevModel> ; narr:over <https://aswritten.ai/narrative#RubricAssess_Resonance_GTM> ; narr:over <https://aswritten.ai/narrative#Rubric_Resonance_ScarletDame> ] ;
