GRAPH <https://aswritten.ai/narrative#Digest_Rubric_Phrasing> {
  <https://aswritten.ai/narrative#Digest_Rubric_Phrasing> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Rubric_Phrasing> ;
