    narr:covers <https://aswritten.ai/narrative#RubricAssess_Phrasing_TXReview> ;
    narr:covers <https://aswritten.ai/narrative#RubricAssess_Phrasing_WeeklyCall> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Assess_Phrasing> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Phrasing_FounderBetaUser> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Phrasing_CustomerArchitect> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Phrasing_PilotPlan> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Phrasing_ScarletDame> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Phrasing_YCDemoBeats> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Phrasing_YC_Call> ;
    narr:keyPhrase [ narr:text "remove dollar signs" ; narr:phraseSource <https://aswritten.ai/narrative#Assess_Phrasing_RevenueModelTAM> ] ;
    narr:keyPhrase [ narr:text "The physics never changed. The substrate did" ; narr:phraseSource <https://aswritten.ai/narrative#RubricAssess_Phrasing> ] ;
    narr:keyPhrase [ narr:text "I know Kung Fu" ; narr:phraseSource <https://aswritten.ai/narrative#Assessment_Phrasing_YC> ] ;
    narr:keyPhrase [ narr:text "gods of Olympus" ; narr:phraseSource <https://aswritten.ai/narrative#Rubric_Phrasing_FounderBetaUser> ] ;
    narr:keyPhrase [ narr:text "no one's selling that" ; narr:phraseSource <https://aswritten.ai/narrative#RubricAssess_Phrasing_WeeklyCall> ] ;
    narr:keyPhrase [ narr:text "builder trap" ; narr:phraseSource <https://aswritten.ai/narrative#RubricAssess_Phrasing_GTM> ] ;
    narr:variation [ narr:text "Idiolect strength is not uniform: most assessments call it 'strong,' but one flags it as merely 'present but not heavy' — a weaker-voice outlier." ; narr:over <https://aswritten.ai/narrative#RubricAssess_Phrasing> ; narr:over <https://aswritten.ai/narrative#Rubric_Assess_Phrasing> ] ;
    narr:variation [ narr:text "Two anchoring devices split the set: metaphor/analogy (GitHub, gods of Olympus, code-as-compilation) vs. consistent canonical terminology and arrow notation." ; narr:over <https://aswritten.ai/narrative#Assess_Phrasing_RevenueModelTAM> ; narr:over <https://aswritten.ai/narrative#Rubric_Phrasing_FounderBetaUser> ; narr:over <https://aswritten.ai/narrative#Rubric_Phrasing_ScarletDame> ] ;
    narr:variation [ narr:text "Phrasing serves different jobs: identity/chemistry signaling ('separated at birth', 'snappy, snappy') vs. conceptual handles ('continuation machines', 'reusable organizational perspective')." ; narr:over <https://aswritten.ai/narrative#Assessment_Phrasing_YC> ; narr:over <https://aswritten.ai/narrative#Rubric_Phrasing_YCDemoBeats> ] ;
    narr:variation [ narr:text "Some children cite supporting StyleObs observations (SeparatedAtBirth, NoOnesSellingThat); most stand alone without that scaffolding." ; narr:over <https://aswritten.ai/narrative#Assessment_Phrasing_YC> ; narr:over <https://aswritten.ai/narrative#RubricAssess_Phrasing_WeeklyCall> ] ;
