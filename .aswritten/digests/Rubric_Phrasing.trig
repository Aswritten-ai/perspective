    narr:covers <https://aswritten.ai/narrative#Rubric_Assess_Phrasing> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Phrasing_CustomerArchitect> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Phrasing_FounderBetaUser> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Phrasing_PilotPlan> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Phrasing_ScarletDame> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Phrasing_YCDemoBeats> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Phrasing_YC_Call> ;
    narr:keyPhrase [ narr:text "The physics never changed. The substrate did" ; narr:phraseSource <https://aswritten.ai/narrative#RubricAssess_Phrasing> ] ;
