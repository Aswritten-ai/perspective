@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_CaseStudies> {
  <https://aswritten.ai/narrative#Digest_CaseStudies> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#CaseStudies> ;
    narr:childCount "11"^^xsd:integer ;
    narr:generatedFrom "c535405ed1a43fba492ea1819bb21e571ffaabbb" ;
    narr:narration """This hub tracks the evolution of real-world engagements, moving from specific enterprise pilots toward a generalized theory of organizational expertise. The [enterprise customer's ARB-to-memory convergence](narr:Narrative_EnterpriseCustomerWeekOneConvergence) remains the primary benchmark, establishing a pattern where engineering governance contexts drive rapid adoption. This success is anchored by the [chief architect's \"clone me\" pain](narr:Obs_CustomerArchitectCloneMeQuote), which catalyzed a [full-loop usage pattern](narr:Obs_CustomerArchitectFullLoopPattern) of perspective, introspection, and citation. Recent efforts focus on [dissolving meta-loop confusion](narr:Narrative_CaseStudyArchitectureInAswritten) by building case study architectures directly within the platform, effectively turning discovery frameworks into productized examples. While the [enterprise customer](narr:Obs_CustomerArchitectEnterpriseCustomerFitsPattern) and [engineering manager deployments](narr:Obs_CustomerEngManagerPilotDemoQuote) validate the \"expert\" archetype, the hub also captures divergent usage, such as [a collaborator's reader-grounder pattern](narr:Obs_OrioleReaderGrounderPattern) that prioritizes grounding over active authoring, and the [early prospect's living module concept](narr:Obs_EarlyProspectLivingModuleQuote), which explores expertise as an evolving, shiftable package.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_CaseStudyArchitectureInAswritten> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_EnterpriseCustomerWeekOneConvergence> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_TextForTopicPrecedent> ;
    narr:covers <https://aswritten.ai/narrative#Obs_CustomerArchitectCloneMeQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_CustomerArchitectEnterpriseCustomerFitsPattern> ;
    narr:covers <https://aswritten.ai/narrative#Obs_CustomerArchitectFullLoopPattern> ;
    narr:covers <https://aswritten.ai/narrative#Obs_CustomerEngManagerPilotDemoQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_EarlyProspectLivingModuleQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_OrioleReaderGrounderPattern> ;
    narr:covers <https://aswritten.ai/narrative#Observation_ElephantCollective> ;
    narr:covers <https://aswritten.ai/narrative#SolutionArchetype_QAOnboarding> ;
    narr:keyPhrase [ narr:text "I wish we could clone me." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerArchitectCloneMeQuote> ] ;
    narr:keyPhrase [ narr:text "the customer's chief architect's full-loop pattern: perspective → introspect → remember → cite, distributed across all four core tools" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerArchitectFullLoopPattern> ] ;
    narr:keyPhrase [ narr:text "a collaborator's reader-grounder pattern: perspective → cite, repeatedly" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_OrioleReaderGrounderPattern> ] ;
    narr:keyPhrase [ narr:text "Building each case study's narrative architecture in aswritten dissolves the meta-loop and produces org-shaped example material" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_CaseStudyArchitectureInAswritten> ] ;
    narr:variation [ narr:text "The 'reader-grounder' pattern suggests value can be realized without active authoring, contrasting with the 'expert' archetype." ; narr:over <https://aswritten.ai/narrative#Obs_OrioleReaderGrounderPattern> ] ;
    narr:variation [ narr:text "The 'living module' pitch focuses on expertise as a shifting, evolving package rather than a static governance tool." ; narr:over <https://aswritten.ai/narrative#Obs_EarlyProspectLivingModuleQuote> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}