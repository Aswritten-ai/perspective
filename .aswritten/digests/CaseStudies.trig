    narr:covers <https://aswritten.ai/narrative#Obs_EarlyProspectLivingModuleQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_EarlyProspectMar22Text> ;
    narr:covers <https://aswritten.ai/narrative#Obs_CustomerEngManagerPilotDemoQuote> ;
