    narr:covers <https://aswritten.ai/narrative#Observation_OrioleCiteVolume> ;
    narr:covers <https://aswritten.ai/narrative#Observation_WebsiteCaseStudyStrategy> ;
    narr:covers <https://aswritten.ai/narrative#Outcome_BetaCommitment> ;
    narr:covers <https://aswritten.ai/narrative#SolutionArchetype_QAOnboarding> ;
    narr:keyPhrase [ narr:text "I wish we could clone me." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerArchitectCloneMeQuote> ] ;
    narr:keyPhrase [ narr:text "I'm sold on the potential value of your application, but I don't feel a rush to begin using it." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_EarlyProspectMar22Text> ] ;
    narr:keyPhrase [ narr:text "upgrading to the Team plan ([amount]/month) on 2026-03-26" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_FirstPayingTeamCustomer> ] ;
    narr:keyPhrase [ narr:text "the killer sales demo" ; narr:phraseSource <https://aswritten.ai/narrative#SolutionArchetype_QAOnboarding> ] ;
    narr:keyPhrase [ narr:text "the customer's chief architect wants to give the ARB perspective to coworkers so they only ask him if they make it to the end of the funnel" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CustomerArchitectEnterpriseCustomerFitsPattern> ] ;
    narr:keyPhrase [ narr:text "Bootstrapped from [amount]to [amount]/event in 6 months." ; narr:phraseSource <https://aswritten.ai/narrative#Observation_ElephantCollective> ] ;
    narr:variation [ narr:text "Converted vs stalled: the enterprise customer bought and converged fast; an engineering manager at the customer explicitly feels no rush, neither trigger firing — opposite outcomes from the same archetype." ; narr:over <https://aswritten.ai/narrative#Narrative_FirstPayingTeamCustomer> ; narr:over <https://aswritten.ai/narrative#Obs_EarlyProspectMar22Text> ; narr:over <https://aswritten.ai/narrative#Actor_EarlyProspect_MVPRef> ] ;
    narr:variation [ narr:text "Distinct usage depths: the customer's chief architect is the full-loop 'expert' (perspective→introspect→remember→cite) while a collaborator is a reader-grounder with zero authoring yet." ; narr:over <https://aswritten.ai/narrative#Obs_CustomerArchitectFullLoopPattern> ; narr:over <https://aswritten.ai/narrative#Obs_OrioleReaderGrounderPattern> ] ;
    narr:variation [ narr:text "an engineering manager at the customer pilot reframed by the a practitioner beta user Barber session (Apr 30): trust-transfer referral becomes the launch flow, not three equal-weight flows." ; narr:over <https://aswritten.ai/narrative#Narrative_EarlyProspectFirstPilot> ] ;
    narr:variation [ narr:text "an engineering manager at the customer as pilot vs demo: framed as not really a demo but a real public-facing deployment, with a free chapter-distillation offered as a trigger-bridge." ; narr:over <https://aswritten.ai/narrative#Obs_CustomerEngManagerPilotDemoQuote> ; narr:over <https://aswritten.ai/narrative#Obs_EarlyProspectLivingModuleQuote> ; narr:over <https://aswritten.ai/narrative#Actor_EarlyProspect_MVPRef> ] ;
    narr:variation [ narr:text "Outlier domain: Elephant Collective is SMS-first event mobilization, structurally unlike the knowledge-packaging/enterprise cases." ; narr:over <https://aswritten.ai/narrative#Observation_ElephantCollective> ] ;
    narr:variation [ narr:text "Commercial-structure thread: a live-demo delivery gate with non-refundable [amount] deposit, separate from the case narratives." ; narr:over <https://aswritten.ai/narrative#Narrative_DeliveryGate> ; narr:over <https://aswritten.ai/narrative#Outcome_BetaCommitment> ] ;
    narr:writer "claude (subscription)" .
