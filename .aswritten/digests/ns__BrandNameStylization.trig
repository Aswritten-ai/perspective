    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """This hub gathers observations about orthographic and brand stylization across aswritten's documents. The dominant pattern is consistent: a [lowercase brand name with .ai TLD](narr:Observation_AswrittenBrand) — `aswritten.ai` — applied throughout, echoed in the [distinctive lowercase orthography](narr:StyleObs_BrandName) and [no-space .ai treatment](narr:StyleObs_BrandStylization_1). Several children read the lowercase choice as deliberate technical positioning, aligning the brand with [intellectual property as code](narr:Observation_IPAsCode) and a [biological metaphor of organization as AI organism](narr:StyleObs_1) whose DNA is expressed in artifacts. Beyond the domain name, the corpus tracks a second stylization layer: a [centralized 'aswritten' system handle](narr:Obs_SystemHandle), a [hyphenated lowercase 'git-native' term](narr:StyleObs_BrandName_GitNative) for developer credibility, and [backtick-wrapped inline code](narr:StyleObs_InlineCode) for type and function names. A recurring two-word lowercase phrase, [collective memory](narr:StyleObs_brand_name), appears as a product/brand handle alongside compact taglines.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Obs_SystemHandle> ;
    narr:covers <https://aswritten.ai/ns/narrative#Observation_AswrittenBrand> ;
    narr:covers <https://aswritten.ai/ns/narrative#Observation_IPAsCode> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_6> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_BrandName> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_BrandName_GitNative> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_BrandStylization> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_BrandStylization_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_InlineCode> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_brand_name> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_brandname_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#Tagline_ADR002> ;
    narr:keyPhrase [ narr:text "aswritten.ai" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_AswrittenBrand> ] ;
    narr:keyPhrase [ narr:text "**Handle**: \"aswritten\" (centralized constant)" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Obs_SystemHandle> ] ;
    narr:keyPhrase [ narr:text "intellectual property as code" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_IPAsCode> ] ;
    narr:keyPhrase [ narr:text "collective memory" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_brand_name> ] ;
    narr:keyPhrase [ narr:text "Bundle `Snapshot` + `Ontology` into single `State` type" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_InlineCode> ] ;
    narr:keyPhrase [ narr:text "the treatment of an organization as an AI organism, right? Whose DNA, if you will, is expressed" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_1> ] ;
    narr:variation [ narr:text "What counts as 'the brand name' splits: most children read 'aswritten.ai' (domain-style), but others treat the two-word lowercase 'collective memory' as the product/brand handle." ; narr:over <https://aswritten.ai/ns/narrative#Observation_AswrittenBrand> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_brand_name> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_BrandStylization> ] ;
    narr:variation [ narr:text "Lowercase is not universal: one observation flags Title case for a heading with no brand name at all — context-focused rather than brand-focused." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_BrandStylization> ] ;
    narr:variation [ narr:text "Distinct from the brand-name stylization, separate orthographic conventions appear — hyphenated 'git-native' and backtick-wrapped code identifiers — which may not belong under the same rule." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_BrandName_GitNative> ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_InlineCode> ] ;
    narr:variation [ narr:text "Two children attached via skos:related (not broader) read as taglines/handles encoding the value prop rather than stylization observations proper." ; narr:over <https://aswritten.ai/ns/narrative#Tagline_ADR002> ] ;
    narr:writer "claude (subscription)" .
