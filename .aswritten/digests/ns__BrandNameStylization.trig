    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_BrandName> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_BrandName_GitNative> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_BrandStylization> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_BrandStylization_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_InlineCode> ;
    narr:covers <https://aswritten.ai/ns/narrative#StyleObs_brand_name> ;
    narr:covers <https://aswritten.ai/ns/narrative#Tagline_ADR002> ;
    narr:keyPhrase [ narr:text "aswritten.ai" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_AswrittenBrand> ] ;
    narr:keyPhrase [ narr:text "intellectual property as code" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Observation_IPAsCode> ] ;
    narr:keyPhrase [ narr:text "the treatment of an organization as an AI organism, right? Whose DNA, if you will, is expressed" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_1> ] ;
    narr:keyPhrase [ narr:text "collective memory" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_brand_name> ] ;
    narr:keyPhrase [ narr:text "Bundle `Snapshot` + `Ontology` into single `State` type" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_InlineCode> ] ;
    narr:keyPhrase [ narr:text "positioning, offering, product, teams, and process" ; narr:phraseSource <https://aswritten.ai/ns/narrative#StyleObs_6> ] ;
    narr:variation [ narr:text "Some documents explicitly depart from brand-centric titling in favor of context-focused headings." ; narr:over <https://aswritten.ai/ns/narrative#StyleObs_BrandStylization> ] ;
