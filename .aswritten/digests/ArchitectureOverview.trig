    narr:covers <https://aswritten.ai/narrative#Narrative_RichnessVsVisibilitySeparation> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_SeparationOfConcerns> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_SynchronousPerMessageIntegration> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ThreeLayerMemory> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_TransformOverQuery> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_VisibilityInvariantAreaIndex> ;
    narr:covers <https://aswritten.ai/narrative#Obs_AsyncDriftArgumentQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_CompileDeprecated> ;
    narr:covers <https://aswritten.ai/narrative#Obs_NamedPerspectiveQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_OntologyGeneralizationQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_PerspectiveOrderFourSections> ;
    narr:covers <https://aswritten.ai/narrative#Obs_RefractionPattern> ;
    narr:covers <https://aswritten.ai/narrative#Obs_RichTierCompositionResult> ;
    narr:covers <https://aswritten.ai/narrative#Observation_GitHubBranchTrunk> ;
