    narr:covers <https://aswritten.ai/narrative#Narrative_GraphInMemoryStorage> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ImplicationConceptProvisional> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_IntrospectAbsorbedScope> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ModelAsOSNotApplication> ;
