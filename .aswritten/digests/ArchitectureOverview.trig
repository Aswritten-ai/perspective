    narr:keyPhrase [ narr:text "Perspective shifts are transforms on an existing graph — not queries that filter it" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_TransformOverQuery> ] ;
    narr:keyPhrase [ narr:text "The conviction stack measures how settled a claim is but not when it applies" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ConvictionStackTemporalityGap> ] ;
    narr:keyPhrase [ narr:text "Navigation through the collapsed digest replaces embedding the full compiled snapshot" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_NavigationReplacesEmbeddedSnapshot> ] ;
    narr:keyPhrase [ narr:text "Richness is a budget decision; visibility is an invariant" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_RichnessVsVisibilitySeparation> ] ;
    narr:keyPhrase [ narr:text "The graph can live in memory, stored nowhere by default" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_GraphInMemoryStorage> ] ;
    narr:variation [ narr:text "The v1 map's reliance on raw in-degree selection inadvertently prioritized style-taxonomy hubs over strategic ones." ; narr:over <https://aswritten.ai/narrative#Position_InDegreeSelectionFlawed> ] ;
    narr:variation [ narr:text "A proposed 'narr:appliesAs' ontology property offers a structural fix for temporality, but remains deferred to avoid mid-launch disruption." ; narr:over <https://aswritten.ai/narrative#Position_NarrAppliesAsOntologyExtension> ] ;
    narr:variation [ narr:text "Synchronous per-message integration is favored over async to prevent drift, despite potential MCP client limitations." ; narr:over <https://aswritten.ai/narrative#Narrative_SynchronousPerMessageIntegration> ] ;
    narr:variation [ narr:text "The 'compile' tool is technically deprecated in practice, superseded by the structural index and LLM selection patterns." ; narr:over <https://aswritten.ai/narrative#Obs_CompileDeprecated> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
