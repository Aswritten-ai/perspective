    narr:keyPhrase [ narr:text "Orchestrators own paths and side effects; pure functions return structured data." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_PureFunctionSettled> ] ;
    narr:keyPhrase [ narr:text "The current conviction stack (notion → claim → decision → principle) measures how settled a claim is but has no axis for when a claim applies." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ConvictionStackTemporalityGap> ] ;
    narr:keyPhrase [ narr:text "The digest is a lossy index over a lossless store; the index never gates the store; it accelerates the recognized path without foreclosing novel readings" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_DigestAsRecognitionAid> ] ;
    narr:keyPhrase [ narr:text "The graph can live in memory, stored nowhere by default — download at session end, upload to resume; GitHub becomes optional storage, not a required third party" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_GraphInMemoryStorage> ] ;
    narr:keyPhrase [ narr:text "Proxy-mediated repo IO as single boundary dispatching between GitHub and filesystem git" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ProxyMediatedRepoIOBoundary> ] ;
    narr:keyPhrase [ narr:text "Richness is a budget decision; visibility is an invariant — the principled separation that makes tier weighting compatible with compression-only" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_RichnessVsVisibilitySeparation> ] ;
    narr:keyPhrase [ narr:text "NOW VALIDATED BY PRODUCTION FAILURE: the customer's chief architect's demo pollution experience (2026-05-01) is the first documented customer case where the absence of this property caused a destructive corrective action (full memory deletion)." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_NarrAppliesAsOntologyExtension> ] ;
    narr:keyPhrase [ narr:text "Every hub in the graph is named in every response — the richest areas render their full digest, and every other area gets a one-line entry with its name and child count, one expand away." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_VisibilityInvariantAreaIndex> ] ;
    narr:variation [ narr:text "GitHub as required third-party vs. GitHub as optional storage: the group=repo primitive assumes GitHub, but the in-memory graph model (Jul 2026) removes that dependency for the self-serve path." ; narr:over <https://aswritten.ai/narrative#Arch_GroupAsRepo> ; narr:over <https://aswritten.ai/narrative#Narrative_GraphInMemoryStorage> ] ;
    narr:variation [ narr:text "Compile tool deprecated in practice (context limits, superseded by structural index + LLM selection) but retained for utility — the brute-force approach is not gone, just demoted." ; narr:over <https://aswritten.ai/narrative#Obs_CompileDeprecated> ] ;
    narr:variation [ narr:text "Async integration explicitly rejected (drift argument: stale individual breaks the promise) — but MCP clients cannot be forced to call a tool every message, leaving a hybrid-model gap unresolved." ; narr:over <https://aswritten.ai/narrative#Narrative_SynchronousPerMessageIntegration> ] ;
    narr:variation [ narr:text "v1 map's in-degree selection flaw: style-taxonomy hubs dominated because extraction funnels every style observation into a small set of hubs, crowding out strategy and architecture overviews that agents actually steer from." ; narr:over <https://aswritten.ai/narrative#Claim_InDegreeSelectionFlawed> ] ;
    narr:variation [ narr:text "narr:appliesAs temporality property: deferred pre-launch as a near-future notion, but production failure (May 2026) validated the gap and the claim was flagged for promotion to stake-level — still not shipped." ; narr:over <https://aswritten.ai/narrative#Claim_NarrAppliesAsOntologyExtension> ; narr:over <https://aswritten.ai/narrative#Narrative_ConvictionStackTemporalityGap> ] ;
    narr:variation [ narr:text "'Implication' as the provisional inverse of escalation — when a perspective should be pulled in — is coined but uncommitted: open design question whether it lives within a single graph or as a multi-graph reconciliation statement." ; narr:over <https://aswritten.ai/narrative#Narrative_ImplicationConceptProvisional> ] ;
    narr:variation [ narr:text "Ontology core primitives claimed as domain-agnostic (Mar 2026), but whether non-org expertise domains need additional concept types (pedagogical structures, diagnostic frameworks) remains an open, unvalidated question." ; narr:over <https://aswritten.ai/narrative#Narrative_OntologyDomainAgnostic> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}