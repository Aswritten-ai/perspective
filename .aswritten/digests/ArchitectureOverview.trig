@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ArchitectureOverview> {
  <https://aswritten.ai/narrative#Digest_ArchitectureOverview> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#ArchitectureOverview> ;
    narr:childCount "41"^^xsd:integer ;
    narr:generatedFrom "53f9889402ea2f13767fd3e09126d25cd1181a86" ;
    narr:narration """The architecture has evolved from a directory-based compilation model into a [transform-based perspective engine](narr:https://aswritten.ai/narrative#Narrative_TransformOverQuery), emphasizing [pure-function workflows](narr:https://aswritten.ai/narrative#Narrative_PureFunctionArchitecture) that decouple computation from side effects. Institutional memory is now anchored to [group-specific repositories](narr:https://aswritten.ai/narrative#Arch_GroupAsRepo) with identity managed via [phone numbers](narr:https://aswritten.ai/narrative#Arch_IdentityViaPhone). Recent refinements (July 2026) established a [four-section response structure](narr:https://aswritten.ai/narrative#Narrative_PerspectiveResponseOrderedByVolatility) that prioritizes [visibility via a complete area index](narr:https://aswritten.ai/narrative#Narrative_VisibilityInvariantAreaIndex) while allocating [rich-tier slots based on steering weight](narr:https://aswritten.ai/narrative#Narrative_RichTierBySteeringWeight). The system now treats [navigation as the primary read path](narr:https://aswritten.ai/narrative#Narrative_NavigationReplacesEmbeddedSnapshot), moving away from embedded snapshots. While the [core ontology remains domain-agnostic](narr:https://aswritten.ai/narrative#Narrative_OntologyDomainAgnostic), the [conviction stack's lack of a temporality axis](narr:https://aswritten.ai/narrative#Narrative_ConvictionStackTemporalityGap) remains a critical structural gap, now validated by production failures. The architecture further explores [named advisor perspectives](narr:https://aswritten.ai/narrative#Narrative_NamedPerspectiveArchitecture) as sub-agents and [in-memory graph storage](narr:https://aswritten.ai/narrative#Narrative_GraphInMemoryStorage) to decouple from GitHub dependencies.""" ;
    narr:covers <https://aswritten.ai/narrative#Arch_GroupAsRepo> ;
    narr:covers <https://aswritten.ai/narrative#Arch_IdentityViaPhone> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_CodeAsCompilationOutput> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_CompileTimeActorLens> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ConvictionStackTemporalityGap> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DataHandlingSubstantiated> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DigestAsRecognitionAid> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_GitHubAsInstitutionalMemory> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_GraphInMemoryStorage> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ImplicationConceptProvisional> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_IntrospectAbsorbedScope> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ModelAsOSNotApplication> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_MultiTenantHub> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_NamedPerspectiveArchitecture> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_NavigationReplacesEmbeddedSnapshot> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_OntologyDomainAgnostic> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PerspectiveResponseOrderedByVolatility> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PureFunctionArchitecture> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PureFunctionDesign> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_RichTierBySteeringWeight> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_RichnessVsVisibilitySeparation> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_SeparationOfConcerns> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_SynchronousPerMessageIntegration> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ThreeLayerMemory> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_TransformOverQuery> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_VisibilityInvariantAreaIndex> ;
    narr:covers <https://aswritten.ai/narrative#Obs_AsyncDriftArgumentQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_CompileDeprecated> ;
    narr:covers <https://aswritten.ai/narrative#Obs_NamedPerspectiveQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_OntologyGeneralizationQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_PerspectiveOrderFourSections> ;
    narr:covers <https://aswritten.ai/narrative#Obs_RefractionPattern> ;
    narr:covers <https://aswritten.ai/narrative#Obs_RichTierCompositionResult> ;
    narr:covers <https://aswritten.ai/narrative#Observation_GitHubBranchTrunk> ;
    narr:covers <https://aswritten.ai/narrative#Observation_StructuralIndex> ;
    narr:covers <https://aswritten.ai/narrative#Position_InDegreeSelectionFlawed> ;
    narr:covers <https://aswritten.ai/narrative#Position_NarrAppliesAsOntologyExtension> ;
    narr:covers <https://aswritten.ai/narrative#Position_PublicPerspectiveSiblingRepo> ;
    narr:covers <https://aswritten.ai/narrative#Position_PureFunctionSettled> ;
    narr:covers <https://aswritten.ai/narrative#Position_RepoPerClient> ;
    narr:covers <https://aswritten.ai/narrative#Position_TransformIsBetterVerbThanQuery> ;
    narr:keyPhrase [ narr:text "The digest is a lossy index over a lossless store; the index never gates the store; it accelerates the recognized path without foreclosing novel readings" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_DigestAsRecognitionAid> ] ;
    narr:keyPhrase [ narr:text "The conviction stack measures how settled a claim is but not when it applies — this missing temporality axis is the structural cause of canon-too-soon drift" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ConvictionStackTemporalityGap> ] ;
    narr:keyPhrase [ narr:text "Richness is a budget decision; visibility is an invariant — the principled separation that makes tier weighting compatible with compression-only" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_RichnessVsVisibilitySeparation> ] ;
    narr:keyPhrase [ narr:text "Integration is synchronous, per-message, and silent — async breaks the individual and the deliberate feedback-in-chat decision" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_SynchronousPerMessageIntegration> ] ;
    narr:keyPhrase [ narr:text "The graph can live in memory, stored nowhere by default — download at session end, upload to resume; GitHub becomes optional storage, not a required third party" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_GraphInMemoryStorage> ] ;
    narr:variation [ narr:text "The v1 selection model relied on raw in-degree, which inadvertently prioritized style-taxonomy hubs over strategy and architecture." ; narr:over <https://aswritten.ai/narrative#Position_InDegreeSelectionFlawed> ] ;
    narr:variation [ narr:text "A proposed 'appliesAs' ontology property could solve the temporality gap, though it remains deliberately deferred to avoid launch-critical disruption." ; narr:over <https://aswritten.ai/narrative#Position_NarrAppliesAsOntologyExtension> ] ;
    narr:variation [ narr:text "While GitHub is currently the primary storage, the system is moving toward optionality via in-memory graph persistence." ; narr:over <https://aswritten.ai/narrative#Narrative_GraphInMemoryStorage> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}