@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Parallelism> {
  <https://aswritten.ai/narrative#Digest_Parallelism> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Parallelism> ;
    narr:childCount "17"^^xsd:integer ;
    narr:generatedFrom "022988b93c06928d86401c84e4103b932d70ce25" ;
    narr:narration """This hub collects the many faces of **parallelism** as Scarlet's dominant structural device. The syntactic core runs from [role+gerund list rhythm](narr:https://aswritten.ai/narrative#StyleObs_Parallelism_1) and [arrow-chained verb phrases](narr:https://aswritten.ai/narrative#StyleObs_ArrowParallelism) ('extract → lens → repeat') through [rule-of-three conditional branches](narr:https://aswritten.ai/narrative#StyleObs_3) and [triadic negative enumeration](narr:https://aswritten.ai/narrative#StyleObs_NegativeParallelism) with anaphoric 'no'. List architecture extends this: [numbered failure progressions](narr:https://aswritten.ai/narrative#StyleObs_FailureProgression) (approach → outcome, building toward breakthrough), [convergent-problem triads](narr:https://aswritten.ai/narrative#StyleObs_NumberedConvergence), [bold-label friction bullets](narr:https://aswritten.ai/narrative#StyleObs_CognitiveFrictionList), and [adaptive-state bullets](narr:https://aswritten.ai/narrative#StyleObs_BulletParallelism). Structural parallelism appears in [deferral tables](narr:https://aswritten.ai/narrative#StyleObs_DeferralTable) (Decision | Rationale | Reversibility), [before/after argument tables](narr:https://aswritten.ai/narrative#StyleObs_TableAsArgument), and [em-dash use-case lists](narr:https://aswritten.ai/narrative#StyleObs_ThreeUseCases_DashList) (dated Jul 2026). A distinct rhetorical mode uses parallelism for *analytical separation* rather than rhythm: [forced three-fact enumeration](narr:https://aswritten.ai/narrative#StyleObs_OutsideTechBetaUserChannel_ThreeFactsSeparated) (Apr 2026) explicitly breaks conflated concepts apart. [Repeated 'No company' anaphora](narr:https://aswritten.ai/narrative#StyleObs_NoCompanyAnaphora) and [parallel quoted inner-voice lines per Enneagram type](narr:https://aswritten.ai/narrative#StyleObs_6) show the device crossing into persuasion and dramatic register.""" ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_10> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_3> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_5> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_6> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_9> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ArrowParallelism> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_BulletParallelism> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_CognitiveFrictionList> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_DeferralTable> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_FailureProgression> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NegativeParallelism> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NoCompanyAnaphora> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NumberedConvergence> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_OutsideTechBetaUserChannel_ThreeFactsSeparated> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Parallelism_1> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TableAsArgument> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ThreeUseCases_DashList> ;
    narr:keyPhrase [ narr:text "extract → lens → micro-telltale → human feedback → modify triples → re-lens → repeat" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ArrowParallelism> ] ;
    narr:keyPhrase [ narr:text "Three facts that the perspective has collapsed into one classification should be held separately" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_OutsideTechBetaUserChannel_ThreeFactsSeparated> ] ;
    narr:keyPhrase [ narr:text "No company would develop software without GitHub. No company should deploy AI agents without versioned organizational context." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_NoCompanyAnaphora> ] ;
    narr:keyPhrase [ narr:text "— Discovery: This is what a consultant who ran enterprise discovery engagements for fifteen years and I were talking about." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ThreeUseCases_DashList> ] ;
    narr:keyPhrase [ narr:text "Parallel numbered list structure (1-5) maps the failure progression. Each item follows the same pattern: approach description → arrow → outcome." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_FailureProgression> ] ;
    narr:keyPhrase [ narr:text "Markdown table used as rhetorical device: before/after structure across all five taxonomy cases makes the argument visually and structurally. Each row is a parallel proof point." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TableAsArgument> ] ;
    narr:keyPhrase [ narr:text "Markdown tables used for architectural decisions and deferred tasks — parallel structure enforces consistent reasoning format (Decision | Rationale | Reversibility)." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DeferralTable> ] ;
    narr:variation [ narr:text "Parallelism as analytical separation (forcing apart conflated facts) vs. parallelism as rhythm or persuasion — a functional split the corpus carries simultaneously" ; narr:over <https://aswritten.ai/narrative#StyleObs_OutsideTechBetaUserChannel_ThreeFactsSeparated> ; narr:over <https://aswritten.ai/narrative#StyleObs_NoCompanyAnaphora> ; narr:over <https://aswritten.ai/narrative#StyleObs_ArrowParallelism> ] ;
    narr:variation [ narr:text "Negative parallelism (anaphoric 'no', 'not X but Y' antithesis) as a distinct sub-mode that constrains rather than enumerates" ; narr:over <https://aswritten.ai/narrative#StyleObs_NegativeParallelism> ; narr:over <https://aswritten.ai/narrative#StyleObs_9> ] ;
    narr:variation [ narr:text "Dramatic/voiced parallelism — each Enneagram type given its own quoted inner-voice line — departs from the analytical register that dominates most instances" ; narr:over <https://aswritten.ai/narrative#StyleObs_6> ] ;
    narr:variation [ narr:text "Em-dash list structure (Jul 2026) as a spoken-word-to-text idiolect variant of bullet parallelism — label-colon-definition rather than bold-lead-in" ; narr:over <https://aswritten.ai/narrative#StyleObs_ThreeUseCases_DashList> ; narr:over <https://aswritten.ai/narrative#StyleObs_CognitiveFrictionList> ] ;
    narr:variation [ narr:text "Bold-label micro-pattern (bold phrase + colon + elaboration) operates at sentence level, distinct from the list- and table-level parallelism that dominates the hub" ; narr:over <https://aswritten.ai/narrative#StyleObs_10> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}