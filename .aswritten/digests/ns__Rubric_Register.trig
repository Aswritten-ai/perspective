    narr:generatedFrom "3fc75bbbd3f39f26eb07aa0963abefcef8fd6f4c" ;
    narr:narration """This hub organizes register assessments across the corpus, mapping the tension between [conversational-authoritative](narr:RubricAssess_register) modes and [formal-technical](narr:Assess_Register_cm) standards. The dominant thread favors a [direct, second-person](narr:RubricAssess_register) approach, characterized by [active voice](narr:RubricAssess_Register_GTM) and [technical precision](narr:Assessment_Register_IPCrisis), as seen in [strategic memos](narr:RubricAssess_Register_GTM) and [enterprise-facing assessments](narr:Assessment_Register_CustomerArchitect). Conversely, [architecture documentation](narr:Assess_Register_cm) and [ADRs](narr:RubricAssess_Register_ADR001) maintain a distinct [formal business](narr:RubricAssess_Register_ADR001) or [structured technical](narr:Assess_Register_collective_memory) register, often prioritizing [first-person plural](narr:RubricAssess_Register_ADR001) ownership over the conversational 'you.' The thematic span is wide, encompassing [founder-visionary](narr:RubricAssess_Register) extremes—which may include [profanity](narr:RubricAssess_Register) or [elevated rhetoric](narr:RubricAssess_Register)—and [conversational](narr:RubricAssess_Register_1) styles that occasionally incorporate [fillers](narr:RubricAssess_Register_1). These assessments do not converge on a single verdict but rather evaluate register as a function of document context and intended audience.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Assess_Register_cm> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assess_Register_collective_memory> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assessment_Register_CustomerArchitect> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assessment_Register_IPCrisis> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Register> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Register_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Register_ADR001> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Register_ADR002> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Register_GTM> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_register> ;
    narr:keyPhrase [ narr:text "technical precision without jargon overload" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assessment_Register_IPCrisis> ] ;
    narr:keyPhrase [ narr:text "Formal technical register; authoritative tone" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assess_Register_cm> ] ;
    narr:keyPhrase [ narr:text "first-person plural establishes ownership" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Register_ADR001> ] ;
    narr:keyPhrase [ narr:text "Tony's quotes use profanity for emphasis" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Register> ] ;
    narr:keyPhrase [ narr:text "Fillers reduce formality." ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Register_1> ] ;
    narr:variation [ narr:text "Formal-technical rigidity vs. conversational-authoritative flexibility." ; narr:over <https://aswritten.ai/ns/narrative#Assess_Register_cm> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_register> ] ;
    narr:variation [ narr:text "Inclusion of profanity and elevated visionary language as valid register choices." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Register> ] ;
    narr:variation [ narr:text "Impact of filler words on perceived formality." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Register_1> ] ;
