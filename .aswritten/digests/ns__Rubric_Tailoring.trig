    narr:covers <https://aswritten.ai/ns/narrative#Assessment_Tailoring_IPCrisis> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Tailoring> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Tailoring_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Tailoring_ADR001> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Tailoring_ADR002> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Tailoring_GTM> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_tailoring> ;
    narr:keyPhrase [ narr:text "Tailored for technical audience (engineering, architecture teams); includes code examples, type signatures" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assess_Tailoring_cm> ] ;
    narr:keyPhrase [ narr:text "Explicitly segments audiences: decision makers (pain), procurement (ROI), VCs (transparency), end users (workflow)." ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Tailoring> ] ;
    narr:keyPhrase [ narr:text "acknowledges developer-first tension; tailored to strategic decision-makers" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assessment_Tailoring_IPCrisis> ] ;
    narr:keyPhrase [ narr:text "would need translation for external stakeholders" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Tailoring_ADR001> ] ;
    narr:keyPhrase [ narr:text "distinct champion profiles (CEO/Strategy/CTO), vertical-specific pain points" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Tailoring_GTM> ] ;
    narr:variation [ narr:text "Some assessments identify a 'developer-first tension' when pivoting to executive audiences." ; narr:over <https://aswritten.ai/ns/narrative#Assessment_Tailoring_IPCrisis> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Tailoring_ADR001> ] ;
    narr:variation [ narr:text "A recurring critique suggests that while personas are identified, they often lack sufficient 'persona-specific examples'." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Tailoring> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_tailoring> ] ;
