    narr:variation [ narr:text "Single technical-audience fit vs. broad multi-persona segmentation — the rubric rewards both, but they pull opposite directions (deep domain assumptions vs. accessibility)." ; narr:over <https://aswritten.ai/ns/narrative#Assess_Tailoring_cm> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Tailoring_1> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Tailoring_20260107> ; narr:over <https://aswritten.ai/ns/narrative#Assess_Tailoring_collective_memory> ] ;
