GRAPH <https://aswritten.ai/narrative#Digest_RegisterFormality> {
  <https://aswritten.ai/narrative#Digest_RegisterFormality> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#RegisterFormality> ;
    narr:childCount "19"^^xsd:integer ;
    narr:generatedFrom "823e027edf9b591d18130284a2d0fdfc53db29a9" ;
    narr:narration """This hub collects register and formality observations spanning the full range from zero-hedging declarative to self-critical tentative. The dominant pattern is **mixed register**: [session-memo code-switching between formal analytical prose and informal verbatim blockquotes](narr:https://aswritten.ai/narrative#StyleObs_12) appears across [agent-simulation documents](narr:https://aswritten.ai/narrative#StyleObs_AgentSim_BlockquoteRegister), [design-collaborator Tokens sessions](narr:https://aswritten.ai/narrative#StyleObs_DesignCollaboratorTokensBlockquoteRegister), and [Fable Window planning memos](narr:https://aswritten.ai/narrative#StyleObs_FableWindowBlockquoteStyle) — identified as Scarlet's session-memo idiolect in which blockquotes carry primary evidence and editorial prose frames significance. A second cluster is **technical-authoritative**: [infrastructure vocabulary applied to product decisions](narr:https://aswritten.ai/narrative#StyleObs_PerspectiveOrdering_TechnicalRegister) and [engineering-expert-to-expert register with deliberate informal asides](narr:https://aswritten.ai/narrative#StyleObs_RegisterTechnical). A third is **epistemic hedging declared upfront**: [conviction status bolded in headers](narr:https://aswritten.ai/narrative#StyleObs_DiscoveryWedge_CaveatEmbedded), [notion-level hedging register](narr:https://aswritten.ai/narrative#StyleObs_NotionLevelCadence), [provisional flags as both content and form](narr:https://aswritten.ai/narrative#StyleObs_ProvisionalFlagVoice), and [unusually self-critical strategic-memo register](narr:https://aswritten.ai/narrative#StyleObs_EnterpriseShape_TentativeRegister). Outlier registers include [unfiltered profanity for emphasis](narr:https://aswritten.ai/narrative#StyleObs_DirectQuote_UXIsShit), [parenthetical italicized meta-commentary on source reliability](narr:https://aswritten.ai/narrative#StyleObs_ParentheticalAsides), and [zero-hedging declarative assertion](narr:https://aswritten.ai/narrative#StyleObs_8). The [blockquote-as-deliverable-speech-act](narr:https://aswritten.ai/narrative#StyleObs_BlockquoteForScript) variant uses the same visual idiom for a different purpose: signaling ready-to-use language rather than evidence.""" ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_12> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_8> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_AgentSim_BlockquoteRegister> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_AgentSim_ProvisionalFlag> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_BlockquoteForScript> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_DesignCollaboratorTokensBlockquoteRegister> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_DirectQuote_UXIsShit> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_DiscoveryWedge_CaveatEmbedded> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_EnterpriseShape_TentativeRegister> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_FableWindowBlockquoteStyle> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_InformalRegisterInQuote> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NegotiationLanguage> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NotionLevelCadence> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ParentheticalAsides> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_PerspectiveOrdering_TechnicalRegister> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ProvisionalFlagVoice> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RegisterTechnical> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Register_Strategic> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_SMB_BulletedExamples> ;
    narr:keyPhrase [ narr:text "Code-switching between formal analytical register and informal conversational register (direct quotes from Scarlet in lowercase, no punctuation). Deliberate contrast." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_12> ] ;
    narr:keyPhrase [ narr:text "Declarative assertion without hedging: 'this isn't a hypothetical failure mode, it's the default state' — authoritative register, zero epistemic softening." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_8> ] ;
    narr:keyPhrase [ narr:text "**Conviction: claim / candidate — NOT a settled decision.**" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DiscoveryWedge_CaveatEmbedded> ] ;
    narr:keyPhrase [ narr:text "notion until repeated" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_NotionLevelCadence> ] ;
    narr:keyPhrase [ narr:text "Provisional — from research/goal-directed-agents exploration branch, not yet promoted to main." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ProvisionalFlagVoice> ] ;
    narr:keyPhrase [ narr:text "if the only evidence for \"enterprise shape\" being primary is one pilot with a lukewarm champion (the customer's chief architect is sponsor, not champion — see separate memory), you are potentially rationalizing" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_EnterpriseShape_TentativeRegister> ] ;
    narr:keyPhrase [ narr:text "A no-focus orientation call is byte-stable for a given graph state." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_PerspectiveOrdering_TechnicalRegister> ] ;
    narr:keyPhrase [ narr:text "Session-sourced, not stated in the transcript and Scarlet noted the transcript was unclear on this" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ParentheticalAsides> ] ;
    narr:variation [ narr:text "Zero-hedging declarative register ('stated as settled fact, not hypothesis') sits in direct tension with the epistemic-hedging cluster — same corpus, opposite epistemic posture." ; narr:over <https://aswritten.ai/narrative#StyleObs_8> ; narr:over <https://aswritten.ai/narrative#StyleObs_EnterpriseShape_TentativeRegister> ; narr:over <https://aswritten.ai/narrative#StyleObs_NotionLevelCadence> ] ;
    narr:variation [ narr:text "Blockquote used as deliverable speech-act (ready-to-use scripted language) rather than as evidence unit — a structurally distinct purpose for the same visual idiom." ; narr:over <https://aswritten.ai/narrative#StyleObs_BlockquoteForScript> ; narr:over <https://aswritten.ai/narrative#StyleObs_FableWindowBlockquoteStyle> ] ;
    narr:variation [ narr:text "Unfiltered profanity for emphasis signals low-ceremony internal communication, an outlier against the otherwise structured memo registers." ; narr:over <https://aswritten.ai/narrative#StyleObs_DirectQuote_UXIsShit> ] ;
    narr:variation [ narr:text "Collaborative negotiation framing ('want to narrow?') softens directives with user agency — a relational register distinct from both the authoritative and the hedging clusters." ; narr:over <https://aswritten.ai/narrative#StyleObs_NegotiationLanguage> ] ;
    narr:variation [ narr:text "Provisional-flag pattern appears in two distinct forms: frontmatter metadata ('branch: research/agent-memory-architecture / status: draft') vs. bold opening sentence — same safety-rail function, different surface register." ; narr:over <https://aswritten.ai/narrative#StyleObs_AgentSim_ProvisionalFlag> ; narr:over <https://aswritten.ai/narrative#StyleObs_ProvisionalFlagVoice> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
