    narr:covers <https://aswritten.ai/narrative#StyleObs_DiscoveryWedge_CaveatEmbedded> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_EnterpriseShape_TentativeRegister> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_EnterpriseCustomerPilot_InternalRegister> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_EnterpriseCustomerWeekOne_BulletMetrics> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_FableWindowBlockquoteStyle> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_HedgedDirectness> ;
