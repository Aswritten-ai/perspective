    narr:keyPhrase [ narr:text "Consistent with Scarlet session-memo idiolect across the perspective." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ARB_ConversationalRegister> ] ;
    narr:keyPhrase [ narr:text "Declarative assertion without hedging: 'this isn't a hypothetical failure mode, it's the default state' — authoritative register, zero epistemic softening." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_8> ] ;
    narr:keyPhrase [ narr:text "if the only evidence for \"enterprise shape\" being primary is one pilot with a lukewarm champion (the customer's chief architect is sponsor, not champion — see separate memory), you are potentially rationalizing" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_EnterpriseShape_TentativeRegister> ] ;
    narr:keyPhrase [ narr:text "**Conviction: claim / candidate — NOT a settled decision.**" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DiscoveryWedge_CaveatEmbedded> ] ;
    narr:keyPhrase [ narr:text "notion until repeated" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_NotionLevelCadence> ] ;
    narr:keyPhrase [ narr:text "**Provisional — from research/agent-memory-architecture exploration branch, not yet promoted to main.**" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AgentSim_ProvisionalFlag> ] ;
    narr:keyPhrase [ narr:text "A no-focus orientation call is byte-stable for a given graph state." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_PerspectiveOrdering_TechnicalRegister> ] ;
    narr:keyPhrase [ narr:text "the protection-status endpoint requires admin permissions the app may not hold on customer repos, and a probe is a race" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_WriteFlow_TechnicalRegister> ] ;
    narr:keyPhrase [ narr:text "proxy loads bundle from Postgres → extracts TX strings → JSON-stringifies → injects into JSON-RPC body" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TechnicalRegister> ] ;
    narr:keyPhrase [ narr:text "Voice memo recorded by Scarlet after completing the section-by-section review of a collaborator's comments on the fundraising brief." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_VoiceMemoRegister> ] ;
    narr:variation [ narr:text "Zero-hedging authoritative declaration ('stated as settled fact, not hypothesis') sits in direct tension with the explicitly self-critical tentative register ('potentially rationalizing', 'working hypothesis') found in strategic memos — same author, opposite epistemic posture depending on document type." ; narr:over <https://aswritten.ai/narrative#StyleObs_8> ; narr:over <https://aswritten.ai/narrative#StyleObs_EnterpriseShape_TentativeRegister> ] ;
    narr:variation [ narr:text "Provisional flag functions as a safety-rail content mechanism in one child and as a stylistic form (document announces its own epistemic status as both content and structure) in another — the same surface feature carries different functional weight." ; narr:over <https://aswritten.ai/narrative#StyleObs_AgentSim_ProvisionalFlag> ; narr:over <https://aswritten.ai/narrative#StyleObs_ProvisionalFlagVoice> ] ;
    narr:variation [ narr:text "Profanity and unfiltered register appear as deliberate authenticity and conviction signals (a beta user from outside tech's idiolect, UX frustration) — an outlier against the dominant analytical-memo formality of the corpus." ; narr:over <https://aswritten.ai/narrative#StyleObs_DirectQuote_UXIsShit> ; narr:over <https://aswritten.ai/narrative#StyleObs_RawRegisterPD> ] ;
    narr:variation [ narr:text "Technical register splits between expert-to-expert prose with deliberate informal asides ('zombie', 'all of that') and purely authoritative technical prose with no explanatory softening — two distinct stances within the same register family." ; narr:over <https://aswritten.ai/narrative#StyleObs_RegisterTechnical> ; narr:over <https://aswritten.ai/narrative#StyleObs_WriteFlow_TechnicalRegister> ] ;
    narr:variation [ narr:text "Spoken-transcript filler preservation (the customer's chief architect's colloquial run-ons, hedged spoken registers) contrasts with the editorial tightening applied to Scarlet's own analytical prose in the same documents — the mixed-register pattern is asymmetric by speaker." ; narr:over <https://aswritten.ai/narrative#StyleObs_CustomerArchitectColloquialRegister> ; narr:over <https://aswritten.ai/narrative#StyleObs_HedgedRegister> ; narr:over <https://aswritten.ai/narrative#StyleObs_ARB_ConversationalRegister> ] ;
    narr:variation [ narr:text "Hedged directness in founder-pitch contexts ('let's call it 5k') and hedged self-deprecation ('I don't actually need that much money') represent a register variant — confidence-through-restraint — distinct from both the analytical memo hedging and the zero-hedging declarative mode." ; narr:over <https://aswritten.ai/narrative#StyleObs_HedgedDirectness> ; narr:over <https://aswritten.ai/narrative#StyleObs_HedgedSelfDeprecation> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
