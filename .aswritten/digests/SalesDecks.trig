    narr:covers <https://aswritten.ai/narrative#Narrative_InterviewForcingFunction> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_KeepingBeatsStarting> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PodcastInterviewSalesMotion> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PreReadDeckConcept> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_QuestionFirstDeck> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ReportAsDeliverablePattern> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_SellTheProcessPreCaseStudy> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_TamarackDemoAsLiveSalesMotion> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_VouchEmailSalesMotionTemplate> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_WhitePaperAIFilter> ;
    narr:covers <https://aswritten.ai/narrative#Obs_GIFHookFeature> ;
    narr:covers <https://aswritten.ai/narrative#Obs_KeepingBeatsStartingQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletInterviewSalesMotionQuote> ;
    narr:covers <https://aswritten.ai/narrative#Observation_EnterpriseCustomerDemoReframe> ;
    narr:covers <https://aswritten.ai/narrative#Position_PreReadDeckRequest> ;
    narr:covers <https://aswritten.ai/narrative#Position_SalesGuideRequest> ;
    narr:covers <https://aswritten.ai/narrative#Question_DemoRepoDomain> ;
    narr:keyPhrase [ narr:text "McDonald picture menu" ; narr:phraseSource <https://aswritten.ai/narrative#Position_PreReadDeckRequest> ] ;
    narr:keyPhrase [ narr:text "The demo GIF shows the before/after of perspective installation in 10 seconds" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_DemoGIFStory> ] ;
    narr:keyPhrase [ narr:text "The human moment sells, not the text." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_HeroVideoFormat> ] ;
    narr:keyPhrase [ narr:text "Generosity is the demonstration." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_GenerosityAsDemonstration> ] ;
    narr:keyPhrase [ narr:text "Keeping beats starting." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_KeepingBeatsStartingQuote> ] ;
    narr:variation [ narr:text "White papers are viewed as ineffective for busy executives who will only AI-summarize them." ; narr:over <https://aswritten.ai/narrative#Narrative_WhitePaperAIFilter> ] ;
    narr:variation [ narr:text "The question-first deck approach prioritizes prospect pain discovery over capability presentation." ; narr:over <https://aswritten.ai/narrative#Narrative_QuestionFirstDeck> ] ;
    narr:variation [ narr:text "Renewal conversations are increasingly anchored in usage evidence rather than marketing claims." ; narr:over <https://aswritten.ai/narrative#Narrative_ReportAsDeliverablePattern> ] ;
