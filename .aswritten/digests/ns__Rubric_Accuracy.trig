GRAPH <https://aswritten.ai/narrative#Digest_ns__Rubric_Accuracy> {
  <https://aswritten.ai/narrative#Digest_ns__Rubric_Accuracy> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#Rubric_Accuracy> ;
    narr:childCount "10"^^xsd:integer ;
    narr:generatedFrom "0ff4f15f62cd7f1ecb036a0746df655affaf6096" ;
    narr:narration """This hub tracks accuracy assessments across the corpus, evaluating factual precision, named-entity integrity, and citation discipline. Technical documentation, including [collective-memory](narr:Assess_Accuracy_collective_memory) and [code-memory](narr:Assess_Accuracy_cm) assessments, emphasizes precise type signatures, SHACL schemas, and explicit correction logging. Strategic and GTM materials, such as the [GTM rubric](narr:RubricAssess_Accuracy_GTM) and [investor-facing assessments](narr:RubricAssess_Accuracy_1), are scrutinized for quantified metrics and alignment with product architecture. Decision records ([ADR-001](narr:RubricAssess_Accuracy_ADR001), [ADR-002](narr:RubricAssess_Accuracy_ADR002)) focus on cross-reference consistency and status clarity. The [IP-crisis entry](narr:Assessment_Accuracy_IPCrisis) and [customer architect call](narr:Assessment_Accuracy_CustomerArchitect) highlight the preservation of verbatim quotes and the explicit labeling of exploratory or uncommitted claims. Broad [foundational rubrics](narr:RubricAssess_Accuracy) validate internal consistency and entity naming, though they occasionally note the absence of external citations for high-level paradigm claims. Recurring markers of quality include verifiable incidents, consistent terminology, and the avoidance of false precision.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Assess_Accuracy_cm> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assess_Accuracy_collective_memory> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assessment_Accuracy_CustomerArchitect> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assessment_Accuracy_IPCrisis> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Accuracy> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Accuracy_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Accuracy_ADR001> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Accuracy_ADR002> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Accuracy_GTM> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_accuracy> ;
    narr:keyPhrase [ narr:text "Precise type signatures; accurate code examples" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assess_Accuracy_cm> ] ;
    narr:keyPhrase [ narr:text "explicit 'uncommitted' status for exploratory claims" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assessment_Accuracy_IPCrisis> ] ;
    narr:keyPhrase [ narr:text "rework rate 15% → <5%, board prep days → 15 minutes" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Accuracy> ] ;
    narr:keyPhrase [ narr:text "Factually accurate named entities (the enterprise customer, USPS, Österreichische Post, Poland Post)" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assessment_Accuracy_CustomerArchitect> ] ;
    narr:keyPhrase [ narr:text "decision status clearly stated; no citations needed for internal decision record" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Accuracy_ADR001> ] ;
    narr:variation [ narr:text "Some assessments identify a lack of external citations for strategic claims, while others deem them unnecessary for internal narratives." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Accuracy> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Accuracy_GTM> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_accuracy> ] ;
    narr:variation [ narr:text "Tension exists between the demand for verifiable external data and the sufficiency of internal consistency for strategic documents." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Accuracy> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_accuracy> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}