@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ValueExchange> {
  <https://aswritten.ai/narrative#Digest_ValueExchange> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#ValueExchange> ;
    narr:childCount "17"^^xsd:integer ;
    narr:generatedFrom "11122b32d6166da49b33c6aeab7ae1a4e0f6dd32" ;
    narr:narration """This hub maps the economics of value exchange, centering on the [senior expert bottleneck](narr:Observation_ValueExchange_1) as the primary site of enterprise value. The trajectory has shifted from viewing experts as [high-cadence contributors](narr:Position_AdvisorAsHighCadenceExpert) who review [agent output](narr:Position_AdvisorReviewsAgentOutput) for free, toward a model where [payment resolves ethical concerns](narr:Position_PaymentResolvesEthicsQuestion) by formalizing the relationship as compensation. On the demand side, the [referral/vetting economy](narr:Narrative_ReferrerGiftEconomy) relies on a [trust transfer mechanic](narr:Narrative_TrustTransferMechanic) that leverages existing practitioner-patient relationships to make vetting economically viable. This framework posits that the [patient pays to vet](narr:Obs_ScarletVettingQuote) while the referrer remains in a gift economy to protect trust capital. Monetization strategies include [converting readers to authors](narr:Narrative_MonetizationAuthorConversion) and framing value through [time-based metrics](narr:Narrative_MetricReframe). While the [customer list](narr:Position_CustomerListAsAsset) is identified as the core asset, the system also emphasizes [post-pilot autonomy](narr:Narrative_PostPilotSelfSufficiency) and [knowledge extraction](narr:Observation_WhatDoesItDo_1) as the primary entry point for enterprise adoption.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_KnowledgeExtractionBeachhead> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_MetricReframe> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_MonetizationAuthorConversion> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PostPilotSelfSufficiency> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PractitionerPaymentReframed> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ReferrerGiftEconomy> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_TrustTransferMechanic> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletReferralQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletVettingQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_TonyValidationAdvisoryQuote> ;
    narr:covers <https://aswritten.ai/narrative#Observation_ValueExchange_1> ;
    narr:covers <https://aswritten.ai/narrative#Observation_WhatDoesItDo_1> ;
    narr:covers <https://aswritten.ai/narrative#Position_AdvisorAsHighCadenceExpert> ;
    narr:covers <https://aswritten.ai/narrative#Position_AdvisorReviewsAgentOutput> ;
    narr:covers <https://aswritten.ai/narrative#Position_BidirectionalCostMechanism> ;
    narr:covers <https://aswritten.ai/narrative#Position_CustomerListAsAsset> ;
    narr:covers <https://aswritten.ai/narrative#Position_PaymentResolvesEthicsQuestion> ;
    narr:keyPhrase [ narr:text "The real enterprise value is in the knowledge that doesn't exist in any system — the senior expert bottleneck." ; narr:phraseSource <https://aswritten.ai/narrative#Observation_ValueExchange_1> ] ;
    narr:keyPhrase [ narr:text "He's happy to refer me, but doesn't have time to vet for me." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletReferralQuote> ] ;
    narr:keyPhrase [ narr:text "That a client can encounter and vet the full depth of a practitioner's perspective" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletVettingQuote> ] ;
    narr:keyPhrase [ narr:text "You could get easily all the people you need who are really senior or insightful people or who have a skill in a certain area that you value to do that." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_TonyValidationAdvisoryQuote> ] ;
    narr:keyPhrase [ narr:text "The trigger fires when bidirectional cost (social currency for asker, attention for expert) blocks interaction entirely." ; narr:phraseSource <https://aswritten.ai/narrative#Position_BidirectionalCostMechanism> ] ;
    narr:variation [ narr:text "The advisor model oscillates between free contribution for perspective and paid compensation to resolve extraction ethics." ; narr:over <https://aswritten.ai/narrative#Position_AdvisorAsHighCadenceExpert> ; narr:over <https://aswritten.ai/narrative#Position_PaymentResolvesEthicsQuestion> ] ;
    narr:variation [ narr:text "Referral incentives are contested: gift-economy reach vs. potential for stronger positive incentives like network expansion." ; narr:over <https://aswritten.ai/narrative#Narrative_ReferrerGiftEconomy> ] ;
    narr:variation [ narr:text "Value is framed either as a high-level enterprise asset (customer list) or as granular, time-saved efficiency metrics." ; narr:over <https://aswritten.ai/narrative#Position_CustomerListAsAsset> ; narr:over <https://aswritten.ai/narrative#Narrative_MetricReframe> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}