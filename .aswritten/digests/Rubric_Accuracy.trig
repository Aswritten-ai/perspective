    narr:generatedFrom "17228b65fed9b2c2a8c4073564fbaa73bcfb9926" ;
    narr:narration """This hub tracks [factual accuracy assessments](narr:RubricAssess_Accuracy) across the organization's documentation, ranging from strategic memos to technical manifestos. The corpus demonstrates a consistent standard of rigor, characterized by [verifiable named entities](narr:Rubric_Accuracy_CustomerArchitect), [precise temporal markers](narr:Rubric_Accuracy_YC_Call), and [explicit revenue or pricing figures](narr:Rubric_Accuracy_FounderBetaUser). Assessments frequently highlight the use of [direct quotes with timestamps](narr:Rubric_Accuracy_FounderBetaUser) and [context-based attribution](narr:Rubric_Assess_Accuracy) as primary evidence of reliability. While factual errors are largely absent, a recurring theme is the tension between formal citation requirements and genre-specific norms; for instance, [manifesto-style documents](narr:RubricAssess_Accuracy) are often granted latitude for citationless claims that would be flagged in a [strategic GTM memo](narr:RubricAssess_Accuracy_GTM). Transparency remains a key metric, with [open questions](narr:Rubric_Accuracy_PilotPlan) and [explicit corrections](narr:Rubric_Accuracy_ScarletDame) serving as indicators of high-quality, self-aware documentation.""" ;
    narr:covers <https://aswritten.ai/narrative#Assessment_Accuracy_YC> ;
    narr:covers <https://aswritten.ai/narrative#RubricAssess_Accuracy> ;
    narr:covers <https://aswritten.ai/narrative#RubricAssess_Accuracy_GTM> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Accuracy_CustomerArchitect> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Accuracy_FounderBetaUser> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Accuracy_PilotPlan> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Accuracy_ScarletDame> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Accuracy_YCDemoBeats> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Accuracy_YC_Call> ;
    narr:covers <https://aswritten.ai/narrative#Rubric_Assess_Accuracy> ;
    narr:keyPhrase [ narr:text "60 markdown files, 46/112 bugs, 3x cost differential" ; narr:phraseSource <https://aswritten.ai/narrative#Rubric_Accuracy_CustomerArchitect> ] ;
    narr:keyPhrase [ narr:text "Do NOT list Cognitect" ; narr:phraseSource <https://aswritten.ai/narrative#Rubric_Accuracy_ScarletDame> ] ;
    narr:keyPhrase [ narr:text "one point deducted for lack of formal citations where external claims are made" ; narr:phraseSource <https://aswritten.ai/narrative#RubricAssess_Accuracy> ] ;
    narr:keyPhrase [ narr:text "timing constraints (60s, 20s per beat) are precise" ; narr:phraseSource <https://aswritten.ai/narrative#Rubric_Accuracy_YCDemoBeats> ] ;
    narr:keyPhrase [ narr:text "6 users → 12 next week, ~68 minutes, 3 years ago" ; narr:phraseSource <https://aswritten.ai/narrative#Rubric_Accuracy_YC_Call> ] ;
    narr:variation [ narr:text "Genre-based leniency: manifestos are permitted citationless claims that trigger deductions in formal strategic documents." ; narr:over <https://aswritten.ai/narrative#RubricAssess_Accuracy> ] ;
    narr:variation [ narr:text "Explicit correction vs. implicit attribution: some documents are penalized for lacking formal citations despite high factual precision." ; narr:over <https://aswritten.ai/narrative#RubricAssess_Accuracy> ; narr:over <https://aswritten.ai/narrative#Rubric_Accuracy_CustomerArchitect> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}