@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_PerspectiveVsInformation> {
  <https://aswritten.ai/narrative#Digest_Narrative_PerspectiveVsInformation> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_PerspectiveVsInformation> ;
    narr:childCount "8"^^xsd:integer ;
    narr:generatedFrom "07b8f68b0cb818a530cfe09048c16401a46acd3c" ;
    narr:narration """This hub centers on the thesis that [modules deliver curated perspective](narr:Position_PerspectiveNotInformation) rather than mere information, distinguishing expert-level AI behavior from standard RAG. The core argument posits that [AIs possess a singular, opaque opinion](narr:Position_AIHasSingularOpinion) derived from training data, which modules must overwrite to enable specific, attributed viewpoints. Recent developments (July 2026) have expanded this into a [marketing-facing dare](narr:Narrative_OpinionatedPromiseMissingArticulation) to explicitly promise 'opinionated' AI, while [independent design-based validation](narr:Position_DesignTokenParallelValidation) suggests this lens-driven architecture is a necessary, non-commodifiable component of expert systems. The [preservation of interpretation](narr:Position_InterpretationPreservation) is highlighted as the primary advantage over code-grounding, which often strips away the 'why' behind decision-making. However, the trajectory is not monolithic; [conversational steering](narr:Position_ConversationalSteeringAlternativeToRAG) is now presented as a structural alternative to RAG-based document retrieval, arguing that the 'conversational why' is the true engine of agent behavior, rather than static perspective modules alone.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_OpinionatedPromiseMissingArticulation> ;
    narr:covers <https://aswritten.ai/narrative#Position_AIHasSingularOpinion> ;
    narr:covers <https://aswritten.ai/narrative#Position_ConversationalSteeringAlternativeToRAG> ;
    narr:covers <https://aswritten.ai/narrative#Position_DesignTokenParallelValidation> ;
    narr:covers <https://aswritten.ai/narrative#Position_InterpretationPreservation> ;
    narr:covers <https://aswritten.ai/narrative#Position_LensIsIrreduciblePart> ;
    narr:covers <https://aswritten.ai/narrative#Position_PerspectiveNotInformation> ;
    narr:covers <https://aswritten.ai/narrative#Position_WorldviewEncodesAIBehavior> ;
    narr:keyPhrase [ narr:text "Modules load a set of perspectives, narratives, approaches, processes, and opinions about how information is used" ; narr:phraseSource <https://aswritten.ai/narrative#Position_PerspectiveNotInformation> ] ;
    narr:keyPhrase [ narr:text "it is the lens that controls all of that" ; narr:phraseSource <https://aswritten.ai/narrative#Position_LensIsIrreduciblePart> ] ;
    narr:keyPhrase [ narr:text "The customer-facing promise 'have an opinion and here's why' is the missing marketing articulation" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_OpinionatedPromiseMissingArticulation> ] ;
    narr:keyPhrase [ narr:text "Conversational steering through accumulated human-agent conversation is an alternative model to RAG" ; narr:phraseSource <https://aswritten.ai/narrative#Position_ConversationalSteeringAlternativeToRAG> ] ;
    narr:variation [ narr:text "Conversational accumulation is proposed as a superior mechanism for behavior installation compared to static module-based perspective." ; narr:over <https://aswritten.ai/narrative#Position_ConversationalSteeringAlternativeToRAG> ] ;
    narr:variation [ narr:text "The 'lens' is framed as an irreducible, non-commodifiable requirement for AI output quality, rather than just an optional enhancement." ; narr:over <https://aswritten.ai/narrative#Position_LensIsIrreduciblePart> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}