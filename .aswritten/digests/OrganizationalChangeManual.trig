@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_OrganizationalChangeManual> {
  <https://aswritten.ai/narrative#Digest_OrganizationalChangeManual> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#OrganizationalChangeManual> ;
    narr:childCount "5"^^xsd:integer ;
    narr:generatedFrom "b453b39bd22aad05251424df59598649648a2ff4" ;
    narr:narration """This hub tracks the evolving manual for organizational change in AI adoption, centering on the premise that human friction, rather than technical limitation, dictates project success. The core challenge is identified as [organizational change management](narr:Obs_OrgChangeManagement), specifically the failure of [real-time strategic decision cascading](narr:Position_WorldviewPropagation) where projects are invalidated by stale, distant mandates. To counter this, the discourse shifts toward structural interventions: [democratizing knowledge collection](narr:Narrative_DemocratizedConsensus) is proposed as a mechanism to bypass political gatekeeping and ensure balanced representation, a strategy further refined in [Scarlet's framing](narr:Obs_DemocratizedConsensus). Simultaneously, the focus on the user experience highlights the [cognitive gap](narr:Narrative_OnboardingGap) between initial technical connection and the realization of value, suggesting that even sophisticated users require active guidance to navigate the transition.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DemocratizedConsensus> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_OnboardingGap> ;
    narr:covers <https://aswritten.ai/narrative#Obs_DemocratizedConsensus> ;
    narr:covers <https://aswritten.ai/narrative#Obs_OrgChangeManagement> ;
    narr:covers <https://aswritten.ai/narrative#Position_WorldviewPropagation> ;
    narr:keyPhrase [ narr:text "organizational change management as the core friction in staffing AI adoption" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_OrgChangeManagement> ] ;
    narr:keyPhrase [ narr:text "real-time strategic decision cascading vs. months-long trickle through management layers" ; narr:phraseSource <https://aswritten.ai/narrative#Position_WorldviewPropagation> ] ;
    narr:keyPhrase [ narr:text "Democratizing knowledge collection creates balanced organizational representation and reduces political influence" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_DemocratizedConsensus> ] ;
    narr:keyPhrase [ narr:text "The gap between technical connection and first value is the core onboarding problem" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_OnboardingGap> ] ;
    narr:variation [ narr:text "The tension between removing cognitive friction for onboarding versus retaining it as a forcing function for fluency." ; narr:over <https://aswritten.ai/narrative#Narrative_OnboardingGap> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}