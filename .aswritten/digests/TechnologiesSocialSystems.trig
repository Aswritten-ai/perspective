    narr:covers <https://aswritten.ai/narrative#Narrative_LongTailPerspectiveAutomation> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_NeurosymbolicKGLLM> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PerspectiveShares_Distribution> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_SteeringVector> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_VouchIdentityForAgents> ;
    narr:covers <https://aswritten.ai/narrative#Obs_FirefliesWebhookQuote> ;
    narr:covers <https://aswritten.ai/narrative#Observation_CodeInferenceMoment> ;
    narr:covers <https://aswritten.ai/narrative#Observation_FlockingInsight> ;
    narr:covers <https://aswritten.ai/narrative#Observation_LLMContinuation> ;
    narr:covers <https://aswritten.ai/narrative#Position_AIAgentLongTailInterviews> ;
    narr:covers <https://aswritten.ai/narrative#Position_MCPAgnostic> ;
    narr:keyPhrase [ narr:text "LLMs are not thinking machines—they're continuation machines" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_LLMsContinuation> ] ;
    narr:keyPhrase [ narr:text "Language, narrative, and meaning operate as steering vectors" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_SteeringVector> ] ;
    narr:keyPhrase [ narr:text "MCP-agnostic architecture claim now has production evidence" ; narr:phraseSource <https://aswritten.ai/narrative#Position_MCPAgnostic> ] ;
    narr:keyPhrase [ narr:text "where exactly is the boundary between what agents should be allowed to do and what humans should do?" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_AgentComputerInterface> ] ;
    narr:keyPhrase [ narr:text "AI agents can autonomously farm perspectives from a large advisor network" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_LongTailPerspectiveAutomation> ] ;
    narr:variation [ narr:text "The Agent Computer Interface introduces a gray-area tension between human oversight and agent autonomy that was absent in earlier, more deterministic system models." ; narr:over <https://aswritten.ai/narrative#Narrative_AgentComputerInterface> ] ;
    narr:variation [ narr:text "The debate over whether agent security infrastructure should be open-source or proprietary remains unresolved." ; narr:over <https://aswritten.ai/narrative#Narrative_VouchIdentityForAgents> ] ;
