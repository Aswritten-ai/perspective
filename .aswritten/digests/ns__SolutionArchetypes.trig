@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__SolutionArchetypes> {
  <https://aswritten.ai/narrative#Digest_ns__SolutionArchetypes> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#SolutionArchetypes> ;
    narr:childCount "8"^^xsd:integer ;
    narr:generatedFrom "c7efcd2c7c38346d49979ee30b865aa84ac8a7b6" ;
    narr:narration """This hub gathers solution archetypes and target use cases organized around a compiled organizational worldview that downstream consumers query. Concrete personas include [AI-assisted development](narr:UseCase_CodingAgents) — coding agents reading product strategy and past decisions from a snapshot, developers saving ADRs as memories, auto-generated documentation staying current — and [content generation](narr:UseCase_ContentGeneration), where speeches, blog posts, and brand voice consistency derive from narrative architecture encoding style and perspective. [Executive assistance](narr:UseCase_ExecutiveAssistance) rounds out the primary triad: strategy discussions become queryable memories, cross-team alignment across sales, product, and engineering flows from shared context. Above these sits the [onboarding-elimination archetype](narr:SolutionArchetype_OnboardingElimination) as the abstracted frame for day-1 productivity through shared worldview. A process scaffold in [Narrative Strategy Process](narr:Narrative_SolutionArchetype_1) describes the delivery cadence: diagnostic → SSoT → pipeline → agents → evolution → review, biweekly. The [DevOps persona](narr:Narrative_DevOpsUseCase) — collective memory of deployment strategies, rollbacks, maintenance mode — is flagged as valuable but untapped, with [a parallel position node](narr:Position_DevOpsUntapped) noting it requires validation with practitioners. The [story-generation flow](narr:Obs_StoryFlow) attaches as `related`, describing synchronous render plumbing beneath these use cases rather than a use case itself.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_DevOpsUseCase> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_SolutionArchetype_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#Obs_StoryFlow> ;
    narr:covers <https://aswritten.ai/ns/narrative#Position_DevOpsUntapped> ;
    narr:covers <https://aswritten.ai/ns/narrative#SolutionArchetype_OnboardingElimination> ;
    narr:covers <https://aswritten.ai/ns/narrative#UseCase_CodingAgents> ;
    narr:covers <https://aswritten.ai/ns/narrative#UseCase_ContentGeneration> ;
    narr:covers <https://aswritten.ai/ns/narrative#UseCase_ExecutiveAssistance> ;
    narr:keyPhrase [ narr:text "Coding agents read from compiled snapshot (know product strategy, past decisions). Developers save ADRs as memories via conversation with AI." ; narr:phraseSource <https://aswritten.ai/ns/narrative#UseCase_CodingAgents> ] ;
    narr:keyPhrase [ narr:text "Brand voice consistency (narrative architecture encodes style/perspective). Automatic updates when worldview changes (strategies compile into stories)." ; narr:phraseSource <https://aswritten.ai/ns/narrative#UseCase_ContentGeneration> ] ;
    narr:keyPhrase [ narr:text "Cross-team alignment (sales, product, engineering work from same context). Meeting notes and decisions persist as structured knowledge." ; narr:phraseSource <https://aswritten.ai/ns/narrative#UseCase_ExecutiveAssistance> ] ;
    narr:keyPhrase [ narr:text "collective memory of deployment strategies, environment spin-up, version control, rollbacks, maintenance mode" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_DevOpsUseCase> ] ;
    narr:keyPhrase [ narr:text "an infrastructure advisor identified DevOps as valuable persona not currently emphasized; requires validation with DevOps practitioners" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Position_DevOpsUntapped> ] ;
    narr:keyPhrase [ narr:text "diagnostic → SSoT → pipeline → agents → evolution → review." ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_SolutionArchetype_1> ] ;
    narr:keyPhrase [ narr:text "- `mcp/draft-story` executes `.story` file against snapshot\n- **Synchronous**: Returns rendered Markdown immediately" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Obs_StoryFlow> ] ;
    narr:variation [ narr:text "DevOps is flagged as a valuable but currently unserved persona — not yet validated with practitioners, sitting outside the three primary use cases." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_DevOpsUseCase> ; narr:over <https://aswritten.ai/ns/narrative#Position_DevOpsUntapped> ] ;
    narr:variation [ narr:text "The story-generation flow attaches as `related` rather than `broader`, marking it as infrastructure beneath use cases rather than a use case archetype — a structural outlier in this hub." ; narr:over <https://aswritten.ai/ns/narrative#Obs_StoryFlow> ] ;
    narr:variation [ narr:text "The process scaffold (biweekly cadence, SSoT creation, agent integration) describes a delivery methodology, not a persona — it sits ambiguously between solution archetype and operational process." ; narr:over <https://aswritten.ai/ns/narrative#Narrative_SolutionArchetype_1> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}