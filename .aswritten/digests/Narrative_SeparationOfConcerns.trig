@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_SeparationOfConcerns> {
  <https://aswritten.ai/narrative#Digest_Narrative_SeparationOfConcerns> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_SeparationOfConcerns> ;
    narr:childCount "10"^^xsd:integer ;
    narr:generatedFrom "c354f003fe2a54a8d5d3268a64e6f8923cccb163" ;
    narr:narration """This hub collects architectural decisions about what belongs where — which tools do which jobs, and what must be kept apart. On the tool-boundary side: [compile should never accept a focus parameter](narr:https://aswritten.ai/narrative#Claim_CompileNoFocusParam), preserving full-worldview grounding; [introspect should not return subgraph content alongside its analysis](narr:https://aswritten.ai/narrative#Claim_IntrospectNoSubgraphReturn), since the two serve different moments; and [absence as a lens dimension was collapsed into introspect](narr:https://aswritten.ai/narrative#Claim_AbsenceIsIntrospect) rather than kept separate. Moving the other direction, [scope was designated a new, distinct tool](narr:https://aswritten.ai/narrative#Claim_ScopeIsNewSeparateTool) — windowed graph to full depth — effectively deprecating worldview domain layers. On the lens side: [the lens tool generates lenses rather than running them](narr:https://aswritten.ai/narrative#Claim_LensToolIsGenerator), [a lens is compound rather than stacked](narr:https://aswritten.ai/narrative#Claim_LensIsCompoundNotStacked), and [eye chart and text refraction are mechanically identical operations](narr:https://aswritten.ai/narrative#Claim_TextAndEyeChartSameOperation) — one saved, one ad-hoc. The [multi-pass extraction pipeline](narr:https://aswritten.ai/narrative#Narrative_MultiPassExtractionPipeline) (dated Jul 2026) draws a related distinction: passes are compute stages, transactions are atomic writes. A [JavaScript spread-order bug fix](narr:https://aswritten.ai/narrative#Claim_Base64SpreadOrderBug) sits as a concrete implementation artifact within this otherwise architectural cluster.""" ;
    narr:covers <https://aswritten.ai/narrative#Claim_AbsenceIsIntrospect> ;
    narr:covers <https://aswritten.ai/narrative#Claim_Base64SpreadOrderBug> ;
    narr:covers <https://aswritten.ai/narrative#Claim_CompileNoFocusParam> ;
    narr:covers <https://aswritten.ai/narrative#Claim_EyeChartIsDocumentBeingEvaluated> ;
    narr:covers <https://aswritten.ai/narrative#Claim_IntrospectNoSubgraphReturn> ;
    narr:covers <https://aswritten.ai/narrative#Claim_LensIsCompoundNotStacked> ;
    narr:covers <https://aswritten.ai/narrative#Claim_LensToolIsGenerator> ;
    narr:covers <https://aswritten.ai/narrative#Claim_ScopeIsNewSeparateTool> ;
    narr:covers <https://aswritten.ai/narrative#Claim_TextAndEyeChartSameOperation> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_MultiPassExtractionPipeline> ;
    narr:keyPhrase [ narr:text "Adding focus to compile risks agents calling compile(focus=task) instead of full worldview bootstrap. Compile/worldview should always ground the agent in the WHOLE organizational context first." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_CompileNoFocusParam> ] ;
    narr:keyPhrase [ narr:text "Returning subgraph alongside introspect analysis causes attention dilution. Analysis (gaps, tensions, questions) and subgraph content serve different purposes at different moments." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_IntrospectNoSubgraphReturn> ] ;
    narr:keyPhrase [ narr:text "Scope tool: takes focus and context like introspect, returns windowed graph to full depth in LLM-readable format. Effectively deprecates worldview:domain layers." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_ScopeIsNewSeparateTool> ] ;
    narr:keyPhrase [ narr:text "The lens tool does not run lenses — it generates them. Output: a set of lenses each containing a centrist focus prompt, a shift prompt, an eye chart, and usage instructions." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_LensToolIsGenerator> ] ;
    narr:keyPhrase [ narr:text "Both text (refraction mode) and eye chart (generation mode) are mechanically identical: run this prompt against the snapshot with this lens applied." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_TextAndEyeChartSameOperation> ] ;
    narr:keyPhrase [ narr:text "Passes ≠ transactions: a pass is a compute stage, a transaction is an atomic write." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_MultiPassExtractionPipeline> ] ;
    narr:keyPhrase [ narr:text "return { content, ...obj } caused original base64 content to overwrite decoded version. Fixed to return { ...obj, content }." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_Base64SpreadOrderBug> ] ;
    narr:variation [ narr:text "Collapse vs. split move in opposite directions: absence is merged into introspect (fewer tools), while scope is spun out as a new separate tool (more tools) — the hub holds both without resolving the general principle." ; narr:over <https://aswritten.ai/narrative#Claim_AbsenceIsIntrospect> ; narr:over <https://aswritten.ai/narrative#Claim_ScopeIsNewSeparateTool> ] ;
    narr:variation [ narr:text "Eye chart and text refraction being mechanically identical could argue against treating them as distinct concerns, sitting in tension with the hub's general thrust of keeping operations separate." ; narr:over <https://aswritten.ai/narrative#Claim_TextAndEyeChartSameOperation> ; narr:over <https://aswritten.ai/narrative#Claim_EyeChartIsDocumentBeingEvaluated> ] ;
    narr:variation [ narr:text "The base64 spread-order bug is a concrete implementation artifact — structurally unlike the architectural boundary claims that dominate this hub, and may be misplaced or signal a broader implementation-vs-design tension." ; narr:over <https://aswritten.ai/narrative#Claim_Base64SpreadOrderBug> ] ;
    narr:variation [ narr:text "The multi-pass pipeline (Jul 2026, predicate: related) is the only dated and only non-supports child — its separation-of-concerns framing (passes ≠ transactions) is analogous but may belong to a different architectural layer than the tool-boundary claims." ; narr:over <https://aswritten.ai/narrative#Narrative_MultiPassExtractionPipeline> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}