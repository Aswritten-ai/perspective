@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_SeparationOfConcerns> {
  <https://aswritten.ai/narrative#Digest_Narrative_SeparationOfConcerns> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_SeparationOfConcerns> ;
    narr:childCount "8"^^xsd:integer ;
    narr:generatedFrom "c48cecebbb3f087cfe484582d56f88a977215cbf" ;
    narr:narration """This hub defines the architectural boundaries between core organizational tools, prioritizing the separation of generation, analysis, and scoping. The [compile tool](narr:https://aswritten.ai/narrative#Position_CompileNoFocusParam) is strictly reserved for full-worldview grounding, while the [scope tool](narr:https://aswritten.ai/narrative#Position_ScopeIsNewSeparateTool) serves as the primary mechanism for windowed graph retrieval, effectively superseding previous domain-layer abstractions. Analysis is governed by the principle that [introspect must remain focused](narr:https://aswritten.ai/narrative#Position_IntrospectNoSubgraphReturn) on gaps and tensions rather than returning raw subgraph content, and that [absence as a dimension](narr:https://aswritten.ai/narrative#Position_AbsenceIsIntrospect) is functionally identical to introspective analysis. Regarding lens architecture, the [lens tool](narr:https://aswritten.ai/narrative#Position_LensToolIsGenerator) is defined as a generator of compound perspectives rather than an execution engine, with the [eye chart](narr:https://aswritten.ai/narrative#Position_EyeChartIsDocumentBeingEvaluated) serving as the foundational document for evaluation. The system treats [text refraction and eye charts](narr:https://aswritten.ai/narrative#Position_TextAndEyeChartSameOperation) as mechanically identical operations, and [lenses themselves](narr:https://aswritten.ai/narrative#Position_LensIsCompoundNotStacked) are designed as singular, multi-dimensional constructs rather than stacked layers.""" ;
    narr:covers <https://aswritten.ai/narrative#Position_AbsenceIsIntrospect> ;
    narr:covers <https://aswritten.ai/narrative#Position_CompileNoFocusParam> ;
    narr:covers <https://aswritten.ai/narrative#Position_EyeChartIsDocumentBeingEvaluated> ;
    narr:covers <https://aswritten.ai/narrative#Position_IntrospectNoSubgraphReturn> ;
    narr:covers <https://aswritten.ai/narrative#Position_LensIsCompoundNotStacked> ;
    narr:covers <https://aswritten.ai/narrative#Position_LensToolIsGenerator> ;
    narr:covers <https://aswritten.ai/narrative#Position_ScopeIsNewSeparateTool> ;
    narr:covers <https://aswritten.ai/narrative#Position_TextAndEyeChartSameOperation> ;
    narr:keyPhrase [ narr:text "Compile/worldview should always ground the agent in the WHOLE organizational context first." ; narr:phraseSource <https://aswritten.ai/narrative#Position_CompileNoFocusParam> ] ;
    narr:keyPhrase [ narr:text "Effectively deprecates worldview:domain layers." ; narr:phraseSource <https://aswritten.ai/narrative#Position_ScopeIsNewSeparateTool> ] ;
    narr:keyPhrase [ narr:text "Analysis (gaps, tensions, questions) and subgraph content serve different purposes at different moments." ; narr:phraseSource <https://aswritten.ai/narrative#Position_IntrospectNoSubgraphReturn> ] ;
    narr:keyPhrase [ narr:text "You do not stack lenses; you craft one compound lens." ; narr:phraseSource <https://aswritten.ai/narrative#Position_LensIsCompoundNotStacked> ] ;
    narr:keyPhrase [ narr:text "Eye chart is the document or set of domain statements being evaluated." ; narr:phraseSource <https://aswritten.ai/narrative#Position_EyeChartIsDocumentBeingEvaluated> ] ;
    narr:variation [ narr:text "Tension exists between the desire for tool-specific purity and the practical need for integrated output (e.g., introspect vs. subgraph return)." ; narr:over <https://aswritten.ai/narrative#Position_IntrospectNoSubgraphReturn> ] ;
    narr:variation [ narr:text "The definition of 'eye chart' shifts between a static document and a dynamic prompt depending on the mode of operation." ; narr:over <https://aswritten.ai/narrative#Position_EyeChartIsDocumentBeingEvaluated> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}