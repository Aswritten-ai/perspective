GRAPH <https://aswritten.ai/narrative#Digest_ProductOverview> {
  <https://aswritten.ai/narrative#Digest_ProductOverview> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#ProductOverview> ;
    narr:childCount "18"^^xsd:integer ;
    narr:generatedFrom "a24e2a9606caedde172d4e1f4dda70ab719e0a7a" ;
    narr:narration """The product trajectory has shifted from a focus on [adaptive architectural infrastructure](narr:Narrative_AdaptiveToolsUX) toward an immersive, consumer-facing [digest browser interface](narr:Narrative_DigestBrowserProductSurface) that treats the human as a participant in the graph's own read-path. While the core technical stack remains anchored in [worldview](narr:Observation_WorldviewTool), [context](narr:Observation_ContextTool), and [introspect](narr:Observation_IntrospectTool) tools, the product definition has expanded to include [personal worldview layers](narr:Narrative_PersonalGraphLayer) and [per-project prompt extensions](narr:Narrative_PerProjectPromptExtension). Packaging has evolved from [starter perspectives](narr:Narrative_StarterPerspectivesAnalysis) to [prepackaged expertise modules](narr:Narrative_PrepackagedModuleConcept), eventually coalescing into a [unified instrument](narr:Narrative_ScarceExpertFilterGoalGated) that uses goal-gated escalation to dissolve previous market-segmentation drift. Recent developments emphasize the [agent as an analytics interface](narr:Narrative_AgentAsAnalyticsInterface) and the emergence of the [individual as a B2C product category](narr:Narrative_IndividualAsBCProductCategory), contrasting with the earlier [SMS-first collective memory](narr:Product_SMSCollectiveMemory) model. Pricing remains tied to [per-group subscriptions](narr:Pricing_PerGroupSubscription), with [conviction levels](narr:Obs_ConvictionLevels) providing a signal for claim maturity.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_AdaptiveToolsUX> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_AgentAsAnalyticsInterface> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DigestBrowserProductSurface> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_IndividualAsBCProductCategory> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PerProjectPromptExtension> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PersonalGraphLayer> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PrepackagedModuleConcept> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ProductAsProof> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ScarceExpertFilterGoalGated> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_StarterPerspectivesAnalysis> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ConvictionLevels> ;
    narr:covers <https://aswritten.ai/narrative#Obs_DigestBrowserUIQuote> ;
    narr:covers <https://aswritten.ai/narrative#Observation_ContextTool> ;
    narr:covers <https://aswritten.ai/narrative#Observation_IntrospectTool> ;
    narr:covers <https://aswritten.ai/narrative#Observation_WorldviewTool> ;
    narr:covers <https://aswritten.ai/narrative#Position_AdaptiveToolsOverMultiServer> ;
    narr:covers <https://aswritten.ai/narrative#Pricing_PerGroupSubscription> ;
    narr:covers <https://aswritten.ai/narrative#Product_SMSCollectiveMemory> ;
    narr:keyPhrase [ narr:text "single /mcp endpoint whose tool set adapts to user state" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_AdaptiveToolsUX> ] ;
    narr:keyPhrase [ narr:text "The product surface is the digest browser" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_DigestBrowserProductSurface> ] ;
    narr:keyPhrase [ narr:text "The B2C product category word is 'individual' — the antonym of monoculture/average" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_IndividualAsBCProductCategory> ] ;
    narr:keyPhrase [ narr:text "One instrument — scarce-expert filter with goal-gated escalation — unifies all deployment contexts" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ScarceExpertFilterGoalGated> ] ;
    narr:keyPhrase [ narr:text "Usage analytics delivered through the agent interface rather than a dashboard" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_AgentAsAnalyticsInterface> ] ;
    narr:variation [ narr:text "The SMS-first, zero-install model stands in tension with the high-fidelity digest browser UI." ; narr:over <https://aswritten.ai/narrative#Product_SMSCollectiveMemory> ; narr:over <https://aswritten.ai/narrative#Narrative_DigestBrowserProductSurface> ] ;
    narr:variation [ narr:text "Per-group subscriptions (back to pay-per-repo) contrast with the free-viral-loop acquisition strategy." ; narr:over <https://aswritten.ai/narrative#Pricing_PerGroupSubscription> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}