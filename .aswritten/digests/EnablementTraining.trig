@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_EnablementTraining> {
  <https://aswritten.ai/narrative#Digest_EnablementTraining> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#EnablementTraining> ;
    narr:childCount "7"^^xsd:integer ;
    narr:generatedFrom "15a9ba14f7af89866bae862f87d18f5cf1419f87" ;
    narr:narration """This hub consolidates enablement and onboarding strategies for the aswritten beta, centering on the tension between user-led discovery and structured separation. Guidance is anchored by [Tony's technical-user separation principle](narr:Position_TechnicalUserSeparationPrinciple) (Mar 17), which mandates that users initiate fresh projects to avoid conflict with existing repositories—a stance reinforced by [his specific implementation advice](narr:Obs_SeparationSolutionQuote). This focus on isolation emerged partly from [prospect feedback](narr:Position_TighterOnboarding) (Mar 11) requesting clearer distinctions between documentation and AI-driven workflows. The onboarding experience is further shaped by [five recurring user questions](narr:Position_FiveQuestionsEveryUserAsks) and [Scarlet's first-use framing](narr:Obs_ChatNotCodingSession), which encourages treating the tool as a conversational partner rather than a traditional coding environment. Underlying these tactical choices is a conceptual distinction: [human-led onboarding](narr:Narrative_OnboardingEffectivenessVsCoverage) (Mar 13) is framed as a method to increase knowledge coverage rather than inherent product effectiveness, with [live bootstrapping guidance](narr:Obs_BootstrappingGuidance) serving as a precursor to future automated onboarding modes.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_OnboardingEffectivenessVsCoverage> ;
    narr:covers <https://aswritten.ai/narrative#Obs_BootstrappingGuidance> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ChatNotCodingSession> ;
    narr:covers <https://aswritten.ai/narrative#Obs_SeparationSolutionQuote> ;
    narr:covers <https://aswritten.ai/narrative#Position_FiveQuestionsEveryUserAsks> ;
    narr:covers <https://aswritten.ai/narrative#Position_TechnicalUserSeparationPrinciple> ;
    narr:covers <https://aswritten.ai/narrative#Position_TighterOnboarding> ;
    narr:keyPhrase [ narr:text "The best thing is to have a completely new thing that haven't started any repos for or anything and then don't let it touch anything else. Keep them separate." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_SeparationSolutionQuote> ] ;
    narr:keyPhrase [ narr:text "Human onboarding increases knowledge coverage, not product effectiveness" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_OnboardingEffectivenessVsCoverage> ] ;
    narr:keyPhrase [ narr:text "The more involved people are, the more they need separation from their own chaos." ; narr:phraseSource <https://aswritten.ai/narrative#Position_TechnicalUserSeparationPrinciple> ] ;
    narr:variation [ narr:text "The necessity of manual onboarding is framed as an optimization phase, not a permanent requirement for product utility." ; narr:over <https://aswritten.ai/narrative#Narrative_OnboardingEffectivenessVsCoverage> ] ;
    narr:variation [ narr:text "User demand for clearer documentation-vs-AI separation highlights a potential friction point in current self-serve onboarding." ; narr:over <https://aswritten.ai/narrative#Position_TighterOnboarding> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}