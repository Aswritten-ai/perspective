    narr:covers <https://aswritten.ai/narrative#StyleObs_Cadence_1> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_EmDashCadence> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_EmDashCausal> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_MicroTelltales> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_NotionCadence> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ProcessEnumeration> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ProgressiveNarrowing> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RuleOfThreeScales> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RuleOfThree_1> ;
