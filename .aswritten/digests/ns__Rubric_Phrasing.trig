    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_phrasing> ;
    narr:keyPhrase [ narr:text "narrative architecture" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Phrasing> ] ;
