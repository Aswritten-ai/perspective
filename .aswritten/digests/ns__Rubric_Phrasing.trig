    narr:keyPhrase [ narr:text "Distinctive phrasing: 'narrative architecture,' 'steering vector,' 'resonant body.'" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Phrasing> ] ;
    narr:keyPhrase [ narr:text "Strong idiolect: 'as written' signature phrase; domain verbs (draft, commit, compile); stock phrases establish brand voice" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assess_Phrasing_rebrand> ] ;
    narr:keyPhrase [ narr:text "Strong idiolect: 'IP as code', 'deepest lever', 'cascading value', 'compilation targets'; consistent terminology; memorable phrases" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assessment_Phrasing_IPCrisis> ] ;
    narr:keyPhrase [ narr:text "Signature phrases ('state secrets to AI', 'IP as code', 'network effects') are memorable, repeatable, and aligned with strategic narrative." ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Phrasing_GTM> ] ;
    narr:keyPhrase [ narr:text "some stock phrases ('production ready', 'complete workflow')" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assess_Phrasing_cm> ] ;
    narr:variation [ narr:text "Technical docs read flatter than strategic material: consistent terminology but generic stock phrases ('production ready', 'complete workflow') rather than branded idiolect." ; narr:over <https://aswritten.ai/ns/narrative#Assess_Phrasing_cm> ; narr:over <https://aswritten.ai/ns/narrative#Assess_Phrasing_collective_memory> ] ;
    narr:variation [ narr:text "Deliberate self-correction ('waymarkers... no, telltales') is read as a quality signal of word choice, not a defect." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Phrasing> ] ;
    narr:variation [ narr:text "Conversational/authenticity markers — repeated 'right?', inside jokes like 'getting there', 'stupid exciting' — sit alongside the polished signature phrases." ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Phrasing> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Phrasing_TonyCall> ] ;
    narr:variation [ narr:text "Several assessments locate idiolect in specific named speakers (Tony, Scarlet, the customer's chief architect, an infrastructure advisor) rather than a single house voice — multiple distinct registers, not one." ; narr:over <https://aswritten.ai/ns/narrative#Assessment_Phrasing_CustomerArchitect> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Phrasing> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Phrasing_TonyCall> ] ;
