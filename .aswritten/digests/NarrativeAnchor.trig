    narr:keyPhrase [ narr:text "A way to install expertise into your AI and verify where it's coming from." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_CoreValuePropInstallExpertise> ] ;
    narr:keyPhrase [ narr:text "I've let go of the memory word sort of entirely and I'm now calling it installable expertise." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_CoreValuePropInstallExpertise> ] ;
    narr:keyPhrase [ narr:text "Expertise from humans you trust. Cited by AI, aswritten." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_TaglineFinalized> ] ;
    narr:keyPhrase [ narr:text "Each use case is a steering loop plus a memory substrate. aswritten is always the substrate" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_UnifierQuote> ] ;
    narr:keyPhrase [ narr:text "It's the same for an AI as a new hire. They need your perspective." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_AIAsNewHireQuote> ] ;
    narr:keyPhrase [ narr:text "Information isn't enough to do your work. You need perspective. So does your AI." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_PitchDirectionSolo> ] ;
    narr:keyPhrase [ narr:text "narrative operates like a velocity or acceleration vector in these particle systems" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_2> ] ;
    narr:variation [ narr:text "The optometrist/eye-chart metaphor structures the product internally but is flagged as confusing for reviewers and end users — present in plain language instead." ; narr:over <https://aswritten.ai/narrative#Observation_OptometristMetaphor> ; narr:over <https://aswritten.ai/narrative#Claim_DropOptometristMetaphor> ; narr:over <https://aswritten.ai/narrative#Narrative_MetaphorClarity> ; narr:over <https://aswritten.ai/narrative#Narrative_3> ] ;
    narr:variation [ narr:text "\"Memory\" was explicitly retired for \"installable expertise,\" yet the Mission still frames the product as \"collective narrative memory\" — superseded framing someone may still reach for." ; narr:over <https://aswritten.ai/narrative#Claim_CoreValuePropInstallExpertise> ; narr:over <https://aswritten.ai/narrative#Mission_1> ] ;
    narr:variation [ narr:text "Superseded Mar 8 claim — AR repo as \"aswritten repo with perspective baked in\" — was corrected: all aswritten repos are perspectives, an AR is just an aswritten repo." ; narr:over <https://aswritten.ai/narrative#Claim_ARRepoHasPerspectiveBakedIn> ; narr:over <https://aswritten.ai/narrative#Claim_ARRepoIsAswrittenRepo> ; narr:over <https://aswritten.ai/narrative#Narrative_ARRepoIdentity> ] ;
    narr:variation [ narr:text "Tagline choice is unresolved and audience-dependent: memorable \"think like your org\" vs. wordier trust-mechanism \"cited or flagged as ungrounded\" — both retained." ; narr:over <https://aswritten.ai/narrative#Narrative_ThinkLikeYourOrg> ] ;
    narr:variation [ narr:text "\"Governance\" speaks the customer's language but must NOT become the product category — GRC is a graveyard; steering is the genus." ; narr:over <https://aswritten.ai/narrative#Narrative_GovernanceAsSpeciesOfSteering> ] ;
    narr:variation [ narr:text "Extraction targets narrative direction, not every fact — but beta users expect the AI to know everything; concerning corollary: the LLM cannot self-detect narrative steering and transparency is necessary but insufficient." ; narr:over <https://aswritten.ai/narrative#Narrative_ExtractionTargetsNarrativeNotFacts> ; narr:over <https://aswritten.ai/narrative#Claim_3> ; narr:over <https://aswritten.ai/narrative#Narrative_3> ] ;
    narr:variation [ narr:text "Fundraising articulated as narrative selling not product readiness — which Scarlet then contradicts by returning to product dev (\"wrong work right now\")." ; narr:over <https://aswritten.ai/narrative#Obs_FundraisingIsStory> ; narr:over <https://aswritten.ai/narrative#StyleObs_WrongWorkRightNow> ] ;
    narr:writer "claude (subscription)" .
