    narr:keyPhrase [ narr:text "Each use case is a steering loop plus a memory substrate. aswritten is always the substrate" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_UnifierQuote> ] ;
    narr:keyPhrase [ narr:text "I've let go of the memory word sort of entirely and I'm now calling it installable expertise." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletInstallableExpertise> ] ;
    narr:keyPhrase [ narr:text "Information isn't enough to do your work. You need perspective. So does your AI." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_PitchDirectionSolo> ] ;
    narr:keyPhrase [ narr:text "I don't want to prove my credentials, I just want to be recognized and treated as the regular I am." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_DeliStoryQuote1> ] ;
    narr:keyPhrase [ narr:text "Synthesized Individual Intelligence (SII) as the owned, portable, relational alternative to lab-owned AGI" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_SII_SynthesizedIndividualIntelligence> ] ;
    narr:variation [ narr:text "The 'optometrist' metaphor is useful for internal design but explicitly deprecated for end-user communication." ; narr:over <https://aswritten.ai/narrative#Narrative_MetaphorClarity> ; narr:over <https://aswritten.ai/narrative#Position_DropOptometristMetaphor> ] ;
    narr:variation [ narr:text "The 'governance' label is a necessary customer-facing bridge, but carries the risk of miscategorization as GRC software." ; narr:over <https://aswritten.ai/narrative#Narrative_GovernanceAsSpeciesOfSteering> ] ;
    narr:variation [ narr:text "The 'opinionated' promise is a powerful marketing dare that remains articulated in brand docs but is absent from the current strategy." ; narr:over <https://aswritten.ai/narrative#Narrative_OpinionatedPromiseMissingArticulation> ] ;
