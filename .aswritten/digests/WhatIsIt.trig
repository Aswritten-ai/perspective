    narr:keyPhrase [ narr:text "MCP server + 3 interviews = working collective memory system" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ProductDeliverable> ] ;
    narr:keyPhrase [ narr:text "competing priorities + alternative perspective weights in the graph → different drafts → delta" ; narr:phraseSource <https://aswritten.ai/narrative#Observation_ScarletLensDefinition> ] ;
