    narr:covers <https://aswritten.ai/narrative#Claim_ProductIsNotPhoneNumber> ;
    narr:covers <https://aswritten.ai/narrative#Claim_SMSIsDistributionChannel> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ProductDeliverable> ;
    narr:covers <https://aswritten.ai/narrative#Observation_CoreFraming> ;
    narr:covers <https://aswritten.ai/narrative#Observation_ScarletLensDefinition> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_12> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_SystemSketchMetaphor> ;
    narr:keyPhrase [ narr:text "curated expertise installation — a way to install expertise into your AI and verify where it's coming from" ; narr:phraseSource <https://aswritten.ai/narrative#Claim_ProductIsCuratedExpertiseInstallation> ] ;
    narr:keyPhrase [ narr:text "the product is NOT a phone number" ; narr:phraseSource <https://aswritten.ai/narrative#Claim_ProductIsNotPhoneNumber> ] ;
    narr:keyPhrase [ narr:text "The phone number / SMS is a distribution channel." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_SMSIsDistributionChannel> ] ;
    narr:keyPhrase [ narr:text "MCP server + 3 interviews = working collective memory system. [amount] price point." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ProductDeliverable> ] ;
    narr:keyPhrase [ narr:text "competing priorities + alternative perspective weights in the graph → different drafts → delta" ; narr:phraseSource <https://aswritten.ai/narrative#Observation_ScarletLensDefinition> ] ;
    narr:variation [ narr:text "The 'phone number' framing is killed as product identity (a pipeline misattribution) yet kept alive as a legitimate distribution channel — a reader might still reach for the superseded tagline." ; narr:over <https://aswritten.ai/narrative#Claim_ProductIsNotPhoneNumber> ; narr:over <https://aswritten.ai/narrative#Claim_SMSIsDistributionChannel> ] ;
    narr:variation [ narr:text "SMS channel fit is explicitly context-dependent (enterprise/trust-signal right; spam-association/operational-cost wrong), qualifying any clean 'not a phone number' reading." ; narr:over <https://aswritten.ai/narrative#Claim_SMSIsDistributionChannel> ] ;
    narr:variation [ narr:text "Abstract identity ('curated expertise installation') vs concrete packaged deliverable ('[amount], MCP server + 3 interviews') — two different answers to 'what is it' depending on altitude." ; narr:over <https://aswritten.ai/narrative#Claim_ProductIsCuratedExpertiseInstallation> ; narr:over <https://aswritten.ai/narrative#Obs_ProductDeliverable> ] ;
    narr:variation [ narr:text "The personal-graph founding insight and the lens tool are distinct sub-framings of the product, not the same claim — separate expandable definitions." ; narr:over <https://aswritten.ai/narrative#Observation_CoreFraming> ; narr:over <https://aswritten.ai/narrative#Observation_ScarletLensDefinition> ] ;
