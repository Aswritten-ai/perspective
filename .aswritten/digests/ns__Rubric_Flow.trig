    narr:generatedFrom "bcb14dc7ed47fac3d7c0f71a50350a5588d47322" ;
    narr:narration """This hub catalogs rubric assessments of *flow*, evaluating how logical progression and structural coherence manifest across diverse artifacts. Formal documentation, including [refinements/workflows](narr:Assess_Flow_cm) and the [collective-memory doc](narr:Assess_Flow_collective_memory), relies on hierarchical headers and explicit section transitions to maintain rigor. The [ADR-001](narr:RubricAssess_Flow_ADR001) and [ADR-002](narr:RubricAssess_Flow_ADR002) assessments highlight how standardized templates enforce a reliable progression from context to consequence. In contrast, communicative artifacts like the [customer architect pitch](narr:Assessment_Flow_CustomerArchitect) and [advisor call](narr:RubricAssess_Flow) are judged on conversational naturalness, where coherence emerges through thematic clustering rather than rigid scaffolding. Strategic materials, such as the [GTM motion](narr:RubricAssess_Flow_GTM) and [IP-crisis brief](narr:Assessment_Flow_IPCrisis), occupy a middle ground, utilizing explicit headers to manage complex problem-to-solution arcs. Finally, spoken [product walkthroughs](narr:RubricAssess_Flow_1) and [general flow assessments](narr:RubricAssess_flow) reveal the tension between intentional structural repetition and the natural digressions inherent in live speech.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Assess_Flow_cm> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assess_Flow_collective_memory> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assessment_Flow_CustomerArchitect> ;
    narr:covers <https://aswritten.ai/ns/narrative#Assessment_Flow_IPCrisis> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Flow> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Flow_1> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Flow_ADR001> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Flow_ADR002> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_Flow_GTM> ;
    narr:covers <https://aswritten.ai/ns/narrative#RubricAssess_flow> ;
    narr:keyPhrase [ narr:text "Excellent logical progression: refinements → workflows → specifications → implementation phases" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assess_Flow_cm> ] ;
    narr:keyPhrase [ narr:text "Logical progression from decisions → workflows → architecture → data types" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assess_Flow_collective_memory> ] ;
    narr:keyPhrase [ narr:text "Natural conversational flow; effective transitions between sections" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Assessment_Flow_CustomerArchitect> ] ;
    narr:keyPhrase [ narr:text "Some backtracking ('I forgot', 'let me step back'). Natural for spoken walkthrough." ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Flow_1> ] ;
    narr:keyPhrase [ narr:text "Strong structural flow via ADR template; logical progression from context → decision → rationale → consequences" ; narr:phraseSource <https://aswritten.ai/ns/narrative#RubricAssess_Flow_ADR001> ] ;
    narr:variation [ narr:text "Intentional repetition for emphasis vs. structural efficiency" ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Flow> ] ;
    narr:variation [ narr:text "Formulaic scaffolding (e.g., IS/NOT patterns) as a constraint on natural flow" ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_flow> ] ;
    narr:variation [ narr:text "Backtracking and digressions as acceptable artifacts of spoken coherence" ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Flow> ; narr:over <https://aswritten.ai/ns/narrative#RubricAssess_Flow_1> ] ;
