GRAPH <https://aswritten.ai/narrative#Digest_MoatLeverage> {
  <https://aswritten.ai/narrative#Digest_MoatLeverage> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#MoatLeverage> ;
    narr:childCount "19"^^xsd:integer ;
    narr:generatedFrom "f3e1f6d06bef56f519e271ee82bc926bc0f9eeee" ;
    narr:narration """This hub tracks the evolving definition of aswritten's defensibility, moving from technical extraction mechanics to broader political and architectural claims. The foundational [extraction pipeline](narr:Narrative_MoatExtractionProcess) remains central, emphasizing that [compiled perspective](narr:Position_MoatCreatorOwnsData) is non-reconstructible by the consumer. This technical framing, articulated by [Scarlet in March](narr:Obs_ScarletMoatQuote), has been augmented by [processor-not-store](narr:Narrative_ProcessorNotStore) positioning, which shifts the value proposition toward high-compliance environments. Recent discourse has radicalized these claims; the [Fable 5 takedown](narr:Narrative_FableWakeUpCall) transformed the anti-lock-in feature into a political argument regarding the [means of production](narr:Obs_FableAntiLockInPolitics). Parallel threads continue to develop: the [trust contract](narr:Narrative_TrustContractWedge) as a competitive wedge, the [git-native worldview](narr:Position_Differentiation_1) versus runtime layers, and the [irreducible lens](narr:Obs_DesignCollaboratorLensIrreducibleQuote) as a core differentiator. The trajectory suggests a shift from defending the 'how' of data extraction to asserting the 'why' of organizational infrastructure, exemplified by the [GitHub analogy](narr:Narrative_GitHubAnalogy).""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_AItoAIProvenance> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_FableWakeUpCall> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_GitHubAnalogy> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_GraphLLMMoat> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_MoatExtractionProcess> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ProcessorNotStore> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_TrustContractWedge> ;
    narr:covers <https://aswritten.ai/narrative#Obs_DesignCollaboratorLensIrreducibleQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_DiscoveryConsultantPlayback> ;
    narr:covers <https://aswritten.ai/narrative#Obs_FableAntiLockInPolitics> ;
    narr:covers <https://aswritten.ai/narrative#Obs_MoatLeverage> ;
    narr:covers <https://aswritten.ai/narrative#Obs_NatureOfExpertiseQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ProcessorNotStore> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletMoatQuote> ;
    narr:covers <https://aswritten.ai/narrative#Position_Differentiation_1> ;
    narr:covers <https://aswritten.ai/narrative#Position_Differentiation_2> ;
    narr:covers <https://aswritten.ai/narrative#Position_MoatCreatorOwnsData> ;
    narr:covers <https://aswritten.ai/narrative#Position_PublishLiberallyDecision> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ProprietaryMoat> ;
    narr:keyPhrase [ narr:text "The real differentiator and the technical moat is that I take textual documents and I extract perspective from them and then I make that perspective citable in the individual task." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletMoatQuote> ] ;
    narr:keyPhrase [ narr:text "aswritten is a processor, not a data store — enabling zero data retention for high-compliance environments" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ProcessorNotStore> ] ;
    narr:keyPhrase [ narr:text "proprietary (it reveals the compiled knowledge graph — a moat)" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ProprietaryMoat> ] ;
    narr:keyPhrase [ narr:text "The moat is the transformation pipeline and the accumulated graph, not the ideas." ; narr:phraseSource <https://aswritten.ai/narrative#Position_PublishLiberallyDecision> ] ;
    narr:variation [ narr:text "The moat is framed as a political necessity for user ownership rather than a technical product feature." ; narr:over <https://aswritten.ai/narrative#Narrative_FableWakeUpCall> ; narr:over <https://aswritten.ai/narrative#Obs_FableAntiLockInPolitics> ] ;
    narr:variation [ narr:text "Human expertise is argued to be the ultimate, irreducible moat that AI cannot replicate." ; narr:over <https://aswritten.ai/narrative#Obs_NatureOfExpertiseQuote> ] ;
    narr:variation [ narr:text "Defensibility is rooted in the specific, proprietary nature of the accumulated graph and deployment experience." ; narr:over <https://aswritten.ai/narrative#Obs_MoatLeverage> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}