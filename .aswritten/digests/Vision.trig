@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Vision> {
  <https://aswritten.ai/narrative#Digest_Vision> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Vision> ;
    narr:childCount "9"^^xsd:integer ;
    narr:generatedFrom "d1b09a828565de86" ;
    narr:narration """Scarlet's [Vision](narr:Narrative_CollaborativeConfigurableAIVision) holds a [steering-vector thesis](narr:Claim_SteeringVectorThesis) as its through-line: [language, narrative, and meaning act as steering vectors](narr:Narrative_SteeringVector) for generative systems, the way velocity steers particle systems. The product framing is the [worldview engine](narr:Obs_WorldviewEngine) — SMS is merely one thing it can do. The fullest articulation (May 2026): [vetting is the beachhead](narr:Narrative_CollaborativeConfigurableAIVision), but the real product is collaboratively configurable AI individuals deployed in pursuit of goals, trustable through citation and visible reference, applicable to every AI task on every vendor. The product metaphor is [AI as ship, human at the tiller](narr:Obs_AIAsShip). Two infrastructure ambitions recur: aswritten as [the first thing you install](narr:Obs_FirstThingYouInstall) (like git/GitHub) and a [marketplace of reusable worldviews](narr:Obs_MarketplaceOfWorldviews), not just skills — instant skill transfer ([\"I know Kung Fu\"](narr:StyleObs_KungFu)). The wedge is enterprise and regulated industries where citation-grounded trust is mandatory; the ambition is venture-scale on calm-company economics.""" ;
    narr:covers <https://aswritten.ai/narrative#Claim_SteeringVectorThesis> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_CollaborativeConfigurableAIVision> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_SteeringVector> ;
    narr:covers <https://aswritten.ai/narrative#Obs_AIAsShip> ;
    narr:covers <https://aswritten.ai/narrative#Obs_FirstThingYouInstall> ;
    narr:covers <https://aswritten.ai/narrative#Obs_MarketplaceOfWorldviews> ;
    narr:covers <https://aswritten.ai/narrative#Obs_WorldviewEngine> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_KungFu> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_SharedMemoryQuote> ;
    narr:keyPhrase [ narr:text "This is going to be the first thing that people install when they start a new company. Like you would never consider starting a software company without GitHub and git" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_FirstThingYouInstall> ] ;
    narr:keyPhrase [ narr:text "A skill is limited context and a set of instructions about how to do something. We're talking about worldview — an entirety of process and methodology and code" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_MarketplaceOfWorldviews> ] ;
    narr:keyPhrase [ narr:text "collaboratively configurable AI individuals deployed in pursuit of goals, trustable through citation and visible reference, applicable to every AI task on every vendor" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_CollaborativeConfigurableAIVision> ] ;
    narr:keyPhrase [ narr:text "Local actor incentives create emergent behavior in larger networks. Language, narrative, and meaning operate as steering vectors analogous to velocity/acceleration in particle systems." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_SteeringVector> ] ;
    narr:keyPhrase [ narr:text "I know Kung Fu" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_KungFu> ] ;
    narr:keyPhrase [ narr:text "Imagine if [the agents] had shared memory or topics and you could say, Scarlet's bot, Tony's bot, a collaborator's bot — we're all friends. Here's shared memory." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_SharedMemoryQuote> ] ;
    narr:variation [ narr:text "Beachhead vs. real product: the May 2026 reframing explicitly corrects \"vetting is the beachhead\" to \"vetting creates a perspective representing an individual\" — the product is the AI individuals, not the vetting." ; narr:over <https://aswritten.ai/narrative#Narrative_CollaborativeConfigurableAIVision> ; narr:over <https://aswritten.ai/narrative#Claim_SteeringVectorThesis> ] ;
    narr:variation [ narr:text "Two scopes of ambition coexist unresolved: foundational dev-tooling infrastructure (git-like, first thing you install) vs. a marketplace of whole organizational worldviews — adjacent but not the same bet." ; narr:over <https://aswritten.ai/narrative#Obs_FirstThingYouInstall> ; narr:over <https://aswritten.ai/narrative#Obs_MarketplaceOfWorldviews> ] ;
    narr:variation [ narr:text "Tension in ambition framing: \"venture-scale goal achievable on calm-company economics\" pairs hypergrowth scale with deliberately non-hypergrowth operating discipline." ; narr:over <https://aswritten.ai/narrative#Narrative_CollaborativeConfigurableAIVision> ] ;
    narr:variation [ narr:text "A distinct shared-memory / networked-individuals motif sits beside the single-individual perspective framing — collaboration across bots, not just configuration of one." ; narr:over <https://aswritten.ai/narrative#StyleObs_SharedMemoryQuote> ] ;
    narr:writer "claude (subscription)" .
}