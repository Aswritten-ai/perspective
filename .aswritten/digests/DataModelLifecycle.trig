@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_DataModelLifecycle> {
  <https://aswritten.ai/narrative#Digest_DataModelLifecycle> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#DataModelLifecycle> ;
    narr:childCount "13"^^xsd:integer ;
    narr:generatedFrom "28167f5886a7baa241da644217ac2e3ea5c7cac6" ;
    narr:narration """This hub tracks the evolution of the knowledge-graph data model, centering on provenance and the shift toward [ontology as speech acts](narr:Narrative_OntologyAsSpeechActs) rather than static facts. The architecture prioritizes [append-only logs](narr:Narrative_AppendOnlyConvictionLog) to enable temporal queries on how organizational conviction shifts, utilizing the [Notion→Stake→Boulder→Grave framework](narr:Narrative_ConvictionFramework) to track settledness. Data integrity is maintained by treating [reviews as RDF named graphs](narr:Obs_ReviewNamedGraphModel) and simplifying the [registry to paths only](narr:Narrative_DocumentAsSelfDescribing) to avoid brittle metadata. Strategic operations include [compiling dual graphs](narr:Narrative_ProductKnowledgeSecondGraph) for worldview and product knowledge, while memory retrieval is governed by [Park et al.'s recency/importance/relevance mechanism](narr:Observation_ParkMemoryMechanism). The model assumes [AI-to-AI provenance](narr:Narrative_AItoAIProvenance) as a structural moat, with recent validation from [git-native versioning](narr:Obs_GitNativeReaction) reinforcing the focus on goal evolution.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_AItoAIProvenance> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_AppendOnlyConvictionLog> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ConvictionFramework> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_DocumentAsSelfDescribing> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_OntologyAsSpeechActs> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ProductKnowledgeSecondGraph> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ShareDataModel> ;
    narr:covers <https://aswritten.ai/narrative#Obs_AppendOnlyLog> ;
    narr:covers <https://aswritten.ai/narrative#Obs_GitNativeReaction> ;
    narr:covers <https://aswritten.ai/narrative#Obs_OntologyAsSpeechActs> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ReviewNamedGraphModel> ;
    narr:covers <https://aswritten.ai/narrative#Observation_ParkMemoryMechanism> ;
    narr:covers <https://aswritten.ai/narrative#Position_RegistrySimplification> ;
    narr:keyPhrase [ narr:text "Ontology modeled as actors, speech acts, and documents — not facts and entities" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_OntologyAsSpeechActs> ] ;
    narr:keyPhrase [ narr:text "The creators of this paper, they suggested a mechanism based on three different parameters. Recency, importance, and relevance to the current context." ; narr:phraseSource <https://aswritten.ai/narrative#Observation_ParkMemoryMechanism> ] ;
    narr:keyPhrase [ narr:text "Conviction levels: notion → stake → boulder → grave" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ConvictionFramework> ] ;
    narr:keyPhrase [ narr:text "Reviews as RDF named graphs: each review carries reviewer identity, timestamp, lens used, feedback, and triples in scope." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ReviewNamedGraphModel> ] ;
    narr:keyPhrase [ narr:text "The document speaks for itself; metadata is brittle and prone to drift" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_DocumentAsSelfDescribing> ] ;
    narr:variation [ narr:text "The shift toward speech-act ontology pushes against traditional fact-based triple stores." ; narr:over <https://aswritten.ai/narrative#Narrative_OntologyAsSpeechActs> ] ;
    narr:variation [ narr:text "Instance-specific goals are isolated within shares to prevent perspective contamination." ; narr:over <https://aswritten.ai/narrative#Narrative_ShareDataModel> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}