@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_ns__Strategy> {
  <https://aswritten.ai/narrative#Digest_ns__Strategy> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/ns/narrative#Strategy> ;
    narr:childCount "7"^^xsd:integer ;
    narr:generatedFrom "a01ed5a7f29cbdc52073bd24de69efc613d70c05" ;
    narr:narration """This hub defines the [narrative as an organizational operating system](narr:Concept_NarrativeArchitecture) thesis, positioning the [worldview as the primary product](narr:Position_WorldviewAsPrimaryProduct) of the organization. The core strategic claim identifies [narrative as the fundamental control mechanism](narr:Narrative_AI_Steering) for AI alignment. To operationalize this, the framework introduces [version-controlled worldview evolution](narr:Narrative_BranchingWorldview), allowing for explicit, testable direction changes. This shift enables [strategic context to propagate automatically](narr:Narrative_DemocratizationContext) across all role agents, while the [review process moves upstream](narr:Narrative_WorldviewReview) to focus on worldview deltas rather than individual outputs. To ensure [accessibility for non-technical users](narr:Narrative_NonTechnicalAccessibility), the architecture abstracts technical complexity through conversational interfaces. The thematic span encompasses AI alignment, version control, democratized context, and the shift from output-based to intent-based governance.""" ;
    narr:covers <https://aswritten.ai/ns/narrative#Concept_NarrativeArchitecture> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_AI_Steering> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_BranchingWorldview> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_DemocratizationContext> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_NonTechnicalAccessibility> ;
    narr:covers <https://aswritten.ai/ns/narrative#Narrative_WorldviewReview> ;
    narr:covers <https://aswritten.ai/ns/narrative#Position_WorldviewAsPrimaryProduct> ;
    narr:keyPhrase [ narr:text "narrative as the fundamental control mechanism for AI behavior and alignment" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_AI_Steering> ] ;
    narr:keyPhrase [ narr:text "Worldview becomes branchable like code; direction changes are explicit, reviewable, testable" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_BranchingWorldview> ] ;
    narr:keyPhrase [ narr:text "Review point moves upstream from outputs to worldview deltas" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Narrative_WorldviewReview> ] ;
    narr:keyPhrase [ narr:text "Central to platform positioning; hard to move; requires multi-party consensus" ; narr:phraseSource <https://aswritten.ai/ns/narrative#Position_WorldviewAsPrimaryProduct> ] ;
    narr:variation [ narr:text "The assertion that worldviews are 'hard to move' and require 'multi-party consensus' introduces a friction point against the promise of agile, branchable evolution." ; narr:over <https://aswritten.ai/ns/narrative#Position_WorldviewAsPrimaryProduct> ; narr:over <https://aswritten.ai/ns/narrative#Narrative_BranchingWorldview> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}