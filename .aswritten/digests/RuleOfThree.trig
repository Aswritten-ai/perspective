    narr:covers <https://aswritten.ai/narrative#StyleObs_RuleOfThreeOutputs> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RuleOfThreeScales> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RuleOfThreeTaxonomy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RuleOfThree_1> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_RuleOfThree_Direction> ;
