    narr:keyPhrase [ narr:text "Three altitudes of the same primitive" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AltitudeTaxonomy> ] ;
    narr:keyPhrase [ narr:text "The physics never changed. The substrate did" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:keyPhrase [ narr:text "One selector, three markets: hiring (Tony), funding (Cowen's \"applications fail by being normal\"), and buying." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_OneSelector3Markets> ] ;
    narr:keyPhrase [ narr:text "1. **Their installable perspective** (the product — they get a free account with it already in it)\n2. **A podcast episode / content piece** (marketing — published with permission)\n3. **A live demo of the product** (proof — the interview itself shows the product working)" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_RuleOfThreeOutputs> ] ;
    narr:keyPhrase [ narr:text "Information: Facts, data, knowledge. (What search and RAG provide.) Perspective: How to interpret, frame, and apply information. Opinions. Processes. Approaches. (What modules provide.) Wisdom:" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_RuleOfThreeTaxonomy> ] ;
    narr:variation [ narr:text "The pattern occasionally breaks its own tricolon constraint with a fourth element for emphasis." ; narr:over <https://aswritten.ai/narrative#StyleObs_RuleOfThree> ] ;
    narr:variation [ narr:text "Structure shifts from triadic to pentadic (five-question framework) at specific conviction peaks." ; narr:over <https://aswritten.ai/narrative#StyleObs_FiveQuestionCadence> ] ;
    narr:variation [ narr:text "Use of two-item lists and negative anaphora provides a counter-rhythm to the dominant rule-of-three." ; narr:over <https://aswritten.ai/narrative#StyleObs_11> ; narr:over <https://aswritten.ai/narrative#StyleObs_NegativeParallelism> ] ;
