    narr:covers <https://aswritten.ai/narrative#StyleObs_RuleOfThree_Tagline> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ShortPunchyTricolon> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ThreeLineSummary> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ThreeSentenceRule> ;
    narr:keyPhrase [ narr:text "rebuilt life, health, identity, and energy" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_RuleOfThree> ] ;
    narr:keyPhrase [ narr:text "where you've been, what you've decided, and where you're headed" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_RuleOfThree_Direction> ] ;
    narr:keyPhrase [ narr:text "what you know, how it's changed, IP as quantifiable code" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_RuleOfThree_1> ] ;
    narr:keyPhrase [ narr:text "Three altitudes of the same primitive" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AltitudeTaxonomy> ] ;
    narr:keyPhrase [ narr:text "across roles (co-founders), tools (Desktop → Code), and contexts (strategy → implementation)" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_RuleOfThree_Propagation> ] ;
    narr:keyPhrase [ narr:text "Not avoidance. Not paralysis. Gravitational pull." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_ShortPunchyTricolon> ] ;
    narr:variation [ narr:text "The 'rule' is repeatedly stretched to FOUR — triad-plus-emphatic-fourth — so the primitive isn't strictly three." ; narr:over <https://aswritten.ai/narrative#StyleObs_RuleOfThree> ; narr:over <https://aswritten.ai/narrative#StyleObs_RuleOfThree_Niches> ; narr:over <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:variation [ narr:text "Two children attach via `related`, not `broader`: negative/anaphoric ('no…no…no') and numbered-convergence forms are kin to the triad but structurally distinct from positive tricola." ; narr:over <https://aswritten.ai/narrative#StyleObs_NegativeParallelism> ; narr:over <https://aswritten.ai/narrative#StyleObs_NumberedConvergence> ] ;
    narr:variation [ narr:text "Scale ambiguity: the primitive spans three-WORD sentences, three-ITEM lists, and three-SENTENCE/section units — 'rule of three' is doing different work at each altitude." ; narr:over <https://aswritten.ai/narrative#StyleObs_AltitudeTaxonomy> ; narr:over <https://aswritten.ai/narrative#StyleObs_ThreeLineSummary> ; narr:over <https://aswritten.ai/narrative#StyleObs_3> ] ;
    narr:variation [ narr:text "Implicit usage vs explicitly named-and-enforced: one child is meta-commentary where the author consciously disciplines the cadence rather than deploying it unconsciously." ; narr:over <https://aswritten.ai/narrative#StyleObs_ThreeSentenceRule> ] ;
    narr:writer "claude (subscription)" .
