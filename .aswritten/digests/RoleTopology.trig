@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_RoleTopology> {
  <https://aswritten.ai/narrative#Digest_RoleTopology> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#RoleTopology> ;
    narr:childCount "8"^^xsd:integer ;
    narr:generatedFrom "3b5993f33e0b01ab52789fb27b9fa58f38daed41" ;
    narr:narration """This hub tracks the evolution of organizational topology within aswritten, centering on the distinction between [abstract roles](narr:Narrative_OrgRolesAbstraction) and [specific actors](narr:Narrative_ActorVsRoleAbstraction). The model treats roles as first-class product concepts—modules that persist independently of their occupants—while actor assignments are expected to emerge dynamically from conversation rather than static tagging. This framework extends to the [practitioner’s multi-faceted identity](narr:Narrative_PractitionerThreeRoles), where one account simultaneously navigates supplier, customer, and trust-broker roles. Complementing this, the team structure is [conceived as a constellation of perspectives](narr:Position_TeamAsPerspectives) rather than traditional full-time hires, a shift [Scarlet formalized](narr:Position_NoCoFounderNeeded) in March 2026. Tension remains regarding the [Microsoft gatekeeper pattern](narr:Position_MultiRoleCoordinationGatekeeper); while initially proposed as a centralized ground-truth mechanism, recent analysis [surfaces unresolved design questions](narr:Position_GatekeeperDesignQuestionsOpen) regarding whether such a gatekeeper should hold truth or merely route information, and at what stage of the coordination plane it should operate.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ActorVsRoleAbstraction> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_OrgRolesAbstraction> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PractitionerThreeRoles> ;
    narr:covers <https://aswritten.ai/narrative#Position_GatekeeperDesignQuestionsOpen> ;
    narr:covers <https://aswritten.ai/narrative#Position_MultiRoleCoordinationGatekeeper> ;
    narr:covers <https://aswritten.ai/narrative#Position_NoCoFounderNeeded> ;
    narr:covers <https://aswritten.ai/narrative#Position_OrgRolesFirstClass> ;
    narr:covers <https://aswritten.ai/narrative#Position_TeamAsPerspectives> ;
    narr:keyPhrase [ narr:text "roles are abstract positions that multiple actors can fill over time" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ActorVsRoleAbstraction> ] ;
    narr:keyPhrase [ narr:text "The practitioner is simultaneously supplier, customer, and unpaid trust node" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PractitionerThreeRoles> ] ;
    narr:keyPhrase [ narr:text "Roles are represented by aswritten perspectives contributed to by humans on cadence" ; narr:phraseSource <https://aswritten.ai/narrative#Position_TeamAsPerspectives> ] ;
    narr:keyPhrase [ narr:text "Does the gatekeeper hold ground truth or just route information?" ; narr:phraseSource <https://aswritten.ai/narrative#Position_GatekeeperDesignQuestionsOpen> ] ;
    narr:variation [ narr:text "The gatekeeper pattern is framed as a missing ground-truth mechanism, yet its implementation remains an open, unresolved design question." ; narr:over <https://aswritten.ai/narrative#Position_MultiRoleCoordinationGatekeeper> ; narr:over <https://aswritten.ai/narrative#Position_GatekeeperDesignQuestionsOpen> ] ;
    narr:variation [ narr:text "The practitioner's fluidity between three distinct transaction shapes challenges standard marketplace platforms that restrict participants to a single role." ; narr:over <https://aswritten.ai/narrative#Narrative_PractitionerThreeRoles> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}