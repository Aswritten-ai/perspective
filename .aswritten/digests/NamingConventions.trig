    narr:covers <https://aswritten.ai/narrative#StyleObs_BrandNames> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_CentristDraft> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_DeltaTable> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_CedarCedarAI> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_GitNative> ;
