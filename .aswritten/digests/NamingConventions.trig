    narr:keyPhrase [ narr:text "tier is defined by what you get, not who you are" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ProfessionalOverEnterprise> ] ;
    narr:keyPhrase [ narr:text "\"Distillation\" is a metaphor that needs explaining. \"Perspective creation\" is what it literally is" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_DistillationQuote> ] ;
    narr:keyPhrase [ narr:text "We should not say 'train'; create a perspective based on your historical meeting notes" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CreatePerspectivePitchQuote> ] ;
    narr:keyPhrase [ narr:text "a synthesizer makes music with a human guiding it. artificial sounds like a food flavoring from a lab." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_SII_SynthesizerAnalogy> ] ;
    narr:keyPhrase [ narr:text "Must live in the writing/language/knowledge space" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_NamingConstraints> ] ;
    narr:variation [ narr:text "The term for the installable unit of expertise remains undecided, with 'module' serving only as a temporary placeholder." ; narr:over <https://aswritten.ai/narrative#Position_ModuleNameTBD> ] ;
    narr:variation [ narr:text "While 'annotate' is slated for replacement, the specific choice between 'cite', 'provenance', or 'source' remains open." ; narr:over <https://aswritten.ai/narrative#Position_AnnotateRename> ] ;
