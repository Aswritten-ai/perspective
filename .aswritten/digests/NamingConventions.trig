    narr:keyPhrase [ narr:text "I should really change the word of the tool to provenance or cite. Annotate is kind of obscure." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_AnnotateRename> ] ;
    narr:keyPhrase [ narr:text "\"Distillation\" is a metaphor that needs explaining. \"Perspective creation\" is what it literally is" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_DistillationQuote> ] ;
    narr:keyPhrase [ narr:text "We should not say 'train'; create a perspective based on your historical meeting notes" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CreatePerspectivePitchQuote> ] ;
    narr:keyPhrase [ narr:text "Can you also rename the param for share by ID from perspective=ID to perspective(id=ID)?" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_IDParamRedundancyQuote> ] ;
    narr:keyPhrase [ narr:text "'Professional' chosen because the tier is defined by what you get, not who you are." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ProfessionalOverEnterprise> ] ;
    narr:keyPhrase [ narr:text "never thought the curated part was particularly necessary" ; narr:phraseSource <https://aswritten.ai/narrative#Obs_CuratedDroppedQuote> ] ;
    narr:variation [ narr:text "Unresolved: the name for the installable unit of expertise is undecided — 'module' is a working term only, and code metaphors may break consistency." ; narr:over <https://aswritten.ai/narrative#Claim_ModuleNameTBD> ; narr:over <https://aswritten.ai/narrative#Narrative_NamingConstraints> ] ;
    narr:variation [ narr:text "'Annotate' rename is flagged but not settled — three candidate words (cite, provenance, source) and no chosen one." ; narr:over <https://aswritten.ai/narrative#Claim_AnnotateRename> ; narr:over <https://aswritten.ai/narrative#Narrative_NamingConstraints> ] ;
    narr:variation [ narr:text "A candidate direction was explicitly rejected: 'writ' deemed too medieval, legal, and singular — a road not taken." ; narr:over <https://aswritten.ai/narrative#Narrative_NamingConstraints> ] ;
    narr:variation [ narr:text "Most children are descriptive brand-style observations (lowercase 'aswritten', backticks, arrow operator, coined terms), not naming decisions — a structurally distinct cluster from the active renames." ; narr:over <https://aswritten.ai/narrative#StyleObs_BrandNameStylization> ; narr:over <https://aswritten.ai/narrative#StyleObs_WorldviewGraph> ; narr:over <https://aswritten.ai/narrative#StyleObs_ArrowOperator> ] ;
    narr:variation [ narr:text "Some renames create downstream redundancy rather than just clarity — the compile→perspective rename forced the perspective(perspective=...) param fix." ; narr:over <https://aswritten.ai/narrative#Narrative_IDParameterRename> ] ;
    narr:writer "claude (subscription)" .
