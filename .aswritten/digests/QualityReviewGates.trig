    narr:covers <https://aswritten.ai/narrative#Obs_ScarletApprovalGateQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletDelegationInstruction> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletEvalFrustrationQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletProbeIterateQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletRelayIterateQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletReviewKickoffQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletSequencingDirectiveQuote> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletTask275CorrectionQuote> ;
    narr:covers <https://aswritten.ai/narrative#Observation_DevBranchChecklist> ;
    narr:keyPhrase [ narr:text "Smokes prove the pipeline runs; only the pre-registered battery proves quality parity — never substitute one for the other" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_SmokesVsBattery> ] ;
    narr:keyPhrase [ narr:text "Assert the mechanism, never the roster" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_AssertMechanismNotRoster> ] ;
    narr:keyPhrase [ narr:text "Verification doctrine: never trust a green check you haven't sliced" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_VerificationDoctrine> ] ;
    narr:keyPhrase [ narr:text "Verify at the seam the user touches, not one layer above it" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_VerifyAtUserSeam> ] ;
    narr:keyPhrase [ narr:text "Make the cheap checks honest, make the expensive checks intentional" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_CheapChecksHonestExpensiveChecksIntentional> ] ;
    narr:keyPhrase [ narr:text "Pre-register before building, keep the baseline clean, report actual numbers — the eval discipline is the product validation" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PreRegisteredEvalDiscipline> ] ;
    narr:keyPhrase [ narr:text "Annotating the full document in one pass at the end is less effective than per-section annotation during drafting." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_AnnotatePerSectionNotFullDoc> ] ;
    narr:keyPhrase [ narr:text "Capturing extraction input/output for evaluation is the most important part of the product." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_ExtractionEvalsAboveLine> ] ;
    narr:keyPhrase [ narr:text "The goal of review is convergence on the branch's intent, not exhaustive completeness" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ConvergenceNotCompleteness> ] ;
    narr:keyPhrase [ narr:text "Unit-testing individual workflows in isolation does not catch wiring bugs." ; narr:phraseSource <https://aswritten.ai/narrative#Claim_IntegrationTestingRequired> ] ;
    narr:variation [ narr:text "A recorded violation: the collapse/expand work was called validated on smokes and one live run alone — the pre-registered battery was never run — directly contradicting the battery discipline this hub otherwise encodes." ; narr:over <https://aswritten.ai/narrative#Claim_SmokesProveMechanism> ; narr:over <https://aswritten.ai/narrative#Narrative_SmokesVsBattery> ; narr:over <https://aswritten.ai/narrative#Narrative_PreRegisteredEvalDiscipline> ] ;
    narr:variation [ narr:text "Pre-registration as immutable one-shot bar vs. iterate-batches as legitimate refinement: two children hold these in tension, with the refinement framed as an explicit founder decision rather than silent drift." ; narr:over <https://aswritten.ai/narrative#Narrative_PreRegisteredEvalDiscipline> ; narr:over <https://aswritten.ai/narrative#Narrative_PreRegistrationRefinementNotSupersession> ; narr:over <https://aswritten.ai/narrative#Narrative_IterateBatchesEvalMethodology> ] ;
    narr:variation [ narr:text "Product-dev bar ('unquestionably superior') explicitly rejects research-grade A/B parity as the framing — a direct tension with the battery-discipline children that invoke parity tables." ; narr:over <https://aswritten.ai/narrative#Narrative_ProductDevBarUnquestionablySuperior> ; narr:over <https://aswritten.ai/narrative#Narrative_PreRegisteredEvalDiscipline> ] ;
    narr:variation [ narr:text "Two near-duplicate convergence narratives carry subtly different endpoints — 'sharpness on intent' vs. 'convergence on intent, not exhaustive completeness' — leaving the exact formulation unsettled." ; narr:over <https://aswritten.ai/narrative#Narrative_ConvergenceAsSharpness> ; narr:over <https://aswritten.ai/narrative#Narrative_ConvergenceNotCompleteness> ] ;
    narr:variation [ narr:text "Claim_5 challenges the hub from outside its domain: it maps conviction and review evidence as independently-operating architectural variables in human organizations, importing a framing the rest of the hub does not use." ; narr:over <https://aswritten.ai/narrative#Claim_5> ] ;
    narr:variation [ narr:text "Integration testing as the only reliable n8n verification method is a structural outlier — a wiring-level engineering constraint sitting inside a hub otherwise concerned with review protocol and eval discipline." ; narr:over <https://aswritten.ai/narrative#Claim_IntegrationTestingRequired> ; narr:over <https://aswritten.ai/narrative#Narrative_IntegrationTestingEssential> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
