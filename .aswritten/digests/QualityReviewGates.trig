@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_QualityReviewGates> {
  <https://aswritten.ai/narrative#Digest_QualityReviewGates> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#QualityReviewGates> ;
    narr:childCount "16"^^xsd:integer ;
    narr:generatedFrom "022988b93c06928d86401c84e4103b932d70ce25" ;
    narr:narration """This hub spans the review, evaluation, and verification disciplines that gate knowledge quality across the aswritten system. The review protocol cluster — established by Mar 2026 — is built around five corrections: [baseline-first comparison before shifts](narr:https://aswritten.ai/narrative#Position_BaselineFirst), [labeled shift intent (improvement vs. counter)](narr:https://aswritten.ai/narrative#Position_LabelShiftIntent), [sentence-scale comparison units](narr:https://aswritten.ai/narrative#Position_ComparisonScale), [large-TX zone-scoping via TX summary → zone identification → targeted shifts](narr:https://aswritten.ai/narrative#Position_LargeTXScale), and [domain-first eye-chart scoping](narr:https://aswritten.ai/narrative#Position_EyeChartScoping). Two entry points — [warm-start (same session) and cold-start (PR-based, different session)](narr:https://aswritten.ai/narrative#Narrative_WarmStartVsColdStart) — feed a shared core, with Scarlet's Jul 2025 kickoff preference on record. Review convergence is framed as [sharpness on branch intent, not exhaustive completeness](narr:https://aswritten.ai/narrative#Narrative_ConvergenceNotCompleteness), with [lenses pushing both toward and away from the branch thesis](narr:https://aswritten.ai/narrative#Position_LensesConvergeOnBranchIntent) to confirm directional correctness. [Annotation is positioned as quality control](narr:https://aswritten.ai/narrative#Narrative_AnnotationAsQualityControl) — per-section during drafting (Mar 2026), not end-of-document, because [text length limits cause silent failures on full sections](narr:https://aswritten.ai/narrative#Position_AnnotatePerSectionNotFullDoc). The [pre-registered eval battery discipline](narr:https://aswritten.ai/narrative#Narrative_PreRegisteredEvalDiscipline) (pre-dating Jul 2025) holds that the bar cannot drift to fit the outcome. The [review flow is framed as peer review for worldview shifts](narr:https://aswritten.ai/narrative#Narrative_ReviewAsPeerReview), not fact-by-fact checking. Verification doctrine extended Jul 5 2026 to [verify at the seam the user touches, not one layer above it](narr:https://aswritten.ai/narrative#Narrative_VerifyAtUserSeam), codified after four 'verified' claims on the Jul 4 release day proved one hop short. [Every saved memory ends that review round and shifts the branch closer to the target](narr:https://aswritten.ai/narrative#Position_EveryMemorySaveEndsReviewRound), with next-round lenses reflecting the updated graph.""" ;
    narr:covers <https://aswritten.ai/narrative#Narrative_AnnotationAsQualityControl> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ConvergenceAsSharpness> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ConvergenceNotCompleteness> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_PreRegisteredEvalDiscipline> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_ReviewAsPeerReview> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_VerifyAtUserSeam> ;
    narr:covers <https://aswritten.ai/narrative#Narrative_WarmStartVsColdStart> ;
    narr:covers <https://aswritten.ai/narrative#Obs_ScarletReviewKickoffQuote> ;
    narr:covers <https://aswritten.ai/narrative#Position_AnnotatePerSectionNotFullDoc> ;
    narr:covers <https://aswritten.ai/narrative#Position_BaselineFirst> ;
    narr:covers <https://aswritten.ai/narrative#Position_ComparisonScale> ;
    narr:covers <https://aswritten.ai/narrative#Position_EveryMemorySaveEndsReviewRound> ;
    narr:covers <https://aswritten.ai/narrative#Position_EyeChartScoping> ;
    narr:covers <https://aswritten.ai/narrative#Position_LabelShiftIntent> ;
    narr:covers <https://aswritten.ai/narrative#Position_LargeTXScale> ;
    narr:covers <https://aswritten.ai/narrative#Position_LensesConvergeOnBranchIntent> ;
    narr:keyPhrase [ narr:text "The goal of review is convergence on the branch's intent, not exhaustive completeness" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ConvergenceNotCompleteness> ] ;
    narr:keyPhrase [ narr:text "Pre-register the comparison before building, committed to git, so the bar cannot drift to fit the outcome." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_PreRegisteredEvalDiscipline> ] ;
    narr:keyPhrase [ narr:text "Annotate per-section as you draft — the text length limit causes silent failures on full sections." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_AnnotationAsQualityControl> ] ;
    narr:keyPhrase [ narr:text "Verify at the seam the user touches, not one layer above it" ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_VerifyAtUserSeam> ] ;
    narr:keyPhrase [ narr:text "If I save a memory after remember returns, I want to have a review immediately started, or it offered to immediately start review." ; narr:phraseSource <https://aswritten.ai/narrative#Obs_ScarletReviewKickoffQuote> ] ;
    narr:keyPhrase [ narr:text "The review flow is exactly peer review, the difference is we're reviewing fundamental worldview shifts, not necessarily all of the specific facts." ; narr:phraseSource <https://aswritten.ai/narrative#Narrative_ReviewAsPeerReview> ] ;
    narr:keyPhrase [ narr:text "Every saved memory ends that review round and shifts the branch closer to the target." ; narr:phraseSource <https://aswritten.ai/narrative#Position_EveryMemorySaveEndsReviewRound> ] ;
    narr:keyPhrase [ narr:text "Maximum comparison unit is a few sentences. Longer content must be broken into comparison-sized chunks." ; narr:phraseSource <https://aswritten.ai/narrative#Position_ComparisonScale> ] ;
    narr:variation [ narr:text "Two convergence framings coexist without explicit reconciliation: one frames the goal as 'sharpness on the branch's intent' while the other frames it as 'convergence on the branch's intent' — subtly different orientations on what review is optimizing for." ; narr:over <https://aswritten.ai/narrative#Narrative_ConvergenceAsSharpness> ; narr:over <https://aswritten.ai/narrative#Narrative_ConvergenceNotCompleteness> ] ;
    narr:variation [ narr:text "The peer-review framing (Mar 2026) positions review as evaluating worldview shifts, not specific facts — which sits in tension with the fact-review step in the shared core protocol that explicitly checks conviction levels and relationships." ; narr:over <https://aswritten.ai/narrative#Narrative_ReviewAsPeerReview> ; narr:over <https://aswritten.ai/narrative#Narrative_WarmStartVsColdStart> ] ;
    narr:variation [ narr:text "Annotation doctrine says 'write full narrative footnotes from the start; the narrative IS the value' — a stronger claim than quality control, positioning annotation as the primary artifact, not a check on it." ; narr:over <https://aswritten.ai/narrative#Narrative_AnnotationAsQualityControl> ; narr:over <https://aswritten.ai/narrative#Position_AnnotatePerSectionNotFullDoc> ] ;
    narr:variation [ narr:text "The eval discipline pre-dates Jul 2025 and holds 'report actual numbers before the words at par or ready' — but the hub carries no child recording what happened when a metric fell short and the iterate instruction was applied, leaving the failure-mode path undocumented here." ; narr:over <https://aswritten.ai/narrative#Narrative_PreRegisteredEvalDiscipline> ] ;
    narr:writer "anthropic/claude-sonnet-4.6" .
}