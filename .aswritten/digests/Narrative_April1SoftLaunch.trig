@prefix narr: <https://aswritten.ai/narrative#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

GRAPH <https://aswritten.ai/narrative#Digest_Narrative_April1SoftLaunch> {
  <https://aswritten.ai/narrative#Digest_Narrative_April1SoftLaunch> a narr:Digest ;
    narr:digestOf <https://aswritten.ai/narrative#Narrative_April1SoftLaunch> ;
    narr:childCount "7"^^xsd:integer ;
    narr:generatedFrom "15a9ba14f7af89866bae862f87d18f5cf1419f87" ;
    narr:narration """The April 1 launch remains anchored as a [forcing function](narr:Position_April1ForcingFunction) to transition from beta testing to public-facing marketing and tiered access. The [above-the-line requirements](narr:Position_AboveTheLine_April1) prioritize core stability—merging dev branches, finalizing the language pass, and shipping initial perspectives—while relegating secondary features to a [below-the-line status](narr:Position_BelowTheLine_April1). This shift is driven by a strategic pivot toward an [interview-first distribution model](narr:Position_MarketplaceInterviewDriven), where marketplace search and starter content are treated as downstream artifacts of expert interviews rather than launch-blocking prerequisites. Supporting infrastructure, including [outreach templates](narr:Position_OutreachTemplates) and a [unified style guide](narr:Position_DesignCollaboratorStyleGuide), is currently in development to ensure brand consistency across the landing page and documentation. A final decision remains pending regarding the [content-site subdomain](narr:Position_ContentSiteSubdomain), as the team seeks to move away from internal-facing naming conventions toward a more professional media-property identity.""" ;
    narr:covers <https://aswritten.ai/narrative#Position_AboveTheLine_April1> ;
    narr:covers <https://aswritten.ai/narrative#Position_April1ForcingFunction> ;
    narr:covers <https://aswritten.ai/narrative#Position_BelowTheLine_April1> ;
    narr:covers <https://aswritten.ai/narrative#Position_ContentSiteSubdomain> ;
    narr:covers <https://aswritten.ai/narrative#Position_DesignCollaboratorStyleGuide> ;
    narr:covers <https://aswritten.ai/narrative#Position_MarketplaceInterviewDriven> ;
    narr:covers <https://aswritten.ai/narrative#Position_OutreachTemplates> ;
    narr:keyPhrase [ narr:text "April 1 is set as a forcing function for launch readiness." ; narr:phraseSource <https://aswritten.ai/narrative#Position_April1ForcingFunction> ] ;
    narr:keyPhrase [ narr:text "distribution is interview-driven, not browse-driven." ; narr:phraseSource <https://aswritten.ai/narrative#Position_MarketplaceInterviewDriven> ] ;
    narr:keyPhrase [ narr:text "a system that AI can apply." ; narr:phraseSource <https://aswritten.ai/narrative#Position_DesignCollaboratorStyleGuide> ] ;
    narr:keyPhrase [ narr:text "The 'drafts' framing is internal; the published version should feel like a media property." ; narr:phraseSource <https://aswritten.ai/narrative#Position_ContentSiteSubdomain> ] ;
    narr:variation [ narr:text "The 'above-the-line' list includes a landing page redo that was technically superseded by a deep-link move." ; narr:over <https://aswritten.ai/narrative#Position_AboveTheLine_April1> ] ;
    narr:variation [ narr:text "The content site naming remains in flux, with tension between internal 'drafts' and external-facing branding." ; narr:over <https://aswritten.ai/narrative#Position_ContentSiteSubdomain> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
}