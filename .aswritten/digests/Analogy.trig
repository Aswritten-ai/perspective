    narr:covers <https://aswritten.ai/narrative#StyleObs_KungFu> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_LeanStartupAnalogy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_McDonaldPictureMenu> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Metaphor_PromptAsSchema> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_OpinionatedWorkflow> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_OpinionatedWorkflowAnalogy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_Optometrist> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_SII_SynthesizerAnalogy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_TamarackReview_PeerReviewAnalogy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ThreeLayerQuote> ;
    narr:covers <https://aswritten.ai/narrative#StyleObservation_Analogy_1> ;
    narr:covers <https://aswritten.ai/narrative#StyleObservation_AppleComparison> ;
    narr:covers <https://aswritten.ai/narrative#StyleObservation_StructuralAnalogy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObservation_TechnicalAnalogy> ;
    narr:keyPhrase [ narr:text "we should treat that like code. We should treat that like a pull request with unit tests." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_CustomerCTOPRMetaphor_Analogy> ] ;
    narr:keyPhrase [ narr:text "The review flow is exactly peer review, the difference is we're reviewing fundamental worldview shifts, not necessarily all of the specific facts" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_TamarackReview_PeerReviewAnalogy> ] ;
    narr:keyPhrase [ narr:text "your book is a snapshot; your module is alive." ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_AnalogyBookVsModule> ] ;
    narr:keyPhrase [ narr:text "the concrete design-token ↔ perspective parallel the graph was explicitly missing" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_DesignCollaboratorTokensAnalogy> ] ;
    narr:keyPhrase [ narr:text "Just as they discovered the internal combustion engine, they also discovered a whole bunch of black stuff under the ground called oil" ; narr:phraseSource <https://aswritten.ai/narrative#StyleObs_CompanionAnalogy> ] ;
    narr:variation [ narr:text "The Carfax analogy is explicitly noted as limited because aswritten synthesizes interpretation rather than just facts." ; narr:over <https://aswritten.ai/narrative#Narrative_CarfaxSubstackAnalogy> ] ;
    narr:variation [ narr:text "The 'synthesizer' analogy is used to encode human agency directly into the product name, contrasting with 'artificial' or 'synthetic' labels." ; narr:over <https://aswritten.ai/narrative#StyleObs_SII_SynthesizerAnalogy> ] ;
    narr:variation [ narr:text "Some analogies, like the 'McDonald picture menu,' emerge from prospects rather than vendor-led positioning, signaling a need for executive-level simplicity." ; narr:over <https://aswritten.ai/narrative#StyleObs_McDonaldPictureMenu> ] ;
    narr:writer "google/gemini-3.1-flash-lite" .
