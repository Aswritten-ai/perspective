    narr:covers <https://aswritten.ai/narrative#StyleObs_Analogy_ResearchPaper> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_BranchTrunkAnalogy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_BrandingAnalogy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_CompanionAnalogy> ;
    narr:covers <https://aswritten.ai/narrative#StyleObs_ConsultantInterviewAnalogy> ;
